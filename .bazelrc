common --enable_bzlmod
common --noenable_workspace
build --enable_runfiles

# Pass GOROOT and PATH to genrules so the transpiler can use go/importer to
# resolve Go package types (function signatures, struct fields, method
# sets, etc.). Required for cross-language type inference.
build --action_env=GOROOT
build --action_env=PATH

# Build-time stamping — bakes git commit, git describe output, and the
# closest release tag into //app/buildinfo via x_defs in cmd/BUILD.bazel.
# Re-runs the link step for stamped targets only when STABLE_* values
# change (commit, tag), so day-to-day rebuilds stay cached.
#
# Platform split: on Windows cmd.exe interprets `/` as a switch prefix
# and strips it from `bash tools/workspace_status.sh`, so we go through
# a .bat wrapper that uses %~dp0 to feed bash an unambiguous path.
# On Linux/macOS the .sh runs directly via its shebang.
build --stamp
build --enable_platform_specific_config
build:windows --workspace_status_command=tools/workspace_status.bat
build:linux   --workspace_status_command=tools/workspace_status.sh
build:macos   --workspace_status_command=tools/workspace_status.sh
