package cli

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "github.com/martianoff/gala-tui"
    . "github.com/martianoff/gala_team/app/ui"
)

// ============================================================================
// keymap_test — every binding in KeyToAppMsg + every InputEvent variant
// in InputToAppMsg. The whole point of the extraction was so this
// table is testable; one case per shortcut, one per event variant.
// ============================================================================

// ----- KeyToAppMsg --------------------------------------------------------

// Ctrl+C is consumed by gala-tui's runtime-level force-quit and
// never reaches the keymap. Ctrl+Q is the graceful path; the app's
// own QuitMsg handler implements the two-press confirmation.
func TestKeyToAppMsg_CtrlQ_Quit(t T) T = expectMsg(t, KeyToAppMsg(Ctrl(Char('q'))), "QuitMsg")
func TestKeyToAppMsg_CtrlA_Approve(t T) T = expectMsg(t, KeyToAppMsg(Ctrl(Char('a'))), "KeyApprove")
func TestKeyToAppMsg_CtrlR_Reject(t T) T = expectMsg(t, KeyToAppMsg(Ctrl(Char('r'))), "KeyReject")
func TestKeyToAppMsg_CtrlM_Merge(t T) T = expectMsg(t, KeyToAppMsg(Ctrl(Char('m'))), "KeyMerge")
func TestKeyToAppMsg_CtrlH_ToggleHistory(t T) T = expectMsg(t, KeyToAppMsg(Ctrl(Char('h'))), "KeyToggleHistory")
func TestKeyToAppMsg_CtrlL_ToggleFocus(t T) T = expectMsg(t, KeyToAppMsg(Ctrl(Char('l'))), "KeyToggleFocus")
func TestKeyToAppMsg_CtrlT_ToggleConsultViewer(t T) T =
    expectMsg(t, KeyToAppMsg(Ctrl(Char('t'))), "KeyToggleConsultViewer")

// Tab is the conventional "next pane" key in TUIs and is bound to
// focus-cycle so users can reach the sidebar without learning
// Ctrl+L.
func TestKeyToAppMsg_Tab_ToggleFocus(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(Tab())), "KeyToggleFocus")

func TestKeyToAppMsg_Backspace_Backspace(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(Backspace())), "KeyBackspace")

func TestKeyToAppMsg_Enter_Submit(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(Enter())), "KeySubmit")

func TestKeyToAppMsg_Up_HistoryCursorUp(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(Up())), "HistoryCursorUp")

func TestKeyToAppMsg_Down_HistoryCursorDown(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(Down())), "HistoryCursorDown")

func TestKeyToAppMsg_Esc_HistoryDeselect(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(Esc())), "HistoryDeselect")

func TestKeyToAppMsg_ArrowLeft_ComposerLeft(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(ArrowLeft())), "KeyComposerLeft")

func TestKeyToAppMsg_ArrowRight_ComposerRight(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(ArrowRight())), "KeyComposerRight")

func TestKeyToAppMsg_Home_ComposerHome(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(Home())), "KeyComposerHome")

func TestKeyToAppMsg_End_ComposerEnd(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(End())), "KeyComposerEnd")

func TestKeyToAppMsg_Delete_KeyDelete(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(Delete())), "KeyDelete")

// Char keys go to the composer. The exact rune is preserved.
func TestKeyToAppMsg_Char_KeyChar(t T) T {
    val m = KeyToAppMsg(PlainKey(Char('h')))
    return m match {
        case KeyChar(c) => Eq(t, c, 'h')
        case _          => IsTrue(t, false)
    }
}

// Multi-byte runes (emoji, accented Latin) survive the round-trip too.
func TestKeyToAppMsg_MultiByteRune_KeyChar(t T) T {
    val m = KeyToAppMsg(PlainKey(Char('é')))
    return m match {
        case KeyChar(c) => Eq(t, c, 'é')
        case _          => IsTrue(t, false)
    }
}

// Space arrives as its own Key variant (the ANSI parser strips it from
// printable-ASCII early); we map it back to KeyChar(' ') so the composer
// inserts a literal space.
func TestKeyToAppMsg_Space_KeyChar(t T) T {
    val m = KeyToAppMsg(PlainKey(Space()))
    return m match {
        case KeyChar(c) => Eq(t, c, ' ')
        case _          => IsTrue(t, false)
    }
}

// F1-F5 set view modes (Default / Focus / Grid / Pipeline / Activity);
// F6 toggles help; F-keys outside that range fall through to NoOp.
//
// Regression: F5/F6 silently dropped through 2026-04 because the
// FKey match arm fell into a default `NoOp` branch after the view-
// mode wiring landed only for F1-F4. The catch-all unit test below
// covers every F1..F8 to lock the contract.
func TestKeyToAppMsg_F1_Default(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(FKey(N = 1))), "KeySetViewMode")

func TestKeyToAppMsg_F2_Focus(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(FKey(N = 2))), "KeySetViewMode")

func TestKeyToAppMsg_F3_Grid(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(FKey(N = 3))), "KeySetViewMode")

func TestKeyToAppMsg_F4_Pipeline(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(FKey(N = 4))), "KeySetViewMode")

func TestKeyToAppMsg_F5_Activity(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(FKey(N = 5))), "KeySetViewMode")

func TestKeyToAppMsg_F6_Help(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(FKey(N = 6))), "KeyToggleHelp")

func TestKeyToAppMsg_F7_AutoApprove(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(FKey(N = 7))), "KeyToggleAutoApprove")

func TestKeyToAppMsg_F8_NoOp(t T) T =
    expectMsg(t, KeyToAppMsg(PlainKey(FKey(N = 8))), "NoOp")

// Ctrl+5 / Ctrl+6 are the fallback bindings users can rely on
// while the upstream F-key gap exists (gala-tui v0.7.1's parseCsi
// only decodes F1-F4; F5+ silently drops, see martianoff/gala-tui#10).
// These cover the common "I pressed F5 but nothing happened" path.
func TestKeyToAppMsg_Ctrl5_Activity(t T) T =
    expectMsg(t, KeyToAppMsg(Ctrl(Char('5'))), "KeySetViewMode")

func TestKeyToAppMsg_Ctrl6_Help(t T) T =
    expectMsg(t, KeyToAppMsg(Ctrl(Char('6'))), "KeyToggleHelp")

// Arrow / Home / End / Delete now drive the composer cursor — see the
// dedicated tests above (TestKeyToAppMsg_{ArrowLeft,ArrowRight,Home,
// End,Delete}). End used to KeyConvoStickToBottom; the focus-aware
// fallback for sidebar mode lives in update.gala::onComposerEndKey.
func TestKeyToAppMsg_PageUp_ConvoPageUp(t T) T = expectMsg(t, KeyToAppMsg(PlainKey(PageUp())), "KeyConvoPageUp")
func TestKeyToAppMsg_PageDown_ConvoPageDown(t T) T = expectMsg(t, KeyToAppMsg(PlainKey(PageDown())), "KeyConvoPageDown")
func TestKeyToAppMsg_Insert_NoOp(t T) T = expectMsg(t, KeyToAppMsg(PlainKey(Insert())), "NoOp")
func TestKeyToAppMsg_Unknown_NoOp(t T) T = expectMsg(t, KeyToAppMsg(PlainKey(Unknown())), "NoOp")

// ----- InputToAppMsg ------------------------------------------------------

// KeyInput delegates to KeyToAppMsg — verify with one representative key.
func TestInputToAppMsg_KeyInput_DelegatesToKeyToAppMsg(t T) T =
    expectMsg(t, InputToAppMsg(KeyInput(Ev = Ctrl(Char('q')))), "QuitMsg")

// MouseInput lifts to MouseAt with X/Y/Pressed/Motion forwarded
// verbatim.
func TestInputToAppMsg_MouseInput_LiftsToMouseAt(t T) T {
    val ev = MouseEvent(Btn = MouseLeft(), X = 7, Y = 13, Pressed = true, Motion = false)
    val m = InputToAppMsg(MouseInput(Ev = ev))
    return m match {
        case MouseAt(x, y, p, _) => {
            val t1 = Eq(t, x, 7)
            val t2 = Eq(t1, y, 13)
            return IsTrue(t2, p)
        }
        case _ => IsTrue(t, false)
    }
}

// MouseInput release forwards Pressed=false.
func TestInputToAppMsg_MouseInput_PreservesReleasePressed(t T) T {
    val ev = MouseEvent(Btn = MouseLeft(), X = 0, Y = 0, Pressed = false, Motion = false)
    val m = InputToAppMsg(MouseInput(Ev = ev))
    return m match {
        case MouseAt(_, _, p, _) => IsFalse(t, p)
        case _                   => IsTrue(t, false)
    }
}

// MouseInput drag motion forwards Motion=true alongside Pressed=true.
// Consumers use this to distinguish a fresh click from drag tracking.
func TestInputToAppMsg_MouseInput_PreservesDragMotion(t T) T {
    val ev = MouseEvent(Btn = MouseLeft(), X = 4, Y = 5, Pressed = true, Motion = true)
    val m = InputToAppMsg(MouseInput(Ev = ev))
    return m match {
        case MouseAt(_, _, _, motion) => IsTrue(t, motion)
        case _                        => IsTrue(t, false)
    }
}

// Resize and Unknown are routed to NoOp until a future component-level
// dispatcher consumes them.
func TestInputToAppMsg_Resize_NoOp(t T) T =
    expectMsg(t, InputToAppMsg(ResizeInput(W = 80, H = 24)), "NoOp")

func TestInputToAppMsg_Unknown_NoOp(t T) T =
    expectMsg(t, InputToAppMsg(UnknownInput()), "NoOp")

// ----- helpers ------------------------------------------------------------

// expectMsg checks that the AppMsg variant name matches `expected`.
// We compare the variant name rather than the full value because some
// variants carry payloads (KeyChar(c), MouseAt(x,y,p)) that aren't
// relevant to the mapping itself — those are tested separately above.
func expectMsg(t T, msg AppMsg, expected string) T = Eq(t, appMsgVariant(msg), expected)

func appMsgVariant(msg AppMsg) string = msg match {
    case KeyChar(_)                  => "KeyChar"
    case KeyBackspace()              => "KeyBackspace"
    case KeyDelete()                 => "KeyDelete"
    case KeyComposerLeft()           => "KeyComposerLeft"
    case KeyComposerRight()          => "KeyComposerRight"
    case KeyComposerHome()           => "KeyComposerHome"
    case KeyComposerEnd()            => "KeyComposerEnd"
    case KeySubmit()                 => "KeySubmit"
    case KeyApprove()                => "KeyApprove"
    case KeyReject()                 => "KeyReject"
    case KeyMerge()                  => "KeyMerge"
    case KeyToggleHistory()          => "KeyToggleHistory"
    case KeyToggleConsultViewer()    => "KeyToggleConsultViewer"
    case HistoryCursorUp()           => "HistoryCursorUp"
    case HistoryCursorDown()         => "HistoryCursorDown"
    case HistorySelect()             => "HistorySelect"
    case HistoryDeselect()           => "HistoryDeselect"
    case HistoryArchiveLoaded(_)     => "HistoryArchiveLoaded"
    case HistoryArchiveFailed(_)     => "HistoryArchiveFailed"
    case ChunkArrived(_, _)          => "ChunkArrived"
    case SessionFailed(_, _)         => "SessionFailed"
    case WriteSent(_)                => "WriteSent"
    case PreMergeHooksPassed(_)      => "PreMergeHooksPassed"
    case PreMergeHooksFailed(_)      => "PreMergeHooksFailed"
    case PrCreated(_, _)             => "PrCreated"
    case PrFailed(_)                 => "PrFailed"
    case OpenBrowser(_)              => "OpenBrowser"
    case WorktreesWiped()            => "WorktreesWiped"
    case Merged(_)                   => "Merged"
    case MergeFailed(_)              => "MergeFailed"
    case PostMergeHooksPassed(_)     => "PostMergeHooksPassed"
    case PostMergeHooksFailed(_)     => "PostMergeHooksFailed"
    case ConsultCompleted(_, _)      => "ConsultCompleted"
    case ConsultFailed(_, _)         => "ConsultFailed"
    case ConsultChunkArrived(_, _)   => "ConsultChunkArrived"
    case ConsultEnded(_, _)          => "ConsultEnded"
    case MouseAt(_, _, _, _)         => "MouseAt"
    case FocusSidebarClicked()       => "FocusSidebarClicked"
    case FocusComposerClicked()      => "FocusComposerClicked"
    case SidebarRowClicked(_)        => "SidebarRowClicked"
    case ConversationDragMsg(_, _)   => "ConversationDragMsg"
    case KeyToggleFocus()            => "KeyToggleFocus"
    case KeySidebarToggleGroup()     => "KeySidebarToggleGroup"
    case KeyEraseSession()           => "KeyEraseSession"
    case KeyYankConversation()       => "KeyYankConversation"
    case KeyPasteClipboard()         => "KeyPasteClipboard"
    case KeyConvoScrollUp()          => "KeyConvoScrollUp"
    case KeyConvoScrollDown()        => "KeyConvoScrollDown"
    case KeyConvoPageUp()            => "KeyConvoPageUp"
    case KeyConvoPageDown()          => "KeyConvoPageDown"
    case KeyConvoStickToBottom()     => "KeyConvoStickToBottom"
    case KeyOpenMemberDetail(_)      => "KeyOpenMemberDetail"
    case KeyCloseMemberDetail()      => "KeyCloseMemberDetail"
    case KeyTogglePalette()          => "KeyTogglePalette"
    case KeyPaletteEvent(_)          => "KeyPaletteEvent"
    case KeySetViewMode(_)           => "KeySetViewMode"
    case KeyPaletteRowClick(_)       => "KeyPaletteRowClick"
    case KeyToggleHelp()             => "KeyToggleHelp"
    case KeyToggleAutoApprove()      => "KeyToggleAutoApprove"
    case KeyToggleProjectInfo()      => "KeyToggleProjectInfo"
    case KeyToggleGuidance()         => "KeyToggleGuidance"
    case KeyToggleCompactSidebar()   => "KeyToggleCompactSidebar"
    case KeyRecoveryCycle()          => "KeyRecoveryCycle"
    case KeyRecoveryConfirm()        => "KeyRecoveryConfirm"
    case KeyRecoveryClick(_)         => "KeyRecoveryClick"
    case AskUserQuestion(_, _, _)    => "AskUserQuestion"
    case KeyQuestionDismiss()        => "KeyQuestionDismiss"
    case StderrArrived(_, _)         => "StderrArrived"
    case StderrEnded(_)              => "StderrEnded"
    case TickMsg()                   => "TickMsg"
    case QuitMsg()                   => "QuitMsg"
    case NoOp()                      => "NoOp"
}
