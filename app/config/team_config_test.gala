// Policy block edge cases
// ---------------------------------------------------------------------------

val policyMergeRuleSquashYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"X\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"calm\"\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"terse\"\n" +
    "workflow:\n  qa_required: false\n" +
    "policy:\n" +
    "  merge_rule: squash\n"

val policyMergeRulePlainYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"X\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"calm\"\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"terse\"\n" +
    "workflow:\n  qa_required: false\n" +
    "policy:\n" +
    "  merge_rule: merge\n"

val policyBadMergeRuleYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"X\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"calm\"\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"terse\"\n" +
    "workflow:\n  qa_required: false\n" +
    "policy:\n" +
    "  merge_rule: ff-only\n"

val policyBadWorkspaceModeYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"X\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"calm\"\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"terse\"\n" +
    "workflow:\n  qa_required: false\n" +
    "policy:\n" +
    "  workspace_mode: detached\n"

val policyOnlyPostMergeYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"X\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"calm\"\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"terse\"\n" +
    "workflow:\n  qa_required: false\n" +
    "policy:\n" +
    "  post_merge:\n" +
    "    - name: notify\n      cmd: echo\n      args:\n        - merged\n"

val policyHookNoArgsYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"X\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"calm\"\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"terse\"\n" +
    "workflow:\n  qa_required: false\n" +
    "policy:\n" +
    "  pre_merge:\n" +
    "    - name: status\n      cmd: git\n"

func TestLoadPolicy_SquashMergeRule(t T) T {
    val res = LoadFromString(policyMergeRuleSquashYaml)
    val t1 = IsSuccess(t, res)
    return res.Get().Policy.MergeRule match {
        case SquashMerge() => IsTrue(t1, true)
        case _             => IsTrue(t1, false)
    }
}

func TestLoadPolicy_PlainMergeRule(t T) T {
    val res = LoadFromString(policyMergeRulePlainYaml)
    val t1 = IsSuccess(t, res)
    return res.Get().Policy.MergeRule match {
        case PlainMerge() => IsTrue(t1, true)
        case _            => IsTrue(t1, false)
    }
}

func TestLoadPolicy_UnknownMergeRule_Fails(t T) T = IsFailure(t, LoadFromString(policyBadMergeRuleYaml))

func TestLoadPolicy_UnknownWorkspaceMode_Fails(t T) T = IsFailure(t, LoadFromString(policyBadWorkspaceModeYaml))

// post_merge can be set on its own without pre_merge — common when
// the team only wants a notification step after a clean merge.
func TestLoadPolicy_OnlyPostMergeIsLegal(t T) T {
    val res = LoadFromString(policyOnlyPostMergeYaml)
    val t1 = IsSuccess(t, res)
    val pol = res.Get().Policy
    val t2 = Eq(t1, pol.PreMerge.Size(),  0)
    val t3 = Eq(t2, pol.PostMerge.Size(), 1)
    return Eq(t3, pol.PostMerge.Get(0).Name, "notify")
}

// A hook with cmd but no args yaml-wise should yield Args = empty
// array (not crash on missing key).
func TestLoadPolicy_HookWithoutArgs_DefaultsToEmpty(t T) T {
    val res = LoadFromString(policyHookNoArgsYaml)
    val t1 = IsSuccess(t, res)
    val pol = res.Get().Policy
    val t2 = Eq(t1, pol.PreMerge.Size(), 1)
    return Eq(t2, pol.PreMerge.Get(0).Args.Size(), 0)
}

// ---------------------------------------------------------------------------
// Member-shape edge cases
// ---------------------------------------------------------------------------

val explicitNullModelYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"X\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"calm\"\n        model: null\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"terse\"\n        model: \"claude-opus-4-7\"\n" +
    "workflow:\n  qa_required: false\n"

func TestLoadMember_ExplicitNullModelIsNone(t T) T {
    val res = LoadFromString(explicitNullModelYaml)
    val t1 = IsSuccess(t, res)
    val members = res.Get().Team.Members
    return members.Get(0).Model match {
        case None()  => IsTrue(t1, true)
        case Some(_) => IsTrue(t1, false)
    }
}

func TestLoadMember_PinnedModelIsSome(t T) T {
    val res = LoadFromString(explicitNullModelYaml)
    val t1 = IsSuccess(t, res)
    val members = res.Get().Team.Members
    return members.Get(1).Model match {
        case Some(name) => Eq(t1, name, "claude-opus-4-7")
        case None()     => IsTrue(t1, false)
    }
}

// Workflow defaults only some fields — verify the rest fall back
// without forcing every key in every team.yaml.
val partialWorkflowYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"X\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"calm\"\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"terse\"\n" +
    "workflow:\n" +
    "  qa_required: false\n"

func TestLoadWorkflow_OmittedKeysDefault(t T) T {
    val res = LoadFromString(partialWorkflowYaml)
    val t1 = IsSuccess(t, res)
    val w = res.Get().Workflow
    val t2 = IsFalse(t1, w.QARequired)        // explicit
    val t3 = IsTrue(t2, w.ParallelEngineers)  // default true
    return IsTrue(t3, w.RequireUserConfirm)   // default true
}

// Two-engineer team — the validate() lead-uniqueness check is keyed on
// role count, not name, so duplicates by role need to be allowed when
// only one is the team_lead.
val multiEngineerYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"BigTeam\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"calm\"\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"terse\"\n" +
    "      - role: engineer\n        name: \"Mira\"\n        personality: \"sharp\"\n" +
    "      - role: engineer\n        name: \"Zara\"\n        personality: \"thorough\"\n" +
    "workflow:\n  qa_required: false\n"

func TestLoad_ManyEngineersAllowed(t T) T {
    val res = LoadFromString(multiEngineerYaml)
    val t1 = IsSuccess(t, res)
    val engs = MembersOf(res.Get().Team, Engineer())
    return Eq(t1, engs.Length(), 3)
}

// Two team leads — must fail (validate enforces exactly one).
val twoLeadsYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"DoubleLead\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"calm\"\n" +
    "      - role: team_lead\n        name: \"Otto\"\n        personality: \"firm\"\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"terse\"\n" +
    "workflow:\n  qa_required: false\n"

func TestLoad_TwoTeamLeads_Fails(t T) T = IsFailure(t, LoadFromString(twoLeadsYaml))

// ---------------------------------------------------------------------------
// Multi-team schema (Phase 4b)
// ---------------------------------------------------------------------------

val multiTeamsYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: Skunkworks\n" +
    "    description: Default product team\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: Iris\n        personality: calm\n" +
    "      - role: engineer\n        name: Felix\n        personality: terse\n" +
    "  - key: transpiler\n" +
    "    name: Transpiler Wizards\n" +
    "    description: Compiler / language work\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: Theo\n        personality: precise\n" +
    "      - role: engineer\n        name: Cade\n        personality: pragmatic\n" +
    "workflow:\n" +
    "  qa_required: false\n"

func TestLoadMultiTeams_ParsesAllEntries(t T) T {
    val res = LoadFromString(multiTeamsYaml)
    val t1 = IsSuccess(t, res)
    val cfg = res.Get()
    val t2 = Eq(t1, cfg.Teams.Size(), 2)
    val t3 = Eq(t2, cfg.Teams.Get(0).Key, "main")
    val t4 = Eq(t3, cfg.Teams.Get(0).Description, "Default product team")
    val t5 = Eq(t4, cfg.Teams.Get(1).Key, "transpiler")
    return Eq(t5, cfg.Teams.Get(1).Lead.Name, "Theo")
}

// First team in the source list becomes the "main" team
// (cfg.Team is the convenience pointer; cfg.Teams.Get(0) is the
// canonical source).
func TestLoadMultiTeams_FirstIsMain(t T) T {
    val res = LoadFromString(multiTeamsYaml)
    val t1 = IsSuccess(t, res)
    val cfg = res.Get()
    val t2 = Eq(t1, cfg.Team.Key, "main")
    return Eq(t2, cfg.Team.Name, "Skunkworks")
}

// Missing `key:` falls back to a slugified `name`.
val noKeyYaml = "teams:\n" +
    "  - name: Transpiler Wizards\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: Theo\n        personality: precise\n" +
    "      - role: engineer\n        name: Cade\n        personality: pragmatic\n" +
    "workflow:\n  qa_required: false\n"

func TestLoadMultiTeams_KeyDefaultsToSluggedName(t T) T {
    val res = LoadFromString(noKeyYaml)
    val t1 = IsSuccess(t, res)
    return Eq(t1, res.Get().Team.Key, "transpiler-wizards")
}

// Duplicate keys across teams — must fail.
val dupKeyYaml = "teams:\n" +
    "  - key: shared\n    name: First\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: A\n        personality: x\n" +
    "      - role: engineer\n        name: B\n        personality: x\n" +
    "  - key: shared\n    name: Second\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: C\n        personality: x\n" +
    "      - role: engineer\n        name: D\n        personality: x\n" +
    "workflow:\n  qa_required: false\n"

func TestLoadMultiTeams_DuplicateKey_Fails(t T) T =
    IsFailure(t, LoadFromString(dupKeyYaml))

// A teams list with no entries — must fail (top-level must declare at
// least one team, same constraint as the legacy shape).
val emptyTeamsYaml = "teams: []\nworkflow:\n  qa_required: false\n"
func TestLoadMultiTeams_Empty_Fails(t T) T =
    IsFailure(t, LoadFromString(emptyTeamsYaml))

// ---------------------------------------------------------------------------
// dangerously_skip_permissions
// ---------------------------------------------------------------------------

val dangerousYaml = "teams:\n" +
    "  - key: main\n    name: Skunkworks\n    dangerously_skip_permissions: true\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: Iris\n        personality: calm\n" +
    "      - role: engineer\n        name: Felix\n        personality: terse\n" +
    "workflow:\n  qa_required: false\n"

val safeYaml = "teams:\n" +
    "  - key: main\n    name: Skunkworks\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: Iris\n        personality: calm\n" +
    "      - role: engineer\n        name: Felix\n        personality: terse\n" +
    "workflow:\n  qa_required: false\n"

func TestLoad_DangerouslySkipPermissions_True(t T) T {
    val res = LoadFromString(dangerousYaml)
    val t1 = IsSuccess(t, res)
    return IsTrue(t1, res.Get().Team.DangerouslySkipPermissions)
}

func TestLoad_DangerouslySkipPermissions_DefaultsFalse(t T) T {
    val res = LoadFromString(safeYaml)
    val t1 = IsSuccess(t, res)
    return IsFalse(t1, res.Get().Team.DangerouslySkipPermissions)
}
