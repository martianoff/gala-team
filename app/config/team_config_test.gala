package main

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "github.com/martianoff/gala_team/app/config"
    . "github.com/martianoff/gala_team/app/policy"
    . "github.com/martianoff/gala_team/app/team"
)

val validTeamYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"Skunkworks\"\n" +
    "    members:\n" +
    "      - role: team_lead\n" +
    "        name: \"Iris\"\n" +
    "        personality: |\n" +
    "          Calm, decisive.\n" +
    "      - role: engineer\n" +
    "        name: \"Felix\"\n" +
    "        personality: |\n" +
    "          Terse.\n" +
    "        extra_instructions: |\n" +
    "          Pattern matching.\n" +
    "      - role: qa\n" +
    "        name: \"Theo\"\n" +
    "        personality: \"Evidence-driven.\"\n" +
    "workflow:\n" +
    "  qa_required: true\n" +
    "  parallel_engineers: true\n" +
    "  approval:\n" +
    "    require_user_confirm: true\n"

val noQaYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"Solo\"\n" +
    "    members:\n" +
    "      - role: team_lead\n" +
    "        name: \"Iris\"\n" +
    "        personality: \"Sole orchestrator.\"\n" +
    "      - role: engineer\n" +
    "        name: \"Felix\"\n" +
    "        personality: \"Implementer.\"\n" +
    "workflow:\n" +
    "  qa_required: false\n"

val noLeadYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"Headless\"\n" +
    "    members:\n" +
    "      - role: engineer\n" +
    "        name: \"Felix\"\n" +
    "        personality: \"No lead.\"\n"

val dupNameYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"Conflict\"\n" +
    "    members:\n" +
    "      - role: team_lead\n" +
    "        name: \"Iris\"\n" +
    "        personality: \"First.\"\n" +
    "      - role: engineer\n" +
    "        name: \"Iris\"\n" +
    "        personality: \"Second.\"\n"

func TestLoadValidTeam(t T) T {
    val res = LoadFromString(validTeamYaml)
    val t1 = IsSuccess(t, res)
    val cfg = res.Get()
    val t2 = Eq(t1, cfg.Team.Name, "Skunkworks")
    val t3 = Eq(t2, cfg.Team.Members.Length(), 3)
    val t4 = Eq(t3, cfg.Team.Lead.Name, "Iris")
    val t5 = IsTrue(t4, cfg.Workflow.QARequired)
    val t6 = IsTrue(t5, cfg.Workflow.ParallelEngineers)
    return IsTrue(t6, cfg.Workflow.RequireUserConfirm)
}

func TestLoadNoQa_AllowedWhenQaNotRequired(t T) T {
    val res = LoadFromString(noQaYaml)
    val t1 = IsSuccess(t, res)
    val cfg = res.Get()
    val t2 = IsFalse(t1, cfg.Workflow.QARequired)
    val qas = MembersOf(cfg.Team, QA())
    return IsTrue(t2, qas.IsEmpty())
}

func TestLoadNoLead_Fails(t T) T = IsFailure(t, LoadFromString(noLeadYaml))
func TestLoadDupName_Fails(t T) T = IsFailure(t, LoadFromString(dupNameYaml))

func TestLoadEmptyMembers_Fails(t T) T {
    val empty = "teams:\n  - key: main\n    name: \"X\"\n    members: []\n"
    return IsFailure(t, LoadFromString(empty))
}

func TestUnknownRole_Fails(t T) T {
    val bad = "teams:\n  - key: main\n    name: \"X\"\n    members:\n" +
        "      - role: designer\n        name: \"Pia\"\n        personality: \"Unsupported role.\"\n"
    return IsFailure(t, LoadFromString(bad))
}

// Policy block parsing -------------------------------------------------------

val withPolicyYaml = "teams:\n" +
    "  - key: main\n" +
    "    name: \"PolicyDemo\"\n" +
    "    members:\n" +
    "      - role: team_lead\n        name: \"Iris\"\n        personality: \"Calm.\"\n" +
    "      - role: engineer\n        name: \"Felix\"\n        personality: \"Terse.\"\n" +
    "workflow:\n" +
    "  qa_required: false\n" +
    "policy:\n" +
    "  workspace_mode: worktree-per-engineer\n" +
    "  merge_rule: rebase\n" +
    "  pre_merge:\n" +
    "    - name: lint\n      cmd: go\n      args:\n        - vet\n        - ./...\n" +
    "    - name: test\n      cmd: go\n      args:\n        - test\n        - ./...\n"

func TestLoadWithPolicy_ParsesAllFields(t T) T {
    val res = LoadFromString(withPolicyYaml)
    val t1 = IsSuccess(t, res)
    val pol = res.Get().Policy
    val t2 = pol.WorkspaceMode match {
        case WorktreePerEngineer() => IsTrue(t1, true)
        case _                     => IsTrue(t1, false)
    }
    val t3 = pol.MergeRule match {
        case RebaseMerge() => IsTrue(t2, true)
        case _             => IsTrue(t2, false)
    }
    val t4 = Eq(t3, pol.PreMerge.Size(), 2)
    val t5 = Eq(t4, pol.PreMerge.Get(0).Name, "lint")
    return Eq(t5, pol.PreMerge.Get(1).Cmd, "go")
}

func TestLoadWithoutPolicy_DefaultsApplied(t T) T {
    val res = LoadFromString(validTeamYaml)
    val t1 = IsSuccess(t, res)
    val pol = res.Get().Policy
    val t2 = pol.WorkspaceMode match {
        case Shared() => IsTrue(t1, true)
        case _        => IsTrue(t1, false)
    }
    return pol.MergeRule match {
        case SquashMerge() => IsTrue(t2, true)
        case _             => IsTrue(t2, false)
    }
}

