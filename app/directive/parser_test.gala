package directive

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
)

func first(t T, msg string) Directive {
    val arr = Parse(msg)
    if arr.IsEmpty() {
        panic("expected at least one directive, got none")
    }
    return arr.Get(0)
}

// ----- @dispatch ------------------------------------------------------------

func TestDispatch_SingleLineBody(t T) T {
    val msg = "@dispatch(Felix) Implement parser.\n@end"
    return first(t, msg) match {
        case Dispatch(target, body) => {
            val t1 = Eq(t, target, "Felix")
            return Eq(t1, body, "Implement parser.")
        }
        case _ => IsTrue(t, false)
    }
}

func TestDispatch_MultiLineBody(t T) T {
    val msg = "@dispatch(Felix)\n" +
        "Implement parser. Spec:\n" +
        "  - validates exactly one team_lead\n" +
        "  - returns Try[Team]\n" +
        "@end"
    return first(t, msg) match {
        case Dispatch(target, body) => {
            val t1 = Eq(t, target, "Felix")
            return IsTrue(t1, body == "Implement parser. Spec:\n  - validates exactly one team_lead\n  - returns Try[Team]")
        }
        case _ => IsTrue(t, false)
    }
}

func TestDispatch_MultipleInOneMessage(t T) T {
    val msg = "Sure, splitting this two ways:\n\n" +
        "@dispatch(Felix) Token store implementation.\n@end\n\n" +
        "@dispatch(Mira) Session middleware patch.\n@end\n"
    val dirs = Parse(msg)
    val t1 = Eq(t, dirs.Length(), 2)
    val firstD  = dirs.Get(0)
    val secondD = dirs.Get(1)
    val t2 = firstD match {
        case Dispatch(name, _) => Eq(t1, name, "Felix")
        case _                  => IsTrue(t1, false)
    }
    return secondD match {
        case Dispatch(name, _) => Eq(t2, name, "Mira")
        case _                  => IsTrue(t2, false)
    }
}

// ----- @consult -------------------------------------------------------------

func TestConsult_BareTarget(t T) T {
    val msg = "@consult(transpiler) Repro inside.\n@end"
    return first(t, msg) match {
        case Consult(target, override, body) => {
            val t1 = Eq(t, target, "transpiler")
            val t2 = IsNone(t1, override)
            return Eq(t2, body, "Repro inside.")
        }
        case _ => IsTrue(t, false)
    }
}

func TestConsult_WithProjectOverride(t T) T {
    val msg = "@consult(transpiler, project=\"~/work/gala_simple-fork\")\n" +
        "Body here.\n@end"
    return first(t, msg) match {
        case Consult(target, override, _) => {
            val t1 = Eq(t, target, "transpiler")
            val t2 = IsSome(t1, override)
            return Eq(t2, override.Get(), "~/work/gala_simple-fork")
        }
        case _ => IsTrue(t, false)
    }
}

func TestConsult_UnknownArgKeyIgnored(t T) T {
    val msg = "@consult(transpiler, unknown=foo, project=\"/x\")\nBody.\n@end"
    return first(t, msg) match {
        case Consult(_, override, _) => Eq(t, override.Get(), "/x")
        case _                       => IsTrue(t, false)
    }
}

// ----- @summary -------------------------------------------------------------

func TestSummary_Block(t T) T {
    val msg = "@summary\n## Summary\nImplemented loader.\n@end"
    return first(t, msg) match {
        case Summary(body) => IsTrue(t, body == "## Summary\nImplemented loader.")
        case _              => IsTrue(t, false)
    }
}

func TestSummary_SameLineHeader(t T) T {
    val msg = "@summary ## Header on same line\nbody line\n@end"
    return first(t, msg) match {
        case Summary(body) => IsTrue(t, body == "## Header on same line\nbody line")
        case _              => IsTrue(t, false)
    }
}

// ----- robustness -----------------------------------------------------------

func TestNoDirectives_EmptyResult(t T) T {
    val msg = "Just normal prose without any tags."
    return Eq(t, Parse(msg).Length(), 0)
}

func TestUnterminatedDispatch_TreatsEofAsEnd(t T) T {
    val msg = "@dispatch(Felix) Mid-stream content"
    return first(t, msg) match {
        case Dispatch(target, body) => {
            val t1 = Eq(t, target, "Felix")
            return Eq(t1, body, "Mid-stream content")
        }
        case _ => IsTrue(t, false)
    }
}

func TestProseAroundDispatch_Ignored(t T) T {
    val msg = "Got it. Splitting the work:\n\n" +
        "@dispatch(Felix) Do the work.\n@end\n\n" +
        "I'll review when both are back."
    return Eq(t, Parse(msg).Length(), 1)
}

func TestDispatch_LeadingWhitespaceTolerated(t T) T {
    val msg = "    @dispatch(Felix) hello\n    @end"
    return first(t, msg) match {
        case Dispatch(target, _) => Eq(t, target, "Felix")
        case _                    => IsTrue(t, false)
    }
}

// Mixed directives in one message — TL response often blends a
// dispatch and a summary or a consult and a dispatch. Source-order
// matters because afterTLDone scans for @summary first; verify the
// parser preserves order so the FSM's "first @summary wins" rule is
// against the user-visible order, not a re-sorted one.

func TestParse_MixedDispatchSummary_PreservesOrder(t T) T {
    val msg = "@dispatch(Felix) work\n@end\n\n@summary\ndone\n@end"
    val dirs = Parse(msg)
    val t1 = Eq(t, dirs.Length(), 2)
    val d0 = dirs.Get(0)
    val d1 = dirs.Get(1)
    val t2 = d0 match {
        case Dispatch(_, _) => IsTrue(t1, true)
        case _              => IsTrue(t1, false)
    }
    return d1 match {
        case Summary(_) => IsTrue(t2, true)
        case _          => IsTrue(t2, false)
    }
}

func TestParse_SummaryThenDispatch(t T) T {
    val msg = "@summary\nfinal\n@end\n@dispatch(Felix) work\n@end"
    val dirs = Parse(msg)
    val t1 = Eq(t, dirs.Length(), 2)
    val d0 = dirs.Get(0)
    return d0 match {
        case Summary(body) => Eq(t1, body, "final")
        case _             => IsTrue(t1, false)
    }
}

// Empty message and whitespace-only message both yield zero directives
// without crashing. Critical for the runtime: an empty TL chunk
// shouldn't panic.

func TestParse_EmptyMessage(t T) T = Eq(t, Parse("").Length(), 0)

func TestParse_WhitespaceOnly(t T) T = Eq(t, Parse("   \n\t  \n").Length(), 0)

// Empty body — `@dispatch(X)` with no payload should still parse the
// target out, body is "" (rule: don't drop the directive on empty
// body — that's a TL screwup the user wants visibility into, not a
// silent no-op).
func TestDispatch_EmptyBody_ParsesTargetAndEmptyBody(t T) T {
    val msg = "@dispatch(Felix)\n@end"
    return first(t, msg) match {
        case Dispatch(target, body) => {
            val t1 = Eq(t, target, "Felix")
            return Eq(t1, body, "")
        }
        case _ => IsTrue(t, false)
    }
}

// Two consults in one message — must round-trip both targets.
func TestParse_MultipleConsults(t T) T {
    val msg = "@consult(transpiler) repro 1\n@end\n\n@consult(qa-lib) repro 2\n@end"
    val dirs = Parse(msg)
    val t1 = Eq(t, dirs.Length(), 2)
    val d0 = dirs.Get(0)
    val d1 = dirs.Get(1)
    val t2 = d0 match {
        case Consult(target, _, _) => Eq(t1, target, "transpiler")
        case _                     => IsTrue(t1, false)
    }
    return d1 match {
        case Consult(target, _, _) => Eq(t2, target, "qa-lib")
        case _                     => IsTrue(t2, false)
    }
}

// Dispatch target with an underscore / digit / hyphen — names aren't
// always alphabetic-only in practice (e.g., "QA-2", "frontend_dev").
func TestDispatch_TargetWithUnderscore(t T) T {
    val msg = "@dispatch(frontend_dev) build form.\n@end"
    return first(t, msg) match {
        case Dispatch(target, _) => Eq(t, target, "frontend_dev")
        case _                   => IsTrue(t, false)
    }
}

// ----- @done / @help / @blocked (member → orchestrator) ---------------------

// Members emit @done when their dispatched task is complete. Body
// (deliverable summary) is what the orchestrator routes back to the TL
// in the relay turn, so multi-line bodies must round-trip cleanly.
func TestDone_MultiLineBody(t T) T {
    val msg = "@done\n" +
        "Token store implementation complete.\n" +
        "  - tests added\n" +
        "  - lint clean\n" +
        "@end"
    return first(t, msg) match {
        case Finished(body) => IsTrue(t, body == "Token store implementation complete.\n  - tests added\n  - lint clean")
        case _          => IsTrue(t, false)
    }
}

// @done can carry the deliverable body on the same line as the tag,
// mirroring the @summary same-line shorthand. Empty body is allowed
// — sometimes a member just signals "I'm done" with no commentary.
func TestDone_SameLineBodyAndEmptyBody(t T) T {
    val msg1 = "@done shipped it\n@end"
    val msg2 = "@done\n@end"
    val t1 = first(t, msg1) match {
        case Finished(body) => Eq(t, body, "shipped it")
        case _          => IsTrue(t, false)
    }
    return first(t1, msg2) match {
        case Finished(body) => Eq(t1, body, "")
        case _          => IsTrue(t1, false)
    }
}

// @help carries a clarification question. Question is the full body —
// orchestrator splices it into the TL clarification turn verbatim.
func TestHelp_QuestionBody(t T) T {
    val msg = "@help\nWhich auth flow — JWT or session cookies?\n@end"
    return first(t, msg) match {
        case Help(question) => Eq(t, question, "Which auth flow — JWT or session cookies?")
        case _              => IsTrue(t, false)
    }
}

// @blocked surfaces an external-environment failure the TL can't fix.
// Reason becomes user-visible LastError text.
func TestBlocked_ReasonBody(t T) T {
    val msg = "@blocked\ngh CLI not installed and PR creation requires it\n@end"
    return first(t, msg) match {
        case Blocked(reason) => Eq(t, reason, "gh CLI not installed and PR creation requires it")
        case _               => IsTrue(t, false)
    }
}

// Mixed member directives — a member can both ask for help AND emit a
// partial deliverable in the same turn. Source order matters; both
// must surface to the orchestrator so the TL sees the full picture.
func TestParse_MixedDoneAndHelp_PreservesOrder(t T) T {
    val msg = "@done partial: scaffold landed\n@end\n\n@help\nshould I proceed with auth or wait?\n@end"
    val dirs = Parse(msg)
    val t1 = Eq(t, dirs.Length(), 2)
    val d0 = dirs.Get(0)
    val d1 = dirs.Get(1)
    val t2 = d0 match {
        case Finished(_) => IsTrue(t1, true)
        case _       => IsTrue(t1, false)
    }
    return d1 match {
        case Help(_) => IsTrue(t2, true)
        case _       => IsTrue(t2, false)
    }
}

// ----- @base ---------------------------------------------------------------

// @base captures a single ref token as the next PR's base branch.
func TestBase_RefOnSameLine(t T) T {
    val msg = "@base previous\n@end"
    return first(t, msg) match {
        case Base(ref) => Eq(t, ref, "previous")
        case _         => IsTrue(t, false)
    }
}

// @base also accepts the ref on a separate body line — TLs sometimes
// wrap directives that way and we shouldn't punish them for it.
func TestBase_RefOnSeparateLine(t T) T {
    val msg = "@base\nmain\n@end"
    return first(t, msg) match {
        case Base(ref) => Eq(t, ref, "main")
        case _         => IsTrue(t, false)
    }
}

// @base with an empty body is a parse failure — drops the directive
// rather than locking the team into an ambiguous base.
func TestBase_EmptyBody_DropsDirective(t T) T {
    val msg = "@base\n@end"
    val dirs = Parse(msg)
    return IsTrue(t, dirs.IsEmpty())
}

// A literal branch name (anything that isn't `main` / `previous`) is
// passed through verbatim. The downstream resolver decides what to do
// with it.
func TestBase_LiteralBranchName(t T) T {
    val msg = "@base feat/payments-stack\n@end"
    return first(t, msg) match {
        case Base(ref) => Eq(t, ref, "feat/payments-stack")
        case _         => IsTrue(t, false)
    }
}

// @base + @dispatch in the same turn — both surface to the
// orchestrator in source order so the FSM sees the dispatch and the
// PR pipeline picks up the base.
func TestParse_BaseThenDispatch_PreservesOrder(t T) T {
    val msg = "@base previous\n@end\n\n@dispatch(Felix)\nImplement the follow-up.\n@end"
    val dirs = Parse(msg)
    val t1 = Eq(t, dirs.Length(), 2)
    val t2 = dirs.Get(0) match {
        case Base(_) => IsTrue(t1, true)
        case _       => IsTrue(t1, false)
    }
    return dirs.Get(1) match {
        case Dispatch(_, _) => IsTrue(t2, true)
        case _              => IsTrue(t2, false)
    }
}

// ----- @plan ---------------------------------------------------------------

// @plan accepts a numbered list. Leading "N." is stripped from each
// item so the queued prompt matches the user-facing text.
func TestPlan_NumberedList(t T) T {
    val msg = "@plan\n1. Stripe SDK\n2. Webhook handler\n3. Refund flow\n@end"
    return first(t, msg) match {
        case Plan(items) => {
            val t1 = Eq(t, items.Length(), 3)
            val t2 = Eq(t1, items.Get(0), "Stripe SDK")
            val t3 = Eq(t2, items.Get(1), "Webhook handler")
            return Eq(t3, items.Get(2), "Refund flow")
        }
        case _ => IsTrue(t, false)
    }
}

// @plan accepts dash bullets too. Same item shape after the bullet
// is stripped.
func TestPlan_DashBullets(t T) T {
    val msg = "@plan\n- One\n- Two\n- Three\n@end"
    return first(t, msg) match {
        case Plan(items) => {
            val t1 = Eq(t, items.Length(), 3)
            val t2 = Eq(t1, items.Get(0), "One")
            val t3 = Eq(t2, items.Get(1), "Two")
            return Eq(t3, items.Get(2), "Three")
        }
        case _ => IsTrue(t, false)
    }
}

// Plain lines without bullets are taken as-is. Empty lines between
// items are skipped.
func TestPlan_PlainLinesWithBlankSeparators(t T) T {
    val msg = "@plan\nFirst PR\n\nSecond PR\n\nThird PR\n@end"
    return first(t, msg) match {
        case Plan(items) => {
            val t1 = Eq(t, items.Length(), 3)
            return Eq(t1, items.Get(0), "First PR")
        }
        case _ => IsTrue(t, false)
    }
}

// Empty plan body drops the directive (no zero-step plan).
func TestPlan_EmptyBody_DropsDirective(t T) T {
    val msg = "@plan\n@end"
    val dirs = Parse(msg)
    return IsTrue(t, dirs.IsEmpty())
}

// @plan + @dispatch in the same turn surface in source order so the
// orchestrator can stash the plan and still spawn the first dispatch.
func TestParse_PlanThenDispatch_PreservesOrder(t T) T {
    val msg = "@plan\nA\nB\n@end\n\n@dispatch(Felix)\nImplement A.\n@end"
    val dirs = Parse(msg)
    val t1 = Eq(t, dirs.Length(), 2)
    val t2 = dirs.Get(0) match {
        case Plan(_) => IsTrue(t1, true)
        case _       => IsTrue(t1, false)
    }
    return dirs.Get(1) match {
        case Dispatch(_, _) => IsTrue(t2, true)
        case _              => IsTrue(t2, false)
    }
}

// ----- LooksLikeWorkTurn ----------------------------------------------------
//
// Conservative heuristic: requires two distinct signals (tool-use prose,
// file paths, build/test invocations, sign-off phrases) on a body of
// 400+ chars. Single signals or short bodies must NOT trip.

func TestLooksLikeWorkTurn_ShortChat_False(t T) T {
    return IsTrue(t, !LooksLikeWorkTurn("I'll wait for direction before dispatching."))
}

func TestLooksLikeWorkTurn_LongChatNoSignals_False(t T) T {
    val msg = "Sure thing — happy to help with that. " +
        "There are a few different angles to think about here. " +
        "On one hand, the simpler approach is usually better, but " +
        "on the other hand, sometimes a more thorough investigation " +
        "pays off in the long run. I'd be happy to discuss whichever " +
        "direction sounds right to you. Let me know what you'd prefer " +
        "and we can go from there. Either approach has merit, really."
    return IsTrue(t, !LooksLikeWorkTurn(msg))
}

func TestLooksLikeWorkTurn_OnlyOneSignal_False(t T) T {
    // A single tool-use phrase isn't enough — body is over 400 chars but
    // has only the one signal.
    val msg = "Let me check the situation here. There are several things to think through " +
        "before deciding on a direction, and I want to lay them out so we can pick " +
        "together. Roughly speaking, the question is whether to invest in the change " +
        "now or to keep the existing approach and revisit later. Both have tradeoffs " +
        "and I don't have a strong prior. Worth a chat before I start anything."
    return IsTrue(t, !LooksLikeWorkTurn(msg))
}

func TestLooksLikeWorkTurn_TwoSignals_True(t T) T {
    val msg = "Let me check the BUILD.bazel changes carefully and review " +
        "every target's deps before reaching for an edit anywhere in the tree. " +
        "There are a few angles to weigh before we touch anything else " +
        "and I want to be certain we don't disturb the existing layout. " +
        "Going to take a moment to sketch the plan and confirm the test " +
        "runner expectations on Windows are met by the existing setup so " +
        "we don't get surprised when the suite spins up later in the loop."
    return IsTrue(t, LooksLikeWorkTurn(msg))
}

func TestLooksLikeWorkTurn_ToolUsePlusFilePath_True(t T) T {
    val msg = "Let me run bazel test //app/fsm:state_machine_test against " +
        "the local checkout and confirm the new transitions land cleanly. " +
        "Then we will review the diff against master to make sure nothing " +
        "else moved while we were working. Once that lands I'll roll " +
        "forward through the rest of the suite to catch any surprises " +
        "before we report back to the user. Should be quick if the cache " +
        "is warm; longer if bazel needs to re-transpile any sibling deps."
    return IsTrue(t, LooksLikeWorkTurn(msg))
}

func TestLooksLikeWorkTurn_PassTallyPlusFilePath_True(t T) T {
    val msg = "All tests pass. Modified app/ui/view.gala and app/view/team_panel.gala " +
        "and a couple of BUILD.bazel files alongside them, plus a small " +
        "tweak in app/cli/keymap.gala for the new shortcut. Build clean " +
        "across all 16 targets after the BUILD config fixups. The diff is " +
        "small enough to land as one PR — happy to split if you want " +
        "tighter reviewability, but the migration touches related files " +
        "that ride together cleanly. Let me know which way you'd prefer."
    return IsTrue(t, LooksLikeWorkTurn(msg))
}

// ----- LooksLikeProseSummary ------------------------------------------------
//
// Strict: requires PR-section heading + 2+ bullet lines + sign-off phrase
// + zero @summary tokens in the buffer. Each missing piece must drop the
// classifier to false.

func TestLooksLikeProseSummary_Empty_False(t T) T {
    return IsTrue(t, !LooksLikeProseSummary(""))
}

func TestLooksLikeProseSummary_HasAtSummary_False(t T) T {
    val msg = "@summary\n## What\n- did the thing\n- and another thing\nAll tests pass.\n@end"
    return IsTrue(t, !LooksLikeProseSummary(msg))
}

func TestLooksLikeProseSummary_NoHeading_False(t T) T {
    val msg = "- bumped gala\n- fixed truncation\n- migrated parser\nAll tests pass."
    return IsTrue(t, !LooksLikeProseSummary(msg))
}

func TestLooksLikeProseSummary_HeadingButNoBullets_False(t T) T {
    val msg = "## What\n\nFixed the bug. All tests pass."
    return IsTrue(t, !LooksLikeProseSummary(msg))
}

func TestLooksLikeProseSummary_HeadingBulletsNoSignOff_False(t T) T {
    val msg = "## Changes\n- A\n- B\n- C\n\nThoughts welcome."
    return IsTrue(t, !LooksLikeProseSummary(msg))
}

func TestLooksLikeProseSummary_FullShape_True(t T) T {
    val msg = "## Changes\n\n- bumped gala 0.44 → 0.48\n" +
        "- fixed sidebar truncation\n- migrated parser to gala-strings\n\n" +
        "Build clean, all tests pass."
    return IsTrue(t, LooksLikeProseSummary(msg))
}

func TestLooksLikeProseSummary_BoldHeadingShape_True(t T) T {
    val msg = "**Summary:** here's what landed.\n\n" +
        "- bump\n- fix\n- migrate\n\nAll tests pass, ready to ship."
    return IsTrue(t, LooksLikeProseSummary(msg))
}
