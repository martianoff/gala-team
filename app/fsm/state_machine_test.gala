package fsm

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "github.com/martianoff/gala_team/app/directive"
)

func ctxWithQA(qaRequired bool) TransitionContext = TransitionContext(
    QAMembers  = ArrayOf[string]("Theo"),
    QARequired = qaRequired,
)

func ctxNoQA() TransitionContext = TransitionContext(
    QAMembers  = EmptyArray[string](),
    QARequired = false,
)

func stateName(s AppState) string = s match {
    case Idle()              => "Idle"
    case TLThinking()        => "TLThinking"
    case Delegating(_, _)    => "Delegating"
    case QAGate(_, _)        => "QAGate"
    case TLReview()          => "TLReview"
    case TLNudging(_, _, _)  => "TLNudging"
    case Approval(_)         => "Approval"
}

func dispatchTo(name string) Directive = Dispatch(Target = name, Body = "do work")
func summary(body string) Directive    = Summary(Body = body)

// ----- Idle ↔ TLThinking ----------------------------------------------------

func TestIdle_OnUserPrompt_GoesToTLThinking(t T) T {
    val s = Transition(Idle(), UserPrompted(), ctxWithQA(true))
    return Eq(t, stateName(s), "TLThinking")
}

func TestIdle_OnIrrelevantEvent_StaysIdle(t T) T {
    val s = Transition(Idle(), QADone(), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

// ----- TLThinking → Delegating / Approval / Idle ----------------------------

func TestTLThinking_OnDispatchDirectives_GoesToDelegating(t T) T {
    val dirs = ArrayOf[Directive](dispatchTo("Felix"), dispatchTo("Mira"))
    val s = Transition(TLThinking(), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Delegating")
}

func TestTLThinking_OnSummary_GoesToApproval(t T) T {
    val dirs = ArrayOf[Directive](summary("## Done"))
    val s = Transition(TLThinking(), TLDone(Directives = dirs), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "Approval")
    return s match {
        case Approval(body) => Eq(t1, body, "## Done")
        case _              => IsTrue(t1, false)
    }
}

func TestTLThinking_OnNoDirectives_BackToIdle(t T) T {
    val dirs = EmptyArray[Directive]()
    val s = Transition(TLThinking(), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

func TestTLThinking_SummaryBeatsDispatch(t T) T {
    val dirs = ArrayOf[Directive](dispatchTo("Felix"), summary("override"))
    val s = Transition(TLThinking(), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Approval")
}

// ----- Delegating drains pending → QAGate / TLReview ------------------------

func TestDelegating_OneMemberDone_StaysDelegating(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix").Add("Mira")
    val s = Transition(Delegating(Pending = pending, Dispatched = pending), MemberDone(MemberName = "Felix", Body = ""), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "Delegating")
    return s match {
        case Delegating(rest, _) => Eq(t1, rest.Size(), 1)
        case _                => IsTrue(t1, false)
    }
}

func TestDelegating_AllDone_QARequired_GoesToQAGate(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val s = Transition(Delegating(Pending = pending, Dispatched = pending), MemberDone(MemberName = "Felix", Body = ""), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "QAGate")
    return s match {
        case QAGate(qaPending, _) => Eq(t1, qaPending.Size(), 1)
        case _                 => IsTrue(t1, false)
    }
}

func TestDelegating_AllDone_NoQA_GoesToTLReview(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val s = Transition(Delegating(Pending = pending, Dispatched = pending), MemberDone(MemberName = "Felix", Body = ""), ctxNoQA())
    return Eq(t, stateName(s), "TLReview")
}

// ----- QAGate → TLReview ----------------------------------------------------

func TestQAGate_OnQADone_GoesToTLReview(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val s = Transition(QAGate(Pending = pending, Dispatched = pending), QADone(), ctxWithQA(true))
    return Eq(t, stateName(s), "TLReview")
}

// ----- Approval lifecycle ---------------------------------------------------

func TestApproval_Accepted_BackToIdle(t T) T {
    val s = Transition(Approval(SummaryBody = "..."), ApprovalAccepted(), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

func TestApproval_Rejected_BackToIdle(t T) T {
    val s = Transition(Approval(SummaryBody = "..."), ApprovalRejected(), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

// ----- TL review re-runs the dispatch logic ---------------------------------

func TestTLReview_OnSummary_GoesToApproval(t T) T {
    val dirs = ArrayOf[Directive](summary("final"))
    val s = Transition(TLReview(), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Approval")
}

func TestTLReview_OnDispatch_GoesBackToDelegating(t T) T {
    val dirs = ArrayOf[Directive](dispatchTo("Felix"))
    val s = Transition(TLReview(), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Delegating")
}

// ----- Irrelevant-event guards: every (state, event) pair the FSM
// sees in production must be defined. The interesting ones land an
// AppMsg through the runtime that the FSM didn't ask for — e.g. a
// stray ChunkArrived after we've already moved out of Delegating.
// Every "wrong event for this state" pair should leave the state
// unchanged so the orchestrator stays drift-free.

func TestIdle_IgnoresTLDone(t T) T {
    val s = Transition(Idle(), TLDone(Directives = EmptyArray[Directive]()), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

func TestIdle_IgnoresMemberDone(t T) T {
    val s = Transition(Idle(), MemberDone(MemberName = "Felix", Body = ""), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

func TestIdle_IgnoresApprovalAccepted(t T) T {
    val s = Transition(Idle(), ApprovalAccepted(), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

func TestTLThinking_IgnoresUserPrompted(t T) T {
    val s = Transition(TLThinking(), UserPrompted(), ctxWithQA(true))
    return Eq(t, stateName(s), "TLThinking")
}

func TestTLThinking_IgnoresMemberDone(t T) T {
    val s = Transition(TLThinking(), MemberDone(MemberName = "Felix", Body = ""), ctxWithQA(true))
    return Eq(t, stateName(s), "TLThinking")
}

func TestTLThinking_IgnoresQADone(t T) T {
    val s = Transition(TLThinking(), QADone(), ctxWithQA(true))
    return Eq(t, stateName(s), "TLThinking")
}

// UserPrompted is a top-level escape hatch in any non-Approval state
// (lets the user break out of QAGate when no QA was actually
// dispatched, or out of Delegating when a member is hung). The FSM
// resets to TLThinking on every fresh user prompt.
func TestDelegating_UserPromptedResetsToTLThinking(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix").Add("Mira")
    val s = Transition(Delegating(Pending = pending, Dispatched = pending), UserPrompted(), ctxWithQA(true))
    return Eq(t, stateName(s), "TLThinking")
}

func TestDelegating_IgnoresQADone(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val s = Transition(Delegating(Pending = pending, Dispatched = pending), QADone(), ctxWithQA(true))
    return Eq(t, stateName(s), "Delegating")
}

func TestDelegating_IgnoresTLDone(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val dirs = ArrayOf[Directive](dispatchTo("Felix"))
    val s = Transition(Delegating(Pending = pending, Dispatched = pending), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Delegating")  // mid-flight TLDone is ignored
}

// QAGate × MemberDone — partial QA drain. If multiple QAs are pending,
// removing one should keep us in QAGate with the rest.
func TestQAGate_OneQADone_StaysQAGateWithRest(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo").Add("Mira")
    val s = Transition(QAGate(Pending = pending, Dispatched = pending), MemberDone(MemberName = "Theo", Body = ""), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "QAGate")
    return s match {
        case QAGate(rest, _) => Eq(t1, rest.Size(), 1)
        case _            => IsTrue(t1, false)
    }
}

func TestQAGate_LastQADone_GoesToTLReview(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val s = Transition(QAGate(Pending = pending, Dispatched = pending), MemberDone(MemberName = "Theo", Body = ""), ctxWithQA(true))
    return Eq(t, stateName(s), "TLReview")
}

// QAGate is one of the states the UserPrompted escape hatch covers
// — see TestDelegating_UserPromptedResetsToTLThinking for the
// rationale.
func TestQAGate_UserPromptedResetsToTLThinking(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val s = Transition(QAGate(Pending = pending, Dispatched = pending), UserPrompted(), ctxWithQA(true))
    return Eq(t, stateName(s), "TLThinking")
}

// QAGate × TLDone — the TL can produce a turn while QA is pending
// (a member's @blocked or @help that didn't drain the pending set
// can still spawn a TL relay). Past behaviour swallowed any TLDone
// here as a self-loop, including a @summary asking the user a
// decision-required question — the user saw the prose with no
// approval modal. Routing rules:
//
//   - @summary present → Approval (user-decision affordance reaches
//     the user; outweighs the still-pending QA review).
//   - Anything else (empty, partial @dispatch, plain prose) → keep
//     QAGate so the pending QA reviewer isn't torn down by a TL
//     turn that didn't intend to ship.
func TestQAGate_TLDoneWithSummary_GoesToApproval(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val dirs = ArrayOf[Directive](summary("## Decision required\nPick one of (1) (2) (3)."))
    val s = Transition(QAGate(Pending = pending, Dispatched = pending), TLDone(Directives = dirs), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "Approval")
    return s match {
        case Approval(body) => Eq(t1, body, "## Decision required\nPick one of (1) (2) (3).")
        case _              => IsTrue(t1, false)
    }
}

func TestQAGate_TLDoneEmpty_StaysQAGateWithPending(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val dirs = EmptyArray[Directive]()
    val s = Transition(QAGate(Pending = pending, Dispatched = pending), TLDone(Directives = dirs), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "QAGate")
    return s match {
        case QAGate(rest, _) => Eq(t1, rest.Contains("Theo"), true)
        case _            => IsTrue(t1, false)
    }
}

// A partial @dispatch while QA is pending shouldn't tear down the
// QAGate either — the TL might be asking another engineer for
// background work, but the open QA review is still the pipeline's
// blocking step. Stay in QAGate; the dispatch directive surfaces
// in the UI via the per-chunk pipeline regardless.
func TestQAGate_TLDoneWithDispatchOnly_StaysQAGateWithPending(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val dirs = ArrayOf[Directive](dispatchTo("Felix"))
    val s = Transition(QAGate(Pending = pending, Dispatched = pending), TLDone(Directives = dirs), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "QAGate")
    return s match {
        case QAGate(rest, _) => Eq(t1, rest.Contains("Theo"), true)
        case _            => IsTrue(t1, false)
    }
}

func TestApproval_IgnoresUserPrompted(t T) T {
    val s = Transition(Approval(SummaryBody = "ship"), UserPrompted(), ctxWithQA(true))
    return Eq(t, stateName(s), "Approval")
}

func TestApproval_IgnoresTLDone(t T) T {
    val dirs = ArrayOf[Directive](summary("ignore me"))
    val s = Transition(Approval(SummaryBody = "ship"), TLDone(Directives = dirs), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "Approval")
    return s match {
        case Approval(body) => Eq(t1, body, "ship")  // SummaryBody preserved
        case _              => IsTrue(t1, false)
    }
}

// QA-required policy interactions. With QARequired=false the
// Delegating drain skips QAGate entirely; with QARequired=true but
// QAMembers=[] it also skips (no one to dispatch to).

func TestDelegating_QARequiredButNoQAMembers_GoesToTLReview(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val ctx = TransitionContext(QAMembers = EmptyArray[string](), QARequired = true)
    val s = Transition(Delegating(Pending = pending, Dispatched = pending), MemberDone(MemberName = "Felix", Body = ""), ctx)
    return Eq(t, stateName(s), "TLReview")
}

// TL routes consult / approval-only directives correctly. Multiple
// summaries: the FIRST one wins (firstSummary semantics).

func TestTLThinking_MultipleSummaries_TakesFirst(t T) T {
    val dirs = ArrayOf[Directive](summary("first"), summary("second"))
    val s = Transition(TLThinking(), TLDone(Directives = dirs), ctxWithQA(true))
    return s match {
        case Approval(body) => Eq(t, body, "first")
        case _              => IsTrue(t, false)
    }
}

// MemberDone for a member who isn't in pending should be a no-op on
// Delegating's pending set — Remove of a missing key is idempotent.
func TestDelegating_MemberDone_UnknownMember_StaysWithFullPending(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix").Add("Mira")
    val s = Transition(Delegating(Pending = pending, Dispatched = pending), MemberDone(MemberName = "Ghost", Body = ""), ctxWithQA(true))
    return s match {
        case Delegating(rest, _) => Eq(t, rest.Size(), 2)
        case _                => IsTrue(t, false)
    }
}

// ----- TLNudging carries Pending; no-directive nudge must not Idle ----------
//
// Repro of the "stuck after a nudge until the user types continue"
// freeze: a nudged TL replied prose-only (no @dispatch / @summary).
// afterTLDone mapped that to Idle, silently abandoning the run — the
// still-working member later finished into Idle and was discarded.

// Delegating + MemberStuck must carry the pending set into TLNudging
// (so the nudge resolution knows who we're still waiting on).
func TestDelegating_OnMemberStuck_CarriesPendingIntoTLNudging(t T) T {
    val pending = EmptyHashSet[string]().Add("Bram").Add("Otis")
    val s = Transition(Delegating(Pending = pending, Dispatched = pending), MemberStuck(MemberName = "Bram"), ctxWithQA(true))
    return s match {
        case TLNudging(_, p, _) => Eq(t, p.Size(), 2)
        case _               => IsTrue(t, false)
    }
}

// Same shape from QAGate: a stuck QA member must route through the
// lead, NOT self-loop. Without this, the heartbeat re-fires
// MemberStuck every cycle (~2 min) — live audit caught this as a
// QAGate→QAGate livelock with a fresh TL nudge each round.
func TestQAGate_OnMemberStuck_CarriesPendingIntoTLNudging(t T) T {
    val pending = EmptyHashSet[string]().Add("Mara").Add("Theo")
    val s = Transition(QAGate(Pending = pending, Dispatched = pending), MemberStuck(MemberName = "Mara"), ctxWithQA(true))
    return s match {
        case TLNudging(reason, p, _) => IsTrue(t, reason == "stuck" && p.Size() == 2)
        case _                    => IsTrue(t, false)
    }
}

func TestQAGate_OnMemberHelpRequested_CarriesPendingIntoTLNudging(t T) T {
    val pending = EmptyHashSet[string]().Add("Mara")
    val s = Transition(QAGate(Pending = pending, Dispatched = pending), MemberHelpRequested(MemberName = "Mara", Question = "What's the contract?"), ctxWithQA(true))
    return s match {
        case TLNudging(reason, p, _) => IsTrue(t, reason == "help" && p.Contains("Mara"))
        case _                    => IsTrue(t, false)
    }
}

// A prose-only nudge resolution drops the FSM to Idle even when
// members are still pending. The carry-back-to-Delegating(pending)
// fallback was retired with the heartbeat-ladder rip-out: a still-
// silent pending member is a delivery non-ack, and the protocol's
// Tick driver re-escalates via Redeliver / IssueNudge / MarkAbandoned
// on the next heartbeat — recovery is owned by the protocol path,
// not by an ad-hoc FSM bounce.
func TestTLNudging_NoDirectiveWithPending_GoesIdle(t T) T {
    val pending = EmptyHashSet[string]().Add("Bram")
    val s = Transition(TLNudging(Reason = "stuck", Pending = pending, Dispatched = pending), TLDone(Directives = EmptyArray[Directive]()), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

// Nudge resolves with no directive AND nothing pending → Idle (the
// pre-existing chat behaviour is preserved when it's actually safe).
func TestTLNudging_NoDirectiveNoPending_GoesIdle(t T) T {
    val s = Transition(TLNudging(Reason = "stuck", Pending = EmptyHashSet[string](), Dispatched = EmptyHashSet[string]()), TLDone(Directives = EmptyArray[Directive]()), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

// A nudge that DOES produce a @summary still ships (Approval), and a
// @dispatch still fans out (Delegating) — the override only rescues
// the empty case.
func TestTLNudging_SummaryStillShips(t T) T {
    val pending = EmptyHashSet[string]().Add("Bram")
    val s = Transition(TLNudging(Reason = "stuck", Pending = pending, Dispatched = pending), TLDone(Directives = ArrayOf[Directive](summary("## Done"))), ctxWithQA(true))
    return Eq(t, stateName(s), "Approval")
}

// A member that completes DURING the nudge turn drains the pending
// set exactly like Delegating (so a finish racing the nudge isn't
// lost into TLNudging).
func TestTLNudging_MemberDoneDuringNudge_Drains(t T) T {
    val pending = EmptyHashSet[string]().Add("Bram").Add("Otis")
    val s = Transition(TLNudging(Reason = "stuck", Pending = pending, Dispatched = pending), MemberDone(MemberName = "Bram", Body = ""), ctxWithQA(true))
    return s match {
        case Delegating(rest, _) => Eq(t, rest.Size(), 1)
        case _                => IsTrue(t, false)
    }
}

// ----- Pending ⊆ Dispatched invariant ---------------------------------------
//
// A TL turn that names a member who never actually spawns — typo
// against the team roster, or runtime SpawnSession failure — must
// not deadlock the Delegating drain waiting for a MemberDone that
// will never arrive. DispatchComplete carries the names whose spawn
// succeeded; any name in Pending but not in (Dispatched ∪ Spawned)
// is unspawned. The FSM routes to TLNudging("<name> never started")
// so the lead can recover via the next turn.

// Typo: TL said @dispatch(Typo) for a name that has no team member.
// The caller emits DispatchComplete with an empty Spawned set;
// Pending still contains the typo'd name → trip invariant → nudge.
func TestDelegating_DispatchCompleteUnspawnedTypo_GoesToTLNudging(t T) T {
    val pending = EmptyHashSet[string]().Add("Typo")
    val s = Transition(
        Delegating(Pending = pending, Dispatched = EmptyHashSet[string]()),
        DispatchComplete(Spawned = EmptyHashSet[string]()),
        ctxWithQA(true),
    )
    val t1 = Eq(t, stateName(s), "TLNudging")
    return s match {
        case TLNudging(reason, p, _) => IsTrue(t1, reason == "Typo never started" && p.Contains("Typo"))
        case _                       => IsTrue(t1, false)
    }
}

// Real member name, runtime SpawnSession failure: TL dispatched two
// members; one spawn succeeded, the other failed. DispatchComplete
// carries only the successful name; the failed one stays unspawned.
func TestDelegating_DispatchCompletePartialSpawn_GoesToTLNudging(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix").Add("Mira")
    val spawned = EmptyHashSet[string]().Add("Felix")
    val s = Transition(
        Delegating(Pending = pending, Dispatched = EmptyHashSet[string]()),
        DispatchComplete(Spawned = spawned),
        ctxWithQA(true),
    )
    val t1 = Eq(t, stateName(s), "TLNudging")
    return s match {
        case TLNudging(reason, p, d) =>
            IsTrue(t1, reason == "Mira never started" && p.Size() == 2 && d.Contains("Felix"))
        case _ => IsTrue(t1, false)
    }
}

// Happy path: every Pending name spawns successfully; DispatchComplete
// merges all of them into Dispatched and the FSM stays in Delegating
// so the run can drain via MemberDone exactly like before.
func TestDelegating_DispatchCompleteAllSpawned_StaysDelegating(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix").Add("Mira")
    val s = Transition(
        Delegating(Pending = pending, Dispatched = EmptyHashSet[string]()),
        DispatchComplete(Spawned = pending),
        ctxWithQA(true),
    )
    val t1 = Eq(t, stateName(s), "Delegating")
    return s match {
        case Delegating(p, d) => IsTrue(t1, p.Size() == 2 && d.Size() == 2 && d.Contains("Felix") && d.Contains("Mira"))
        case _                => IsTrue(t1, false)
    }
}

// After a successful DispatchComplete, the normal MemberDone drain
// still routes through QAGate / TLReview just like before — the
// invariant adds a guard, it doesn't change the happy-path shape.
func TestDelegating_HappyPath_DispatchCompleteThenDrainsToQAGate(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val afterSpawn = Transition(
        Delegating(Pending = pending, Dispatched = EmptyHashSet[string]()),
        DispatchComplete(Spawned = pending),
        ctxWithQA(true),
    )
    val afterDone = Transition(afterSpawn, MemberDone(MemberName = "Felix", Body = ""), ctxWithQA(true))
    return Eq(t, stateName(afterDone), "QAGate")
}

func TestDelegating_HappyPath_DispatchCompleteThenDrainsToTLReview(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val afterSpawn = Transition(
        Delegating(Pending = pending, Dispatched = EmptyHashSet[string]()),
        DispatchComplete(Spawned = pending),
        ctxNoQA(),
    )
    val afterDone = Transition(afterSpawn, MemberDone(MemberName = "Felix", Body = ""), ctxNoQA())
    return Eq(t, stateName(afterDone), "TLReview")
}

// Multiple unspawned names: the lexicographically first name is
// surfaced in the reason so the message is deterministic across
// runs (HashSet iteration order is unspecified). The TL can address
// the rest in the same nudge turn.
func TestDelegating_DispatchCompleteMultipleUnspawned_NamesFirstAlphabetically(t T) T {
    val pending = EmptyHashSet[string]().Add("Zeta").Add("Alpha").Add("Mira")
    val s = Transition(
        Delegating(Pending = pending, Dispatched = EmptyHashSet[string]()),
        DispatchComplete(Spawned = EmptyHashSet[string]()),
        ctxWithQA(true),
    )
    return s match {
        case TLNudging(reason, _, _) => Eq(t, reason, "Alpha never started")
        case _                       => IsTrue(t, false)
    }
}

// QAGate has its own DispatchComplete reducer (the auto-QA fan-out
// fires once engineers complete). Same shape: a QA member whose
// spawn fails trips the invariant and routes to TLNudging instead
// of waiting forever for a QADone.
func TestQAGate_DispatchCompleteUnspawned_GoesToTLNudging(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val s = Transition(
        QAGate(Pending = pending, Dispatched = EmptyHashSet[string]()),
        DispatchComplete(Spawned = EmptyHashSet[string]()),
        ctxWithQA(true),
    )
    val t1 = Eq(t, stateName(s), "TLNudging")
    return s match {
        case TLNudging(reason, p, _) => IsTrue(t1, reason == "Theo never started" && p.Contains("Theo"))
        case _                       => IsTrue(t1, false)
    }
}

func TestQAGate_DispatchCompleteAllSpawned_StaysQAGate(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val s = Transition(
        QAGate(Pending = pending, Dispatched = EmptyHashSet[string]()),
        DispatchComplete(Spawned = pending),
        ctxWithQA(true),
    )
    val t1 = Eq(t, stateName(s), "QAGate")
    return s match {
        case QAGate(p, d) => IsTrue(t1, p.Contains("Theo") && d.Contains("Theo"))
        case _            => IsTrue(t1, false)
    }
}

// A nudge turn can itself emit a fresh @dispatch (TL recovering
// from an earlier unspawned-name nudge). The new dispatch's
// DispatchComplete fires while still in TLNudging; an unspawned
// name there must trip the invariant too, otherwise a TL stuck in
// a typo loop would silently never recover.
func TestTLNudging_DispatchCompleteUnspawned_StaysTLNudgingWithNewReason(t T) T {
    val pending = EmptyHashSet[string]().Add("Typo2")
    val s = Transition(
        TLNudging(Reason = "stuck", Pending = pending, Dispatched = EmptyHashSet[string]()),
        DispatchComplete(Spawned = EmptyHashSet[string]()),
        ctxWithQA(true),
    )
    val t1 = Eq(t, stateName(s), "TLNudging")
    return s match {
        case TLNudging(reason, _, _) => Eq(t1, reason, "Typo2 never started")
        case _                       => IsTrue(t1, false)
    }
}

// DispatchComplete after a partial in-flight Dispatched (e.g. a
// nudge that already had some names dispatched from the original
// fanout): the merge of the existing Dispatched with the new
// Spawned set is what's checked against Pending.
func TestDelegating_DispatchCompleteMergesWithExistingDispatched(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix").Add("Mira")
    val alreadyDispatched = EmptyHashSet[string]().Add("Felix")
    val s = Transition(
        Delegating(Pending = pending, Dispatched = alreadyDispatched),
        DispatchComplete(Spawned = EmptyHashSet[string]().Add("Mira")),
        ctxWithQA(true),
    )
    val t1 = Eq(t, stateName(s), "Delegating")
    return s match {
        case Delegating(_, d) => IsTrue(t1, d.Contains("Felix") && d.Contains("Mira"))
        case _                => IsTrue(t1, false)
    }
}
