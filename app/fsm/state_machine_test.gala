package main

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "github.com/martianoff/gala_team/app/directive"
    . "github.com/martianoff/gala_team/app/fsm"
)

func ctxWithQA(qaRequired bool) TransitionContext = TransitionContext(
    QAMembers  = ArrayOf[string]("Theo"),
    QARequired = qaRequired,
)

func ctxNoQA() TransitionContext = TransitionContext(
    QAMembers  = EmptyArray[string](),
    QARequired = false,
)

func stateName(s AppState) string = s match {
    case Idle()           => "Idle"
    case TLThinking()     => "TLThinking"
    case Delegating(_)    => "Delegating"
    case QAGate(_)        => "QAGate"
    case TLReview()       => "TLReview"
    case TLNudging(_)     => "TLNudging"
    case Approval(_)      => "Approval"
}

func dispatchTo(name string) Directive = Dispatch(Target = name, Body = "do work")
func summary(body string) Directive    = Summary(Body = body)

// ----- Idle ↔ TLThinking ----------------------------------------------------

func TestIdle_OnUserPrompt_GoesToTLThinking(t T) T {
    val s = Transition(Idle(), UserPrompted(), ctxWithQA(true))
    return Eq(t, stateName(s), "TLThinking")
}

func TestIdle_OnIrrelevantEvent_StaysIdle(t T) T {
    val s = Transition(Idle(), QADone(), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

// ----- TLThinking → Delegating / Approval / Idle ----------------------------

func TestTLThinking_OnDispatchDirectives_GoesToDelegating(t T) T {
    val dirs = ArrayOf[Directive](dispatchTo("Felix"), dispatchTo("Mira"))
    val s = Transition(TLThinking(), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Delegating")
}

func TestTLThinking_OnSummary_GoesToApproval(t T) T {
    val dirs = ArrayOf[Directive](summary("## Done"))
    val s = Transition(TLThinking(), TLDone(Directives = dirs), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "Approval")
    return s match {
        case Approval(body) => Eq(t1, body, "## Done")
        case _              => IsTrue(t1, false)
    }
}

func TestTLThinking_OnNoDirectives_BackToIdle(t T) T {
    val dirs = EmptyArray[Directive]()
    val s = Transition(TLThinking(), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

func TestTLThinking_SummaryBeatsDispatch(t T) T {
    val dirs = ArrayOf[Directive](dispatchTo("Felix"), summary("override"))
    val s = Transition(TLThinking(), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Approval")
}

// ----- Delegating drains pending → QAGate / TLReview ------------------------

func TestDelegating_OneMemberDone_StaysDelegating(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix").Add("Mira")
    val s = Transition(Delegating(Pending = pending), MemberDone(MemberName = "Felix", Body = ""), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "Delegating")
    return s match {
        case Delegating(rest) => Eq(t1, rest.Size(), 1)
        case _                => IsTrue(t1, false)
    }
}

func TestDelegating_AllDone_QARequired_GoesToQAGate(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val s = Transition(Delegating(Pending = pending), MemberDone(MemberName = "Felix", Body = ""), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "QAGate")
    return s match {
        case QAGate(qaPending) => Eq(t1, qaPending.Size(), 1)
        case _                 => IsTrue(t1, false)
    }
}

func TestDelegating_AllDone_NoQA_GoesToTLReview(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val s = Transition(Delegating(Pending = pending), MemberDone(MemberName = "Felix", Body = ""), ctxNoQA())
    return Eq(t, stateName(s), "TLReview")
}

// ----- QAGate → TLReview ----------------------------------------------------

func TestQAGate_OnQADone_GoesToTLReview(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val s = Transition(QAGate(Pending = pending), QADone(), ctxWithQA(true))
    return Eq(t, stateName(s), "TLReview")
}

// ----- Approval lifecycle ---------------------------------------------------

func TestApproval_Accepted_BackToIdle(t T) T {
    val s = Transition(Approval(SummaryBody = "..."), ApprovalAccepted(), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

func TestApproval_Rejected_BackToIdle(t T) T {
    val s = Transition(Approval(SummaryBody = "..."), ApprovalRejected(), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

// ----- TL review re-runs the dispatch logic ---------------------------------

func TestTLReview_OnSummary_GoesToApproval(t T) T {
    val dirs = ArrayOf[Directive](summary("final"))
    val s = Transition(TLReview(), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Approval")
}

func TestTLReview_OnDispatch_GoesBackToDelegating(t T) T {
    val dirs = ArrayOf[Directive](dispatchTo("Felix"))
    val s = Transition(TLReview(), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Delegating")
}

// ----- Irrelevant-event guards: every (state, event) pair the FSM
// sees in production must be defined. The interesting ones land an
// AppMsg through the runtime that the FSM didn't ask for — e.g. a
// stray ChunkArrived after we've already moved out of Delegating.
// Every "wrong event for this state" pair should leave the state
// unchanged so the orchestrator stays drift-free.

func TestIdle_IgnoresTLDone(t T) T {
    val s = Transition(Idle(), TLDone(Directives = EmptyArray[Directive]()), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

func TestIdle_IgnoresMemberDone(t T) T {
    val s = Transition(Idle(), MemberDone(MemberName = "Felix", Body = ""), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

func TestIdle_IgnoresApprovalAccepted(t T) T {
    val s = Transition(Idle(), ApprovalAccepted(), ctxWithQA(true))
    return Eq(t, stateName(s), "Idle")
}

func TestTLThinking_IgnoresUserPrompted(t T) T {
    val s = Transition(TLThinking(), UserPrompted(), ctxWithQA(true))
    return Eq(t, stateName(s), "TLThinking")
}

func TestTLThinking_IgnoresMemberDone(t T) T {
    val s = Transition(TLThinking(), MemberDone(MemberName = "Felix", Body = ""), ctxWithQA(true))
    return Eq(t, stateName(s), "TLThinking")
}

func TestTLThinking_IgnoresQADone(t T) T {
    val s = Transition(TLThinking(), QADone(), ctxWithQA(true))
    return Eq(t, stateName(s), "TLThinking")
}

func TestDelegating_IgnoresUserPrompted(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix").Add("Mira")
    val s = Transition(Delegating(Pending = pending), UserPrompted(), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "Delegating")
    return s match {
        case Delegating(rest) => Eq(t1, rest.Size(), 2)  // pending preserved
        case _                => IsTrue(t1, false)
    }
}

func TestDelegating_IgnoresQADone(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val s = Transition(Delegating(Pending = pending), QADone(), ctxWithQA(true))
    return Eq(t, stateName(s), "Delegating")
}

func TestDelegating_IgnoresTLDone(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val dirs = ArrayOf[Directive](dispatchTo("Felix"))
    val s = Transition(Delegating(Pending = pending), TLDone(Directives = dirs), ctxWithQA(true))
    return Eq(t, stateName(s), "Delegating")  // mid-flight TLDone is ignored
}

// QAGate × MemberDone — partial QA drain. If multiple QAs are pending,
// removing one should keep us in QAGate with the rest.
func TestQAGate_OneQADone_StaysQAGateWithRest(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo").Add("Mira")
    val s = Transition(QAGate(Pending = pending), MemberDone(MemberName = "Theo", Body = ""), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "QAGate")
    return s match {
        case QAGate(rest) => Eq(t1, rest.Size(), 1)
        case _            => IsTrue(t1, false)
    }
}

func TestQAGate_LastQADone_GoesToTLReview(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val s = Transition(QAGate(Pending = pending), MemberDone(MemberName = "Theo", Body = ""), ctxWithQA(true))
    return Eq(t, stateName(s), "TLReview")
}

func TestQAGate_IgnoresUserPrompted(t T) T {
    val pending = EmptyHashSet[string]().Add("Theo")
    val s = Transition(QAGate(Pending = pending), UserPrompted(), ctxWithQA(true))
    return Eq(t, stateName(s), "QAGate")
}

func TestApproval_IgnoresUserPrompted(t T) T {
    val s = Transition(Approval(SummaryBody = "ship"), UserPrompted(), ctxWithQA(true))
    return Eq(t, stateName(s), "Approval")
}

func TestApproval_IgnoresTLDone(t T) T {
    val dirs = ArrayOf[Directive](summary("ignore me"))
    val s = Transition(Approval(SummaryBody = "ship"), TLDone(Directives = dirs), ctxWithQA(true))
    val t1 = Eq(t, stateName(s), "Approval")
    return s match {
        case Approval(body) => Eq(t1, body, "ship")  // SummaryBody preserved
        case _              => IsTrue(t1, false)
    }
}

// QA-required policy interactions. With QARequired=false the
// Delegating drain skips QAGate entirely; with QARequired=true but
// QAMembers=[] it also skips (no one to dispatch to).

func TestDelegating_QARequiredButNoQAMembers_GoesToTLReview(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    val ctx = TransitionContext(QAMembers = EmptyArray[string](), QARequired = true)
    val s = Transition(Delegating(Pending = pending), MemberDone(MemberName = "Felix", Body = ""), ctx)
    return Eq(t, stateName(s), "TLReview")
}

// TL routes consult / approval-only directives correctly. Multiple
// summaries: the FIRST one wins (firstSummary semantics).

func TestTLThinking_MultipleSummaries_TakesFirst(t T) T {
    val dirs = ArrayOf[Directive](summary("first"), summary("second"))
    val s = Transition(TLThinking(), TLDone(Directives = dirs), ctxWithQA(true))
    return s match {
        case Approval(body) => Eq(t, body, "first")
        case _              => IsTrue(t, false)
    }
}

// MemberDone for a member who isn't in pending should be a no-op on
// Delegating's pending set — Remove of a missing key is idempotent.
func TestDelegating_MemberDone_UnknownMember_StaysWithFullPending(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix").Add("Mira")
    val s = Transition(Delegating(Pending = pending), MemberDone(MemberName = "Ghost", Body = ""), ctxWithQA(true))
    return s match {
        case Delegating(rest) => Eq(t, rest.Size(), 2)
        case _                => IsTrue(t, false)
    }
}
