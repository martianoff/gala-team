package headless

import (
    "strings"
    "martianoff/gala/json"
    "github.com/martianoff/gala_team/app/onboarding"
    "github.com/martianoff/gala_team/app/session"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "github.com/martianoff/gala_team/app/directive"
    . "github.com/martianoff/gala_team/app/policy"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/runtime"
    . "github.com/martianoff/gala_team/app/team"
)

// ============================================================================
// Headless-side claude stream-json filter.
//
// Mirrors app/ui's filterClaudeStreamJsonFor, but without the AppModel
// dependency so headless / consult flows can use it without pulling
// in the entire UI package. Single entry point: ExtractClaudeText(line)
// returns the user-facing text or "" when the line is pure orchestration
// noise (system:init, tool_use envelopes, malformed JSON, etc.).
// ============================================================================

// HeadlessPart is one element of an assistant message's content[].
struct HeadlessPart(Type string, Text string)

// HeadlessMessage carries the content array we care about. Usage is
// declared so the codec doesn't trip over the field; we don't read it.
struct HeadlessMessage(Content Array[HeadlessPart])

// HeadlessAssistantEvent is the outer event for `type=assistant`.
struct HeadlessAssistantEvent(Type string, Message HeadlessMessage)

// HeadlessResultEvent is `type=result` — IsError + Result are what
// we need to render the final-turn text in bulk mode (claude
// configurations that don't stream).
struct HeadlessResultEvent(
    Type    string,
    IsError bool,
    Result  string,
)

val headlessAssistantCodec = json.Codec[HeadlessAssistantEvent](json.SnakeCase())
val headlessResultCodec    = json.Codec[HeadlessResultEvent](json.SnakeCase())

// ExtractClaudeText classifies a single stream-json line. Returns the
// joined visible text (empty when nothing user-facing). Same two-step
// guard as the UI side: drop whole-envelope stream-json, truncate
// at marker when the codec returned envelope tail mixed with prose.
func ExtractClaudeText(line string) string {
    val trimmed = strings.TrimSpace(line)
    if trimmed == "" { return "" }
    if !strings.HasPrefix(trimmed, "{") {
        if isHeadlessBareJsonCloser(trimmed) { return "" }
        return line
    }
    // Drop known non-renderable event types by prefix BEFORE codec
    // attempts. The codec sometimes mis-handles nested objects in
    // tool_use / tool_use_result / user.tool_result content blocks
    // and leaks the raw envelope into the transcript. Same fix as
    // the UI side's filterClaudeStreamJsonFor.
    if headlessHasTypePrefix(trimmed, "rate_limit_event") ||
       headlessHasTypePrefix(trimmed, "tool_use_result") ||
       headlessHasTypePrefix(trimmed, "system") ||
       headlessHasTypePrefix(trimmed, "user") ||
       headlessHasTypePrefix(trimmed, "control_request") ||
       headlessHasTypePrefix(trimmed, "control_response") {
        return ""
    }
    val asAssistant = headlessAssistantCodec.Decode(trimmed)
    asAssistant match {
        case Success(evt) => {
            if evt.Type == "assistant" {
                val texts = evt.Message.Content.Collect({
                    case HeadlessPart(kind, text) if kind == "text" => text
                })
                return sanitizeHeadlessText(texts.MkString("\n"))
            }
        }
        case Failure(_) => {}
    }
    val asResult = headlessResultCodec.Decode(trimmed)
    asResult match {
        case Success(evt) => {
            if evt.Type == "result" && !evt.IsError {
                return sanitizeHeadlessText(evt.Result)
            }
        }
        case Failure(_) => {}
    }
    return ""
}

// sanitizeHeadlessText is the leak guard. ONE check: drop the chunk
// entirely if the text is a recognisable stream-json envelope.
// Same rationale as the UI sanitizer — partial-tail truncation was
// over-aggressive on legitimate prose containing JSON-shaped
// substrings, and the codec has been verified not to overshoot.
func sanitizeHeadlessText(text string) string {
    if text == "" { return "" }
    if isHeadlessStreamJson(text) { return "" }
    return text
}

func isHeadlessStreamJson(text string) bool {
    val t = strings.TrimSpace(text)
    if !strings.HasPrefix(t, "{\"") { return false }
    return strings.Contains(t, "\"type\":\"assistant\"") ||
           strings.Contains(t, "\"type\":\"tool_use\"") ||
           strings.Contains(t, "\"type\":\"tool_result\"") ||
           strings.Contains(t, "\"stop_reason\":") ||
           strings.Contains(t, "\"session_id\":")
}

func truncateAtHeadlessMarker(text string) string {
    val markers = ArrayOf(
        "\"stop_reason\":",
        "\"stop_sequence\":",
        "\"session_id\":",
        "\"usage\":{\"input_tokens",
        "\"usage\":{\"output_tokens",
        "\"parent_tool_use_id\":",
        "}],\"stop_reason\"",
        "}],\"usage\":",
    )
    var truncated = text
    var i = 0
    val n = markers.Size()
    for i < n {
        val parts = strings.SplitN(truncated, markers.Get(i), 2)
        if len(parts) > 1 {
            truncated = parts[0]
        }
        i = i + 1
    }
    return strings.TrimRight(truncated, " \t\n\"}],")
}

func isHeadlessBareJsonCloser(s string) bool =
    s == "}" || s == "]}" || s == "}}" || s == "]"

// headlessHasTypePrefix mirrors the UI's hasJsonTypePrefix — checks
// whether `trimmed` opens with `{"type":"<kind>"`. Used as a fast
// pre-filter for non-renderable stream-json event types.
func headlessHasTypePrefix(trimmed string, kind string) bool =
    strings.HasPrefix(trimmed, "{\"type\":\"" + kind + "\"")

// ============================================================================
// app/headless — non-interactive driver. Spawns the team-lead `claude`
// session, sends a single prompt, drains the chunk stream until the
// process closes, returns the captured conversation as a typed value.
// `cmd/gala_team_headless/main.gala` wraps this with arg parsing and
// JSON output.
//
// Scope: one-shot prompt → capture response. No FSM transitions, no
// approval / merge — that's for the interactive TUI to drive. The
// goal here is a primitive scriptable enough that the consult runner
// (Phase 2 next step) can fan out child gala_team invocations and
// collect their summaries.
//
// Termination: the loop ends when the TL session writes EOF on stdout
// (claude exited cleanly). A `@summary` directive in the captured
// text is surfaced as Result.Summary; absence of one means the team
// produced an open-ended response that the caller has to interpret.
// ============================================================================

// HeadlessResult is the typed shape returned from RunHeadless. JSON
// emission is the caller's job (see EncodeJson below).
struct HeadlessResult(
    Project      Project,
    TeamName     string,
    Prompt       string,
    Conversation Array[session.ConversationLine],
    Summary      Option[string],
    Err          Option[string],
)

// RunHeadless launches the team lead, sends `prompt`, and drains
// chunks until the session closes. Synchronous: every Future returned
// by the runtime is `Await`ed before dispatching the resulting Msg,
// so the call returns when there's no more work in flight.
//
// Returns Right(result) on success — the Conversation is populated
// even when the team didn't emit a `@summary`, so the caller can do
// its own analysis. Returns Left(err) only on infrastructure failure
// (spawn, read of an unreachable repo, etc.). The result's Err field
// captures non-fatal stream-level errors (a chunk read that didn't
// land cleanly but the rest of the conversation is intact).
func RunHeadless(proj Project, tm Team, mode WorkspaceMode, prompt string) Either[string, HeadlessResult] =
    RunHeadlessAs(proj, tm, mode, tm.Lead.Name, prompt)

// RunHeadlessAs spawns ANY team member (lead, engineer, QA) and
// drives one prompt through their claude session. Used by multi-
// member E2E tests that need to manually orchestrate the chain of
// command without driving the full FSM.
//
// `mode` is the team's WorkspaceMode (from the policy block). Engineers
// and QAs run in their own worktree under WorktreePerEngineer; the lead
// always runs on the lead branch in `proj.Repo`. Without honouring the
// mode here, every member ends up in `proj.Repo` and engineer commits
// land on whichever branch the project root happens to be on (the
// lead branch), bypassing the per-engineer isolation guarantee.
//
// Returns Left on lookup or spawn failure (member missing from team,
// claude binary failing to start, worktree creation failed). Returns
// Right(result) even when the spawned session reported a non-fatal
// error mid-stream — the Err field carries it.
func RunHeadlessAs(proj Project, tm Team, mode WorkspaceMode, memberName string, prompt string) Either[string, HeadlessResult] {
    val pick = tm.Members.Find((m) => m.Name == memberName)
    return pick match {
        case None() => Left[string, HeadlessResult](s"member '${memberName}' is not on team '${tm.Name}'")
        case Some(member) => {
            val (wrapped, onbErr) = onboarding.WrapPromptSafe(proj, tm, member, mode, prompt)
            return EnsureWorkspace(proj, member, mode) match {
                case Failure(e) => Left[string, HeadlessResult](s"workspace ${member.Name}: ${e.Error()}")
                case Success(cwd) => SpawnSession(proj, member, cwd, tm.DangerouslySkipPermissions, NewSessionId(), true) match {
                    case Failure(e) => Left[string, HeadlessResult](s"spawn ${member.Name}: ${e.Error()}")
                    case Success(s) => Right[string, HeadlessResult](driveLoop(proj, tm, s, prompt, wrapped, onbErr))
                }
            }
        }
    }
}

// driveLoop sends the prompt and walks the chunk stream until the
// session closes. Each iteration awaits the runtime's read future
// synchronously, dispatches the resulting Msg, and decides whether
// to re-arm the pump.
//
// `displayPrompt` is what we record in the Conversation log — the
// raw user prompt without onboarding boilerplate. `wirePrompt` is
// what actually goes to claude — typically the wrapped version with
// the onboarding pack prepended.
func driveLoop(proj Project, tm Team, s MemberSession, displayPrompt string, wirePrompt string, onbErr Option[string]) HeadlessResult {
    var convo = EmptyArray[session.ConversationLine]()
        .Append(session.ConversationLine(Speaker = "you", Text = displayPrompt))
    val name = s.Member.Name

    // Fire the prompt write — SendFuture writes the prompt and
    // closes stdin so claude (running with --print) sees the
    // request as a complete transaction and produces output.
    val _ = SendFuture(s, wirePrompt).Await()

    var stopped = false
    var failure = onbErr.Map((e) => s"onboarding: ${e}")
    for !stopped {
        NextChunkFuture(s).Await() match {
            case Failure(err) => {
                failure = Some(s"runtime: ${err.Error()}")
                stopped = true
            }
            case Success(RtChunkArrived(_, line)) => {
                // Same filter the TUI applies — extract text from
                // assistant / result events; drop system:init / tool
                // envelopes / non-prose lines. Without this, the
                // headless transcript leaks raw stream-json that the
                // consult runner then tries to parse as @summary
                // directives, breaking the cross-team flow.
                val visible = ExtractClaudeText(line)
                if visible != "" && !isDuplicateOfLast(convo, name, visible) {
                    convo = convo.Append(session.ConversationLine(Speaker = name, Text = visible))
                }
            }
            case Success(RtSessionFailed(_, err)) => {
                val msg = err.Error()
                if (msg != "EOF") {
                    failure = Some(s"${name}: ${msg}")
                }
                stopped = true
            }
            case _ => {}
        }
    }

    val _ = CloseSession(s)
    return HeadlessResult(
        Project      = proj,
        TeamName     = tm.Name,
        Prompt       = displayPrompt,
        Conversation = convo,
        Summary      = extractSummary(convo),
        Err          = failure,
    )
}

// isDuplicateOfLast returns true when `text` (from `speaker`) matches
// the last conversation line by the same speaker. claude's stream-json
// often emits an intermediate assistant chunk plus a final consolidated
// assistant message carrying the same text — both decode through
// ExtractClaudeText and would otherwise show up twice in the
// transcript. Dedupe consecutive identical lines.
func isDuplicateOfLast(convo Array[session.ConversationLine], speaker string, text string) bool =
    convo.LastOption() match {
        case None()       => false
        case Some(last) => last.Speaker == speaker && last.Text == text
    }

// extractSummary joins every member-spoken line of the conversation
// (skipping the user's prompt), runs the directive parser, and
// returns the body of the first @summary if one is present.
func extractSummary(convo Array[session.ConversationLine]) Option[string] =
    Parse(convo.Collect({ case cl if cl.Speaker != "you" => cl.Text }).MkString("\n"))
        .Collect({ case Summary(body) => body })
        .HeadOption()

// EncodeJson serialises a HeadlessResult to a JSON string suitable for
// piping into another tool. Conversation is a JSON array of
// `{speaker, text}` objects; Summary and Err become null when None.
func EncodeJson(r HeadlessResult) Try[string] = Try[string](() => {
    val w = json.NewJsonEncoder()
    w.WriteStartObject()
    w.WriteKey("project_repo");  w.WriteString(r.Project.Repo)
    w.WriteKey("team");          w.WriteString(r.TeamName)
    w.WriteKey("prompt");        w.WriteString(r.Prompt)

    w.WriteKey("conversation")
    w.WriteStartArray()
    r.Conversation.ForEach((cl) => {
        w.WriteStartObject()
        w.WriteKey("speaker"); w.WriteString(cl.Speaker)
        w.WriteKey("text");    w.WriteString(cl.Text)
        w.WriteEndObject()
    })
    w.WriteEndArray()

    w.WriteKey("summary")
    r.Summary match {
        case Some(s) => w.WriteString(s)
        case None()  => w.WriteNull()
    }
    w.WriteKey("error")
    r.Err match {
        case Some(s) => w.WriteString(s)
        case None()  => w.WriteNull()
    }
    w.WriteEndObject()
    return w.String()
})
