package onboarding

import (
    "os"
    "strings"
    "path/filepath"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/go_interop"
    . "github.com/martianoff/gala_team/app/policy"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/team"
)

// ============================================================================
// app/onboarding — read each team / member's onboarding documents from
// disk and compose them into the prefix that gets prepended to the
// member's first prompt.
//
// Used in two places:
//   1. The interactive TUI's onSubmit, when the team lead's session
//      hasn't been spawned yet.
//   2. The headless / consult driver's first SendFuture, when an
//      external team is being asked something via @consult.
//
// In both cases the docs are loaded synchronously (small files, fast
// reads, on-disk cache hot once the user is interacting). Failures
// surface as Try[string] — caller decides whether a missing doc
// should panic ("strict" interactive UX) or fall back to a header-
// only message ("forgiving" CI / consult flow).
// ============================================================================

// Compose returns the ordered list of paths that should be loaded for
// `member`. Team-wide docs come first, then member-specific —
// matches the user's mental model of "general project context, then
// my role-specific runbook".
func Compose(team Team, member Member) Array[string] =
    team.Onboarding.AppendAll(member.Onboarding)

// Load reads each path under `proj.Repo` (relative paths resolve
// there; absolute paths are taken as-is) and concatenates the
// contents with `--- <path> ---` separators so the model knows where
// each doc starts. Returns Failure on any read error — keeping the
// failure surface narrow (Try[string]) so callers don't have to
// invent partial-success semantics.
func Load(proj Project, paths Array[string]) Try[string] = Try(() => {
    return paths.FoldLeft(EmptyArray[string](), (acc, raw) => {
        val resolved = if (filepath.IsAbs(raw)) raw
                       else                     filepath.Join(proj.Repo, raw)
        val bytes, err = os.ReadFile(resolved)
        if err != nil {
            panic(s"onboarding: cannot read '${resolved}': ${err.Error()}")
        }
        return acc.Append(s"--- ${raw} ---").Append(string(bytes))
    }).MkString("\n\n")
})

// WrapPrompt assembles the first-prompt payload sent to a freshly
// spawned member. The wire shape is:
//
//     # Your role
//
//     You are <Name>, the <role> on team <TeamName>.
//
//     ## Personality
//     <Member.Personality, free-form>
//
//     ## Additional instructions
//     <Member.Extra, free-form>      (omitted if empty)
//
//     # Project onboarding             (omitted if no onboarding paths)
//
//     --- <path> ---
//     <file contents>
//
//     # Your task
//
//     <user prompt>
//
// Sections are stitched in this order so the model sees identity →
// project context → ask. Subsequent prompts in the same session
// don't re-send any of this — only the bare prompt goes through
// because the model already has the role + onboarding in context.
//
// Returns Try[string] so a missing onboarding doc surfaces as a
// Failure the caller can either propagate (interactive UX panics
// on first-prompt setup errors) or degrade (consult / headless
// flow falls back to the raw prompt — see WrapPromptSafe).
func WrapPrompt(proj Project, team Team, member Member, mode WorkspaceMode, prompt string) Try[string] {
    val role = roleSection(proj, team, member, mode)
    val paths = Compose(team, member)
    if paths.IsEmpty() {
        return Success[string](s"${role}\n\n# Your task\n\n${prompt}")
    }
    // Map directly off Load's Try so the underlying read error
    // propagates verbatim — calling `.Get()` here would surface as
    // a "Try.Get on Failure: <inner error>" double-wrap that
    // makes the LastError banner unreadable.
    return Load(proj, paths).Map[string]((loaded) =>
        s"${role}\n\n# Project onboarding\n\n${loaded}\n\n# Your task\n\n${prompt}"
    )
}

// roleSection renders the persona + orchestration block for `member`
// on `team`. The header tells the model who it's playing; the roster
// + protocol sections teach it how to operate inside the gala_team
// orchestrator (delegate via @dispatch, finish via @summary, etc.).
//
// The TL gets a different protocol section than other members because
// the directive vocabularies are different:
//   - TL: @dispatch / @consult / @summary  (outbound delegation)
//   - others: @finished / @help / @blocked (reporting back to TL)
//
// Without this teaching, the model has no idea the gala_team protocol
// exists — it just answers the prompt as a generic claude session and
// the dispatch / pipeline machinery never trips.
func roleSection(proj Project, team Team, member Member, mode WorkspaceMode) string {
    val header = s"# Your role\n\nYou are ${member.Name}, the ${RoleName(member.Role)} on team ${team.Name}."
    val personality = if (member.Personality == "") ""
                      else                          s"\n\n## Personality\n\n${member.Personality}"
    val extra = if (member.Extra == "") ""
                else                    s"\n\n## Additional instructions\n\n${member.Extra}"
    val isTL = SameRole(member.Role, TeamLead())
    val roster = if (isTL) s"\n\n${teamRosterSection(team, member)}" else ""
    val workspace = s"\n\n${workspaceSection(proj, member, mode)}"
    val hasQa = !MembersOf(team, QA()).IsEmpty()
    val protocol = s"\n\n${protocolSection(isTL, hasQa)}"
    return s"${header}${personality}${extra}${roster}${workspace}${protocol}"
}

// WorkspacePathFor mirrors runtime.EnsureWorkspace's path computation
// without the side effect of creating directories — pure derivation
// for prompt assembly. Keep these two in sync if the worktree layout
// changes.
//
// The TL ALWAYS gets `<proj.Repo>/.gala_team/worktrees/_lead`,
// regardless of mode — orchestrator git ops (lead-branch reset,
// snapshot push, gh pr create) target the TL's cwd, and routing them
// through the user's main checkout is what causes "we keep breaking
// master" incidents.
//
// Shared mode → engineers / QAs share `proj.Repo`, TL still in `_lead`.
// WorktreePerEngineer → engineers / QAs each get
// `<proj.Repo>/.gala_team/worktrees/<member-name>` on branch
// `gala_team/<member-name>`; TL still in `_lead`.
func WorkspacePathFor(proj Project, m Member, mode WorkspaceMode) string {
    val isLead = SameRole(m.Role, TeamLead())
    if isLead { return filepath.Join(proj.Repo, ".gala_team", "worktrees", "_lead") }
    return mode match {
        case Shared()              => proj.Repo
        case WorktreePerEngineer() => filepath.Join(proj.Repo, ".gala_team", "worktrees", m.Name)
    }
}

// workspaceSection teaches the model where its own files live AND
// where its peers' files live. Without this, the TL routinely
// concludes "the engineers didn't produce any files" when in reality
// the engineers wrote everything in their own isolated worktree and
// the TL was looking in the wrong cwd.
func workspaceSection(proj Project, member Member, mode WorkspaceMode) string {
    val isTL = SameRole(member.Role, TeamLead())
    val myCwd = WorkspacePathFor(proj, member, mode)
    return mode match {
        case Shared()              => sharedWorkspaceSection(proj, isTL, myCwd)
        case WorktreePerEngineer() => worktreeWorkspaceSection(proj, member, isTL, myCwd)
    }
}

// leadBranchOf mirrors runtime.LeadBranchFor without taking a runtime
// dep — onboarding stays a pure-data package. Slug logic mirrors
// runtime.gitSlug; we duplicate it here rather than import runtime
// because it'd create a cycle (runtime depends on onboarding via
// the spawn flow). Keep these two helpers in sync.
func leadBranchOf(proj Project) string = "gala_team/" + onbGitSlug(proj.Name) + "/lead"

// onbGitSlug must match runtime.gitSlug; see comment above for why
// we duplicate. If you touch one, touch the other.
func onbGitSlug(s string) string {
    if s == "" { return "project" }
    val lower = strings.ToLower(s)
    val rs = ToRunes(lower)
    var out = EmptyArray[string]()
    var i = 0
    val n = len(rs)
    var lastWasDash = false
    for i < n {
        val c = rs[i]
        val safe = (c >= 'a' && c <= 'z') || (c >= '0' && c <= '9') || c == '-' || c == '_' || c == '.' || c == '/'
        if safe {
            out = out.Append(string(c))
            lastWasDash = false
        } else {
            if !lastWasDash {
                out = out.Append("-")
                lastWasDash = true
            }
        }
        i = i + 1
    }
    val joined = strings.Trim(out.MkString(""), "-/.")
    if joined == "" { return "project" }
    return joined
}

func sharedWorkspaceSection(proj Project, isTL bool, cwd string) string {
    val header = "# Workspace layout\n\n"
    if isTL {
        val leadBranch = leadBranchOf(proj)
        return header +
            s"Your cwd is your dedicated lead worktree at `${cwd}`. **You are checked out on branch `${leadBranch}`** — forked from `${proj.DefaultBranch}` (latest origin tip). " +
            s"Commit your work here; the user opens a PR from it via Ctrl+A. Each fresh session hard-resets this branch back to `${proj.DefaultBranch}`, so don't expect prior turns' files to persist across `Start fresh`.\n\n" +
            s"**Engineers and QAs run in the project root at `${proj.Repo}`** (shared mode). When inspecting their deliverables, read files from `${proj.Repo}`, not your own cwd."
    }
    return header +
        s"Your cwd is `${cwd}`, shared with the rest of the team. " +
        "Other members may edit files concurrently. " +
        "When you finish, list the files you touched in your `@finished` body so the TL can review."
}

func worktreeWorkspaceSection(proj Project, member Member, isTL bool, cwd string) string {
    val header = "# Workspace layout\n\n"
    val branchPattern = "gala_team/" + onbGitSlug(proj.Name) + "/<MemberName>"
    if isTL {
        val leadBranch = leadBranchOf(proj)
        return header +
            s"Your cwd is your dedicated lead worktree at `${cwd}`. **You are checked out on branch `${leadBranch}`** — forked from `${proj.DefaultBranch}` (latest origin tip). The user's main repo lives at `${proj.Repo}` and is OFF LIMITS — never `cd` there, never `git checkout` / `git reset` / `git push` from there. Every git op you run stays inside your worktree.\n\n" +
            s"Commit your work to this branch; the user opens a PR from it via Ctrl+A. Each fresh session removes this worktree, then re-creates it forked off `${proj.DefaultBranch}` again, so don't expect prior turns' files to persist across `Start fresh`.\n\n" +
            s"**Engineers and QAs each run in their own isolated git worktree** at " +
            s"`${proj.Repo}/.gala_team/worktrees/<MemberName>` on branch `${branchPattern}`. " +
            "Their file edits live ONLY on that branch until merged — they are NOT visible from your cwd.\n\n" +
            "When inspecting a member's deliverables (e.g. after they emit `@finished`), read files from their worktree path, not your own. " +
            "If you don't see an expected file in your cwd, that does NOT mean the member failed — check the worktree at " +
            s"`${proj.Repo}/.gala_team/worktrees/<MemberName>/` first.\n\n" +
            "## Branches & PRs\n\n" +
            s"`${leadBranch}` is your INTERNAL working ref. You commit there. Engineers fast-forward INTO it. **It is never the source branch of a PR on origin.**\n\n" +
            "When you `@summary`, the orchestrator: (1) snapshots the lead tip onto a unique per-PR branch named `gala_team/" + onbGitSlug(proj.Name) + "/pr/<short-sha>`, (2) force-pushes that snapshot to origin, (3) opens a GitHub PR from it. The lead branch on origin is never touched.\n\n" +
            "Implications you need to know:\n" +
            "- **Multiple PRs from one workspace coexist.** Different lead tip → different short SHA → different PR branch. You can `@summary` again later to ship a follow-up; it gets its own PR.\n" +
            "- **Re-approving the same lead state is idempotent.** Same SHA → same destination branch, force-push is a no-op, no duplicate PR is created (gh will refuse with \"already exists\").\n" +
            "- **Don't try to merge engineer branches into lead via push to origin yourself.** Use local `git merge --ff-only <engineer-branch>` from your cwd; the orchestrator handles all origin pushes during `@summary`.\n" +
            "- **Don't pre-push lead.** It's local-only by design. The orchestrator only ever pushes the snapshot branches.\n\n" +
            "If a prior PR you opened is still pending review and you make follow-up changes, your next `@summary` opens a SECOND PR (with the new SHA in the branch name). Mention this in the PR body so reviewers can decide whether to land them in order or together."
    }
    val branch = "gala_team/" + onbGitSlug(proj.Name) + "/" + member.Name
    return header +
        s"Your cwd is `${cwd}`, an isolated git worktree on branch `${branch}`. The main repo lives at `${proj.Repo}`.\n\n" +
        "Your file edits stay on your branch — nothing is auto-merged, and the TL is in a different cwd. " +
        "When you emit `@finished`, list the files you wrote (relative paths from your cwd, OR absolute paths) so the TL can find them. " +
        "The TL won't see your files unless they read from your worktree path.\n\n" +
        "**Commit before `@finished`.** The orchestrator REJECTS any `@finished` while your worktree has uncommitted changes — QA reviews committed work and the TL merges your branch into lead, both of which need your edits to be on the branch (not just in the working tree). Run `git add -A && git commit -m \"<short message>\"` before emitting `@finished`. Verify with `git log --oneline " + proj.DefaultBranch + ".." + branch + "` — at least one commit must show. Do NOT push; the orchestrator handles that. If you have nothing to commit (e.g. you produced an analytical recommendation with no code changes), `@finished` is allowed only when `git status` is fully clean."
}

// teamRosterSection lists every other member with their role + one-
// line personality so the TL can pick who to delegate to. The TL is
// excluded from the list (they don't dispatch to themselves) and a
// truncated personality (first line only) keeps the prompt compact.
func teamRosterSection(team Team, lead Member) string {
    val others = team.Members.Filter((mem) => mem.Name != lead.Name)
    if others.IsEmpty() {
        return "# Your team\n\n(You're a solo team — no other members. Answer the user directly.)"
    }
    val rows = others.Map((mem) => {
        val role = RoleName(mem.Role)
        val tag = if (mem.Personality == "") ""
                  else                       s" — ${firstLine(mem.Personality)}"
        return s"- **${mem.Name}** (${role})${tag}"
    })
    return s"# Your team\n\nThese are the members you can delegate to:\n\n${rows.MkString("\n")}"
}

// firstLine returns the first non-empty line of `s`, trimmed. Used
// to compact a multi-line personality blurb into a single roster
// row without dropping the most informative line.
func firstLine(s string) string {
    val parts = strings.Split(s, "\n")
    var i = 0
    val n = len(parts)
    for i < n {
        val ln = strings.TrimSpace(parts[i])
        if ln != "" { return ln }
        i = i + 1
    }
    return ""
}

// protocolSection teaches the directive vocabulary the orchestrator
// listens for. Two flavours: the TL outbound directives, or the
// member inbound-reporting directives. Both end blocks with `@end`
// because the parser is line-based and the closing tag is what makes
// streaming chunks safe to parse incrementally.
func protocolSection(isTL bool, hasQa bool) string {
    if isTL {
        val qaNote = if (hasQa)
            "QA runs automatically after engineers `@finished` — only `@dispatch` engineers, not QA.\n"
        else
            ""
        return "# How to delegate (orchestration protocol)\n\n" +
            "Three directives drive the orchestrator. Use them to coordinate the team:\n\n" +
            "- `@dispatch(<MemberName>) ... @end` — assign the body text to that member as their next task. Multiple back-to-back `@dispatch` blocks fan out in parallel.\n" +
            "- `@consult(<TeamKey>) ... @end` — ask another team for input. Cross-team. Less common.\n" +
            "- `@summary ... @end` — finalize the turn for the user. The user is then asked to approve and the turn ends.\n\n" +
            "## Example — two engineers in parallel\n\n" +
            "```\n" +
            "I'll split this two ways.\n\n" +
            "@dispatch(Felix)\n" +
            "Implement the parser per RFC-12 §3. Acceptance: round-trip tests pass.\n" +
            "@end\n\n" +
            "@dispatch(Mira)\n" +
            "Implement the validator. Acceptance: rejects malformed input with a useful error.\n" +
            "@end\n" +
            "```\n\n" +
            "## Example — closing out the turn\n\n" +
            "```\n" +
            "@summary\n" +
            "Add SHA-256 / SHA-512 hashing to the standard library.\n" +
            "\n" +
            "## What\n" +
            "- New `crypto` package: `Hash(algo, bytes) -> Digest`, streaming `Hasher`, hex/base64 encoding.\n" +
            "- Stdlib registration so `import crypto` works in user code.\n" +
            "- 14 unit tests including NIST FIPS 180-4 known-answer vectors.\n" +
            "\n" +
            "## Why\n" +
            "Hashing is a baseline primitive for content addressing, ETags, and HMAC chains. Several user-facing libraries (caches, signed tokens) blocked on it.\n" +
            "\n" +
            "## Follow-ups\n" +
            "- HMAC + AEAD encryption — separate PR.\n" +
            "- MD5 deliberately omitted (not safe for collision-resistant use).\n" +
            "- Pattern-matching extractor on `Digest` not requested; deferred.\n" +
            "@end\n" +
            "```\n\n" +
            "## @summary body — write a PR description, not a chat recap\n\n" +
            "The `@summary` body becomes the PR description **verbatim**. Reviewers on GitHub will read it cold, with no access to your transcript, your TUI, your worktrees, or anything that happened in this orchestration. Treat the body like the description field on any other PR you'd open by hand. Four firm rules:\n\n" +
            "- **Sections.** Use `## What`, `## Why`, `## Follow-ups` (and `## Gaps` if relevant). Reviewers scan headings. A body with no headings reads as a chat dump and reviewers will request a rewrite.\n" +
            "- **No names, no internal nuance.** Don't write \"Felix did X then Mira fixed Y after three blocked attempts.\" The reader doesn't know who Felix is and doesn't care. Write the PR as if a single author wrote it: \"Added X. Fixed Y.\" Skip orchestration trivia (\"I dispatched...\", \"after retries\", \"the merger turn\"). Skip the apology-and-postmortem voice.\n" +
            "- **No orchestration internals.** The reviewer doesn't know about `.gala_team/`, `worktrees/_lead`, `gala_team/<proj>/lead`, pre-flight checks, or any of the orchestrator's bookkeeping. Never paste those paths or terms into the body. PR #333 (2026-05-07) is the canonical bad example: the TL pasted `Please run git -C ...\\.gala_team\\worktrees\\_lead log...` as the @summary body and it became the public PR description verbatim — incomprehensible to anyone outside this orchestrator.\n" +
            "- **If you can't ship, don't @summary.** When something is genuinely broken (orchestrator state inconsistent, branch state weird, gh credentials missing), do NOT emit @summary with a \"please fix manually\" prose body — that goes straight to GitHub. Instead, emit prose-only output (no directive) explaining what's wrong; the user reads it in the TUI, not on GitHub. Reserve @summary for the case where the work is genuinely PR-ready.\n\n" +
            "## Rules\n\n" +
            "- Each directive opens with the tag on its own line and closes with `@end` on its own line.\n" +
            "- Plain prose between directives is rendered as your message to the user.\n" +
            "- If you simply want to chat (no orchestration), reply with prose only — no directives needed.\n" +
            "- Only dispatch to members listed in '# Your team' above; don't fabricate names.\n" +
            qaNote +
            "\n" +
            "## What does NOT dispatch\n\n" +
            "Only the literal `@dispatch(<Name>)` form is recognised. These look similar but do nothing:\n\n" +
            "- `→ Felix:` / `-> Felix:` (decorative arrow)\n" +
            "- `**Felix:**` / `## Felix` (markdown heading)\n" +
            "- `@dispatch(Felix, Mira)` (multi-target — open one block per name instead)\n" +
            "- `@dispatch(Felix)` without a matching `@end` line\n" +
            "- Mentioning a member by name in prose (they read only the body of an `@dispatch` block)\n\n" +
            "## Cross-team consult etiquette\n\n" +
            "If the **first** prompt of this turn arrived from another team via `@consult`, the orchestrator is bridging two teams. The **body of your `@summary` block** is what gets sent back to the consulting team's TL — not your full transcript. So:\n\n" +
            "- Treat the prompt as a question from a peer TL, not the user.\n" +
            "- Do whatever delegation / investigation the question needs.\n" +
            "- When done, reply with a single `@summary ... @end` block whose body is the answer (think \"executive summary\" — direct, no preamble). That body is what the upstream TL reads.\n" +
            "- `@dispatch` inside a consult is fine — the orchestrator routes member output back to you the same way as a normal turn.\n" +
            "- Do not `@consult` a third team from inside a consult unless absolutely necessary; recursion gets confusing for the user."
    }
    return "# How to report back (orchestration protocol)\n\n" +
        "You are working under a Team Lead inside an orchestrator. When you finish or get stuck, use these directives so the TL knows what happened:\n\n" +
        "- `@finished ... @end` — your task is complete. Body is the deliverable / summary the TL will read.\n" +
        "- `@help ... @end` — you need clarification. Body is the question. The TL will reply with a follow-up dispatch.\n" +
        "- `@blocked ... @end` — you cannot proceed (missing tool, ambiguous spec, conflicting requirement). Body is the reason.\n\n" +
        "Rules:\n" +
        "- Open the tag on its own line, close with `@end` on its own line.\n" +
        "- Send exactly one of these per turn — they're terminal.\n" +
        "- Free-form prose before the tag is fine; the TL sees your full output.\n\n" +
        "Example:\n\n" +
        "```\n" +
        "I implemented the parser using a hand-written recursive-descent walker.\n\n" +
        "@finished\n" +
        "Done. parser.gala (124 lines), 8 round-trip tests green. PR-ready.\n" +
        "@end\n" +
        "```"
}

// SuppressLoadFailure is the forgiving variant for the consult /
// headless paths: a missing onboarding doc shouldn't sink an entire
// cross-team consult, so we degrade to "no onboarding pack" + the
// raw prompt and surface the error message in the second tuple slot
// for the caller to log.
func WrapPromptSafe(proj Project, team Team, member Member, mode WorkspaceMode, prompt string) Tuple[string, Option[string]] {
    return WrapPrompt(proj, team, member, mode, prompt) match {
        case Success(wrapped) => (wrapped, None[string]())
        case Failure(err)     => (prompt, Some(err.Error()))
    }
}
