package protocol

import (
    "martianoff/gala/strings"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    "github.com/martianoff/gala-acp"
)

// ============================================================================
// decode.gala — the idempotent inbound decoder.
//
// This is gala-team's DOMAIN half of the protocol: the text-buffer parser that
// turns a streaming agent buffer into protocol messages. The transport-neutral
// MECHANISM — the content-hash envelope identity, the dedup Ledger, and the
// delivery / liveness FSM — now lives in the shared gala-acp library
// (acp.Envelope / acp.Ledger / acp.Tick …); this file produces acp.Envelope
// values and leans on acp.DedupById for idempotency.
//
// Decode is a PURE function of the full accumulated agent text buffer. It
// subsumes two directive-extraction concerns:
//
//   - front-to-back @dispatch / @consult / @summary / @base / @plan extraction
//     from a Team-Lead buffer.
//   - end-anchored @finished / @review / @done / @help / @blocked extraction
//     from a member buffer — robust against deliverables that QUOTE protocol
//     syntax (audits / PRs about this orchestrator are full of documented
//     `@dispatch(` / `@finished` / `@end` examples). Anchoring on the LAST bare
//     `@end` and scanning back to the nearest opener ignores every quoted
//     example before the real sign-off.
//
// The idempotency property is the whole point: decoding a buffer, then decoding
// that same buffer grown by a byte-identical duplicate chunk (the claude stream
// occasionally re-emits a chunk on reconnect) yields the SAME Array[acp.Envelope]
// — identical Ids, identical order. A duplicated directive block re-derives an
// Envelope whose content hash already appeared, and acp.DedupById collapses it.
//
// THE KIND VOCABULARY IS A SET OF STRING TAGS. acp.Envelope carries Kind as an
// opaque lowercase tag, so this package speaks the team vocabulary
// (dispatch / consult / summary / base / plan / finished / help / blocked)
// directly as the strings the parser already works in — no separate sealed
// enum to keep in sync. The frozen tag set below is the single source of the
// kind vocabulary; the delivery-side kinds (nudge / ack) are produced by the
// orchestrator, never decoded inbound, so they do not appear here.
// ============================================================================

// Reserved address tokens. Members address the lead as LeadAddr; the TL's final
// @summary is addressed to the user. Real members use their configured name.
func LeadAddr() string = "_lead"
func UserAddr() string = "_user"

// DecodeContext carries the per-buffer facts Decode needs to stamp identity and
// routing onto the directives it finds.
//
//   Sender    — who produced this buffer (member name | "_lead").
//   Recipient — default counterparty for member terminals (normally LeadAddr).
//               TL directives override this from the directive's own target.
//   Epoch     — the monotone per-(Sender,Recipient) counter. A re-dispatch
//               bumps it so a late duplicate of the PREVIOUS turn's directive
//               hashes differently and cannot be mistaken for the live one
//               (defeats stale redelivery across re-dispatch without a
//               side-channel watermark).
//   LeadView  — true: extract @dispatch / @consult / @summary front-to-back
//               (the TL emits those). false: extract ONLY the end-anchored
//               member terminal — a member buffer that quotes `@dispatch(` in
//               an audit must NOT be parsed as a real dispatch, which is exactly
//               why MemberTerminal exists as a separate path.
struct DecodeContext(
    Sender    string,
    Recipient string,
    Epoch     int,
    LeadView  bool,
)

// TLDecodeContext is the context for the Team Lead's own buffer.
func TLDecodeContext(epoch int) DecodeContext = DecodeContext(
    Sender    = LeadAddr(),
    Recipient = UserAddr(),
    Epoch     = epoch,
    LeadView  = true,
)

// MemberDecodeContext is the context for a member's (engineer / QA) buffer.
// Member terminals are routed back to the lead.
func MemberDecodeContext(member string, epoch int) DecodeContext = DecodeContext(
    Sender    = member,
    Recipient = LeadAddr(),
    Epoch     = epoch,
    LeadView  = false,
)

// DecodeIssue is a parser-level problem the decoder surfaces instead of
// silently dropping. Currently:
//
//   UnclosedBlock(kind)        — an opener (@dispatch / @consult / @summary /
//                                 @base / @plan) had no matching bare `@end`.
//                                 collectBody would otherwise drop the trailing
//                                 block, leaving the FSM stuck because nothing
//                                 parsed (a long @summary asking the user to
//                                 decide vanished without surfacing the approval
//                                 dialog).
//   MultiTargetDispatch(names) — `@dispatch(A, B)` shape; the parser takes only
//                                 the first target so the remaining engineers
//                                 never spawn.
//   EmptyBody(directive)       — `@plan ... @end` / `@base ... @end` with an
//                                 empty body. Without surfacing this, the
//                                 directive would silently no-op (no Base ref to
//                                 apply, no Plan items to queue) and the TL would
//                                 never learn the directive vanished. `directive`
//                                 is the literal token ("@plan" / "@base").
//
// The UI maps DecodeIssue values to nudge prompts. Keeping the structural rule
// ("each directive closes with @end on its own line") here, next to the parser
// that enforces it, means a new bodied directive only has to be taught to the
// parser and the UI keeps consuming issues unchanged.
sealed type DecodeIssue {
    case UnclosedBlock(Kind string)
    case MultiTargetDispatch(Names string)
    case EmptyBody(Directive string)
}

// IssueTag projects a DecodeIssue to a stable lowercase token so callers in
// other packages can dispatch by string compare. Gala's pattern match binds
// positional variables on a qualified constructor (`protocol.UnclosedBlock(kind)`
// would bind `protocol` and `kind`), so a tag-plus-accessor pair is the
// cleanest cross-package shape.
func IssueTag(i DecodeIssue) string = i match {
    case UnclosedBlock(_)       => "unclosed_block"
    case MultiTargetDispatch(_) => "multi_target_dispatch"
    case EmptyBody(_)           => "empty_body"
}

// IssueUnclosedKind returns the directive kind of an UnclosedBlock (e.g.
// "summary" / "consult" / "dispatch"). Returns "" for any other issue variant —
// callers should gate on IssueTag first.
func IssueUnclosedKind(i DecodeIssue) string = i match {
    case UnclosedBlock(k) => k
    case _                => ""
}

// IssueMultiTargetNames returns the comma-separated target list of a
// MultiTargetDispatch issue. Returns "" for any other variant.
func IssueMultiTargetNames(i DecodeIssue) string = i match {
    case MultiTargetDispatch(n) => n
    case _                      => ""
}

// IssueEmptyBodyDirective returns the literal directive token of an EmptyBody
// issue ("@plan" / "@base"). Returns "" for any other variant.
func IssueEmptyBodyDirective(i DecodeIssue) string = i match {
    case EmptyBody(d) => d
    case _            => ""
}

// DecodeResult is what DecodeWithIssues returns: the parsed messages plus any
// parser-level issues the buffer carried. Decode (the existing callers' entry
// point) discards Issues — only code that wants to nudge the agent should reach
// for DecodeWithIssues.
struct DecodeResult(
    Messages Array[acp.Envelope],
    Issues   Array[DecodeIssue],
)

// Decode is the pure inbound decoder. Returns every protocol Envelope the buffer
// carries, in source order, deduplicated by content-hash Id. Thin wrapper over
// DecodeWithIssues that discards parser issues — most callers (delivery loop,
// headless driver, terminal-detection probes) only want the messages.
func Decode(buffer string, ctx DecodeContext) Array[acp.Envelope] =
    DecodeWithIssues(buffer, ctx).Messages

// DecodeWithIssues is the inbound decoder with parser-level diagnostics
// included. The UI uses this at the TL turn-buffer boundary so it can nudge the
// TL when an opener never closed (instead of routing through Idle with no
// surfaced cause).
func DecodeWithIssues(buffer string, ctx DecodeContext) DecodeResult {
    val lines = strings.Split(buffer, "\n")
    val (raw, issues) =
        if (ctx.LeadView) extractLeadDirectives(lines, ctx)
        else              (extractMemberTerminal(lines, ctx), EmptyArray[DecodeIssue]())
    return DecodeResult(Messages = acp.DedupById(raw), Issues = issues)
}

// ----------------------------------------------------------------------------
// Lead-buffer extraction
// ----------------------------------------------------------------------------

// extractLeadDirectives walks the buffer front-to-back and emits one Envelope
// per CLOSED @dispatch / @consult / @summary / @base / @plan block. Closed-only
// is deliberate: acting on a half-streamed directive is never correct, and it
// keeps Decode idempotent — the same closed block re-emitted is the same content
// hash. An unclosed trailing block is recorded as an UnclosedBlock issue so the
// UI can nudge the TL to close it. Multi-target dispatch (`@dispatch(A, B)`) is
// also surfaced as an issue: the parser still emits A as a message (current
// behaviour), but the issue lets the UI nudge the TL to open a separate block
// for B. Empty-body @plan / @base produce an EmptyBody issue instead of silently
// dropping — without the nudge the TL never learns the directive vanished.
func extractLeadDirectives(lines Array[string], ctx DecodeContext) Tuple[Array[acp.Envelope], Array[DecodeIssue]] {
    var out = EmptyArray[acp.Envelope]()
    var issues = EmptyArray[DecodeIssue]()
    var i = 0
    val n = lines.Length()
    for i < n {
        parseOpeningTag(lines.Get(i)) match {
            case Some(o) => {
                if (isLeadKind(o.Kind)) {
                    if (!o.ExtraTargets.IsEmpty()) {
                        val joined = o.Target + ", " + o.ExtraTargets.MkString(", ")
                        issues = issues.Append(MultiTargetDispatch(Names = joined))
                    }
                    val (body, next, closed) = collectBody(lines, i, n, o.SameLineRest)
                    if (closed) {
                        if (requiresNonEmptyBody(o.Kind) && body == "") {
                            issues = issues.Append(EmptyBody(Directive = "@" + o.Kind))
                        } else {
                            buildLeadMessage(o, body, ctx) match {
                                case Some(msg) => out = out.Append(msg)
                                case None()    => {}
                            }
                        }
                        i = next
                    } else {
                        issues = issues.Append(UnclosedBlock(Kind = o.Kind))
                        i = n
                    }
                } else {
                    i = i + 1
                }
            }
            case None() => i = i + 1
        }
    }
    return (out, issues)
}

// buildLeadMessage maps a TL opener + body to a routed Envelope. The recipient
// comes from the directive's own target for dispatch / consult; @summary /
// @base / @plan are TL→orchestrator side-channels addressed to the user (the
// same address @summary uses, since neither kind is routed to a member — Kind
// is what discriminates them in the content hash and downstream filter). The
// opener's Kind token IS the envelope kind tag.
func buildLeadMessage(o openingTag, body string, ctx DecodeContext) Option[acp.Envelope] {
    if (o.Kind == "dispatch") {
        if (o.Target == "") { return None[acp.Envelope]() }
        return Some[acp.Envelope](acp.NewEnvelope(ctx.Sender, o.Target, "dispatch", body, ctx.Epoch))
    }
    if (o.Kind == "consult") {
        if (o.Target == "") { return None[acp.Envelope]() }
        return Some[acp.Envelope](acp.NewEnvelope(ctx.Sender, o.Target, "consult", body, ctx.Epoch))
    }
    if (o.Kind == "summary") {
        return Some[acp.Envelope](acp.NewEnvelope(ctx.Sender, UserAddr(), "summary", body, ctx.Epoch))
    }
    if (o.Kind == "base") {
        return Some[acp.Envelope](acp.NewEnvelope(ctx.Sender, UserAddr(), "base", body, ctx.Epoch))
    }
    if (o.Kind == "plan") {
        return Some[acp.Envelope](acp.NewEnvelope(ctx.Sender, UserAddr(), "plan", body, ctx.Epoch))
    }
    return None[acp.Envelope]()
}

func isLeadKind(kind string) bool =
    kind == "dispatch" || kind == "consult" || kind == "summary" ||
    kind == "base"     || kind == "plan"

// requiresNonEmptyBody marks the kinds whose semantics collapse if the body is
// empty (@plan with no items is a no-op; @base with no ref can't pick a branch).
// @dispatch / @consult / @summary are allowed through with an empty body —
// current behaviour, and a zero-body @summary still legitimately opens the
// approval modal.
func requiresNonEmptyBody(kind string) bool =
    kind == "base" || kind == "plan"

// ----------------------------------------------------------------------------
// Member-terminal extraction
// ----------------------------------------------------------------------------

// extractMemberTerminal returns the member's single operative sign-off. A member
// works, then emits exactly one terminal block (@finished / @review / @done /
// @help / @blocked) closed by a bare `@end`.
//
// Anchoring on the LAST bare `@end`, then scanning backward for the nearest
// member-terminal opener, ignores every quoted protocol example before the real
// sign-off — the front-to-back greedy parser let an earlier QUOTED opener
// swallow the real terminal as its body, so no completion ever fired and the
// orchestrator parked forever waiting on a member that had already finished.
//
// Empty array (not an error) when there is no closed terminal block yet (still
// streaming / member never signed off) — the caller simply waits.
//
// The opener's normalised Kind token (finished / help / blocked — see
// nearestTerminalOpener's isMemberTerminalKind gate) IS the envelope kind tag.
func extractMemberTerminal(lines Array[string], ctx DecodeContext) Array[acp.Envelope] {
    val n = lines.Length()
    val endIdx = lastBareEndIndex(lines, n)
    if (endIdx < 0) { return EmptyArray[acp.Envelope]() }
    val opener = nearestTerminalOpener(lines, endIdx)
    return opener match {
        case None()  => EmptyArray[acp.Envelope]()
        case Some(o) => {
            val body = bodyBetween(lines, o.OpenIdx, endIdx, o.Tag.SameLineRest)
            return ArrayOf[acp.Envelope](
                acp.NewEnvelope(ctx.Sender, ctx.Recipient, o.Tag.Kind, body, ctx.Epoch))
        }
    }
}

// anchoredOpener pairs a parsed opener with the line it was found on, so callers
// don't need a nested (int, openingTag) tuple pattern (GALA tuple destructuring
// binds identifiers, which is fragile here).
struct anchoredOpener(
    OpenIdx int,
    Tag     openingTag,
)

// lastBareEndIndex scans backward for the last line that is exactly `@end`
// (trailing whitespace tolerated). -1 when none.
func lastBareEndIndex(lines Array[string], n int) int {
    var endIdx = -1
    var k = n - 1
    for endIdx < 0 && k >= 0 {
        if (strings.TrimSpace(lines.Get(k)) == "@end") { endIdx = k }
        k = k - 1
    }
    return endIdx
}

// nearestTerminalOpener scans backward from `endIdx-1` for the nearest line that
// opens a MEMBER-terminal directive (finished / help / blocked). @dispatch /
// @consult / @summary are TL-only and never a member's sign-off, so a member
// quoting `@dispatch(` in an audit must not anchor here.
func nearestTerminalOpener(lines Array[string], endIdx int) Option[anchoredOpener] {
    var found = None[anchoredOpener]()
    var j = endIdx - 1
    for found.IsEmpty() && j >= 0 {
        val tag = parseOpeningTag(lines.Get(j))
        tag match {
            case Some(o) => {
                if isMemberTerminalKind(o.Kind) {
                    found = Some[anchoredOpener](anchoredOpener(OpenIdx = j, Tag = o))
                }
            }
            case None() => {}
        }
        j = j - 1
    }
    return found
}

func isMemberTerminalKind(kind string) bool =
    kind == "finished" || kind == "help" || kind == "blocked"

// bodyBetween joins the same-line remainder of the opener plus every line
// strictly between the opener and the anchoring `@end`.
func bodyBetween(lines Array[string], openIdx int, endIdx int, sameLineRest string) string {
    var parts = EmptyArray[string]()
    if (sameLineRest != "") { parts = parts.Append(sameLineRest) }
    var b = openIdx + 1
    for b < endIdx {
        parts = parts.Append(lines.Get(b))
        b = b + 1
    }
    return joinBody(parts)
}

// ----------------------------------------------------------------------------
// Shared opener / body parsing
// ----------------------------------------------------------------------------

// openingTag is the parsed result of one opening line.
//   Kind         — normalised token: dispatch | consult | summary | base | plan
//                   | finished | help | blocked.
//   Target       — member / team name for dispatch / consult; "" else.
//   SameLineRest — body text after the tag on the same line.
//   ExtraTargets — additional comma-separated targets after Target, excluding
//                   key=value kwargs (so `@consult(team, project="/x")` has
//                   none). Non-empty means the TL emitted a multi-target shape;
//                   the parser still extracts only Target (current behaviour)
//                   but the caller surfaces an issue.
struct openingTag(
    Kind         string,
    Target       string,
    SameLineRest string,
    ExtraTargets Array[string],
)

// parseOpeningTag normalises @finished / @review / @done to the single
// "finished" token — every member- and QA-facing protocol surface advertises
// those words, and an earlier version of this code only recognised one of them,
// so a member following the documented vocabulary signed off and nothing fired.
// Accept what the protocol actually advertises.
func parseOpeningTag(line string) Option[openingTag] {
    val trimmed = strings.TrimLeft(line, " \t")
    if (strings.HasPrefix(trimmed, "@dispatch(")) {
        return parseTargeted("dispatch", strings.TrimPrefix(trimmed, "@dispatch("))
    }
    if (strings.HasPrefix(trimmed, "@consult(")) {
        return parseTargeted("consult", strings.TrimPrefix(trimmed, "@consult("))
    }
    if (strings.HasPrefix(trimmed, "@summary")) {
        return bodyOnly("summary", strings.TrimPrefix(trimmed, "@summary"))
    }
    if (strings.HasPrefix(trimmed, "@base")) {
        return bodyOnly("base", strings.TrimPrefix(trimmed, "@base"))
    }
    if (strings.HasPrefix(trimmed, "@plan")) {
        return bodyOnly("plan", strings.TrimPrefix(trimmed, "@plan"))
    }
    if (strings.HasPrefix(trimmed, "@finished")) {
        return bodyOnly("finished", strings.TrimPrefix(trimmed, "@finished"))
    }
    if (strings.HasPrefix(trimmed, "@review")) {
        return bodyOnly("finished", strings.TrimPrefix(trimmed, "@review"))
    }
    if (strings.HasPrefix(trimmed, "@done")) {
        return bodyOnly("finished", strings.TrimPrefix(trimmed, "@done"))
    }
    if (strings.HasPrefix(trimmed, "@help")) {
        return bodyOnly("help", strings.TrimPrefix(trimmed, "@help"))
    }
    if (strings.HasPrefix(trimmed, "@blocked")) {
        return bodyOnly("blocked", strings.TrimPrefix(trimmed, "@blocked"))
    }
    return None[openingTag]()
}

func bodyOnly(kind string, afterTag string) Option[openingTag] = Some[openingTag](openingTag(
    Kind         = kind,
    Target       = "",
    SameLineRest = strings.TrimLeft(afterTag, " \t"),
    ExtraTargets = EmptyArray[string](),
))

// parseTargeted handles @dispatch( / @consult( — splits at the first ")" to
// separate the target from the same-line body. The target is the first
// comma-separated arg; remaining bare comma-separated names (no `=`) populate
// ExtraTargets so the caller can surface a MultiTargetDispatch issue. `key=value`
// tail args (e.g. `project="/x"`) are kwargs, not extra targets, and are ignored
// for identity.
func parseTargeted(kind string, afterOpen string) Option[openingTag] {
    val parts = strings.SplitN(afterOpen, ")", 2)
    if (parts.Length() < 2) { return None[openingTag]() }
    val allArgs = strings.Split(parts.Get(0), ",")
    val target = strings.TrimSpace(allArgs.Get(0))
    if (target == "") { return None[openingTag]() }
    val extras = allArgs
        .Drop(1)
        .Map((s) => strings.TrimSpace(s))
        .Filter((s) => s != "" && !strings.Contains(s, "="))
    return Some[openingTag](openingTag(
        Kind         = kind,
        Target       = target,
        SameLineRest = strings.TrimLeft(parts.Get(1), " \t"),
        ExtraTargets = extras,
    ))
}

// collectBody walks from the opener to the next bare `@end`. Returns
// (body, nextIndex, closed). closed=false means the buffer ran out before an
// `@end` — the caller drops the unclosed block.
func collectBody(lines Array[string], start int, n int, sameLineRest string) Tuple3[string, int, bool] {
    var parts = EmptyArray[string]()
    if (sameLineRest != "") { parts = parts.Append(sameLineRest) }
    var i = start + 1
    for i < n {
        val line = lines.Get(i)
        if (strings.TrimSpace(line) == "@end") {
            return (joinBody(parts), i + 1, true)
        }
        parts = parts.Append(line)
        i = i + 1
    }
    return (joinBody(parts), n, false)
}

func joinBody(parts Array[string]) string =
    strings.TrimSpace(parts.MkString("\n"))
