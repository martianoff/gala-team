package protocol

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
)

// One-second-resolution clock helper (Tick runs on nanos).
func ns(seconds int) int = seconds * 1000000000

// A 30 / 120 / 300s ladder with a 2-redelivery budget (the design
// defaults), built without importing app/policy.
func pol() DeliveryPolicy = DefaultDeliveryPolicy()

func dispatchMsg(attempt int) Message =
    WithAttempt(NewMessage("_lead", "Felix", Dispatch(), "work", 0), attempt)

// ----- proof of life --------------------------------------------------------

func TestOnChunk_AnyChunkIsWorking(t T) T {
    val s = OnChunk(Sent(AtNanos = 0, Attempt = 1), ns(5))
    return Eq(t, StateName(s), "working")
}

// A chunk after going Silent RECOVERS the delivery — this is the rule
// that subsumes "onChunk clears RetryCount", so transient silence never
// permanently burns the budget.
func TestOnChunk_RecoversFromSilent(t T) T {
    val s = OnChunk(Silent(SinceNanos = ns(130), Attempt = 4), ns(140))
    return Eq(t, StateName(s), "working")
}

// Terminal states are sticky — a stray late chunk does not resurrect a
// signed-off or abandoned delivery.
func TestOnChunk_TerminalSticky(t T) T {
    val t1 = Eq(t, StateName(OnChunk(Acked(), ns(1))), "acked")
    return Eq(t1, StateName(OnChunk(Abandoned(), ns(1))), "abandoned")
}

func TestOnTerminal_SignOffAcks(t T) T {
    val t1 = Eq(t, StateName(OnTerminal(Working(LastSeenNanos = ns(3)))), "acked")
    // A sign-off arriving only AFTER abandon is too late.
    return Eq(t1, StateName(OnTerminal(Abandoned())), "abandoned")
}

// ----- the silence ladder ---------------------------------------------------

// Below the stuck threshold (the slow / working band) → NoOp.
func TestTick_BelowStuckIsNoOp(t T) T {
    val (s, a) = Tick(Sent(AtNanos = 0, Attempt = 1), dispatchMsg(1), ns(60), pol())
    val t1 = Eq(t, ActionName(a), "noop")
    return Eq(t1, StateName(s), "sent")
}

// Past the stuck threshold with budget left → Redeliver, attempt bumped,
// clock restarts (subsumes liveRespawnMember's bounded auto-retry).
func TestTick_StuckWithBudgetRedelivers(t T) T {
    val (s, a) = Tick(Sent(AtNanos = 0, Attempt = 1), dispatchMsg(1), ns(130), pol())
    val t1 = Eq(t, ActionName(a), "redeliver")
    val t2 = a match {
        case Redeliver(mm) => Eq(t1, mm.Attempt, 2)
        case _             => IsTrue(t1, false)
    }
    return Eq(t2, StateName(s), "sent")
}

// Budget spent (attempt past MaxRetries) → IssueNudge ONCE; the state
// goes Silent so re-ticking before abandon does NOT pile on.
func TestTick_BudgetSpentNudgesOnce(t T) T {
    val (s1, a1) = Tick(Sent(AtNanos = 0, Attempt = 3), dispatchMsg(3), ns(130), pol())
    val t1 = Eq(t, ActionName(a1), "nudge")
    val t2 = Eq(t1, StateName(s1), "silent")
    // Re-tick while still Silent (pre-abandon) → NoOp, no pile-on.
    val (_, a2) = Tick(s1, dispatchMsg(3), ns(150), pol())
    return Eq(t2, ActionName(a2), "noop")
}

// Past the abandon horizon → MarkAbandoned (terminal).
func TestTick_PastAbandonMarksAbandoned(t T) T {
    val (s, a) = Tick(Silent(SinceNanos = 0, Attempt = 3), dispatchMsg(3), ns(310), pol())
    val t1 = Eq(t, ActionName(a), "abandon")
    return Eq(t1, StateName(s), "abandoned")
}

// Full lifecycle: Sent → Working → (silent) Redeliver → Redeliver →
// nudge → Abandoned.
func TestTick_FullEscalationLifecycle(t T) T {
    val p = pol()
    // chunk arrives → Working
    val w = OnChunk(Sent(AtNanos = 0, Attempt = 1), ns(10))
    val t1 = Eq(t, StateName(w), "working")
    // silent 130s past last chunk, attempt 1 → Redeliver (→2)
    val (r1s, r1a) = Tick(w, dispatchMsg(1), ns(140), p)
    val t2 = Eq(t1, ActionName(r1a), "redeliver")
    // still silent, attempt 2 (==MaxRetries) → Redeliver (→3)
    val (_, r2a) = Tick(r1s, dispatchMsg(2), ns(260), p)
    val t3 = Eq(t2, ActionName(r2a), "redeliver")
    // attempt 3 (> MaxRetries) → nudge, state Silent
    val (sil, na) = Tick(Sent(AtNanos = ns(260), Attempt = 3), dispatchMsg(3), ns(390), p)
    val t4 = Eq(t3, ActionName(na), "nudge")
    val t5 = Eq(t4, StateName(sil), "silent")
    // far past abandon → Abandoned
    val (ab, aa) = Tick(sil, dispatchMsg(3), ns(700), p)
    val t6 = Eq(t5, ActionName(aa), "abandon")
    return Eq(t6, StateName(ab), "abandoned")
}

// The Acked happy path: a working delivery that signs off is terminal
// and ticking it is inert.
func TestTick_AckedHappyPathIsInert(t T) T {
    val acked = OnTerminal(Working(LastSeenNanos = ns(5)))
    val (s, a) = Tick(acked, dispatchMsg(1), ns(9999), pol())
    val t1 = Eq(t, StateName(s), "acked")
    return Eq(t1, ActionName(a), "noop")
}

// ----- AggregateNudges (the pile-on fix) ------------------------------------

// N silent members fold into AT MOST ONE batched nudge naming them all.
func TestAggregateNudges_BatchesAllSilent(t T) T {
    val states = ArrayOf[Tuple[string, DeliveryState]](
        ("Kael", Silent(SinceNanos = 0, Attempt = 3)),
        ("Lyra", Working(LastSeenNanos = ns(5))),
        ("Mira", Silent(SinceNanos = 0, Attempt = 4)),
    )
    return AggregateNudges(states, ns(400), pol()) match {
        case Some(act) => act match {
            case IssueNudge(member, _) =>
                // Folded in input order; Lyra (Working) is excluded.
                Eq(t, member, "Kael, Mira")
            case _ => IsTrue(t, false)
        }
        case None() => IsTrue(t, false)
    }
}

// Nobody silent → no nudge.
func TestAggregateNudges_NoneWhenAllHealthy(t T) T {
    val states = ArrayOf[Tuple[string, DeliveryState]](
        ("Kael", Working(LastSeenNanos = ns(5))),
        ("Lyra", Sent(AtNanos = 0, Attempt = 1)),
    )
    return IsNone(t, AggregateNudges(states, ns(10), pol()))
}

// ----- PolicyFromHeartbeat adapter ------------------------------------------

// The adapter converts the existing Heartbeat seconds to the nanosecond
// clock without inventing tunables.
func TestPolicyFromHeartbeat_SecondsToNanos(t T) T {
    val p = PolicyFromHeartbeat(int64(30), int64(120), int64(300), 2)
    val t1 = Eq(t,  p.SlowNanos, ns(30))
    val t2 = Eq(t1, p.StuckNanos, ns(120))
    val t3 = Eq(t2, p.AbandonNanos, ns(300))
    return Eq(t3, p.MaxRetries, 2)
}

// ----- action / state name projections --------------------------------------

func TestActionName_AllVariants(t T) T {
    val m = dispatchMsg(1)
    val t1 = Eq(t,  ActionName(NoOp()), "noop")
    val t2 = Eq(t1, ActionName(Redeliver(M = m)), "redeliver")
    val t3 = Eq(t2, ActionName(IssueNudge(Member = "K", Text = "x")), "nudge")
    val t4 = Eq(t3, ActionName(Escalate(Member = "K")), "escalate")
    return Eq(t4, ActionName(MarkAbandoned(Member = "K")), "abandon")
}
