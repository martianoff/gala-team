package runtime

import (
    "errors"
    "path/filepath"
    "martianoff/gala/fs"
    "martianoff/gala/strings"
    "martianoff/gala/subprocess"
    "martianoff/gala/concurrent"
    "martianoff/gala/json"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/go_interop"
    . "github.com/martianoff/gala_team/app/policy"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/team"
)

// ============================================================================
// app/runtime — bridges the pure FSM (app/fsm) to actual `claude` CLI
// subprocesses via concurrent.Future[Msg].
//
// This package depends only on gala stdlib (subprocess + concurrent) plus
// our own team / project types — explicitly NOT on gala_tui.  The Future
// values returned here can be wrapped into gala_tui's FutureCmd by a
// thin UI layer (added when wiring the TUI).  Keeping that boundary
// clean means runtime is testable in isolation and could later host an
// alternative TUI / CLI front end without changes here.
//
// Reads are a self-perpetuating pump: each NextChunk Future completion
// dispatches a ChunkArrived through the consumer's update loop, which
// schedules another NextChunk. One in-flight Future[Msg] per active
// member.
// ============================================================================

// Msg is the runtime side of the gala_team event vocabulary.  Cases here
// are the things subprocess interactions produce; the full app Msg sealed
// type folds these in alongside keyboard / mouse / tick events. Names
// are prefixed `Rt` so they don't collide with the lifted versions in
// app/ui.AppMsg when both are dot-imported in the same file.
sealed type Msg {
    case RtChunkArrived(Member string, Line string)
    case RtSessionFailed(Member string, Err error)
    case RtWriteSent(Member string)
    case RtStderrArrived(Member string, Line string)
    case RtStderrEnded(Member string)
    case RtPrCreated(Url string, Branch string)
    case RtPrFailed(Err error)
    case RtWorktreesWiped()
}

// MemberSession pairs a Member with the live subprocess driving them.
struct MemberSession(
    Member  Member,
    Process subprocess.Process,
)

// ----------------------------------------------------------------------------
// Spawning
// ----------------------------------------------------------------------------

// SpawnSession launches a `claude` CLI process for `m` with cwd
// `workspace`. Every member — including the team lead — runs in
// their own git worktree under `<proj.Repo>/.gala_team/worktrees/`
// (see `EnsureWorkspace`); the user's main checkout is never used
// as a session cwd by the orchestrator.
//
// Flags:
//   - m.Model pins the model when set (--model <name>).
//   - dangerouslySkipPermissions adds --dangerously-skip-permissions
//     when true (opt-in per-team via team.yaml).
//   - sessionId pairs with isNewSession to control the
//     `--session-id` / `--resume` flag: a fresh session uses
//     `--session-id <id>` (claude creates the conversation under
//     that id); a returning session uses `--resume <id>` (claude
//     loads the prior conversation by id). Per-member ids let
//     multiple members run concurrently in the same cwd without
//     racing on `--continue`'s "most recent" semantics.
//
// The prompt itself is delivered through stdin (see SendFuture +
// CloseStdinFuture), not as an argv element — Windows caps argv
// length around 32 KB and the onboarding pack alone can blow that
// limit on the first turn.
//
// `claude --print` exits after responding, so a "session" here is
// per-turn — the orchestrator threads conversation context across
// turns via the session id.
//
// Returns Try[MemberSession]; failure carries the underlying spawn error.
func SpawnSession(
    proj Project,
    m Member,
    workspace string,
    dangerouslySkipPermissions bool,
    sessionId string,
    isNewSession bool,
) Try[MemberSession] {
    val opts = subprocess.NewSpawnOpts(
        "claude",
        claudeArgs(m, dangerouslySkipPermissions, sessionId, isNewSession).ToGoSlice(),
        SliceEmpty[string](),
        workspace,
    )
    return subprocess.Spawn(opts).Map((p) => MemberSession(Member = m, Process = p))
}

// EnsureWorkspace returns the cwd to spawn `m` in, given the team's
// workspace policy. For Shared mode, every member gets `proj.Repo`.
// For WorktreePerEngineer, EVERY member — including the team lead —
// gets a dedicated git worktree under `<proj.Repo>/.gala_team/worktrees/`.
// Engineers / QAs land in `<m.Name>/` on `gala_team/<proj.Name>/<m.Name>`;
// the lead lands in `_lead/` on `gala_team/<proj.Name>/lead`. The
// project-scoped branch keeps runs against different projects (same
// team yaml, different `--project` dirs) from clobbering each other's
// branches if the same repo is reused.
//
// Why the TL also gets a worktree (was: TL ran in `proj.Repo`):
// orchestrator git ops — Start fresh hard-reset, lead-branch checkout,
// snapshot push, `gh pr create` — all mutated the user's main checkout
// directly. A bad TL turn left the user on a stale branch with stray
// commits or a wrong-base reset. Routing the TL through its own
// worktree means the user's main repo is never touched by orchestrator
// code, full stop.
//
// The worktree is created on first call; subsequent calls for the same
// member just return the existing path.
//
// The TL gets a worktree REGARDLESS of `mode` — even in `Shared()`,
// where engineers/QAs share `proj.Repo`. The TL alone has its own
// `_lead/` worktree because every orchestrator git op (ResetLeadBranch,
// pushSnapshotBranch, gh pr create) targets the TL's cwd; if that cwd
// were `proj.Repo`, the user's main checkout would be mutated by every
// turn. Shared mode keeps its meaning for engineers (no per-engineer
// isolation) but the TL's safety story is non-negotiable.
func EnsureWorkspace(proj Project, m Member, mode WorkspaceMode) Try[string] {
    val isLead = SameRole(m.Role, TeamLead())
    if isLead { return EnsureLeadWorktree(proj) }
    return mode match {
        case Shared()              => Success[string](proj.Repo)
        case WorktreePerEngineer() => ensureWorktree(proj, m)
    }
}

// LeadBranchFor returns the branch name the lead operates on for a
// given project. Mirrors WorktreeBranchFor's convention so users see
// a consistent gala_team/<proj>/<who> namespace across all members.
//
// Project name is slugified (`gitSlug`) because git refuses refs
// containing spaces / `~` / `^` / etc. The auto-detected default
// project name is "Default Project" with a literal space, which
// would produce an invalid branch — slugified to "default-project".
func LeadBranchFor(proj Project) string = "gala_team/" + gitSlug(proj.Name) + "/lead"

// gitSlug normalises arbitrary project names into something git
// accepts as a ref component. Per git-check-ref-format(1) refs
// can't contain space, control chars, `~`, `^`, `:`, `?`, `*`,
// `[`, `\`, sequences `..` / `@{`, leading or trailing `/` or
// `.`. We map every invalid char to `-`, lowercase the result,
// collapse runs, and trim. Empty input falls back to "project".
func gitSlug(s string) string {
    if s == "" { return "project" }
    val acc = strings.S(strings.ToLower(s)).ToChars().FoldLeft(("", false), (state, c) => {
        val (out, lastUnsafe) = state
        val safe = (c >= 'a' && c <= 'z') || (c >= '0' && c <= '9') ||
                   c == '-' || c == '_' || c == '.' || c == '/'
        if (safe)            (out + string(c), false)
        else if (lastUnsafe) state
        else                 (out + "-", true)
    })
    val (built, _) = acc
    val joined = strings.Trim(built, "-/.")
    if joined == "" { return "project" }
    return joined
}

// LeadWorktreePath returns the on-disk location of the team lead's
// dedicated worktree. Mirrors the per-engineer path convention so
// downstream code (logs, view surfaces, sweepers) can locate it
// without re-implementing the formula. Underscore prefix keeps it
// distinct from any member named "lead" and sorts at the top of
// directory listings.
func LeadWorktreePath(proj Project) string =
    filepath.Join(proj.Repo, ".gala_team", "worktrees", "_lead")

// isGitRepoDir returns true iff `dir` contains a `.git` entry (file
// or directory — `.git` is a file inside worktree checkouts, a dir
// in the main checkout). Cheap stat; no subprocess. Used to gate
// worktree creation so non-git fixtures degrade cleanly instead of
// failing every git op the orchestrator tries to run.
func isGitRepoDir(dir string) bool = fs.Exists(filepath.Join(dir, ".git"))

// leadWtPathIsLiveDir is the "exists AND is a directory" check used by
// the worktree-prep paths to decide whether a defensive cleanup of a
// stale leftover dir is needed. fs.Stat returns Failure on missing
// paths; the Success arm narrows to IsDir.
func leadWtPathIsLiveDir(path string) bool = fs.Stat(path) match {
    case Success(info) => info.IsDir
    case Failure(_)    => false
}

// EnsureLeadWorktree creates the team lead's worktree at
// `<proj.Repo>/.gala_team/worktrees/_lead` checked out on the
// `gala_team/<proj.Name>/lead` branch. Idempotent: subsequent calls
// just return the path. Subsumes the older `ensureLeadBranch` —
// the worktree is on the right branch by construction.
//
// Critically, this is what keeps orchestrator git ops off the user's
// main checkout. ResetLeadBranch, pushSnapshotBranch, and gh pr create
// all run with cwd set to this path; the user's `proj.Repo` is never
// `git checkout`ed or `git reset`ed by the orchestrator.
func EnsureLeadWorktree(proj Project) Try[string] = Try(() => {
    // Graceful degradation: if proj.Repo isn't even a git repo (test
    // fixtures with bare temp dirs, headless setups pointed at a
    // non-VCS workspace), the worktree machinery has nothing to bite
    // on. Fall back to proj.Repo so callers still get a usable cwd.
    // Production always satisfies the git-repo precondition; this
    // branch only fires in degenerate environments.
    if !isGitRepoDir(proj.Repo) {
        return proj.Repo
    }
    val wtPath = LeadWorktreePath(proj)
    val branch = LeadBranchFor(proj)
    if isRegisteredWorktree(proj, wtPath) {
        return wtPath
    }
    val parent = filepath.Dir(wtPath)
    fs.MkdirAll(parent, 0755) match {
        case Failure(err) => panic(s"lead worktree mkdir ${parent}: ${err.Error()}")
        case Success(_)   => {}
    }
    if leadWtPathIsLiveDir(wtPath) {
        // Same defensive cleanup as ensureWorktree: a leftover dir
        // from a prior interrupted run will block `git worktree add`.
        // Try git's own remove first, then fall back to fs.RemoveAll.
        val gitRm = subprocess.NewSpawnOpts(
            "git",
            ArrayOf("worktree", "remove", "--force", wtPath).ToGoSlice(),
            SliceEmpty[string](),
            proj.Repo,
        )
        subprocess.Spawn(gitRm) match {
            case Success(p) => { val _ = p.Wait() }
            case Failure(_) => {}
        }
        if leadWtPathIsLiveDir(wtPath) {
            val _ = fs.RemoveAll(wtPath)
        }
    }
    // Fork the lead worktree from the project's DEFAULT BRANCH so a
    // brand-new lead session starts at the same baseline the user has
    // on main. `-B` re-creates the branch if it already exists locally
    // (left over from a prior session); the worktree adopts whatever
    // tip lead currently points at if it does, otherwise it's freshly
    // forked. Either way, ResetLeadBranch's hard-reset on Start fresh
    // cleans the slate per session.
    val opts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("worktree", "add", "-B", branch, wtPath, proj.DefaultBranch).ToGoSlice(),
        SliceEmpty[string](),
        proj.Repo,
    )
    val proc = subprocess.Spawn(opts) match {
        case Success(p)   => p
        case Failure(err) => panic(s"git worktree add ${wtPath}: ${err.Error()}")
    }
    val code = proc.Wait().Get()
    if code != 0 {
        if isRegisteredWorktree(proj, wtPath) {
            LogWorktreeCreate("_lead", wtPath, branch)
            return wtPath
        }
        panic(s"git worktree add ${wtPath} exited with code ${code}")
    }
    LogWorktreeCreate("_lead", wtPath, branch)
    return wtPath
})

// ResetLeadBranch hard-resets the lead's branch back to the project's
// default branch. Called by the Start fresh / Ctrl+N paths so the new
// session doesn't inherit committed leftover work from the prior
// session. Best-effort — IO failures don't block the data-side reset.
//
// Operates on the lead WORKTREE (not the user's main checkout). The
// worktree is created on demand if missing; the reset target is
// origin/<defaultBranch> so a stale local default doesn't anchor lead
// to a pre-merged ancestor.
func ResetLeadBranch(proj Project) Try[bool] = Try(() => {
    val wtPath = EnsureLeadWorktree(proj).Get()
    // Fetch origin/<defaultBranch> first so the reset target reflects
    // the REMOTE's current state, not the user's possibly-stale
    // local ref. Without this, a user who never `git pull`s sees
    // ResetLeadBranch reset lead to whatever ancient SHA their
    // local master happens to be at — even if a prior PR has
    // already landed upstream and advanced origin/master past it.
    // The worst case: lead resets to a pre-PR ancestor, the next
    // session re-creates files a prior PR had already committed,
    // and the resulting PR effectively tries to overwrite
    // already-merged work.
    //
    // Fetch is best-effort. If the remote is unreachable (offline,
    // no origin configured), fall through and reset against the
    // local branch — better to do something than block.
    val fetchOpts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("fetch", "--quiet", "origin", proj.DefaultBranch).ToGoSlice(),
        SliceEmpty[string](),
        wtPath,
    )
    val resetTarget = subprocess.Spawn(fetchOpts) match {
        case Failure(_) => proj.DefaultBranch
        case Success(p) => {
            val code = p.Wait().Get()
            if (code == 0) "origin/" + proj.DefaultBranch else proj.DefaultBranch
        }
    }
    val opts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("reset", "--hard", resetTarget).ToGoSlice(),
        SliceEmpty[string](),
        wtPath,
    )
    val proc = subprocess.Spawn(opts) match {
        case Success(p)   => p
        case Failure(err) => panic(s"git reset --hard ${resetTarget}: ${err.Error()}")
    }
    val code = proc.Wait().Get()
    if code != 0 { panic(s"git reset --hard ${resetTarget} exited with code ${code}") }
    // Drop untracked files left behind by the prior turn so the next
    // session starts from a truly clean tree. `-f` force, `-d` recurse
    // into directories, `-x` include .gitignored entries (the prior
    // session's bazel-out/ etc. would otherwise persist). Best-effort
    // — clean failures don't sink the reset.
    val cleanOpts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("clean", "-fdx", "--quiet").ToGoSlice(),
        SliceEmpty[string](),
        wtPath,
    )
    subprocess.Spawn(cleanOpts) match {
        case Success(p) => { val _ = p.Wait() }
        case Failure(_) => {}
    }
    return true
})

// WipeWorktreesFuture runs the heavy "Start fresh" cleanup off the UI
// thread. The returned Future resolves to RtWorktreesWiped() once
// every git op has completed; the UI shows a "wiping…" banner in
// the meantime and clears it when the message arrives. Without this,
// the synchronous version froze the TUI for ~5-10s on Start fresh
// while git fetched + reset + per-engineer worktree-removed serially.
//
// Operations performed (in order):
//   1. ResetLeadBranch — hard-reset the lead worktree to
//      origin/<defaultBranch>, plus `git clean -fdx` to drop the
//      prior session's untracked files. The lead WORKTREE is reused
//      (no remove + re-create dance — the cheap "reset in place"
//      gives the same end state without the worktree-add overhead).
//   2. RemoveWorktree per engineer / QA member when in
//      WorktreePerEngineer mode. Skipped in Shared mode.
//   3. PruneWorktrees — clean up any orphan .git/worktrees/ entries
//      left behind by out-of-band removes.
//
// Best-effort throughout — IO failures don't stop the rest of the
// wipe. The user opted into "Start fresh = blank slate"; partial
// cleanup is better than aborting on the first lockfile.
func WipeWorktreesFuture(proj Project, members Array[Member], mode WorkspaceMode) concurrent.Future[Msg] {
    return concurrent.FutureApply[Msg](() => {
        val _ = ResetLeadBranch(proj)
        val isWorktreeMode = mode match {
            case Shared()              => false
            case WorktreePerEngineer() => true
        }
        if isWorktreeMode {
            members.ForEach((mem) => {
                val isLead = SameRole(mem.Role, TeamLead())
                if isLead { return }
                val _ = RemoveWorktree(proj, mem)
            })
        }
        val _ = PruneWorktrees(proj)
        return RtWorktreesWiped()
    })
}

// WorktreeBranchFor mirrors the branch-naming convention used by
// ensureWorktree so other layers (onboarding prompts, view, log
// surfaces) can name the same branch without re-implementing the
// formula. Format: `gala_team/<proj.Name>/<member.Name>`.
func WorktreeBranchFor(proj Project, m Member) string =
    "gala_team/" + gitSlug(proj.Name) + "/" + m.Name

// ensureWorktree creates `<proj.Repo>/.gala_team/worktrees/<m.Name>`
// if it isn't already a registered worktree. If the dir exists but git
// doesn't know about it (stale from a prior run / filesystem leftover),
// the dir is wiped and re-created so the engineer always lands in a
// clean checkout of `gala_team/<proj.Name>/<m.Name>`.
//
// Without this, `?? crypto/` and other untracked files from the prior
// engineer leak through and the new engineer reads them as legitimate
// in-progress work, which derails their dispatch.
func ensureWorktree(proj Project, m Member) Try[string] = Try(() => {
    val wtPath = filepath.Join(proj.Repo, ".gala_team", "worktrees", m.Name)
    val branch = WorktreeBranchFor(proj, m)
    if isRegisteredWorktree(proj, wtPath) {
        return wtPath
    }
    // Either the dir doesn't exist yet, or it's a stale leftover. Either
    // way, ensure parent exists and wipe whatever is at wtPath so the
    // fresh `git worktree add` doesn't trip over leftover content.
    val parent = filepath.Dir(wtPath)
    fs.MkdirAll(parent, 0755) match {
        case Failure(err) => panic(s"worktree mkdir ${parent}: ${err.Error()}")
        case Success(_)   => {}
    }
    if leadWtPathIsLiveDir(wtPath) {
        // Try git's own cleanup first — `git worktree remove --force`
        // is worktree-aware and handles the case where some metadata
        // ghost still references this path (would block a plain
        // `git worktree add`). Best-effort; we don't care if it fails
        // because the dir wasn't a registered worktree.
        val gitRm = subprocess.NewSpawnOpts(
            "git",
            ArrayOf("worktree", "remove", "--force", wtPath).ToGoSlice(),
            SliceEmpty[string](),
            proj.Repo,
        )
        subprocess.Spawn(gitRm) match {
            case Success(p) => { val _ = p.Wait() }
            case Failure(_) => {}
        }
        // Re-stat. If git's remove did the job we're done with this
        // step. Otherwise fall through to fs.RemoveAll. Don't panic on
        // "in use by another process" / lock failures. A stale
        // claude.exe with cwd inside this dir, or a Windows file
        // watcher (gopls / IDE indexer) holding handles, can keep the
        // dir un-unlinkable for tens of seconds. The `git worktree
        // add` below will either succeed (git can sometimes adopt a
        // half-empty dir) or surface its own error via the
        // idempotency fallback.
        if leadWtPathIsLiveDir(wtPath) {
            val _ = fs.RemoveAll(wtPath)
        }
    }
    // Fork the engineer's worktree from the project's DEFAULT BRANCH
    // (e.g. main / master), NOT from current HEAD. The lead has its
    // own branch (gala_team/<proj>/lead) which Start fresh hard-resets
    // — without an explicit start point, `git worktree add -B` forks
    // from current HEAD = the reset lead branch, leaving engineers
    // with an empty checkout that doesn't even have the user's
    // committed baseline. Forking from the default branch gives them
    // the same starting state the user has on main.
    val opts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("worktree", "add", "-B", branch, wtPath, proj.DefaultBranch).ToGoSlice(),
        SliceEmpty[string](),
        proj.Repo,
    )
    val proc = subprocess.Spawn(opts) match {
        case Success(p)   => p
        case Failure(err) => panic(s"git worktree add ${wtPath}: ${err.Error()}")
    }
    val code = proc.Wait().Get()
    if code != 0 {
        // Idempotency fallback. `git worktree add` exits non-zero in
        // a few "already exists" shapes — concurrent callers racing
        // through the isRegisteredWorktree check, or a stale ghost
        // entry git refuses to overwrite. Re-query: if the path IS
        // registered now, treat as success and hand back the path.
        // Only panic when we genuinely failed to land a worktree at
        // this location.
        if isRegisteredWorktree(proj, wtPath) {
            LogWorktreeCreate(m.Name, wtPath, branch)
            return wtPath
        }
        panic(s"git worktree add ${wtPath} exited with code ${code}")
    }
    LogWorktreeCreate(m.Name, wtPath, branch)
    return wtPath
})

// isRegisteredWorktree returns true iff `git worktree list --porcelain`
// includes `wtPath` as a registered worktree. The dir merely existing
// on disk is not enough — a stale dir from a `git worktree remove`
// failure or a manual `rm` of `.git/worktrees/<name>/gitdir` leaves
// untracked files that confuse engineers.
func isRegisteredWorktree(proj Project, wtPath string) bool {
    val opts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("worktree", "list", "--porcelain").ToGoSlice(),
        SliceEmpty[string](),
        proj.Repo,
    )
    val procTry = subprocess.Spawn(opts)
    if procTry.IsFailure() { return false }
    val proc = procTry.Get()
    var lines = EmptyArray[string]()
    var stopped = false
    for !stopped {
        val ln = proc.ReadLine()
        if ln.IsFailure() {
            stopped = true
        } else {
            lines = lines.Append(ln.Get())
        }
    }
    val _ = proc.Wait()
    val abs, absErr = filepath.Abs(wtPath)
    if absErr != nil { return false }
    val needle = "worktree " + filepath.ToSlash(abs)
    val needleAlt = "worktree " + abs
    return lines.Exists((l) => {
        val t = strings.TrimSpace(l)
        return t == needle || t == needleAlt ||
               strings.EqualFold(t, needle) ||
               strings.EqualFold(t, needleAlt)
    })
}

// RemoveWorktree drops the per-engineer worktree on shutdown so the
// repo doesn't accumulate stale checkouts. Best-effort: a failure
// here is informational, never fatal — the user can `git worktree
// prune` manually.
func RemoveWorktree(proj Project, m Member) Try[bool] = Try(() => {
    val wtPath = filepath.Join(proj.Repo, ".gala_team", "worktrees", m.Name)
    return removeWorktreeAt(proj, wtPath)
})

// RemoveLeadWorktree drops the lead's `_lead/` worktree on Start
// fresh / Ctrl+N so the next session starts from a freshly-created
// worktree forked off origin/<defaultBranch>. Best-effort, same
// shape as RemoveWorktree.
func RemoveLeadWorktree(proj Project) Try[bool] = Try(() => {
    return removeWorktreeAt(proj, LeadWorktreePath(proj))
})

func removeWorktreeAt(proj Project, wtPath string) bool {
    if !leadWtPathIsLiveDir(wtPath) { return true }  // already gone
    val opts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("worktree", "remove", "--force", wtPath).ToGoSlice(),
        SliceEmpty[string](),
        proj.Repo,
    )
    val proc = subprocess.Spawn(opts) match {
        case Success(p)   => p
        case Failure(err) => panic(s"git worktree remove ${wtPath}: ${err.Error()}")
    }
    val code = proc.Wait().Get()
    if code != 0 { panic(s"git worktree remove ${wtPath} exited with code ${code}") }
    return true
}

// PruneWorktrees runs `git worktree prune` to drop git's internal
// metadata for worktrees whose directories were removed out-of-band
// (e.g. via Start fresh's filesystem wipe, or an aborted prior run
// that left .git/worktrees/<name>/ ghosts behind). Without this,
// `git worktree list` keeps reporting `prunable` entries that confuse
// subsequent `git worktree add -B <branch> <path>` calls.
//
// Best-effort: failures are silently swallowed via Try[].
func PruneWorktrees(proj Project) Try[bool] = Try(() => {
    val opts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("worktree", "prune").ToGoSlice(),
        SliceEmpty[string](),
        proj.Repo,
    )
    val proc = subprocess.Spawn(opts) match {
        case Success(p)   => p
        case Failure(err) => panic(s"git worktree prune: ${err.Error()}")
    }
    val code = proc.Wait().Get()
    if code != 0 { panic(s"git worktree prune exited with code ${code}") }
    return true
})

// claudeArgs assembles the `claude` CLI flags for a spawn:
//   - `--print` always, so claude reads the prompt from stdin
//     and exits after responding instead of starting a TTY-bound
//     REPL. Without this, claude hangs on piped stdin.
//   - `--output-format stream-json` always, so the chunk pump can
//     walk member output line-by-line. claude requires
//     `--verbose` alongside it under `--print` (otherwise it
//     errors with "stream-json requires --verbose").
//   - `--verbose` always — required by `--print +
//     --output-format=stream-json`.
//   - `--model <name>` when m.Model is Some — pins the model.
//   - `--dangerously-skip-permissions` when the enclosing team
//     opted in via team.yaml. Off by default; turning it on is a
//     deliberate decision the user makes per-team.
//   - `--session-id <id>` on the first turn, `--resume <id>` on
//     subsequent turns. Per-member ids keep concurrent fan-outs
//     (Felix and Mira dispatched in parallel) from racing on
//     claude's implicit "most recent in cwd" `--continue`
//     semantics.
func claudeArgs(m Member, dangerouslySkipPermissions bool, sessionId string, isNewSession bool) Array[string] {
    // `--input-format stream-json` lets us pipe multiple JSON envelopes
    // (initial prompt + zero-or-more tool_result envelopes) to the
    // subprocess on a single stdin without closing it after the first
    // write. Required for AskUserQuestion handling: when the model
    // emits a tool_use, claude blocks on stdin waiting for the
    // matching tool_result; with the prior plain-text input mode there
    // was no way to satisfy that block, so the tool call was reported
    // back to the model as "user dismissed" and the question was lost
    // to the user. Now we keep stdin open for the duration of the
    // turn, forward the question to the UI, and write the tool_result
    // envelope back when the user answers.
    val base = ArrayOf(
        "--print",
        "--input-format", "stream-json",
        "--output-format", "stream-json",
        "--verbose",
    )
    val withModel = m.Model match {
        case Some(name) => base.AppendAll(ArrayOf("--model", name))
        case None()     => base
    }
    val withDanger = if (dangerouslySkipPermissions) withModel.Append("--dangerously-skip-permissions")
                     else                            withModel
    val sessionFlag = if (isNewSession) "--session-id" else "--resume"
    return withDanger.AppendAll(ArrayOf(sessionFlag, sessionId))
}

// ----------------------------------------------------------------------------
// Future builders
// ----------------------------------------------------------------------------

// NextChunkFuture schedules the next ReadLine on the session's stdout.
// Returns a Future that resolves to ChunkArrived (success), SessionFailed
// (any error including EOF — callers can match on Err to distinguish).
//
// EOF is treated as SessionFailed(io.EOF) so the orchestrator can
// transition the member's status to Done; matching on Err lets callers
// distinguish "stream done" from a real failure.
func NextChunkFuture(s MemberSession) concurrent.Future[Msg] {
    val name = s.Member.Name
    return concurrent.FutureApply[Msg](() => s.Process.ReadLine() match {
        case Success(line) => RtChunkArrived(Member = name, Line = line)
        case Failure(err)  => RtSessionFailed(Member = name, Err = err)
    })
}

// NextStderrFuture schedules the next ReadStderrLine on the session.
// Mirrors NextChunkFuture's shape but emits RtStderrArrived (or
// RtStderrEnded on EOF) so the orchestrator can surface auth /
// permission / install errors that claude only writes to stderr.
//
// stderr drain is best-effort — failures here don't terminate the
// member; the stdout side remains the authoritative liveness signal.
func NextStderrFuture(s MemberSession) concurrent.Future[Msg] {
    val name = s.Member.Name
    return concurrent.FutureApply[Msg](() => s.Process.ReadStderrLine() match {
        case Success(line) => RtStderrArrived(Member = name, Line = line)
        case Failure(_)    => RtStderrEnded(Member = name)
    })
}

// SendFuture writes the initial-turn user prompt to claude's stdin as
// a `{"type":"user","message":{"role":"user","content":"..."}}`
// envelope. Stdin is intentionally left OPEN — with
// `--input-format stream-json` claude reads additional envelopes (tool_result
// for AskUserQuestion, follow-up prompts) on the same stdin. Closing
// it would terminate the subprocess mid-turn the moment a tool_use
// block is emitted, which used to happen on every clarifying question.
//
// CloseSendFuture is the explicit close path, dispatched once the
// turn's `result` event lands (no more tool calls coming).
//
// Returns WriteSent on success, SessionFailed on a write error
// (rare; usually means claude already exited).
func SendFuture(s MemberSession, prompt string) concurrent.Future[Msg] {
    val name = s.Member.Name
    return concurrent.FutureApply[Msg](() => {
        val line = encodeUserPromptEnvelope(prompt)
        val w = s.Process.WriteLine(line)
        if w.IsFailure() {
            return RtSessionFailed(Member = name, Err = w.GetError())
        }
        return RtWriteSent(Member = name)
    })
}

// SendToolResultFuture writes a tool_result envelope to the session's
// stdin in response to a prior AskUserQuestion tool_use. `toolUseId`
// MUST exactly match the `id` from the assistant's tool_use block —
// claude joins them on this id and a mismatch makes the model see the
// tool call as unanswered. `answer` is the user's free-text response;
// claude accepts free-text content for AskUserQuestion fine.
//
// Stdin stays open after this write — claude continues the turn,
// streaming more assistant chunks and eventually a `result` event,
// after which the orchestrator closes stdin via CloseSendFuture.
func SendToolResultFuture(s MemberSession, toolUseId string, answer string) concurrent.Future[Msg] {
    val name = s.Member.Name
    return concurrent.FutureApply[Msg](() => {
        val line = encodeToolResultEnvelope(toolUseId, answer)
        val w = s.Process.WriteLine(line)
        if w.IsFailure() {
            return RtSessionFailed(Member = name, Err = w.GetError())
        }
        return RtWriteSent(Member = name)
    })
}

// CloseSendFuture sends EOF to the subprocess's stdin so it can
// gracefully shut down at the end of a turn. Dispatched from the
// onChunk handler when a `result` event lands — that's claude's
// "done with this turn" signal, after which the model has no more
// work to do until the next user prompt (which spawns a fresh
// --resume subprocess).
func CloseSendFuture(s MemberSession) concurrent.Future[Msg] {
    val name = s.Member.Name
    return concurrent.FutureApply[Msg](() => {
        val c = s.Process.CloseStdin()
        if c.IsFailure() {
            return RtSessionFailed(Member = name, Err = c.GetError())
        }
        return RtWriteSent(Member = name)
    })
}

// userPromptEnvelope is the stream-json shape for the first turn's
// prompt. `Role` is always "user"; `Content` is the prompt text.
struct userPromptEnvelope(
    Type    string,
    Message userPromptMessage,
)
struct userPromptMessage(
    Role    string,
    Content string,
)

// toolResultEnvelope is the stream-json shape for satisfying a prior
// tool_use. Wraps a tool_result content block in a user-role message.
// `Content` here is a list with exactly one tool_result entry.
struct toolResultEnvelope(
    Type    string,
    Message toolResultMessage,
)
struct toolResultMessage(
    Role    string,
    Content Array[toolResultBlock],
)
struct toolResultBlock(
    Type      string,
    ToolUseId string,
    Content   string,
    IsError   bool,
)

val userPromptCodec = json.Codec[userPromptEnvelope](json.SnakeCase())
val toolResultCodec = json.Codec[toolResultEnvelope](json.SnakeCase())

// EncodeUserPromptEnvelopeForTest is the exported test seam for the
// internal encodeUserPromptEnvelope — keeps the production caller path
// unchanged (private) while letting the test binary across packages
// assert on the wire format without re-deriving it.
func EncodeUserPromptEnvelopeForTest(prompt string) string = encodeUserPromptEnvelope(prompt)

// EncodeToolResultEnvelopeForTest mirrors EncodeUserPromptEnvelopeForTest
// for the tool_result envelope. Production callers use the in-package
// `encodeToolResultEnvelope`.
func EncodeToolResultEnvelopeForTest(toolUseId string, answer string) string = encodeToolResultEnvelope(toolUseId, answer)

// encodeUserPromptEnvelope builds the first-turn JSON envelope for
// `prompt`. Falls back to the raw prompt on encoder failure (defensive
// — the codec is a pure function over a tiny struct; failure would
// indicate a runtime bug, but we should not lose the turn for it).
func encodeUserPromptEnvelope(prompt string) string {
    val env = userPromptEnvelope(
        Type    = "user",
        Message = userPromptMessage(Role = "user", Content = prompt),
    )
    return userPromptCodec.Encode(env) match {
        case Success(s) => s
        case Failure(_) => prompt
    }
}

// encodeToolResultEnvelope builds the JSON envelope acknowledging the
// AskUserQuestion tool_use whose id is `toolUseId`. `answer` is
// rendered as the tool_result content (free-text — claude accepts it).
func encodeToolResultEnvelope(toolUseId string, answer string) string {
    val block = toolResultBlock(
        Type      = "tool_result",
        ToolUseId = toolUseId,
        Content   = answer,
        IsError   = false,
    )
    val env = toolResultEnvelope(
        Type    = "user",
        Message = toolResultMessage(Role = "user", Content = ArrayOf(block)),
    )
    return toolResultCodec.Encode(env) match {
        case Success(s) => s
        case Failure(_) => answer  // not ideal — caller will see no response from the model
    }
}

// ----------------------------------------------------------------------------
// Lifecycle
// ----------------------------------------------------------------------------

// CloseSession gracefully terminates a member's subprocess: kills it,
// then waits for the OS to reap it. The first failure short-circuits;
// the result is Success(true) only when both legs succeed.
func CloseSession(s MemberSession) Try[bool] =
    s.Process.Kill().FlatMap((_) => s.Process.Wait()).Map((_) => true)

// CloseAllSessions kills every live MemberSession in `sessions` and
// waits for the OS to reap each one. Returns an Array of (member
// name, error) tuples for the sessions that didn't close cleanly —
// empty array on the happy path.
//
// Used on shutdown (QuitMsg) so the spawned `claude` subprocesses
// don't outlive the TUI. Best-effort: a failed Kill on one member
// does not stop the other Kills from running.
func CloseAllSessions(sessions HashMap[string, MemberSession]) Array[Tuple[string, error]] =
    sessions.FoldLeftKV(EmptyArray[Tuple[string, error]](), (acc, name, sess) => CloseSession(sess) match {
        case Success(_)   => acc
        case Failure(err) => acc.Append((name, err))
    })

// MsgMember extracts the member name from any runtime Msg variant.
// PR / merge variants don't have a member; they return "" so callers
// can branch on that or pattern-match instead.
func MsgMember(msg Msg) string = msg match {
    case RtChunkArrived(name, _)    => name
    case RtSessionFailed(name, _)   => name
    case RtWriteSent(name)          => name
    case RtStderrArrived(name, _)   => name
    case RtStderrEnded(name)        => name
    case RtPrCreated(_, _)          => ""
    case RtPrFailed(_)              => ""
    case RtWorktreesWiped()         => ""
}

// ----------------------------------------------------------------------------
// Approval / PR creation
// ----------------------------------------------------------------------------

// GhPrCreateFuture spawns `gh pr create` from the lead worktree with
// the summary text as the PR body. The first line of `body` becomes the
// title (capped at 70 chars per gala-style rule), the rest goes into
// the body via the `--body` flag. `baseRef` is the branch the PR
// targets — None lets gh pick the project's default branch (the usual
// case); Some(ref) is set when the TL emitted an `@base <ref>`
// directive earlier in the turn (V2 stacking).
//
// `forceBranch` decides the PR snapshot branch name:
//   - None         → derive `gala_team/<project>/pr/<short-sha>` from
//                    the lead tip. Used for the FIRST PR of an
//                    iteration cycle (or after merge/Start-fresh).
//   - Some(branch) → reuse `branch` verbatim. Used after the user
//                    rejects a summary, gives feedback, the TL fixes
//                    it, and re-approves: pushing the new lead tip to
//                    the SAME branch makes GitHub auto-update the
//                    existing PR instead of cutting a new one.
//
// Returns RtPrCreated(url, branch) on success — `gh` prints the PR
// URL on its last stdout line, so we read until the stream closes and
// take the last non-empty line. The snapshot branch is also surfaced
// so the model can record it on the BatchPr entry; that's what later
// `@base previous` directives resolve against.
//
// If a PR already exists for the target branch (because the user is
// updating an existing PR with feedback, or a prior session opened
// it), we detect that BEFORE calling `gh pr create` and return the
// existing URL — `gh pr create` would otherwise fail with "a pull
// request for branch ... already exists" and leave the user without
// a clickable link.
//
// Returns RtPrFailed(err) on any spawn or non-zero exit. The user
// typically reads the URL from the conversation log then opens it in
// their browser; the alternative `gh pr view --web` would bypass the
// audit trail of "what summary did the team agree to".
func GhPrCreateFuture(proj Project, body string, baseRef Option[string], forceBranch Option[string] = None[string]()) concurrent.Future[Msg] {
    val title = GhTitle(body)
    val bodyWithFooter = body + "\n\n---\n🍎 orchestrated by [Gala Team](https://github.com/martianoff/gala-team)"
    val leadBranch = LeadBranchFor(proj)
    val leadWtPath = LeadWorktreePath(proj)
    return concurrent.FutureApply[Msg](() => {
        // Snapshot the lead branch's current tip onto a per-PR
        // branch. With `forceBranch` set we reuse the named branch
        // (the user is iterating on an existing PR — push updates
        // it). Otherwise we derive a fresh `gala_team/<project>/pr/<short-sha>`
        // so the first PR of a cycle gets its own identity.
        val sha = forceBranch match {
            case Some(_) => "skip"
            case None()  => readShortSha(leadWtPath, leadBranch)
        }
        if sha == "" {
            return RtPrFailed(Err = errors.New("could not resolve lead branch tip — is the branch present?"))
        }
        val prBranch = forceBranch match {
            case Some(b) => b
            case None()  => "gala_team/" + gitSlug(proj.Name) + "/pr/" + sha
        }
        val pushResult = pushSnapshotBranch(proj, leadBranch, prBranch)
        if pushResult != "" {
            return RtPrFailed(Err = errors.New(s"git push pr branch failed: ${pushResult}"))
        }
        // Existing-PR detection: before calling `gh pr create`, ask gh
        // whether an open PR already targets this branch. Two cases
        // hit this path:
        //   - The user is iterating on the active PR (forceBranch is
        //     Some — push above already landed the new commits, so
        //     the PR auto-updates; we just need its URL).
        //   - The branch SHA happened to collide with an earlier PR
        //     in this project (rare but possible after a revert or
        //     amend cycle).
        // Either way, surfacing the existing URL is what the user
        // wants — `gh pr create` would error with "a pull request for
        // branch ... already exists" and leave them stuck.
        val existing = lookupExistingPrUrl(leadWtPath, prBranch)
        if existing != "" {
            return RtPrCreated(Url = existing, Branch = prBranch)
        }
        val baseArgs = baseRef match {
            case None()    => EmptyArray[string]()
            case Some(ref) => ArrayOf("--base", ref)
        }
        val args = ArrayOf("pr", "create", "--head", prBranch, "--title", title, "--body", bodyWithFooter).AppendAll(baseArgs)
        val opts = subprocess.NewSpawnOpts(
            "gh",
            args.ToGoSlice(),
            SliceEmpty[string](),
            leadWtPath,
        )
        return subprocess.Spawn(opts) match {
            case Failure(err) => RtPrFailed(Err = err)
            case Success(p)   => readGhPrUrl(p, prBranch, leadWtPath)
        }
    })
}

// lookupExistingPrUrl asks gh for the URL of an open PR whose head is
// `branch`. Returns "" when no PR exists, when gh fails (auth missing,
// no remote, etc.), or when the JSON output is empty. Best-effort: a
// failure here just falls through to `gh pr create`, which surfaces
// any environmental errors with its own clearer messaging.
//
// Uses `gh pr list --json url --jq .[0].url` rather than `gh pr view
// --json url` because pr view picks the PR for the CURRENT branch and
// we may be querying a snapshot branch we just pushed but never
// checked out.
func lookupExistingPrUrl(cwd string, branch string) string {
    val opts = subprocess.NewSpawnOpts(
        "gh",
        ArrayOf("pr", "list", "--head", branch, "--state", "open", "--json", "url", "--jq", ".[0].url").ToGoSlice(),
        SliceEmpty[string](),
        cwd,
    )
    return subprocess.Spawn(opts) match {
        case Failure(_) => ""
        case Success(p) => {
            var lastLine = ""
            for {
                val line = p.ReadLine()
                if line.IsFailure() { break }
                val trimmed = strings.TrimSpace(line.Get())
                if trimmed != "" {
                    lastLine = trimmed
                }
            }
            // Drain stderr too so the subprocess doesn't block on a
            // full pipe; we don't need the contents.
            for {
                val line = p.ReadStderrLine()
                if line.IsFailure() { break }
            }
            return p.Wait() match {
                case Failure(_)  => ""
                case Success(_)  => lastLine
            }
        }
    }
}

// readShortSha runs `git rev-parse --short=10 <ref>` in `cwd` and
// returns the trimmed first line. Empty string on any failure
// (branch missing, git not installed). 10 chars is enough to be
// collision-free across a session's worth of commits while
// keeping the resulting branch name short enough to read.
func readShortSha(cwd string, ref string) string {
    val opts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("rev-parse", "--short=10", ref).ToGoSlice(),
        SliceEmpty[string](),
        cwd,
    )
    return subprocess.Spawn(opts) match {
        case Failure(_) => ""
        case Success(p) => {
            val line = p.ReadLine()
            val _ = p.Wait()
            line match {
                case Failure(_)  => ""
                case Success(s)  => strings.TrimSpace(s)
            }
        }
    }
}

// pushSnapshotBranch pushes `srcBranch`'s current commit to
// origin under the name `dstBranch`, replacing any prior content
// at that name. Used to materialize per-PR snapshot branches off
// the orchestrator's lead ref without touching lead itself on
// origin (lead stays a local-only working ref).
//
// Force-push semantics: the gala_team/<project>/pr/<sha>
// namespace is owned entirely by this orchestrator. No human
// commits there. Plain --force is appropriate; the SHA in the
// branch name means "same content → same dest", so re-pushing
// after a no-op rebuild is also safe.
func pushSnapshotBranch(proj Project, srcBranch string, dstBranch string) string {
    val refspec = srcBranch + ":refs/heads/" + dstBranch
    val opts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("push", "--force", "origin", refspec).ToGoSlice(),
        SliceEmpty[string](),
        LeadWorktreePath(proj),
    )
    return subprocess.Spawn(opts) match {
        case Failure(err) => err.Error()
        case Success(p)   => drainGitPushResult(p)
    }
}

// drainGitPushResult reads the push process to completion, capturing
// stderr (where git emits its progress + errors) and surfacing it
// only on a non-zero exit. git push prints "Everything up-to-date"
// or push counts to stderr even on success, so we don't surface
// stderr unless the exit code says it actually failed.
func drainGitPushResult(p subprocess.Process) string {
    for {
        val line = p.ReadLine()
        if line.IsFailure() { break }
    }
    var stderrAcc = EmptyArray[string]()
    for {
        val line = p.ReadStderrLine()
        if line.IsFailure() { break }
        val trimmed = strings.TrimSpace(line.Get())
        if trimmed != "" {
            stderrAcc = stderrAcc.Append(trimmed)
        }
    }
    return p.Wait() match {
        case Failure(err)  => err.Error()
        case Success(code) => {
            if code == 0 {
                return ""
            }
            val joined = stderrAcc.MkString(" | ")
            return s"exit ${code}: ${joined}"
        }
    }
}

// readGhPrUrl drains gh's stdout AND stderr, looking for the URL
// line on stdout (last non-empty stdout line) and capturing stderr
// in case gh fails. gh pr create writes the actual error reason
// (auth, no remote, branch not pushed, PR already exists, etc.)
// to stderr — without draining it we'd surface only "exited with
// code N" which leaves the user with no path to fix the failure.
//
// Drain order: stdout first (one line at a time), then stderr in
// bulk after Wait. The OS buffers small stderr writes, so reading
// stderr after stdout is drained keeps the code linear without
// risking deadlock for the size of output gh pr create produces
// (stderr is typically a few short lines).
func readGhPrUrl(p subprocess.Process, prBranch string, cwd string) Msg {
    var lastLine = ""
    for {
        val line = p.ReadLine()
        if line.IsFailure() { break }
        val trimmed = line.Get()
        if trimmed != "" {
            lastLine = trimmed
        }
    }
    var stderrAcc = EmptyArray[string]()
    for {
        val line = p.ReadStderrLine()
        if line.IsFailure() { break }
        val trimmed = strings.TrimSpace(line.Get())
        if trimmed != "" {
            stderrAcc = stderrAcc.Append(trimmed)
        }
    }
    val stderrJoined = stderrAcc.MkString(" | ")
    return p.Wait() match {
        case Failure(err)  => RtPrFailed(Err = err)
        case Success(code) =>
            if (code != 0) {
                // "a pull request for branch <X> already exists" race:
                // the pre-create lookup missed it (PR was opened
                // between our list and create call, or the user opened
                // it manually). Recover by surfacing the existing URL
                // instead of an opaque non-zero exit.
                if (stderrMentionsExistingPr(stderrJoined)) {
                    val existing = lookupExistingPrUrl(cwd, prBranch)
                    if (existing != "") {
                        return RtPrCreated(Url = existing, Branch = prBranch)
                    }
                }
                val detail = if (stderrJoined != "") s": ${stderrJoined}" else ""
                RtPrFailed(Err = errors.New(s"gh pr create exited with code ${code}${detail}"))
            }
            else if (lastLine == "") {
                val detail = if (stderrJoined != "") s": ${stderrJoined}" else ""
                RtPrFailed(Err = errors.New(s"gh pr create produced no output${detail}"))
            }
            else                     RtPrCreated(Url = lastLine, Branch = prBranch)
    }
}

// stderrMentionsExistingPr matches the gh CLI's "a pull request for
// branch ... already exists" error so we can recover by fetching the
// existing PR's URL instead of failing the whole approval. gh phrases
// this consistently across versions; we match on the stable substring
// "already exists" qualified by "pull request" so we don't false-match
// unrelated errors.
func stderrMentionsExistingPr(stderr string) bool {
    val lower = strings.ToLower(stderr)
    return strings.Contains(lower, "pull request") && strings.Contains(lower, "already exists")
}

// Merge is intentionally not performed by the app. After `gh pr
// create` opens the PR, the user reviews and merges it on GitHub —
// the orchestrator never shells `gh pr merge`. (No GhPrMergeFuture /
// mergeFlag / awaitMergeExit; policy.merge_rule stays declarative for
// documentation only.)

// ghTitle picks the first non-empty line of `body` and clamps it to 70
// chars (with an ellipsis when truncated) for use as the PR title.
// strings.SplitN returns a Go []string at the interop boundary so we
// rebuild as an Array for GALA-side access.
// GhTitle derives a PR title from `body`. GitHub renders titles as
// plain text (no markdown), so we strip the markdown emphasis
// markers a TL summary typically opens with (`**`, `__`, surrounding
// backticks). The result is capped at 70 characters AT A WORD
// BOUNDARY so titles don't end mid-word like
// "**Crypto MVP — hash functions only. Lead is now 3 commits ahead of ...".
//
// Title source is the first non-empty line of the body — TL
// @summary blocks conventionally start with a one-line headline.
//
// Exported (capitalized) so external tests in app/runtime can
// exercise it directly without an internal-test build.
func GhTitle(body string) string {
    val firstLine = firstNonEmptyLine(body)
    val cleaned = stripTitleMarkdown(firstLine)
    return capTitleAtWordBoundary(cleaned, 70)
}

// firstNonEmptyLine returns the first line of `body` that has
// non-whitespace content. Falls back to "Untitled" when every line
// is empty (defensive — TL summaries should never be blank, but
// avoid producing a literal empty PR title).
func firstNonEmptyLine(body string) string =
    strings.Split(body, "\n")
        .Map((ln) => strings.TrimSpace(ln))
        .Find((s) => s != "")
        .GetOrElse("Untitled")

// stripTitleMarkdown removes the markdown emphasis markers a
// TL summary typically wraps its headline in: leading/trailing
// `**` (bold), `__` (bold), `*` / `_` (italic), and surrounding
// backticks. Inner markdown is left alone — collapsing every
// `**word**` mid-string would mangle technical terms.
func stripTitleMarkdown(s string) string {
    var out = strings.TrimSpace(s)
    // Repeatedly strip wrapping pairs so `**__foo__**` collapses
    // cleanly. Each iteration strips at most one pair from each
    // end; loop until no change.
    var changed = true
    for changed {
        changed = false
        out = strings.TrimSpace(out)
        if strings.HasPrefix(out, "**") && strings.HasSuffix(out, "**") && len(out) >= 4 {
            out = stripWrap(out, 2)
            changed = true
        } else if strings.HasPrefix(out, "__") && strings.HasSuffix(out, "__") && len(out) >= 4 {
            out = stripWrap(out, 2)
            changed = true
        } else if strings.HasPrefix(out, "`") && strings.HasSuffix(out, "`") && len(out) >= 2 {
            out = stripWrap(out, 1)
            changed = true
        } else if strings.HasPrefix(out, "*") && strings.HasSuffix(out, "*") && len(out) >= 2 && !strings.HasPrefix(out, "**") {
            out = stripWrap(out, 1)
            changed = true
        } else if strings.HasPrefix(out, "_") && strings.HasSuffix(out, "_") && len(out) >= 2 && !strings.HasPrefix(out, "__") {
            out = stripWrap(out, 1)
            changed = true
        }
    }
    return out
}

// stripWrap removes `n` runes from each end of `s`. Caller must
// ensure len(s) >= 2*n (enforced by stripTitleMarkdown's len
// guards). Used only for symmetric markdown-emphasis stripping;
// kept narrow rather than exposing a generic substring helper.
func stripWrap(s string, n int) string {
    val rs = ToRunes(s)
    val total = len(rs)
    val keep = total - 2 * n
    if keep <= 0 { return "" }
    val tail = SliceFrom(rs, n)
    val window = SliceTo(tail, keep)
    return string(window)
}

// capTitleAtWordBoundary truncates `s` to at most `cap` BYTES (when
// content is ASCII), rolling back to the most recent space within
// ~10 chars of the hard limit so titles don't end mid-word.
// Appends "..." (3 ASCII chars) when truncation happens. Using
// ASCII dots — not the single "…" rune — keeps byte length
// predictable: PR title byte budgets matter (some hosts impose
// 256-byte limits) and "…" is 3 bytes in UTF-8, which would push
// the total over the cap if we naïvely subtracted 1.
//
// Loop bound is `i >= rollbackFloor` (inclusive). The earlier
// strict-greater form missed the floor position itself — a real
// PR (#336) lost its "in `subprocess`" boundary because the space
// happened to sit exactly at `hardLimit - 10` and was never
// checked, falling through to a mid-word cut inside backticks.
func capTitleAtWordBoundary(s string, cap int) string {
    val rs = ToRunes(s)
    if len(rs) <= cap { return s }
    // Reserve 3 chars for "...".
    val hardLimit = cap - 3
    var cutAt = hardLimit
    var i = hardLimit
    val rollbackFloor = if (hardLimit > 10) hardLimit - 10 else 0
    var foundSpace = false
    for i >= rollbackFloor && !foundSpace {
        val c = rs[i]
        if c == ' ' || c == '\t' {
            cutAt = i
            foundSpace = true
        }
        i = i - 1
    }
    val tail = SliceTo(rs, cutAt)
    return string(tail) + "..."
}
