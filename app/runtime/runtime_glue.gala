package runtime

import (
    "errors"
    "strings"
    "martianoff/gala/subprocess"
    "martianoff/gala/concurrent"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/go_interop"
    . "github.com/martianoff/gala_team/app/team"
    . "github.com/martianoff/gala_team/app/project"
)

// ============================================================================
// app/runtime — bridges the pure FSM (app/fsm) to actual `claude` CLI
// subprocesses via concurrent.Future[Msg].
//
// This package depends only on gala stdlib (subprocess + concurrent) plus
// our own team / project types — explicitly NOT on gala_tui.  The Future
// values returned here can be wrapped into gala_tui's FutureCmd by a
// thin UI layer (added when wiring the TUI).  Keeping that boundary
// clean means runtime is testable in isolation and could later host an
// alternative TUI / CLI front end without changes here.
//
// Reads are a self-perpetuating pump: each NextChunk Future completion
// dispatches a ChunkArrived through the consumer's update loop, which
// schedules another NextChunk. One in-flight Future[Msg] per active
// member.
// ============================================================================

// Msg is the runtime side of the gala_team event vocabulary.  Cases here
// are the things subprocess interactions produce; the full app Msg sealed
// type folds these in alongside keyboard / mouse / tick events. Names
// are prefixed `Rt` so they don't collide with the lifted versions in
// app/ui.AppMsg when both are dot-imported in the same file.
sealed type Msg {
    case RtChunkArrived(Member string, Line string)
    case RtSessionFailed(Member string, Err error)
    case RtWriteSent(Member string)
    case RtPrCreated(Url string)
    case RtPrFailed(Err error)
}

// MemberSession pairs a Member with the live subprocess driving them.
struct MemberSession(
    Member  Member,
    Process subprocess.Process,
)

// ----------------------------------------------------------------------------
// Spawning
// ----------------------------------------------------------------------------

// SpawnSession launches a `claude` CLI process for `m` inside `proj.Repo`,
// optionally pinned to `m.Model` if set.  Returns Try[MemberSession];
// failure carries the underlying spawn error.
func SpawnSession(proj Project, m Member) Try[MemberSession] {
    val opts = subprocess.NewSpawnOpts(
        "claude",
        claudeArgs(m).ToGoSlice(),
        SliceEmpty[string](),
        proj.Repo,
    )
    return subprocess.Spawn(opts).Map((p) => MemberSession(Member = m, Process = p))
}

// claudeArgs assembles the standard `claude` CLI flags. We always use
// stream-json so the FieldDecoder parser can walk chunks line-by-line.
func claudeArgs(m Member) Array[string] {
    val base = ArrayOf("--output-format", "stream-json")
    return m.Model match {
        case Some(name) => base.AppendAll(ArrayOf("--model", name))
        case None()     => base
    }
}

// ----------------------------------------------------------------------------
// Future builders
// ----------------------------------------------------------------------------

// NextChunkFuture schedules the next ReadLine on the session's stdout.
// Returns a Future that resolves to ChunkArrived (success), SessionFailed
// (any error including EOF — callers can match on Err to distinguish).
//
// EOF is treated as SessionFailed(io.EOF) so the orchestrator can
// transition the member's status to Done; matching on Err lets callers
// distinguish "stream done" from a real failure.
func NextChunkFuture(s MemberSession) concurrent.Future[Msg] {
    val name = s.Member.Name
    return concurrent.FutureApply[Msg](() => s.Process.ReadLine() match {
        case Success(line) => RtChunkArrived(Member = name, Line = line)
        case Failure(err)  => RtSessionFailed(Member = name, Err = err)
    })
}

// SendFuture writes `prompt` + "\n" to the session's stdin and returns
// a Future that resolves to WriteSent (success) or SessionFailed
// (write error — usually means the child closed stdin or exited).
func SendFuture(s MemberSession, prompt string) concurrent.Future[Msg] {
    val name = s.Member.Name
    return concurrent.FutureApply[Msg](() => s.Process.WriteLine(prompt) match {
        case Success(_)   => RtWriteSent(Member = name)
        case Failure(err) => RtSessionFailed(Member = name, Err = err)
    })
}

// ----------------------------------------------------------------------------
// Lifecycle
// ----------------------------------------------------------------------------

// CloseSession gracefully terminates a member's subprocess: kills it, then
// waits for the OS to reap it. The first failure short-circuits and the
// result is Success(true) only when both legs succeed.
//
// Plain Try.FlatMap(_).Map((_) => true) lowers correctly upstream
// (examples/try_chain_typeparam_repro), but when Process is a struct
// imported from another package (here martianoff/gala/subprocess) the
// inner Map's Try[bool] type still gets erased to bare Try in the
// emitted closure. Tracked separately; the match-nested shape
// produces correct Go either way.
func CloseSession(s MemberSession) Try[bool] = s.Process.Kill() match {
    case Failure(err) => Failure[bool](err)
    case Success(_)   => s.Process.Wait() match {
        case Failure(err) => Failure[bool](err)
        case Success(_)   => Success[bool](true)
    }
}

// MsgMember extracts the member name from any runtime Msg variant.
// PR-related variants don't have a member; they return "" so callers
// can branch on that or pattern-match instead.
func MsgMember(msg Msg) string = msg match {
    case RtChunkArrived(name, _)    => name
    case RtSessionFailed(name, _)   => name
    case RtWriteSent(name)          => name
    case RtPrCreated(_)             => ""
    case RtPrFailed(_)              => ""
}

// ----------------------------------------------------------------------------
// Approval / PR creation
// ----------------------------------------------------------------------------

// GhPrCreateFuture spawns `gh pr create` against `proj.Repo` with the
// summary text as the PR body. The first line of `body` becomes the
// title (capped at 70 chars per gala-style rule), the rest goes into
// the body via the `--body` flag.
//
// Returns RtPrCreated(url) on success — `gh` prints the PR URL on its
// last stdout line, so we read until the stream closes and take the
// last non-empty line. Returns RtPrFailed(err) on any spawn or non-zero
// exit. The user typically reads the URL from the conversation log
// then opens it in their browser; alternative would be to launch the
// browser directly via `gh pr view --web` but that bypasses the audit
// trail of "what summary did the team agree to".
func GhPrCreateFuture(proj Project, body string) concurrent.Future[Msg] {
    val title = ghTitle(body)
    val args = ArrayOf("pr", "create", "--title", title, "--body", body)
    return concurrent.FutureApply[Msg](() => {
        val opts = subprocess.NewSpawnOpts(
            "gh",
            args.ToGoSlice(),
            SliceEmpty[string](),
            proj.Repo,
        )
        return subprocess.Spawn(opts) match {
            case Failure(err) => RtPrFailed(Err = err)
            case Success(p)   => readGhPrUrl(p)
        }
    })
}

// readGhPrUrl drains gh's stdout, looking for the URL line. `gh pr
// create` prints assorted status to stderr and the final PR URL on
// stdout; the URL is the last non-empty stdout line.
func readGhPrUrl(p subprocess.Process) Msg {
    var lastLine = ""
    for {
        val line = p.ReadLine()
        if line.IsFailure() { break }
        val trimmed = line.Get()
        if trimmed != "" {
            lastLine = trimmed
        }
    }
    return p.Wait() match {
        case Failure(err)  => RtPrFailed(Err = err)
        case Success(code) =>
            if (code != 0)           RtPrFailed(Err = errors.New(s"gh pr create exited with code ${code}"))
            else if (lastLine == "") RtPrFailed(Err = errors.New("gh pr create produced no output"))
            else                     RtPrCreated(Url = lastLine)
    }
}

// ghTitle picks the first non-empty line of `body` and clamps it to 70
// chars (with an ellipsis when truncated) for use as the PR title.
// strings.SplitN returns a Go []string at the interop boundary so we
// rebuild as an Array for GALA-side access.
func ghTitle(body string) string {
    val parts = ArrayOf(strings.SplitN(body, "\n", 2)...)
    val firstLine = parts.HeadOption().GetOrElse("")
    val trimmed = strings.TrimSpace(firstLine)
    return if (len(trimmed) <= 70) trimmed
           else                    string(SliceTo(ToRunes(trimmed), 67)) + "..."
}
