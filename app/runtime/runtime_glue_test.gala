package runtime

import (
    "errors"
    "os"
    "strings"
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/go_interop"
    "martianoff/gala/subprocess"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/team"
)

// runtime_glue's surface is mostly Cmd[Msg] builders that wrap subprocess
// IO — those are exercised end-to-end against the real `claude` CLI when
// cmd/main.gala wires the full TUI loop.  These unit tests just lock in
// the Msg sealed type's shape so refactors don't silently break callers.

func TestMsg_RtChunkArrived_Construction(t T) T {
    val msg = RtChunkArrived(Member = "Felix", Line = "{\"type\":\"text\"}")
    return msg match {
        case RtChunkArrived(name, line) => {
            val t1 = Eq(t, name, "Felix")
            return Eq(t1, line, "{\"type\":\"text\"}")
        }
        case _ => IsTrue(t, false)
    }
}

func TestMsg_RtSessionFailed_Construction(t T) T {
    val err = errors.New("spawn failed")
    val msg = RtSessionFailed(Member = "Iris", Err = err)
    return msg match {
        case RtSessionFailed(name, e) => {
            val t1 = Eq(t, name, "Iris")
            return Eq(t1, e.Error(), "spawn failed")
        }
        case _ => IsTrue(t, false)
    }
}

func TestMsg_RtWriteSent_Construction(t T) T {
    val msg = RtWriteSent(Member = "Theo")
    return msg match {
        case RtWriteSent(name) => Eq(t, name, "Theo")
        case _                 => IsTrue(t, false)
    }
}

func TestMsgMember_AcrossAllVariants(t T) T {
    val t1 = Eq(t,  MsgMember(RtChunkArrived(Member = "A", Line = "x")),   "A")
    val t2 = Eq(t1, MsgMember(RtWriteSent(Member = "B")),                  "B")
    return       Eq(t2, MsgMember(RtSessionFailed(Member = "C", Err = errors.New("e"))), "C")
}

// PR-related variants don't carry a member name; MsgMember returns ""
// so callers can pattern-match on emptiness or pivot to RtPrCreated /
// RtPrFailed directly.
func TestMsgMember_PrVariantsHaveNoMember(t T) T {
    val t1 = Eq(t,  MsgMember(RtPrCreated(Url = "https://x/y/pull/1", Branch = "gala_team/x/pr/aaa1")), "")
    return       Eq(t1, MsgMember(RtPrFailed(Err = errors.New("auth"))), "")
}

func TestMsg_RtPrCreated_Construction(t T) T {
    val msg = RtPrCreated(Url = "https://github.com/x/y/pull/42", Branch = "gala_team/x/pr/snap42")
    return msg match {
        case RtPrCreated(url, branch) => {
            val a = Eq(t, url, "https://github.com/x/y/pull/42")
            return Eq(a, branch, "gala_team/x/pr/snap42")
        }
        case _ => IsTrue(t, false)
    }
}

func TestMsg_RtPrFailed_Construction(t T) T {
    val err = errors.New("not authenticated")
    val msg = RtPrFailed(Err = err)
    return msg match {
        case RtPrFailed(e) => Eq(t, e.Error(), "not authenticated")
        case _             => IsTrue(t, false)
    }
}

// Branch-name slugification: "Default Project" must NOT produce a
// branch ref containing a space (git rejects that). Regression test
// for the live bug that caused `git worktree add` to exit 255 on
// fresh sessions where the user hadn't supplied --project-name.
func TestWorktreeBranchFor_SlugifiesSpaces(t T) T {
    val proj = Project(
        Name = "Default Project",
        Repo = "/tmp/whatever",
        Github = None[string](),
        DefaultBranch = "main",
    )
    val mem = Member(
        Name = "Felix", Role = Engineer(),
        Personality = "", Model = None[string](),
        Extra = "", Onboarding = EmptyArray[string](),
    )
    val branch = WorktreeBranchFor(proj, mem)
    return Eq(t, branch, "gala_team/default-project/Felix")
}

func TestLeadBranchFor_SlugifiesSpaces(t T) T {
    val proj = Project(
        Name = "Default Project",
        Repo = "/tmp/whatever",
        Github = None[string](),
        DefaultBranch = "main",
    )
    return Eq(t, LeadBranchFor(proj), "gala_team/default-project/lead")
}

// Plain ASCII project names pass through untouched (lower-cased).
func TestLeadBranchFor_AlphaNumPassthrough(t T) T {
    val proj = Project(
        Name = "Skunkworks", Repo = "/x",
        Github = None[string](), DefaultBranch = "main",
    )
    return Eq(t, LeadBranchFor(proj), "gala_team/skunkworks/lead")
}

// Lead worktree path matches the per-engineer convention with the
// `_lead` reserved name. Underscore prefix keeps it distinct from
// any team member named "lead" and sorts at the top of directory
// listings.
func TestLeadWorktreePath_PerProjectConvention(t T) T {
    val proj = Project(
        Name = "Default Project",
        Repo = "/repo",
        Github = None[string](),
        DefaultBranch = "main",
    )
    val path = LeadWorktreePath(proj)
    return IsTrue(t, strings.HasSuffix(path, ".gala_team/worktrees/_lead") ||
                     strings.HasSuffix(path, ".gala_team\\worktrees\\_lead"))
}

// Fallback contract: when proj.Repo isn't a git repo, EnsureLeadWorktree
// returns the bare repo path instead of failing. Production always
// passes a real git repo; this fallback keeps test fixtures (and any
// degenerate non-VCS workspace) working without a panic. Without it,
// any test that exercised the TL spawn path against a temp-dir project
// would fail at git worktree add.
func TestEnsureLeadWorktree_FallsBackForNonGitDir(t T) T {
    val dir, err = os.MkdirTemp("", "gala_team_lead_wt_fallback_")
    if err != nil { return IsTrue(t, false) }
    defer os.RemoveAll(dir)
    val proj = Project(
        Name = "demo", Repo = dir,
        Github = None[string](),
        DefaultBranch = "main",
    )
    val result = EnsureLeadWorktree(proj)
    return result match {
        case Success(path) => Eq(t, path, dir)  // fell back to proj.Repo
        case Failure(_)    => IsTrue(t, false)
    }
}

// Real git repo: EnsureLeadWorktree creates the worktree on first
// call, returns the same path on subsequent calls (idempotent), and
// the returned path is a registered git worktree.
func TestEnsureLeadWorktree_CreatesAndIsIdempotent(t T) T {
    val dir, err = os.MkdirTemp("", "gala_team_lead_wt_create_")
    if err != nil { return IsTrue(t, false) }
    defer os.RemoveAll(dir)
    runGitInDir(dir, ArrayOf("init", "-q", "-b", "main"))
    runGitInDir(dir, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                              "commit", "--allow-empty", "-q", "-m", "init"))
    val proj = Project(
        Name = "demo", Repo = dir,
        Github = None[string](),
        DefaultBranch = "main",
    )
    val firstPath = EnsureLeadWorktree(proj) match {
        case Success(p) => p
        case Failure(_) => ""
    }
    if firstPath == "" { return IsTrue(t, false) }
    val secondPath = EnsureLeadWorktree(proj) match {
        case Success(p) => p
        case Failure(_) => ""
    }
    if secondPath == "" { return IsTrue(t, false) }
    val a = Eq(t, firstPath, secondPath)
    return IsTrue(a, strings.HasSuffix(firstPath, "_lead"))
}

// Helper: runs a git command in `dir`. Used by lead-worktree tests to
// stand up a real git fixture without dragging in the git-fixture
// helpers that only live in the ui package.
func runGitInDir(dir string, args Array[string]) {
    val opts = subprocess.NewSpawnOpts(
        "git",
        args.ToGoSlice(),
        SliceEmpty[string](),
        dir,
    )
    val proc = subprocess.Spawn(opts)
    proc match {
        case Success(p) => { val _ = p.Wait() }
        case Failure(_) => {}
    }
}

// ----------------------------------------------------------------------------
// ghTitle — derive a clean PR title from a TL @summary body
// ----------------------------------------------------------------------------

// Markdown bold wrap (`**foo**`) must be stripped from the title.
// GitHub renders titles as plain text, so leaving the asterisks
// produces "**Crypto MVP — hash...**" verbatim. A past regression
// that triggered this fix.
func TestGhTitle_StripsBoldWrap(t T) T {
    return Eq(t, GhTitle("**Crypto MVP shipped**"), "Crypto MVP shipped")
}

// Italic wrap (`_foo_`, `*foo*`) and code wrap (`` `foo` ``) get
// the same treatment.
func TestGhTitle_StripsItalicAndCode(t T) T {
    val t1 = Eq(t, GhTitle("_release notes_"), "release notes")
    val t2 = Eq(t1, GhTitle("`bazel build //...`"), "bazel build //...")
    return Eq(t2, GhTitle("*lower italic*"), "lower italic")
}

// Nested wrappers (`**__foo__**`) collapse cleanly — the loop
// strips one pair per iteration until none remain.
func TestGhTitle_StripsNestedWraps(t T) T {
    return Eq(t, GhTitle("**__double bold__**"), "double bold")
}

// Inner markdown (`shipped **crypto** package`) is NOT stripped —
// only wrapping pairs at the very ends. Collapsing inner asterisks
// would mangle technical terms.
func TestGhTitle_PreservesInnerMarkdown(t T) T {
    return Eq(t, GhTitle("Shipped **crypto** package"), "Shipped **crypto** package")
}

// Long titles must cap at a word boundary, NOT mid-word. The
// earlier code truncated to "...Lead is now 3 commits ahead of ..."
// which is
// readable but the original cut at exactly 67 chars sometimes
// landed mid-word.
func TestGhTitle_CapsAtWordBoundary(t T) T {
    val long = "Crypto MVP hash functions only and lead is now three commits ahead of master with full integration test coverage"
    val title = GhTitle(long)
    val t1 = IsTrue(t, len(title) <= 70)
    val t2 = IsTrue(t1, strings.HasSuffix(title, "..."))
    // Must end with a complete word + ellipsis, not a partial word.
    val withoutEllipsis = strings.TrimSuffix(title, "...")
    val trimmed = strings.TrimSpace(withoutEllipsis)
    return IsTrue(t2, !strings.HasSuffix(trimmed, "func") && !strings.HasSuffix(trimmed, "comm"))
}

// Short titles (≤70 chars) pass through unchanged with no
// ellipsis appended.
func TestGhTitle_ShortTitlePassthrough(t T) T {
    val title = GhTitle("fix(crypto): handle empty Bytes input")
    return Eq(t, title, "fix(crypto): handle empty Bytes input")
}

// Regression for PR #336: the rollback-floor was checked with
// strict-greater, missing the floor position itself. A space that
// happened to sit at exactly hardLimit - 10 was never seen, and
// the algorithm fell through to a mid-word cut. The exact input
// below produced the title
// `Replace panic-driven failure with explicit Try returns in `subproce...`
// — mid-word inside an unclosed backtick. Inclusive bound (i >=
// rollbackFloor) catches the boundary space and cuts cleanly at
// "in...".
func TestGhTitle_RollbackFloorIsInclusive(t T) T {
    val body = "Replace panic-driven failure with explicit Try returns in `subprocess` and `crypto.RandomBytes`."
    val title = GhTitle(body)
    val t1 = IsTrue(t, len(title) <= 70)
    // Must NOT cut mid-word inside the backticks — the regression
    // shape is `subproce` (and similar truncated tokens).
    val t2 = IsFalse(t1, strings.Contains(title, "subproce..."))
    val t3 = IsFalse(t2, strings.Contains(title, "subproc..."))
    // Should end at a real word boundary. "in..." is the natural
    // stop for the inclusive-floor algorithm on this input.
    return IsTrue(t3, strings.HasSuffix(title, "in..."))
}

// First-line extraction skips leading blank lines (TL summaries
// occasionally start with whitespace before the headline).
func TestGhTitle_SkipsLeadingBlankLines(t T) T {
    return Eq(t, GhTitle("\n\n  \n**Real headline**\nbody starts here"),
              "Real headline")
}

// Empty / whitespace-only body falls back to "Untitled" so we
// never produce a literal empty PR title.
func TestGhTitle_EmptyBodyFallsBackToUntitled(t T) T {
    val t1 = Eq(t, GhTitle(""), "Untitled")
    return Eq(t1, GhTitle("\n  \n  \n"), "Untitled")
}

// Regression test for a real-world body that previously produced
// the "**Crypto MVP — hash functions only. Lead is now 3 commits
// ahead of ..." title. After fix: stripped + word-boundary cap.
func TestGhTitle_BoldWrapAndLongTitleRegression(t T) T {
    val body = "**Crypto MVP — hash functions only. Lead is now 3 commits ahead of master.**\n```\n99a2ad1 feat..."
    val title = GhTitle(body)
    val t1 = IsTrue(t, !strings.Contains(title, "**"))
    val t2 = IsTrue(t1, len(title) <= 70)
    val t3 = IsTrue(t2, strings.HasPrefix(title, "Crypto MVP"))
    return t3
}

