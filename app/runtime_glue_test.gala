package main

import (
    "errors"
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "github.com/martianoff/gala_team/app"
)

// runtime_glue's surface is mostly Cmd[Msg] builders that wrap subprocess
// IO — those are exercised end-to-end against the real `claude` CLI when
// cmd/main.gala wires the full TUI loop in the next commit.  These unit
// tests just lock in the Msg sealed type's shape so refactors don't
// silently break callers.

func TestMsg_ChunkArrived_Construction(t T) T {
    val msg = ChunkArrived(Member = "Felix", Line = "{\"type\":\"text\"}")
    return msg match {
        case ChunkArrived(name, line) => {
            val t1 = Eq(t, name, "Felix")
            return Eq(t1, line, "{\"type\":\"text\"}")
        }
        case _ => IsTrue(t, false)
    }
}

func TestMsg_SessionFailed_Construction(t T) T {
    val err = errors.New("spawn failed")
    val msg = SessionFailed(Member = "Iris", Err = err)
    return msg match {
        case SessionFailed(name, e) => {
            val t1 = Eq(t, name, "Iris")
            return Eq(t1, e.Error(), "spawn failed")
        }
        case _ => IsTrue(t, false)
    }
}

func TestMsg_WriteSent_Construction(t T) T {
    val msg = WriteSent(Member = "Theo")
    return msg match {
        case WriteSent(name) => Eq(t, name, "Theo")
        case _               => IsTrue(t, false)
    }
}

func TestMsgMember_AcrossAllVariants(t T) T {
    val t1 = Eq(t,  MsgMember(ChunkArrived(Member = "A", Line = "x")),   "A")
    val t2 = Eq(t1, MsgMember(WriteSent(Member = "B")),                  "B")
    return       Eq(t2, MsgMember(SessionFailed(Member = "C", Err = errors.New("e"))), "C")
}
