package session

import (
    "martianoff/gala/go_builtins"
    "os"
    "path/filepath"
    "time"
    "martianoff/gala/fs"
    "martianoff/gala/json"
    "martianoff/gala/strings"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
)

// ============================================================================
// app/session — durable per-project conversation log.
//
// Every time the user sees a chunk arrive, the new conversation log is
// JSON-serialized to <project repo>/.gala_team/sessions/latest.json. On
// startup, cmd/main.gala reads that file (if present) and primes the
// AppModel's Conversation field so the user sees their prior context
// without re-prompting.
//
// Serialized: the conversation log, project name, saved-at timestamp,
// per-member claude session ids, and the orchestration state (FSM
// position, @plan queue, open PRs, pending AskUserQuestion). Resuming
// mid-flight is no longer "start Idle and hope" — app/ui rebuilds the
// exact AppState and auto-respawns any in-flight members against their
// persisted claude session. We still do NOT serialize:
//   - live subprocess handles (not portable; members are respawned)
//   - workflow / team config (re-read from team.yaml on every launch)
//
// ConversationLine lives here rather than in app/ui so app/ui can depend
// on session (and not the other way around) — saves the type from being
// duplicated and keeps app/session self-contained for the cmd-side load.
// ============================================================================

// ConversationLine is a single rendered turn in the Team-Lead conversation
// log: who spoke (the user, or a member name) and the text they produced.
//
// `At` is the unix-nano timestamp when the line was appended. Defaults
// to 0 so legacy snapshots (pre-timestamp) load cleanly; the activity
// view treats zero as "no timestamp" and omits the prefix. New entries
// stamped via `time_utils.Now().UnixNanos()` at append time.
//
// `Undelivered` marks a line whose content never reached the model it
// was meant for (e.g. an answer to an AskUserQuestion that couldn't be
// re-delivered because the member's session was gone and the respawn
// failed). Defaults to false so the codec's zero value on legacy
// snapshots reads as "delivered" — only an explicit true means "this
// was dropped". The view renders these with a warning highlight so a
// silently-lost message is impossible to miss.
// `Pending` marks a user line shown in the UI but not yet delivered to
// the (about-to-be-spawned) team lead. onSubmit paints the line
// immediately with Pending=true, then kills the prior subprocess and
// spawns the new one off-thread; onLeadSpawned clears the flag once the
// prompt is actually sent. The view shows a "(sending…)" hint while
// Pending. Defaults false; cleared on snapshot load so a crash mid-send
// never leaves a permanently-pending line.
struct ConversationLine(Speaker string, Text string, At int64 = int64(0), Undelivered bool = false, Pending bool = false)

// ClearPending flips every Pending line back to delivered. Applied on
// snapshot load so a crash mid-send never restores a permanently
// "(sending…)" line — the subprocess that would have cleared it is gone.
func ClearPending(convo Array[ConversationLine]) Array[ConversationLine] =
    convo.Map((cl ConversationLine) =>
        if (cl.Pending) ConversationLine(Speaker = cl.Speaker, Text = cl.Text, At = cl.At, Undelivered = cl.Undelivered, Pending = false)
        else cl)

// SessionIdEntry pairs a member name with the persisted claude session
// UUID. Stored as an array (not a HashMap) so the JSON codec handles
// it cleanly — gala's codec has a stable encoding for `Array[T]` of
// struct values; HashMap-of-strings is also supported but the
// per-entry shape here makes the on-disk format easier to inspect by
// hand.
struct SessionIdEntry(Member string, SessionId string)

// SnapPr is the on-disk shape of one AppModel.OpenPrs entry. BatchPr
// carries an `Instant` (OpenedAt) which isn't a codec-stable scalar,
// so it's flattened to unix-nanos here and rebuilt on load — the same
// "flatten for codec round-tripping" rationale as SessionIdEntry.
struct SnapPr(
    Url           string,
    Branch        string,
    Title         string,
    OpenedAtNanos int64,
)

// Snapshot is the on-disk shape. ProjectName is informational (lets us
// detect cross-project mismatches later); SavedAt is unix nanos at the
// moment Save was called.
//
// ActiveMembers carries the names of every team member whose Claude
// CLI subprocess was alive when the save happened. The recovery flow
// uses this list to spawn those members with `--continue` so Claude
// picks up its prior in-process conversation instead of starting a
// fresh session.
//
// SessionIds is the per-member claude session UUID map (flattened to
// an array for codec round-tripping). On the next launch,
// `primeFromSnapshot` restores these into AppModel.SessionIds so the
// first `ensureSession` for each member spawns claude with
// `--resume <id>` (loading the prior conversation from claude's own
// session storage) instead of `--session-id <new>` (a fresh session
// with no context). Without this the TL sees a brand-new claude
// process on every relaunch and loses the conversation thread —
// observed as "fresh session, clean worktree, no in-flight work I can
// see" in audit logs even though the user clearly resumed.
//
// Defaulted to empty so legacy snapshots (saved before this field
// existed) decode cleanly — gala's codec fills missing fields with
// their type zero, and the empty-array path through ensureSession is
// the same as a first-launch behaviour.
// The orchestration block below makes Resume restore the *run*, not
// just the transcript. All fields are defaulted so a legacy snapshot
// (written before these existed) decodes with the codec's type-zero
// values: an empty StateTag is the "no persisted orchestration state"
// sentinel — recovery then falls back to the conversation-scan
// heuristic exactly as it did before this field block.
//
//   StateTag/StatePending/StateReason/StateSummaryBody — the AppState
//     sealed value flattened to scalars (tag + the per-variant
//     payload). Rebuilt by app/ui on resume.
//   Plan/PlanShipped/PlanContinuing — the in-flight @plan queue.
//   ActiveBase/ActivePrBranch — empty string == None.
//   OpenPrs — PRs opened this session (for @base/stacking + the UI
//     open-PR list).
//   PendingQ* — an unanswered AskUserQuestion (empty Member == none).
//   PostPromptSent — engineers that already received the
//     workflow.post_engineer_prompt this dispatch cycle. Without this,
//     a resume mid-cycle wipes the in-memory HashSet and the next
//     @finished re-fires the post-prompt (e.g. /simplify) on engineers
//     that already ran it — the FSM appears stuck on Delegating(name)
//     for the duration of the redundant round. Persisted as a flat
//     Array[string]; rehydrated back into the HashSet shape the
//     orchestrator uses.
struct Snapshot(
    ProjectName    string,
    SavedAt        int64,
    Conversation   Array[ConversationLine],
    ActiveMembers  Array[string],
    SessionIds     Array[SessionIdEntry] = EmptyArray[SessionIdEntry](),
    StateTag         string = "",
    StatePending     Array[string] = EmptyArray[string](),
    StateReason      string = "",
    StateSummaryBody string = "",
    Plan             Array[string] = EmptyArray[string](),
    PlanShipped      int = 0,
    PlanContinuing   bool = false,
    ActiveBase       string = "",
    ActivePrBranch   string = "",
    OpenPrs          Array[SnapPr] = EmptyArray[SnapPr](),
    PendingQMember   string = "",
    PendingQToolUse  string = "",
    PendingQText     string = "",
    PostPromptSent   Array[string] = EmptyArray[string](),
)

// SessionPath returns the canonical save path for a given project repo.
// Always under .gala_team/sessions/latest.json — leaves room for future
// multi-snapshot retention without breaking the "load latest" contract.
func SessionPath(repoDir string) string =
    filepath.Join(repoDir, ".gala_team", "sessions", "latest.json")

// Save writes a Snapshot to .gala_team/sessions/latest.json under
// repoDir. Returns Try[bool] so callers can decide whether a save
// failure (disk full, permissions, …) should bubble up. Failures are
// logged via the AppModel's LastError; the running TUI never blocks
// on Save.
//
// `activeMembers` is the list of member names whose Claude
// subprocess is alive at this save. On the next launch, recovery
// uses this list to spawn those members with `--continue` so the
// agents pick up where they left off.
// snapshotCodec returns a Codec[Snapshot] each call rather than as a
// package-level val — gala wraps top-level vals in Immutable[T] which
// shadows the codec's `.Decode` / `.Encode` methods at the call site.
// Constructing per call is cheap (the codec is just metadata).
func snapshotCodec() json.JsonEncoder[Snapshot] = json.Codec[Snapshot](json.SnakeCase())

// Orchestration is the caller-facing bundle of run state. Kept as one
// defaulted struct so Save's signature stays readable and a caller
// that doesn't care (or a legacy path) just omits it — the all-zero
// value round-trips to the same "no persisted state" snapshot a
// pre-PR-B build wrote. The fields are mapped onto Snapshot's flat
// columns (the codec has a proven encoding for scalars + Array[T];
// a single nested struct field is deliberately avoided).
struct Orchestration(
    StateTag         string = "",
    StatePending     Array[string] = EmptyArray[string](),
    StateReason      string = "",
    StateSummaryBody string = "",
    Plan             Array[string] = EmptyArray[string](),
    PlanShipped      int = 0,
    PlanContinuing   bool = false,
    ActiveBase       string = "",
    ActivePrBranch   string = "",
    OpenPrs          Array[SnapPr] = EmptyArray[SnapPr](),
    PendingQMember   string = "",
    PendingQToolUse  string = "",
    PendingQText     string = "",
    PostPromptSent   Array[string] = EmptyArray[string](),
)

// noOrchestration is the "no persisted run state" value. It exists as
// a function (not a bare `Orchestration()` default) on purpose: gala
// lowers a zero-arg struct constructor to a Go *type conversion*
// (`Orchestration()` — "missing argument"), whereas a named-field
// construction lowers to a struct literal correctly. Used as Save's
// default so callers/tests that don't carry run state still compile.
func noOrchestration() Orchestration = Orchestration(
    StateTag         = "",
    StatePending     = EmptyArray[string](),
    StateReason      = "",
    StateSummaryBody = "",
    Plan             = EmptyArray[string](),
    PlanShipped      = 0,
    PlanContinuing   = false,
    ActiveBase       = "",
    ActivePrBranch   = "",
    OpenPrs          = EmptyArray[SnapPr](),
    PendingQMember   = "",
    PendingQToolUse  = "",
    PendingQText     = "",
    PostPromptSent   = EmptyArray[string](),
)

func Save(
    repoDir string,
    projectName string,
    conversation Array[ConversationLine],
    activeMembers Array[string],
    sessionIds Array[SessionIdEntry] = EmptyArray[SessionIdEntry](),
    orch Orchestration = noOrchestration(),
) Try[bool] = Try(() => {
    val snap = Snapshot(
        ProjectName      = projectName,
        SavedAt          = time.Now().UnixNano(),
        Conversation     = conversation,
        ActiveMembers    = activeMembers,
        SessionIds       = sessionIds,
        StateTag         = orch.StateTag,
        StatePending     = orch.StatePending,
        StateReason      = orch.StateReason,
        StateSummaryBody = orch.StateSummaryBody,
        Plan             = orch.Plan,
        PlanShipped      = orch.PlanShipped,
        PlanContinuing   = orch.PlanContinuing,
        ActiveBase       = orch.ActiveBase,
        ActivePrBranch   = orch.ActivePrBranch,
        OpenPrs          = orch.OpenPrs,
        PendingQMember   = orch.PendingQMember,
        PendingQToolUse  = orch.PendingQToolUse,
        PendingQText     = orch.PendingQText,
        PostPromptSent   = orch.PostPromptSent,
    )
    val encoded = snapshotCodec().Encode(snap).Get()
    val path    = SessionPath(repoDir)
    val parent  = filepath.Dir(path)
    fs.MkdirAll(parent, 0o755).Get()
    fs.WriteFileString(path, encoded, 0o644).Get()
    return true
})

// Load reads a Snapshot from .gala_team/sessions/latest.json under
// repoDir. Returns None when no file exists (first run) OR when the
// file is corrupted — we prefer "start clean" over "blow up at startup"
// since the durable log is for convenience, not correctness.
func Load(repoDir string) Option[Snapshot] = LoadOrError(repoDir) match {
    case Right(snap) => Some(snap)
    case Left(_)     => None[Snapshot]()
}

// LoadOrError mirrors Load but surfaces the underlying error string
// when the file exists but decoding fails. Useful for tests and the
// LastError surface in the running TUI.
func LoadOrError(repoDir string) Either[string, Snapshot] {
    val path = SessionPath(repoDir)
    return fs.ReadFileString(path) match {
        case Failure(err) => Left[string, Snapshot](s"read: ${err.Error()}")
        case Success(text) => snapshotCodec().Decode(text) match {
            case Success(snap) => Right[string, Snapshot](snap)
            case Failure(err)  => Left[string, Snapshot](s"decode: ${err.Error()}")
        }
    }
}

// All snapshot encode/decode now flows through `snapshotCodec` above.
// The hand-rolled walkers (encodeSnapshot, decodeSnapshot,
// decodeConversation, decodeLine, decodeStringArray) lived here
// pre-0.41.0 because Codec[T] couldn't decode `Conversation
// Array[ConversationLine]`. A later gala release closed that gap,
// so we no longer need them.

// EnsureGitignore appends `.gala_team/` to the project's .gitignore
// if (a) the file doesn't already mention it, and (b) the project is
// a git repo (we don't litter random folders with stray .gitignore
// files). Returns Success(true) when an append happened, Success(false)
// when nothing changed, Failure on IO error.
//
// Per DESIGN.md §4.6: "`.gala_team/` is appended to the project's
// `.gitignore` automatically on first run (with a Don't strip if
// present guard so we don't fight the user)."
func EnsureGitignore(repoDir string) Try[bool] = Try(() => {
    val gitDir = filepath.Join(repoDir, ".git")
    if !fs.Exists(gitDir) {
        return false
    }
    val path = filepath.Join(repoDir, ".gitignore")
    val current = fs.ReadFileString(path).GetOrElse("")
    if hasGalaTeamLine(current) {
        return false
    }
    val sep = if (current == "" || strings.HasSuffix(current, "\n")) "" else "\n"
    val updated = current + sep + ".gala_team/\n"
    fs.WriteFileString(path, updated, 0o644).Get()
    return true
})

// hasGalaTeamLine returns true iff `body` already mentions the
// `.gala_team` path in some form — covers `.gala_team`,
// `.gala_team/`, `.gala_team/*`, and any leading whitespace. Avoids
// re-appending the line on every launch.
func hasGalaTeamLine(body string) bool =
    strings.Split(body, "\n").Exists((ln) => strings.HasPrefix(strings.TrimSpace(ln), ".gala_team"))

// AppendEvent appends one JSON line to the per-session events.jsonl
// file under .gala_team/sessions/events.jsonl. Each event is a
// caller-supplied JSON object (free-form for now — future versions
// can wire a typed Event sealed type). Returns Success(true) on the
// happy path; failures land as Failure so the caller can decide to
// surface in LastError or silently drop.
//
// Per DESIGN.md §4.6: "events.jsonl — append-only, one JSON object
// per line. Every state-machine transition, every dispatch, every
// status flip, every hook result, every chunk hash. Cheap to fsync,
// cheap to replay."
func AppendEvent(repoDir string, eventJson string) Try[bool] = Try(() => {
    val path = filepath.Join(repoDir, ".gala_team", "sessions", "events.jsonl")
    val parent = filepath.Dir(path)
    fs.MkdirAll(parent, 0o755).Get()
    // O_APPEND open isn't surfaced by martianoff/gala/fs; keep the
    // raw os.OpenFile call here so appends remain atomic per write.
    val f, openErr = os.OpenFile(path, os.O_APPEND|os.O_CREATE|os.O_WRONLY, os.FileMode(0644))
    if openErr != nil { go_builtins.Panic(s"session: open ${path}: ${openErr.Error()}") }
    val _, writeErr = f.WriteString(eventJson + "\n")
    val closeErr = f.Close()
    if writeErr != nil { go_builtins.Panic(s"session: write ${path}: ${writeErr.Error()}") }
    if closeErr != nil { go_builtins.Panic(s"session: close ${path}: ${closeErr.Error()}") }
    return true
})
