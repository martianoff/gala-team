package session

import (
    "os"
    "path/filepath"
    "strings"
    "time"
    "martianoff/gala/json"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/go_interop"
)

// ============================================================================
// app/session — durable per-project conversation log.
//
// Every time the user sees a chunk arrive, the new conversation log is
// JSON-serialized to <project repo>/.gala_team/sessions/latest.json. On
// startup, cmd/main.gala reads that file (if present) and primes the
// AppModel's Conversation field so the user sees their prior context
// without re-prompting.
//
// Scope is deliberately narrow: only the conversation log + project name
// + saved-at timestamp. We do NOT serialize:
//   - subprocess sessions (live OS handles, not portable)
//   - workflow / team config (re-read from team.yaml on every launch)
//   - FSM state (resuming mid-flight is brittle; prefer to start Idle)
//
// ConversationLine lives here rather than in app/ui so app/ui can depend
// on session (and not the other way around) — saves the type from being
// duplicated and keeps app/session self-contained for the cmd-side load.
//
// Implementation note: drives json.JsonEncoderImpl / JsonDecoderImpl
// directly rather than `Codec[Snapshot]` because the typed codegen still
// emits `WriteNull` for non-primitive array elements (the
// "primitives only" gate in genCollectionWrite). The decoder side
// supports nested arrays-of-structs since gala 0.39 (FIX-001).
// ============================================================================

// ConversationLine is a single rendered turn in the Team-Lead conversation
// log: who spoke (the user, or a member name) and the text they produced.
struct ConversationLine(Speaker string, Text string)

// Snapshot is the on-disk shape. ProjectName is informational (lets us
// detect cross-project mismatches later); SavedAt is unix nanos at the
// moment Save was called.
//
// ActiveMembers carries the names of every team member whose Claude
// CLI subprocess was alive when the save happened. The recovery flow
// uses this list to spawn those members with `--continue` so Claude
// picks up its prior in-process conversation instead of starting a
// fresh session.
struct Snapshot(
    ProjectName    string,
    SavedAt        int64,
    Conversation   Array[ConversationLine],
    ActiveMembers  Array[string],
)

// SessionPath returns the canonical save path for a given project repo.
// Always under .gala_team/sessions/latest.json — leaves room for future
// multi-snapshot retention without breaking the "load latest" contract.
func SessionPath(repoDir string) string =
    filepath.Join(repoDir, ".gala_team", "sessions", "latest.json")

// Save writes a Snapshot to .gala_team/sessions/latest.json under
// repoDir. Returns Try[bool] so callers can decide whether a save
// failure (disk full, permissions, …) should bubble up. Failures are
// logged via the AppModel's LastError; the running TUI never blocks
// on Save.
//
// `activeMembers` is the list of member names whose Claude
// subprocess is alive at this save. On the next launch, recovery
// uses this list to spawn those members with `--continue` so the
// agents pick up where they left off.
// snapshotCodec returns a Codec[Snapshot] each call rather than as a
// package-level val — gala wraps top-level vals in Immutable[T] which
// shadows the codec's `.Decode` / `.Encode` methods at the call site.
// Constructing per call is cheap (the codec is just metadata).
func snapshotCodec() json.JsonEncoder[Snapshot] = json.Codec[Snapshot](json.SnakeCase())

func Save(
    repoDir string,
    projectName string,
    conversation Array[ConversationLine],
    activeMembers Array[string],
) Try[bool] = Try[bool](() => {
    val snap = Snapshot(
        ProjectName   = projectName,
        SavedAt       = time.Now().UnixNano(),
        Conversation  = conversation,
        ActiveMembers = activeMembers,
    )
    val encoded = snapshotCodec().Encode(snap).Get()
    val path    = SessionPath(repoDir)
    val parent  = filepath.Dir(path)
    val mkErr   = os.MkdirAll(parent, os.FileMode(0755))
    if mkErr != nil { panic(s"session: mkdir ${parent}: ${mkErr.Error()}") }
    val writeErr = os.WriteFile(path, ToBytes(encoded), os.FileMode(0644))
    if writeErr != nil { panic(s"session: write ${path}: ${writeErr.Error()}") }
    return true
})

// Load reads a Snapshot from .gala_team/sessions/latest.json under
// repoDir. Returns None when no file exists (first run) OR when the
// file is corrupted — we prefer "start clean" over "blow up at startup"
// since the durable log is for convenience, not correctness.
func Load(repoDir string) Option[Snapshot] = LoadOrError(repoDir) match {
    case Right(snap) => Some(snap)
    case Left(_)     => None[Snapshot]()
}

// LoadOrError mirrors Load but surfaces the underlying error string
// when the file exists but decoding fails. Useful for tests and the
// LastError surface in the running TUI.
func LoadOrError(repoDir string) Either[string, Snapshot] {
    val path = SessionPath(repoDir)
    val readResult = Try(() => os.ReadFile(path))
    return readResult match {
        case Failure(err) => Left[string, Snapshot](s"read: ${err.Error()}")
        case Success(bytes) => snapshotCodec().Decode(string(bytes)) match {
            case Success(snap) => Right[string, Snapshot](snap)
            case Failure(err)  => Left[string, Snapshot](s"decode: ${err.Error()}")
        }
    }
}

// All snapshot encode/decode now flows through `snapshotCodec` above.
// The hand-rolled walkers (encodeSnapshot, decodeSnapshot,
// decodeConversation, decodeLine, decodeStringArray) lived here
// pre-0.41.0 because Codec[T] couldn't decode `Conversation
// Array[ConversationLine]`. PR #314 closed that gap, so we no longer
// need them.

// EnsureGitignore appends `.gala_team/` to the project's .gitignore
// if (a) the file doesn't already mention it, and (b) the project is
// a git repo (we don't litter random folders with stray .gitignore
// files). Returns Success(true) when an append happened, Success(false)
// when nothing changed, Failure on IO error.
//
// Per DESIGN.md §4.6: "`.gala_team/` is appended to the project's
// `.gitignore` automatically on first run (with a Don't strip if
// present guard so we don't fight the user)."
func EnsureGitignore(repoDir string) Try[bool] = Try[bool](() => {
    val gitDir = filepath.Join(repoDir, ".git")
    val gitInfo, gitErr = os.Stat(gitDir)
    val _ = gitInfo
    if gitErr != nil {
        return false
    }
    val path = filepath.Join(repoDir, ".gitignore")
    val existing, readErr = os.ReadFile(path)
    val current = if (readErr == nil) string(existing) else ""
    if hasGalaTeamLine(current) {
        return false
    }
    val sep = if (current == "" || strings.HasSuffix(current, "\n")) "" else "\n"
    val updated = current + sep + ".gala_team/\n"
    val writeErr = os.WriteFile(path, ToBytes(updated), os.FileMode(0644))
    if writeErr != nil { panic(s"session: write ${path}: ${writeErr.Error()}") }
    return true
})

// hasGalaTeamLine returns true iff `body` already mentions the
// `.gala_team` path in some form — covers `.gala_team`,
// `.gala_team/`, `.gala_team/*`, and any leading whitespace. Avoids
// re-appending the line on every launch.
func hasGalaTeamLine(body string) bool {
    val lines = strings.Split(body, "\n")
    var i = 0
    val n = len(lines)
    for i < n {
        val t = strings.TrimSpace(lines[i])
        if strings.HasPrefix(t, ".gala_team") { return true }
        i = i + 1
    }
    return false
}

// AppendEvent appends one JSON line to the per-session events.jsonl
// file under .gala_team/sessions/events.jsonl. Each event is a
// caller-supplied JSON object (free-form for now — future versions
// can wire a typed Event sealed type). Returns Success(true) on the
// happy path; failures land as Failure so the caller can decide to
// surface in LastError or silently drop.
//
// Per DESIGN.md §4.6: "events.jsonl — append-only, one JSON object
// per line. Every state-machine transition, every dispatch, every
// status flip, every hook result, every chunk hash. Cheap to fsync,
// cheap to replay."
func AppendEvent(repoDir string, eventJson string) Try[bool] = Try[bool](() => {
    val path = filepath.Join(repoDir, ".gala_team", "sessions", "events.jsonl")
    val parent = filepath.Dir(path)
    val mkErr = os.MkdirAll(parent, os.FileMode(0755))
    if mkErr != nil { panic(s"session: mkdir ${parent}: ${mkErr.Error()}") }
    val f, openErr = os.OpenFile(path, os.O_APPEND|os.O_CREATE|os.O_WRONLY, os.FileMode(0644))
    if openErr != nil { panic(s"session: open ${path}: ${openErr.Error()}") }
    val _, writeErr = f.WriteString(eventJson + "\n")
    val closeErr = f.Close()
    if writeErr != nil { panic(s"session: write ${path}: ${writeErr.Error()}") }
    if closeErr != nil { panic(s"session: close ${path}: ${closeErr.Error()}") }
    return true
})
