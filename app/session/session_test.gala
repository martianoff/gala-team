package session

import (
    "path/filepath"
    "martianoff/gala/fs"
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
)

// mkTempDir creates a fresh empty directory for the duration of one test
// case. Tests panic the test rather than skipping; the test framework
// records the failure and moves on.
func mkTempDir(label string) string =
    fs.MkdirTemp("", "gala_team_session_" + label).Get()

func TestSessionPath_PutsFileUnderGalaTeam(t T) T {
    val path = SessionPath("/tmp/proj")
    return Eq(t, path, filepath.Join("/tmp/proj", ".gala_team", "sessions", "latest.json"))
}

func TestLoad_MissingFileReturnsNone(t T) T {
    val dir = mkTempDir("load_missing")
    val loaded = Load(dir)
    return loaded match {
        case None()   => IsTrue(t, true)
        case Some(_)  => IsTrue(t, false)
    }
}

func TestSaveThenLoad_RoundTripsConversation(t T) T {
    val dir = mkTempDir("roundtrip")
    val convo = ArrayOf(
        ConversationLine(Speaker = "you",  Text = "ship it"),
        ConversationLine(Speaker = "Iris", Text = "@summary done"),
    )
    val saved = Save(dir, "demo", convo, EmptyArray[string]())
    val saveErr = saved match {
        case Success(_)   => "OK"
        case Failure(err) => err.Error()
    }
    val t1 = Eq(t, saveErr, "OK")
    val loaded = Load(dir)
    var loadOK = "OK"
    LoadOrError(dir) match {
        case Right(_)  => loadOK = "OK"
        case Left(err) => loadOK = err
    }
    val t2 = Eq(t1, loadOK, "OK")
    return loaded match {
        case None()       => IsTrue(t2, false)
        case Some(snap)   => {
            val t3 = Eq(t2, snap.ProjectName, "demo")
            val t4 = Eq(t3, snap.Conversation.Size(), 2)
            val t5 = Eq(t4, snap.Conversation.Get(0).Text, "ship it")
            return Eq(t5, snap.Conversation.Get(1).Speaker, "Iris")
        }
    }
}

func TestSave_OverwritesPriorSnapshot(t T) T {
    val dir = mkTempDir("overwrite")
    val first = ArrayOf(ConversationLine(Speaker = "you", Text = "first"))
    val second = ArrayOf(
        ConversationLine(Speaker = "you", Text = "second"),
        ConversationLine(Speaker = "Iris", Text = "ack"),
    )
    val s1 = Save(dir, "demo", first, EmptyArray[string]())
    val t1 = IsSuccess(t, s1)
    val s2 = Save(dir, "demo", second, EmptyArray[string]())
    val t2 = IsSuccess(t1, s2)
    val loaded = Load(dir)
    return loaded match {
        case None()     => IsTrue(t2, false)
        case Some(snap) => Eq(t2, snap.Conversation.Size(), 2)
    }
}

func TestLoad_CorruptedFileReturnsNone(t T) T {
    val dir = mkTempDir("corrupt")
    val parent = filepath.Dir(SessionPath(dir))
    fs.MkdirAll(parent, 0o755).Get()
    fs.WriteFileString(SessionPath(dir), "{not json", 0o644).Get()
    return Load(dir) match {
        case None()  => IsTrue(t, true)
        case Some(_) => IsTrue(t, false)
    }
}

// ---------------------------------------------------------------------------
// Round-trip edge cases — JSON has sharp edges around quotes, escapes,
// embedded newlines, unicode. Conversation text from Claude often
// contains all of them; the codec needs to handle them transparently.
// ---------------------------------------------------------------------------

func TestSaveThenLoad_EmptyConversation(t T) T {
    val dir = mkTempDir("empty_convo")
    val saved = Save(dir, "demo", EmptyArray[ConversationLine](), EmptyArray[string]())
    val t1 = IsSuccess(t, saved)
    return Load(dir) match {
        case Some(snap) => Eq(t1, snap.Conversation.Size(), 0)
        case None()     => IsTrue(t1, false)
    }
}

func TestSaveThenLoad_TextWithDoubleQuotes(t T) T {
    val dir = mkTempDir("quotes")
    val convo = ArrayOf(
        ConversationLine(Speaker = "you",  Text = "look at \"quoted\" stuff"),
        ConversationLine(Speaker = "Iris", Text = "{\"key\": \"value\"}"),
    )
    val saved = Save(dir, "demo", convo, EmptyArray[string]())
    val t1 = IsSuccess(t, saved)
    return Load(dir) match {
        case Some(snap) => {
            val t2 = Eq(t1, snap.Conversation.Get(0).Text, "look at \"quoted\" stuff")
            return Eq(t2, snap.Conversation.Get(1).Text, "{\"key\": \"value\"}")
        }
        case None() => IsTrue(t1, false)
    }
}

func TestSaveThenLoad_TextWithBackslashes(t T) T {
    val dir = mkTempDir("backslash")
    val convo = ArrayOf(
        ConversationLine(Speaker = "you", Text = "C:\\workdir\\file.txt"),
    )
    val saved = Save(dir, "demo", convo, EmptyArray[string]())
    val t1 = IsSuccess(t, saved)
    return Load(dir) match {
        case Some(snap) => Eq(t1, snap.Conversation.Get(0).Text, "C:\\workdir\\file.txt")
        case None()     => IsTrue(t1, false)
    }
}

func TestSaveThenLoad_TextWithEmbeddedNewlines(t T) T {
    val dir = mkTempDir("newlines")
    val convo = ArrayOf(
        ConversationLine(Speaker = "Iris", Text = "line one\nline two\nline three"),
    )
    val saved = Save(dir, "demo", convo, EmptyArray[string]())
    val t1 = IsSuccess(t, saved)
    return Load(dir) match {
        case Some(snap) => Eq(t1, snap.Conversation.Get(0).Text, "line one\nline two\nline three")
        case None()     => IsTrue(t1, false)
    }
}

// Multi-byte UTF-8 (emoji, accented Latin, CJK) must survive the
// JSON encoder + decoder without mojibake. Conversation logs from the
// real claude CLI contain emoji in confirmation lines.
func TestSaveThenLoad_TextWithUnicode(t T) T {
    val dir = mkTempDir("unicode")
    val convo = ArrayOf(
        ConversationLine(Speaker = "you",  Text = "ship it 🚀"),
        ConversationLine(Speaker = "Iris", Text = "café résumé"),
        ConversationLine(Speaker = "Felix", Text = "日本語テスト"),
    )
    val saved = Save(dir, "demo", convo, EmptyArray[string]())
    val t1 = IsSuccess(t, saved)
    return Load(dir) match {
        case Some(snap) => {
            val t2 = Eq(t1, snap.Conversation.Get(0).Text, "ship it 🚀")
            val t3 = Eq(t2, snap.Conversation.Get(1).Text, "café résumé")
            return Eq(t3, snap.Conversation.Get(2).Text, "日本語テスト")
        }
        case None() => IsTrue(t1, false)
    }
}

// Speaker names with non-ASCII — defensive: not common but the team
// config schema doesn't constrain names.
func TestSaveThenLoad_SpeakerWithUnicode(t T) T {
    val dir = mkTempDir("speaker_unicode")
    val convo = ArrayOf(
        ConversationLine(Speaker = "Иван",   Text = "приветствие"),
    )
    val saved = Save(dir, "demo", convo, EmptyArray[string]())
    val t1 = IsSuccess(t, saved)
    return Load(dir) match {
        case Some(snap) => {
            val t2 = Eq(t1, snap.Conversation.Get(0).Speaker, "Иван")
            return Eq(t2, snap.Conversation.Get(0).Text,    "приветствие")
        }
        case None() => IsTrue(t1, false)
    }
}

// Many-line conversations exercise per-element comma handling in the
// JSON codec. 50 lines is overkill but fast enough.
func TestSaveThenLoad_FiftyLineConversation(t T) T {
    val dir = mkTempDir("many_lines")
    var convo = EmptyArray[ConversationLine]()
    var i = 0
    for i < 50 {
        convo = convo.Append(ConversationLine(Speaker = "Iris", Text = s"line ${i}"))
        i = i + 1
    }
    val saved = Save(dir, "demo", convo, EmptyArray[string]())
    val t1 = IsSuccess(t, saved)
    return Load(dir) match {
        case Some(snap) => {
            val t2 = Eq(t1, snap.Conversation.Size(), 50)
            val t3 = Eq(t2, snap.Conversation.Get(0).Text,  "line 0")
            return Eq(t3, snap.Conversation.Get(49).Text, "line 49")
        }
        case None() => IsTrue(t1, false)
    }
}

func TestSave_PreservesProjectName(t T) T {
    val dir = mkTempDir("projname")
    val saved = Save(dir, "Skunkworks_v2", EmptyArray[ConversationLine](), EmptyArray[string]())
    val t1 = IsSuccess(t, saved)
    return Load(dir) match {
        case Some(snap) => Eq(t1, snap.ProjectName, "Skunkworks_v2")
        case None()     => IsTrue(t1, false)
    }
}

func TestSave_RecordsSavedAtMonotonic(t T) T {
    val dir = mkTempDir("savedat")
    val s1 = Save(dir, "demo", EmptyArray[ConversationLine](), EmptyArray[string]())
    val first = IsSuccess(t, s1)
    val snap1 = Load(dir).Get()
    val s2 = Save(dir, "demo", EmptyArray[ConversationLine](), EmptyArray[string]())
    val second = IsSuccess(first, s2)
    val snap2 = Load(dir).Get()
    // Second save's timestamp should be >= the first. Equal is allowed
    // because some CI runners have low-resolution wall clocks.
    return IsTrue(second, snap2.SavedAt >= snap1.SavedAt)
}

func TestLoadOrError_OnMissingFile_LeftWithReadError(t T) T {
    val dir = mkTempDir("loaderr_missing")
    return LoadOrError(dir) match {
        case Right(_)  => IsTrue(t, false)
        case Left(err) => IsTrue(t, len(err) > 0)
    }
}

func TestLoadOrError_OnCorrupted_LeftWithDecodeError(t T) T {
    val dir = mkTempDir("loaderr_bad")
    val parent = filepath.Dir(SessionPath(dir))
    fs.MkdirAll(parent, 0o755).Get()
    fs.WriteFileString(SessionPath(dir), "{not json", 0o644).Get()
    return LoadOrError(dir) match {
        case Right(_)  => IsTrue(t, false)
        case Left(err) => IsTrue(t, len(err) > 0)
    }
}

// ----------------------------------------------------------------------------
// SessionIds round-trip — pinning the TL-amnesia fix.
//
// On a recovery launch, primeFromSnapshot needs the per-member claude
// session UUIDs back so the first ensureSession can hand `--resume <id>`
// to claude. The Snapshot struct gained SessionIds as Array[SessionIdEntry]
// for codec round-tripping; these tests confirm Save → Load preserves
// the entries verbatim (Member + SessionId) and that legacy snapshots
// without the field decode cleanly into an empty array.
// ----------------------------------------------------------------------------

func TestSessionIds_RoundTrip(t T) T {
    val dir = mkTempDir("sids_rt")
    defer fs.RemoveAll(dir)
    val entries = ArrayOf(
        SessionIdEntry(Member = "Vesper", SessionId = "11111111-aaaa-bbbb-cccc-222222222222"),
        SessionIdEntry(Member = "Kael",   SessionId = "33333333-aaaa-bbbb-cccc-444444444444"),
    )
    val saveRes = Save(
        dir,
        "demo",
        EmptyArray[ConversationLine](),
        EmptyArray[string](),
        entries,
    )
    val t1 = IsTrue(t, saveRes.IsSuccess())
    return Load(dir) match {
        case None()       => IsTrue(t1, false)
        case Some(snap)   => {
            val t2 = Eq(t1, snap.SessionIds.Size(), 2)
            val first = snap.SessionIds.Get(0)
            val t3 = Eq(t2, first.Member, "Vesper")
            val t4 = Eq(t3, first.SessionId, "11111111-aaaa-bbbb-cccc-222222222222")
            val second = snap.SessionIds.Get(1)
            val t5 = Eq(t4, second.Member, "Kael")
            return Eq(t5, second.SessionId, "33333333-aaaa-bbbb-cccc-444444444444")
        }
    }
}

// Legacy snapshots saved before SessionIds existed must still load —
// gala's codec fills missing optional fields with their type zero,
// and the AppModel-side primeFromSnapshot path treats an empty array
// the same as "no recovered ids" (first ensureSession spawns fresh).
func TestSessionIds_LegacySnapshotLoadsAsEmptyArray(t T) T {
    val dir = mkTempDir("sids_legacy")
    defer fs.RemoveAll(dir)
    val parent = filepath.Dir(SessionPath(dir))
    fs.MkdirAll(parent, 0o755).Get()
    // Hand-rolled snapshot WITHOUT a session_ids key — what older
    // installs would have on disk.
    val legacy = "{\"project_name\":\"demo\",\"saved_at\":1700000000000000000,\"conversation\":[],\"active_members\":[]}"
    fs.WriteFileString(SessionPath(dir), legacy, 0o644).Get()
    return Load(dir) match {
        case None()       => IsTrue(t, false)
        case Some(snap)   => Eq(t, snap.SessionIds.Size(), 0)
    }
}

// Empty SessionIds (default) round-trips as an empty array on disk
// — pinned so that a save during normal operation doesn't break the
// decode of the next launch.
func TestSessionIds_EmptyRoundTrip(t T) T {
    val dir = mkTempDir("sids_empty")
    defer fs.RemoveAll(dir)
    val saveRes = Save(
        dir,
        "demo",
        EmptyArray[ConversationLine](),
        EmptyArray[string](),
        EmptyArray[SessionIdEntry](),
    )
    val t1 = IsTrue(t, saveRes.IsSuccess())
    return Load(dir) match {
        case None()       => IsTrue(t1, false)
        case Some(snap)   => Eq(t1, snap.SessionIds.Size(), 0)
    }
}

// PR B: the orchestration block round-trips through the codec so
// Resume can rebuild the run, not just the transcript.
func TestSaveThenLoad_RoundTripsOrchestration(t T) T {
    val dir = mkTempDir("orch")
    val orch = Orchestration(
        StateTag         = "Delegating",
        StatePending     = ArrayOf("Kael", "Lyra"),
        Plan             = ArrayOf("port", "harness", "tests"),
        PlanShipped      = 1,
        PlanContinuing   = true,
        ActiveBase       = "gala_team/x/pr/abc",
        ActivePrBranch   = "gala_team/x/pr/def",
        OpenPrs          = ArrayOf(SnapPr(
            Url = "https://pr/1", Branch = "b1", Title = "PR 1",
            OpenedAtNanos = int64(1700000000000000000))),
        PendingQMember   = "Vesper",
        PendingQToolUse  = "toolu_z",
        PendingQText     = "Which approach?",
    )
    val saved = Save(dir, "demo", EmptyArray[ConversationLine](),
        EmptyArray[string](), EmptyArray[SessionIdEntry](), orch)
    val t1 = IsTrue(t, saved.IsSuccess())
    return Load(dir) match {
        case None()     => IsTrue(t1, false)
        case Some(snap) => {
            val t2 = Eq(t1, snap.StateTag, "Delegating")
            val t3 = Eq(t2, snap.StatePending.Size(), 2)
            val t4 = Eq(t3, snap.Plan.Size(), 3)
            val t5 = Eq(t4, snap.PlanShipped, 1)
            val t6 = IsTrue(t5, snap.PlanContinuing)
            val t7 = Eq(t6, snap.ActiveBase, "gala_team/x/pr/abc")
            val t8 = Eq(t7, snap.OpenPrs.Size(), 1)
            val t9 = Eq(t8, snap.OpenPrs.Get(0).Title, "PR 1")
            return Eq(t9, snap.PendingQText, "Which approach?")
        }
    }
}

// A snapshot written the old way (no orchestration arg) decodes with
// an empty StateTag — the "no persisted run state" sentinel that keeps
// legacy snapshots resuming conversation-only.
func TestSaveThenLoad_LegacySnapshotHasEmptyStateTag(t T) T {
    val dir = mkTempDir("legacy")
    val saved = Save(dir, "demo",
        ArrayOf(ConversationLine(Speaker = "you", Text = "hi")),
        EmptyArray[string]())
    val t1 = IsTrue(t, saved.IsSuccess())
    return Load(dir) match {
        case None()     => IsTrue(t1, false)
        case Some(snap) => {
            val t2 = Eq(t1, snap.StateTag, "")
            return Eq(t2, snap.PlanShipped, 0)
        }
    }
}

// PostPromptSent round-trip — the per-dispatch latch that prevents
// the workflow.post_engineer_prompt (e.g. `/simplify`) from firing
// twice for the same engineer in one cycle MUST survive tui_exit /
// resume. Without persisting it, an engineer who already ran the
// prompt pre-resume gets put through it again on the post-resume
// @finished, and the FSM appears stuck on Delegating(name) for the
// duration of the redundant round.
func TestSaveThenLoad_PostPromptSentRoundTrips(t T) T {
    val dir = mkTempDir("postpromptsent")
    val orch = Orchestration(
        StateTag       = "Delegating",
        StatePending   = ArrayOf("Lyra"),
        PostPromptSent = ArrayOf("Lyra", "Kael"),
    )
    val saved = Save(dir, "demo", EmptyArray[ConversationLine](),
        EmptyArray[string](), EmptyArray[SessionIdEntry](), orch)
    val t1 = IsTrue(t, saved.IsSuccess())
    return Load(dir) match {
        case None()     => IsTrue(t1, false)
        case Some(snap) => {
            val t2 = Eq(t1, snap.PostPromptSent.Size(), 2)
            val t3 = Eq(t2, snap.PostPromptSent.Get(0), "Lyra")
            return Eq(t3, snap.PostPromptSent.Get(1), "Kael")
        }
    }
}

// A snapshot written without the PostPromptSent field (legacy shape
// via the no-orchestration Save overload) decodes to an EmptyArray —
// the rehydrate path then builds an empty HashSet exactly like a
// fresh model. Pins the "legacy snapshot still resumes" contract.
func TestSaveThenLoad_PostPromptSentDefaultsToEmpty(t T) T {
    val dir = mkTempDir("postpromptsent_default")
    val saved = Save(dir, "demo",
        ArrayOf(ConversationLine(Speaker = "you", Text = "hi")),
        EmptyArray[string]())
    val t1 = IsTrue(t, saved.IsSuccess())
    return Load(dir) match {
        case None()     => IsTrue(t1, false)
        case Some(snap) => IsTrue(t1, snap.PostPromptSent.IsEmpty())
    }
}
