package team

import (
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
)

// ============================================================================
// app/team — domain types about who's on the team.
//
// This is the leaf package: pure value objects, no IO, no dependencies on
// other gala_team subpackages.  Every other component (config loader,
// state machine, runtime glue, view) imports from here.
// ============================================================================

// ----------------------------------------------------------------------------
// Roles
// ----------------------------------------------------------------------------

// Role identifies what a member does.  MVP catalogue is hard-coded; future
// versions can extend this when a real second team running gala_team needs
// e.g. Designer or PM.
sealed type Role {
    case TeamLead
    case Engineer
    case QA
}

// RoleName returns the canonical YAML spelling used in team.yaml.
func RoleName(r Role) string = r match {
    case TeamLead() => "team_lead"
    case Engineer() => "engineer"
    case QA()       => "qa"
}

// RoleFromName parses the canonical YAML spelling back to a Role; None on
// unknown input so callers can surface a useful validation error pointing
// at the offending line.
func RoleFromName(s string) Option[Role] {
    if s == "team_lead" { return Some[Role](TeamLead()) }
    if s == "engineer"  { return Some[Role](Engineer()) }
    if s == "qa"        { return Some[Role](QA()) }
    return None[Role]()
}

// SameRole compares two Role values via their canonical name (cheap and
// exhaustive). Avoids a tuple-match — keeps the analyzer simple.
func SameRole(a Role, b Role) bool = RoleName(a) == RoleName(b)

// ----------------------------------------------------------------------------
// Members + Workflow
// ----------------------------------------------------------------------------

// Member is one Claude session in the team.
//
// Onboarding is a list of file paths (relative to the project repo)
// the member reads as context BEFORE its first user prompt. Each
// path's contents get prepended to the very first message sent to
// the spawned claude process, alongside any team-wide onboarding
// docs. Subsequent prompts within the same session don't re-send
// the docs — the model already has them in context.
struct Member(
    Name        string,
    Role        Role,
    Personality string,
    Model       Option[string],
    Extra       string,
    Onboarding  Array[string],
)

// Workflow describes how *this team* operates internally — distinct from
// per-project policy (.gala_team.yaml). All fields are optional in the
// YAML; defaults are applied at load time.
struct Workflow(
    QARequired         bool,
    ParallelEngineers  bool,
    RequireUserConfirm bool,
)

// DefaultWorkflow — applied when team.yaml omits the `workflow:` block, or
// individual fields within it.
func DefaultWorkflow() Workflow = Workflow(
    QARequired         = true,
    ParallelEngineers  = true,
    RequireUserConfirm = true,
)

// ----------------------------------------------------------------------------
// Teams
// ----------------------------------------------------------------------------

// Team is the loaded team.yaml: a name plus an ordered list of members
// plus a precomputed Lead pointer for convenience. Order is preserved so
// the UI shows roles in the user's authored order, not alphabetised.
//
// Key is the lookup token used by `@consult(<key>)` directives and by
// the `--team-key <key>` CLI flag. When omitted in YAML, the loader
// derives it from Name (lowercased, spaces → dashes).
//
// Description is a one-line human-readable hint surfaced in the team
// picker and the TUI header so the user can tell apart "main" from
// "transpiler-wizards" at a glance.
//
// Onboarding is a list of file paths every member reads before its
// first prompt — typically architecture docs, conventions, the
// project's CONTRIBUTING.md. Composed with each Member.Onboarding to
// form the per-member onboarding pack (see app/onboarding.Compose).
struct Team(
    Key         string,
    Name        string,
    Description string,
    Members     Array[Member],
    Lead        Member,
    Onboarding  Array[string],
)

// MembersOf returns the members with the given role, in source order.
func MembersOf(t Team, r Role) Array[Member] =
    t.Members.Filter((m) => SameRole(m.Role, r))

// MemberByName looks up a member; None if no match. Names are unique
// within a team (validated at load time, in app/config).
func MemberByName(t Team, name string) Option[Member] = t.Members.Find((m) => m.Name == name)

// FindTeamByKey scans `teams` for the entry whose Key equals `key`.
// Lives in the team package so the lambda body can do
// `tm.Key == key` cleanly — the transpiler doesn't auto-unwrap the
// std.Immutable[string] wrapper on cross-package field access in
// equality comparisons.
func FindTeamByKey(teams Array[Team], key string) Option[Team] =
    teams.Find((tm) => tm.Key == key)

// ----------------------------------------------------------------------------
// Per-member status (drives the team panel pills + spinners)
// ----------------------------------------------------------------------------

// Status is the live state of one member.  Pure value — the state machine
// in app/fsm flips members through these transitions in response to
// subprocess events.
//
// Cases use the `St` prefix to avoid shadowing the AppState orchestration
// cases defined in app/fsm (which also has an `Idle` variant): GALA case
// constructors share package namespace within their own package, but
// the same convention helps when both types end up dot-imported into a
// view file.
sealed type Status {
    case StIdle
    case StQueued
    case StWorking
    case StDone
    case StFailed(Reason string)
}

func StatusName(s Status) string = s match {
    case StIdle()    => "idle"
    case StQueued()  => "queued"
    case StWorking() => "working"
    case StDone()    => "done"
    case StFailed(_) => "failed"
}
