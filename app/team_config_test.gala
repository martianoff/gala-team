package main

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "github.com/martianoff/gala_team/app"
)

// Each YAML literal mirrors the corresponding testdata/teams/*.yaml fixture
// — kept inline here so the test binary doesn't need the fixture files in
// runfiles.  If the wire format ever drifts, sync both copies.

val validTeamYaml = "team:\n" +
    "  name: \"Skunkworks\"\n" +
    "  members:\n" +
    "    - role: team_lead\n" +
    "      name: \"Iris\"\n" +
    "      personality: |\n" +
    "        Calm, decisive.\n" +
    "    - role: engineer\n" +
    "      name: \"Felix\"\n" +
    "      personality: |\n" +
    "        Terse.\n" +
    "      extra_instructions: |\n" +
    "        Pattern matching.\n" +
    "    - role: qa\n" +
    "      name: \"Theo\"\n" +
    "      personality: \"Evidence-driven.\"\n" +
    "workflow:\n" +
    "  qa_required: true\n" +
    "  parallel_engineers: true\n" +
    "  approval:\n" +
    "    require_user_confirm: true\n"

val noQaYaml = "team:\n" +
    "  name: \"Solo\"\n" +
    "  members:\n" +
    "    - role: team_lead\n" +
    "      name: \"Iris\"\n" +
    "      personality: \"Sole orchestrator.\"\n" +
    "    - role: engineer\n" +
    "      name: \"Felix\"\n" +
    "      personality: \"Implementer.\"\n" +
    "workflow:\n" +
    "  qa_required: false\n"

val noLeadYaml = "team:\n" +
    "  name: \"Headless\"\n" +
    "  members:\n" +
    "    - role: engineer\n" +
    "      name: \"Felix\"\n" +
    "      personality: \"No lead.\"\n"

val dupNameYaml = "team:\n" +
    "  name: \"Conflict\"\n" +
    "  members:\n" +
    "    - role: team_lead\n" +
    "      name: \"Iris\"\n" +
    "      personality: \"First.\"\n" +
    "    - role: engineer\n" +
    "      name: \"Iris\"\n" +
    "      personality: \"Second.\"\n"

func TestLoadValidTeam(t T) T {
    val res = LoadTeamFromString(validTeamYaml)
    val t1 = IsSuccess(t, res)
    val cfg = res.Get()
    val t2 = Eq(t1, cfg.Team.Name, "Skunkworks")
    val t3 = Eq(t2, cfg.Team.Members.Length(), 3)
    val t4 = Eq(t3, cfg.Team.Lead.Name, "Iris")
    val t5 = IsTrue(t4, cfg.Workflow.QARequired)
    val t6 = IsTrue(t5, cfg.Workflow.ParallelEngineers)
    return IsTrue(t6, cfg.Workflow.RequireUserConfirm)
}

func TestLoadNoQa_AllowedWhenQaNotRequired(t T) T {
    val res = LoadTeamFromString(noQaYaml)
    val t1 = IsSuccess(t, res)
    val cfg = res.Get()
    val t2 = IsFalse(t1, cfg.Workflow.QARequired)
    val qas = MembersOf(cfg.Team, QA())
    return IsTrue(t2, qas.IsEmpty())
}

func TestLoadNoLead_Fails(t T) T {
    val res = LoadTeamFromString(noLeadYaml)
    return IsFailure(t, res)
}

func TestLoadDupName_Fails(t T) T {
    val res = LoadTeamFromString(dupNameYaml)
    return IsFailure(t, res)
}

func TestLoadEmptyMembers_Fails(t T) T {
    val empty = "team:\n  name: \"X\"\n  members: []\n"
    return IsFailure(t, LoadTeamFromString(empty))
}

func TestUnknownRole_Fails(t T) T {
    val bad = "team:\n  name: \"X\"\n  members:\n" +
        "    - role: designer\n      name: \"Pia\"\n      personality: \"Unsupported role.\"\n"
    return IsFailure(t, LoadTeamFromString(bad))
}
