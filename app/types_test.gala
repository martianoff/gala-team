package main

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "github.com/martianoff/gala_team/app"
)

// Sample team — wired by hand for the type tests.  Real teams come from
// team_config.LoadTeam in a follow-up commit.
func sampleTeam() Team {
    val iris = Member(
        Name = "Iris", Role = TeamLead{}.Apply(),
        Personality = "Calm, decisive.",
        Model = None[string]{}.Apply(), Extra = "",
    )
    val felix = Member(
        Name = "Felix", Role = Engineer{}.Apply(),
        Personality = "Functional-leaning, terse.",
        Model = None[string]{}.Apply(), Extra = "",
    )
    val theo = Member(
        Name = "Theo", Role = QA{}.Apply(),
        Personality = "Evidence-driven.",
        Model = None[string]{}.Apply(), Extra = "",
    )
    return Team(
        Name    = "Skunkworks",
        Members = ArrayOf[Member](iris, felix, theo),
        Lead    = iris,
    )
}

func TestRoleNameRoundTrip(t T) T {
    val t1 = Eq(t,  RoleName(TeamLead{}.Apply()), "team_lead")
    val t2 = Eq(t1, RoleName(Engineer{}.Apply()), "engineer")
    val t3 = Eq(t2, RoleName(QA{}.Apply()),       "qa")

    val parsed = RoleFromName("engineer")
    val t4 = IsSome(t3, parsed)
    val unknown = RoleFromName("designer")
    return IsNone(t4, unknown)
}

func TestMembersOf_FiltersByRole(t T) T {
    val team = sampleTeam()
    val engineers = MembersOf(team, Engineer{}.Apply())
    val t1 = Eq(t, engineers.Length(), 1)
    val t2 = Eq(t1, engineers.Get(0).Name, "Felix")
    val qas = MembersOf(team, QA{}.Apply())
    return Eq(t2, qas.Get(0).Name, "Theo")
}

func TestMemberByName(t T) T {
    val team = sampleTeam()
    val felix = MemberByName(team, "Felix")
    val t1 = IsSome(t, felix)
    val missing = MemberByName(team, "NoSuchPerson")
    return IsNone(t1, missing)
}

func TestStatusName(t T) T {
    val t1 = Eq(t,  StatusName(StIdle{}.Apply()),    "idle")
    val t2 = Eq(t1, StatusName(StQueued{}.Apply()),  "queued")
    val t3 = Eq(t2, StatusName(StWorking{}.Apply()), "working")
    val t4 = Eq(t3, StatusName(StDone{}.Apply()),    "done")
    return Eq(t4, StatusName(StFailed(Reason = "boom")), "failed")
}

func TestDefaultWorkflow(t T) T {
    val w = DefaultWorkflow()
    val t1 = IsTrue(t, w.QARequired)
    val t2 = IsTrue(t1, w.ParallelEngineers)
    return IsTrue(t2, w.RequireUserConfirm)
}
