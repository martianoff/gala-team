package ui

import (
    "os"
    "strings"
    "martianoff/gala/time_utils"
    "github.com/martianoff/gala_team/app/protocol"
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "github.com/martianoff/gala_team/app/fsm"
    . "github.com/martianoff/gala_team/app/policy"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/team"
)

// ============================================================================
// app/ui/e2e_test — integration scenarios that drive Update through
// multi-step sequences and assert end state.
//
// Each scenario seeds the model directly into the FSM state under test
// (skipping the spawn path that would synchronously start a real claude
// subprocess) and exercises the downstream behaviour with canned
// AppMsgs. Cmds are discarded — the test feeds whatever events real
// Cmds would have produced (ChunkArrived, SessionFailed, TickMsg)
// directly into Update.
//
// Why this shape: scenarios that route through KeySubmit → onSubmit →
// ensureSession spawn the real `claude` binary synchronously, which
// makes them slow (~30-120s per test) and flaky in CI. Direct state
// seeding gives the same observable behaviour without the IO.
// ============================================================================

func e2eProject() Project {
    val dir, err = os.MkdirTemp("", "gala_team_e2e_test_")
    if err != nil { panic(s"MkdirTemp: ${err.Error()}") }
    return Project(
        Name = "demo", Repo = dir,
        Github = None[string](),
        DefaultBranch = "main",
    )
}

// Fixture names ARE allowed in test code per project conventions.
// Iris is the lead; Felix is the lone engineer. The team has no QA
// so scenarios involving QA gates seed an explicit QA member into
// the model where needed.
func e2eTeam() Team {
    val iris = Member(
        Name = "Iris", Role = TeamLead(),
        Personality = "calm",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val felix = Member(
        Name = "Felix", Role = Engineer(),
        Personality = "terse",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    return Team(
        Key                        = "main",
        Name                       = "Skunkworks",
        Description                = "",
        Members                    = ArrayOf[Member](iris, felix),
        Lead                       = iris,
        Onboarding                 = EmptyArray[string](),
        DangerouslySkipPermissions = false,
    )
}

// e2eModel anchors NowAt at real wall-clock now. InitialModel uses
// UnixEpoch, which would make any backward timeTravel push timestamps
// negative — the watchdog's `<=0` guard treats that as "not yet
// observed" and skips, defeating the test. Real production NowAt is
// set on the first TickMsg; we skip the warm-up.
func e2eModel() AppModel = InitialModel(e2eProject(), e2eTeam(), DefaultWorkflow(), DefaultPolicy()).Copy(
    NowAt = time_utils.Now(),
)

// staleInstantSec returns "now minus secsAgo seconds" as an Instant.
// Used to seed StateEnteredAt / LastChunkAt into the past without
// dropping below epoch (which would trip the watchdog's
// not-yet-observed guard).
func staleInstantSec(secsAgo int64) time_utils.Instant {
    val nowSec = time_utils.Now().UnixNanos() / int64(1000000000)
    return time_utils.FromUnixSeconds(nowSec - secsAgo)
}

func stateIsIdle(m AppModel) bool = m.State match {
    case Idle() => true
    case _      => false
}
func stateIsTLThinking(m AppModel) bool = m.State match {
    case TLThinking() => true
    case _            => false
}

// ============================================================================
// Watchdog scenarios — all skip the spawn path by seeding TLThinking
// directly with a stale StateEnteredAt + optional LastChunkAt.
// ============================================================================

// Active TL with a recent chunk must NOT trip the watchdog even when
// state-dwell is well past the ceiling. The trigger metric is silence
// (time since last chunk), not state dwell — a productive long turn
// must keep running.
func TestE2E_ActiveTL_DoesNotTripWatchdog(t T) T {
    val seed = e2eModel()
    val leadName = seed.Team.Lead.Name
    val staleState = seed.Copy(
        State          = TLThinking(),
        StateEnteredAt = staleInstantSec(int64(400)),
        // Most recent chunk arrived just now → silence ≈ 0s.
        LastChunkAt    = seed.LastChunkAt.Put(leadName, time_utils.Now()),
    )
    val (m, _) = Update(staleState, TickMsg())
    return IsTrue(t, stateIsTLThinking(m))
}

// Genuinely silent TL (no chunks ever) DOES trip the watchdog. Falls
// back to state-dwell because LastChunkAt has no entry for the lead.
// FSM must hop out of TLThinking; the auto-retry path runs only when
// LastUserPrompt is non-empty, which we DON'T seed here — so the
// observable signal is "no longer in the original stale TLThinking
// state with the same StateEnteredAt."
func TestE2E_SilentTL_TripsWatchdog(t T) T {
    val seed = e2eModel()
    val staleEntered = staleInstantSec(int64(400))
    val staleState = seed.Copy(
        State          = TLThinking(),
        StateEnteredAt = staleEntered,
    )
    val (m, _) = Update(staleState, TickMsg())
    // After watchdog fire: state is Idle (no auto-retry, latch
    // stays false). The forced-Idle path also resets StateEnteredAt
    // to now, so the timestamp must have moved.
    val stateMovedToIdle = stateIsIdle(m)
    val timestampMoved = m.StateEnteredAt.UnixNanos() != staleEntered.UnixNanos()
    return IsTrue(t, stateMovedToIdle && timestampMoved)
}

// Watchdog rotates a stale SessionId.
func TestE2E_WatchdogRotatesSessionId(t T) T {
    val seed = e2eModel()
    val leadName = seed.Team.Lead.Name
    val staleState = seed.Copy(
        State          = TLThinking(),
        StateEnteredAt = staleInstantSec(int64(400)),
        SessionIds     = seed.SessionIds.Put(leadName, "STALE-LEAD-SID"),
    )
    val (m, _) = Update(staleState, TickMsg())
    val sid = m.SessionIds.Get(leadName).GetOrElse("")
    return IsTrue(t, sid != "STALE-LEAD-SID")
}

// Watchdog clears PendingClosures so the fresh respawn's first chunk
// isn't eaten by onChunk's stale-drop.
func TestE2E_WatchdogClearsPendingClosures(t T) T {
    val seed = e2eModel()
    val leadName = seed.Team.Lead.Name
    val staleState = seed.Copy(
        State           = TLThinking(),
        StateEnteredAt  = staleInstantSec(int64(400)),
        PendingClosures = seed.PendingClosures.Put(leadName, 3),
    )
    val (m, _) = Update(staleState, TickMsg())
    return Eq(t, m.PendingClosures.Get(leadName).GetOrElse(0), 0)
}

// Watchdog flips member status back to StIdle so the sidebar timer
// stops ticking.
func TestE2E_WatchdogResetsMemberStatus(t T) T {
    val seed = e2eModel()
    val leadName = seed.Team.Lead.Name
    val staleState = seed.Copy(
        State          = TLThinking(),
        StateEnteredAt = staleInstantSec(int64(400)),
        Statuses       = seed.Statuses.Put(leadName, StWorking()),
    )
    val (m, _) = Update(staleState, TickMsg())
    return m.Statuses.Get(leadName).GetOrElse(StWorking()) match {
        case StIdle() => IsTrue(t, true)
        case _        => IsTrue(t, false)
    }
}

// Second watchdog fire with the latch already set lands cleanly in
// Idle (no infinite retry loop).
func TestE2E_WatchdogSecondFire_LandsInIdle(t T) T {
    val seed = e2eModel()
    val staleState = seed.Copy(
        State              = TLThinking(),
        StateEnteredAt     = staleInstantSec(int64(400)),
        LastUserPrompt     = "previous prompt",
        WatchdogRetryFired = true,
    )
    val (m, _) = Update(staleState, TickMsg())
    return IsTrue(t, stateIsIdle(m))
}

// Idle / Approval never trip the watchdog regardless of dwell time —
// the user is the next event there.
func TestE2E_Idle_NeverTripsWatchdog(t T) T {
    val seed = e2eModel()
    val staleIdle = seed.Copy(
        State          = Idle(),
        StateEnteredAt = staleInstantSec(int64(400)),
    )
    val (m, _) = Update(staleIdle, TickMsg())
    return IsTrue(t, stateIsIdle(m))
}

func TestE2E_Approval_NeverTripsWatchdog(t T) T {
    val seed = e2eModel()
    val staleApproval = seed.Copy(
        State          = Approval(SummaryBody = "ship it"),
        StateEnteredAt = staleInstantSec(int64(400)),
    )
    val (m, _) = Update(staleApproval, TickMsg())
    return m.State match {
        case Approval(_) => IsTrue(t, true)
        case _           => IsTrue(t, false)
    }
}

// ============================================================================
// Chunk-pipeline scenario: stale-drop must not kill the read pump.
//
// When PendingClosures[name] > 0, the FIRST chunk is dropped as stale
// (the killed-subprocess's straggler), but subsequent chunks must
// flow normally. An earlier shape returned NoCmd from the stale-drop
// path and the read pump died after one drop.
// ============================================================================
func TestE2E_ChunkAfterStaleDrop_ProcessesNormally(t T) T {
    val seed = e2eModel()
    val leadName = seed.Team.Lead.Name
    val staleState = seed.Copy(
        State           = TLThinking(),
        StateEnteredAt  = time_utils.Now(),
        PendingClosures = seed.PendingClosures.Put(leadName, 1),
    )
    val (m1, _) = Update(staleState, ChunkArrived(Member = leadName, Line = "stale straggler"))
    val t1 = Eq(t, m1.PendingClosures.Get(leadName).GetOrElse(0), 0)
    val (m2, _) = Update(m1, ChunkArrived(Member = leadName, Line = "real chunk after drop"))
    val leadConvo = m2.Conversation.Filter((cl) => cl.Speaker == leadName)
    return IsTrue(t1, leadConvo.Size() >= 1)
}

// ============================================================================
// Respawn-after-rotation replays the original dispatch instead of the
// generic "Continue your previous task." rescue prompt.
//
// Regression for a heartbeat-respawn shape where the engineer's
// rotated session had no prior context — the model replied "what
// should I work on?" and the heartbeat fired again, looping.
// We can't introspect the outbound Cmd's prompt without a fake
// transport, but we CAN confirm the precondition: LastDispatchedMsg
// is preserved across respawnMember so the rescue path can consult it.
// ============================================================================
func TestE2E_RespawnAfterRotation_PreservesDispatchBody(t T) T {
    val seed = e2eModel()
    val dispatchBody = "Refactor the foo module; tests must pass."
    val dispatchMsg = protocol.NewMessage(seed.Team.Lead.Name, "Felix", protocol.Dispatch(), dispatchBody, 0)
    val seeded = seed.Copy(
        State             = Delegating(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
        LastDispatchedMsg = seed.LastDispatchedMsg.Put("Felix", dispatchMsg),
        // SessionIds intentionally MISSING — simulates the post-
        // rotation state where respawnMember is about to mint a
        // fresh UUID via ensureSession.
    )
    val (m, _) = respawnMember(seeded, "Felix")
    val bodyPreserved = m.LastDispatchedMsg.Get("Felix") match {
        case Some(msg) => msg.Body == dispatchBody
        case None()    => false
    }
    return IsTrue(t, bodyPreserved)
}

// spawnTLNudge fires when the TL needs to address stuck members
// (heartbeat aggregate nudge, malformed dispatch, etc). It MUST NOT
// wipe LastDispatchedMsg — those entries are how respawnMember
// reconstructs the original task when a downstream watchdog rotates
// a still-pending member. Live audit showed rotated members waking
// up with no context after a TL nudge had cleared the map.
func TestE2E_SpawnTLNudge_PreservesLastDispatchedMsg(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val dispatchBody = "Refactor the foo module; tests must pass."
    val dispatchMsg = protocol.NewMessage(base.Team.Lead.Name, "Felix", protocol.Dispatch(), dispatchBody, 0)
    val seeded = base.Copy(
        State             = Delegating(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
        LastDispatchedMsg = base.LastDispatchedMsg.Put("Felix", dispatchMsg),
    )
    val (m, _) = spawnTLNudge(seeded, "stuck-batch", "Felix has been silent")
    val felixPreserved = m.LastDispatchedMsg.Get("Felix") match {
        case Some(msg) => msg.Body == dispatchBody
        case None()    => false
    }
    return IsTrue(t, felixPreserved)
}

// End-to-end: dispatch → TL nudge (which used to wipe dispatch) →
// rotation → assert respawnMember can still find the original body
// for the rescue prompt. The prior bug shape was: silent member →
// fireAggregateNudge → spawnTLNudge clears LastDispatchedMsg →
// watchdog rotates member → respawnMember's LastDispatchedMsg.Get(name)
// returns None → fallback rescue "Continue your previous task." sent
// → fresh claude session has zero context → "I don't have context."
func TestE2E_DispatchThenNudgeThenRotation_ReplaysOriginalBody(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val dispatchBody = "Refactor the foo module; tests must pass."
    val dispatchMsg = protocol.NewMessage(base.Team.Lead.Name, "Felix", protocol.Dispatch(), dispatchBody, 0)
    val seeded = base.Copy(
        State             = Delegating(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
        LastDispatchedMsg = base.LastDispatchedMsg.Put("Felix", dispatchMsg),
    )
    val (afterNudge, _) = spawnTLNudge(seeded, "stuck-batch", "Felix has been silent")
    // Now simulate the rotation: drop Felix's SessionId.
    val rotated = afterNudge.Copy(SessionIds = afterNudge.SessionIds.Remove("Felix"))
    val (afterRespawn, _) = respawnMember(rotated, "Felix")
    val bodyStillThere = afterRespawn.LastDispatchedMsg.Get("Felix") match {
        case Some(msg) => msg.Body == dispatchBody
        case None()    => false
    }
    return IsTrue(t, bodyStillThere)
}

// ============================================================================
// Heartbeat must NOT tick member liveness outside Delegating/QAGate.
// Live audit caught this as a TLReview self-loop livelock: every ~2
// minutes the heartbeat re-fired MemberStuck(<silent member>) from
// TLReview → TLReview, AND spawned a fresh TL nudge each time —
// clobbering the lead's actual review turn.
// ============================================================================

// TLReview state with a stale DeliveryState entry for a non-pending
// member: heartbeat must be a no-op. State must stay TLReview, no
// FSM transition fires.
func TestE2E_Heartbeat_InTLReview_NoMemberStuckRefires(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val staleNanos = int(base.NowAt.UnixNanos()) - int(time_utils.Seconds(int64(600)).ToNanos())
    val dispatchMsg = protocol.NewMessage(base.Team.Lead.Name, "Felix", protocol.Dispatch(), "old task", 0)
    val seeded = base.Copy(
        State             = TLReview(),
        LastDispatchedMsg = base.LastDispatchedMsg.Put("Felix", dispatchMsg),
        DeliveryStates    = base.DeliveryStates.Put("Felix", protocol.Sent(AtNanos = staleNanos, Attempt = 1)),
    )
    val (m, _) = Update(seeded, TickMsg())
    return m.State match {
        case TLReview() => IsTrue(t, true)
        case _          => IsTrue(t, false)
    }
}

// Same for Idle: the user is the next event, no member should be
// nudged regardless of how stale their delivery state is.
func TestE2E_Heartbeat_InIdle_NoMemberStuckRefires(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val staleNanos = int(base.NowAt.UnixNanos()) - int(time_utils.Seconds(int64(600)).ToNanos())
    val dispatchMsg = protocol.NewMessage(base.Team.Lead.Name, "Felix", protocol.Dispatch(), "old task", 0)
    val seeded = base.Copy(
        State             = Idle(),
        LastDispatchedMsg = base.LastDispatchedMsg.Put("Felix", dispatchMsg),
        DeliveryStates    = base.DeliveryStates.Put("Felix", protocol.Sent(AtNanos = staleNanos, Attempt = 1)),
    )
    val (m, _) = Update(seeded, TickMsg())
    return IsTrue(t, stateIsIdle(m))
}

// Delegating is the canonical active state — heartbeat MUST tick
// here (regression in case the skip logic accidentally over-broadens).
// Seed: dispatch in the Stuck band (120-300s old) AND retry budget
// already spent (Attempt > MaxRetries=2) so escalate() returns
// IssueNudge instead of Redeliver. AggregateNudges then fires
// MemberStuck → TLNudging(reason="stuck", ...).
func TestE2E_Heartbeat_InDelegating_StillFiresMemberStuck(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val staleNanos = int(base.NowAt.UnixNanos()) - int(time_utils.Seconds(int64(200)).ToNanos())
    val dispatchMsg = protocol.WithAttempt(
        protocol.NewMessage(base.Team.Lead.Name, "Felix", protocol.Dispatch(), "old task", 0),
        3,  // > MaxRetries=2
    )
    val seeded = base.Copy(
        State             = Delegating(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
        Statuses          = base.Statuses.Put("Felix", StWorking()),
        LastDispatchedMsg = base.LastDispatchedMsg.Put("Felix", dispatchMsg),
        DeliveryStates    = base.DeliveryStates.Put("Felix", protocol.Sent(AtNanos = staleNanos, Attempt = 3)),
        // Don't seed StateEnteredAt as stale — we don't want the
        // state-dwell watchdog to fire; we want the per-member
        // heartbeat to fire MemberStuck through AggregateNudges.
        StateEnteredAt    = base.NowAt,
    )
    val (m, _) = Update(seeded, TickMsg())
    val movedToNudging = m.State match {
        case TLNudging(reason, _, _) => reason == "stuck"
        case _                    => false
    }
    return IsTrue(t, movedToNudging)
}

// ============================================================================
// No-status-directive nudge: a member's session ending without
// @finished / @help / @blocked must NOT silently drain the pending
// set. Live audits saw rotated members reply with plain prose ("I
// don't have context...") and exit; the prior orchestrator marked
// them MemberDone with empty body. Now we nudge and bump RetryCount;
// after maxRetries escalations the member lands in StFailed.
// ============================================================================

// Plain-prose EOF: member's buffer holds only chat — no directive,
// no malformation. FSM must stay in Delegating with Felix still
// pending; status flips to StWorking (the nudge respawn fired).
func TestE2E_SessionFailed_NoStatusDirective_NudgesNotMemberDone(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val seeded = base.Copy(
        State         = Delegating(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
        MemberBuffers = base.MemberBuffers.Put("Felix", "I'm not sure what you'd like me to work on."),
    )
    val (m, _) = Update(seeded, SessionFailed(Member = "Felix", ErrText = "EOF"))
    val stillPending = m.State match {
        case Delegating(p, _) => p.Contains("Felix")
        case _             => false
    }
    val nudgeBumped = m.RetryCount.Get("Felix").GetOrElse(0) == 1
    val noMemberDoneBody = !m.MemberDoneBodies.Contains("Felix")
    val t1 = IsTrue(t,  stillPending)
    val t2 = IsTrue(t1, nudgeBumped)
    return IsTrue(t2, noMemberDoneBody)
}

// Empty-buffer EOF: member spawned, never spoke, then session ended.
// Same shape as above — the member did NOT complete the work; nudge
// them.
func TestE2E_SessionFailed_EmptyBuffer_NudgesNotMemberDone(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val seeded = base.Copy(
        State = Delegating(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
    )
    val (m, _) = Update(seeded, SessionFailed(Member = "Felix", ErrText = "EOF"))
    val stillPending = m.State match {
        case Delegating(p, _) => p.Contains("Felix")
        case _             => false
    }
    return IsTrue(t, stillPending)
}

// After maxRetries no-directive nudges, the member is StFailed and
// the FSM no longer wastes cycles re-nudging. State stays Delegating
// (the TL still needs to learn about the failure via a relay).
func TestE2E_SessionFailed_NoStatusDirective_PastMaxNudges_Escalates(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val maxNudges = maxAutoRetriesOf(base)
    val seeded = base.Copy(
        State         = Delegating(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
        MemberBuffers = base.MemberBuffers.Put("Felix", "still no idea"),
        // Already exhausted the nudge budget — next EOF must escalate.
        RetryCount    = base.RetryCount.Put("Felix", maxNudges),
    )
    val (m, _) = Update(seeded, SessionFailed(Member = "Felix", ErrText = "EOF"))
    val felixFailed = m.Statuses.Get("Felix") match {
        case Some(StFailed(_)) => true
        case _                 => false
    }
    val noMemberDoneBody = !m.MemberDoneBodies.Contains("Felix")
    val t1 = IsTrue(t,  felixFailed)
    return IsTrue(t1, noMemberDoneBody)
}

// Regression for the EOF-after-@finished path: when MemberDoneBodies
// already has an entry (finaliseMemberDone fired inline from chunk
// parsing), the trailing EOF must remain a no-op — NOT a nudge.
func TestE2E_SessionFailed_AlreadyFiredMemberDone_NoNudge(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val seeded = base.Copy(
        State            = TLReview(),
        MemberDoneBodies = base.MemberDoneBodies.Put("Felix", "shipped"),
        Statuses         = base.Statuses.Put("Felix", StWorking()),
    )
    val (m, _) = Update(seeded, SessionFailed(Member = "Felix", ErrText = "EOF"))
    val stillTLReview = m.State match {
        case TLReview() => true
        case _          => false
    }
    val statusIdle = m.Statuses.Get("Felix") match {
        case Some(StIdle()) => true
        case _              => false
    }
    val noNudgeBump = m.RetryCount.Get("Felix").GetOrElse(0) == 0
    val t1 = IsTrue(t,  stillTLReview)
    val t2 = IsTrue(t1, statusIdle)
    return IsTrue(t2, noNudgeBump)
}

// ============================================================================
// FSM property tests — global invariants over the (state, event) matrix.
// These avoid KeySubmit because that path synchronously spawns a real
// claude subprocess via ensureSession. The onSubmit/KeySubmit-related
// contracts (LastUserPrompt capture, latch reset) are covered by the
// existing TestOnSubmit_* cases in update_test.gala — those run more
// slowly but already exist; we don't reproduce them here.
// ============================================================================

// Every non-terminal state with stale timestamps reaches Idle or
// TLThinking on one Tick. (TLThinking via auto-retry; Idle otherwise.)
func TestE2EProperty_NonTerminalStates_WatchdogReachesIdleOrTLThinking(t T) T {
    val states = ArrayOf[AppState](
        TLThinking(),
        TLReview(),
        TLNudging(Reason = "stuck", Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
        Delegating(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
        QAGate(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
    )
    val seed = e2eModel()
    val results = states.Map((st) => {
        val m = seed.Copy(
            State          = st,
            StateEnteredAt = staleInstantSec(int64(700)),  // > member ceiling (600s)
        )
        val (m1, _) = Update(m, TickMsg())
        return stateIsIdle(m1) || stateIsTLThinking(m1)
    })
    val allReached = results.FoldLeft(true, (acc, r) => acc && r)
    return IsTrue(t, allReached)
}

// Idle and Approval are exempt from the watchdog.
func TestE2EProperty_IdleApproval_NeverTripWatchdog(t T) T {
    val seed = e2eModel()
    val staleIdle = seed.Copy(
        State          = Idle(),
        StateEnteredAt = staleInstantSec(int64(700)),
    )
    val staleApproval = seed.Copy(
        State          = Approval(SummaryBody = "ship it"),
        StateEnteredAt = staleInstantSec(int64(700)),
    )
    val (mIdle, _)     = Update(staleIdle, TickMsg())
    val (mApproval, _) = Update(staleApproval, TickMsg())
    val idleStayed     = stateIsIdle(mIdle)
    val approvalStayed = mApproval.State match {
        case Approval(_) => true
        case _           => false
    }
    return IsTrue(t, idleStayed && approvalStayed)
}

// stateTag is total + unique. Catches a new AppState case added
// without updating stateTag.
func TestE2EProperty_StateTag_IsTotalAndUnique(t T) T {
    val states = ArrayOf[AppState](
        Idle(),
        TLThinking(),
        TLReview(),
        TLNudging(Reason = "stuck", Pending = EmptyHashSet[string](), Dispatched = EmptyHashSet[string]()),
        Delegating(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
        QAGate(Pending = EmptyHashSet[string]().Add("Felix"), Dispatched = EmptyHashSet[string]().Add("Felix")),
        Approval(SummaryBody = "ship it"),
    )
    val tags = states.Map((st) => stateTag(st))
    val allNonEmpty = tags.FoldLeft(true, (acc, tag) => acc && tag != "")
    val allUnique = tags.Size() == tags.FoldLeft(EmptyHashSet[string](), (s, t) => s.Add(t)).Size()
    val t1 = IsTrue(t, allNonEmpty)
    return IsTrue(t1, allUnique)
}

// looksLikeStreamJson detects only real envelope shapes; arbitrary
// prose and partial fragments return false.
func TestE2EProperty_LooksLikeStreamJson_OnlyTrueForEnvelopes(t T) T {
    val envelopes = ArrayOf[string](
        "{\"type\":\"assistant\",\"message\":{\"content\":[]}}",
        "{\"type\":\"user\",\"message\":{}}",
        "{\"type\":\"result\",\"is_error\":false}",
        // Multi-envelope: claude occasionally dumps two newline-joined
        // stream-json lines into one stderr write. First line still
        // parses; the second-line tail used to break the strict
        // decoder and leak raw JSON into LastError.
        "{\"type\":\"user\",\"message\":{}}\n{\"type\":\"user\",\"message\":{}}",
        // Truncated mid-envelope (claude write got cut off). The bytes
        // are still recognisably a stream-json envelope; the prefix
        // heuristic catches it so the user sees the friendly tag
        // instead of the raw JSON.
        "{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01abc",
    )
    val prose = ArrayOf[string](
        "",
        "I am working on it",
        "{ malformed json",
        "Failed to authenticate. API Error: 401",
        "{\"not_type\":\"x\"}",
        // Important: a plain object that doesn't start with
        // {"type":"..." must NOT match — otherwise we'd suppress
        // legitimate JSON-looking content like config blocks the
        // user pasted.
        "{\"foo\":\"bar\"}",
    )
    val allEnvelopesTrue = envelopes.Map((s) => looksLikeStreamJson(s)).FoldLeft(true, (acc, b) => acc && b)
    val allProseFalse    = prose.Map((s) => !looksLikeStreamJson(s)).FoldLeft(true, (acc, b) => acc && b)
    val t1 = IsTrue(t, allEnvelopesTrue)
    return IsTrue(t1, allProseFalse)
}

// ============================================================================
// KeySubmit-driven scenarios. These exercise the real onSubmit path
// (FSM transition, prompt capture, latch reset, spawn) but the spawn
// itself is short-circuited via SetSpawnDisabledForTest — ensureSession
// records a SessionId + LastChunkAt without launching a real claude
// process. Sessions stays unset, so sendAndPumpCmd returns NoCmd.
// ============================================================================

// IMPORTANT: every KeySubmit test below binds `e2eModel()` to a val
// BEFORE calling `.Copy(...)`. The transpiler inlines a bare
// `e2eModel().Copy(...)` once per Copy field (~80 fields in
// AppModel), making 80 fresh MkdirTemp + InitialModel calls per test
// — minutes of work each. Bind to a val first.

// KeySubmit on a non-empty composer captures the prompt into
// LastUserPrompt so the watchdog auto-retry can replay it on
// recovery. Resets the per-prompt latch (WatchdogRetryFired) so this
// turn gets its own one-shot retry budget.
func TestE2E_KeySubmit_CapturesPromptAndResetsLatch(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val seed = base.Copy(
        Composer           = "do the thing",
        ComposerCursor     = len("do the thing"),
        WatchdogRetryFired = true,
    )
    val (m, _) = Update(seed, KeySubmit())
    val promptCaptured  = m.LastUserPrompt == "do the thing"
    val latchReset      = !m.WatchdogRetryFired
    val composerCleared = m.Composer == ""
    val t1 = IsTrue(t,  promptCaptured)
    val t2 = IsTrue(t1, latchReset)
    return IsTrue(t2, composerCleared)
}

// KeySubmit on empty composer is a no-op: no FSM transition, no
// LastUserPrompt mutation, no Composer change.
func TestE2E_KeySubmit_EmptyComposer_NoOp(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val seed = base.Copy(
        Composer       = "",
        LastUserPrompt = "previous",
    )
    val (m, _) = Update(seed, KeySubmit())
    val stateUnchanged  = stateIsIdle(m)
    val promptPreserved = m.LastUserPrompt == "previous"
    val t1 = IsTrue(t, stateUnchanged)
    return IsTrue(t1, promptPreserved)
}

// KeySubmit transitions Idle → TLThinking, mints a SessionId for the
// lead, and stamps LastChunkAt at spawn time so the heartbeat doesn't
// trip against a zero-valued instant.
func TestE2E_KeySubmit_TransitionsToTLThinkingAndSpawns(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val seed = base.Copy(
        Composer       = "ship the feature",
        ComposerCursor = len("ship the feature"),
    )
    val leadName = seed.Team.Lead.Name
    val (m, _) = Update(seed, KeySubmit())
    val transitioned = stateIsTLThinking(m)
    val sidMinted    = m.SessionIds.Get(leadName).IsDefined()
    val stampSet     = m.LastChunkAt.Get(leadName).IsDefined()
    val t1 = IsTrue(t,  transitioned)
    val t2 = IsTrue(t1, sidMinted)
    return IsTrue(t2, stampSet)
}

// Two consecutive KeySubmits keep the lead's SessionId stable across
// turns. claude --print is conversation-resumed via --resume <sid>,
// not re-minted per turn — drifting the sid would lose context.
func TestE2E_KeySubmit_TwiceSameLead_SessionIdStableAcrossTurns(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val seed = base.Copy(
        Composer       = "turn one",
        ComposerCursor = len("turn one"),
    )
    val leadName = seed.Team.Lead.Name
    val (m1, _) = Update(seed, KeySubmit())
    val sid1 = m1.SessionIds.Get(leadName).GetOrElse("")
    val m1Idle = m1.Copy(
        State          = Idle(),
        Composer       = "turn two",
        ComposerCursor = len("turn two"),
    )
    val (m2, _) = Update(m1Idle, KeySubmit())
    val sid2 = m2.SessionIds.Get(leadName).GetOrElse("")
    return Eq(t, sid1, sid2)
}

// Auto-retry chain: KeySubmit lands TLThinking, then a watchdog fire
// against a silent lead must restamp state, set the latch, and keep
// LastUserPrompt — the auto-retry path needs all three.
func TestE2E_KeySubmit_ThenSilentWatchdog_AutoRetries(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val seed = base.Copy(
        Composer       = "retry me",
        ComposerCursor = len("retry me"),
    )
    val (m1, _) = Update(seed, KeySubmit())
    val staleM1 = m1.Copy(
        StateEnteredAt = staleInstantSec(int64(400)),
        LastChunkAt    = m1.LastChunkAt.Remove(m1.Team.Lead.Name),
    )
    val (m2, _) = Update(staleM1, TickMsg())
    val retried    = stateIsTLThinking(m2)
    val latchSet   = m2.WatchdogRetryFired
    val promptKept = m2.LastUserPrompt == "retry me"
    val t1 = IsTrue(t,  retried)
    val t2 = IsTrue(t1, latchSet)
    return IsTrue(t2, promptKept)
}

// Second silent watchdog fire with the latch already burned lands in
// Idle (no infinite retry loop). End-to-end variant driving the latch
// via a real KeySubmit + auto-retry rather than seeding by hand.
func TestE2E_KeySubmit_SecondSilentWatchdog_LandsInIdle(t T) T {
    SetSpawnDisabledForTest(true)
    defer SetSpawnDisabledForTest(false)
    val base = e2eModel()
    val seed = base.Copy(
        Composer       = "first try",
        ComposerCursor = len("first try"),
    )
    val (m1, _) = Update(seed, KeySubmit())
    val leadName = m1.Team.Lead.Name
    val stale1 = m1.Copy(
        StateEnteredAt = staleInstantSec(int64(400)),
        LastChunkAt    = m1.LastChunkAt.Remove(leadName),
    )
    val (m2, _) = Update(stale1, TickMsg())
    val stale2 = m2.Copy(
        StateEnteredAt = staleInstantSec(int64(400)),
        LastChunkAt    = m2.LastChunkAt.Remove(leadName),
    )
    val (m3, _) = Update(stale2, TickMsg())
    return IsTrue(t, stateIsIdle(m3))
}

// guard against unused-import warnings while the file grows.
val _e2eUnusedImport = strings.TrimSpace("")
