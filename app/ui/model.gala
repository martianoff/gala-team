package ui

import (
    "github.com/martianoff/gala_team/app/session"
    "github.com/martianoff/gala_team/app/directive"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/time_utils"
    . "github.com/martianoff/gala-tui"
    . "github.com/martianoff/gala_team/app/consult"
    . "github.com/martianoff/gala_team/app/guidance"
    . "github.com/martianoff/gala_team/app/team"
    . "github.com/martianoff/gala_team/app/fsm"
    . "github.com/martianoff/gala_team/app/policy"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/runtime"
    . "github.com/martianoff/gala_team/app/view"
)

// ============================================================================
// app/ui — Elm model + message vocabulary for the gala_team TUI.
//
// Owns the full AppModel that the gala_tui runtime drives, plus the
// AppMsg sealed type that carries every event the UI cares about
// (keyboard, tick, runtime subprocess events).
// ============================================================================

// ConversationLine lives in app/session — durably-storable shape that
// the on-disk snapshot uses too. Re-exported here as a convenience so
// existing references in update.gala / view.gala still resolve.

// AppModel is the top-level Elm model.  Everything the view() function
// needs to render must live here.  Mutations happen only through
// update() returning a new copy.
struct AppModel(
    Project      Project,
    Guidance     Guidance,
    Team         Team,
    // Every team declared in team.yaml. The main team is `Team`
    // (selected at startup via --team-key); the rest are
    // in-project consult targets addressable by Key from
    // `@consult(<key>)`. Empty for legacy single-team yamls is
    // never observed because team_config.validate always populates
    // at least one entry.
    Teams        Array[Team],
    Workflow     Workflow,
    Policy       Policy,
    Registry     Registry,                         // cross-team consult targets
    State        AppState,
    Statuses     HashMap[string, Status],
    Pipeline     PipelineState,
    Sessions     HashMap[string, MemberSession],   // live subprocess per member name
    Conversation Array[session.ConversationLine],  // rendered log of TL talk + chunks
    // ConversationOffset is the top visible line of the scrollback when
    // ConversationSticky is false. Sticky mode (the default) ignores
    // Offset and keeps the view pinned to the latest line. PgUp /
    // arrow-up flips Sticky off; End / PgDn-past-bottom flips it back.
    ConversationOffset int,
    ConversationSticky bool,
    // MemberDetailOpen, when Some(name), pops a full-screen modal that
    // shows just `name`'s transcript + role / status metadata. The
    // user opens it with Enter on a sidebar member row (FocusSidebar)
    // and closes it with Esc. None means no modal is displayed.
    MemberDetailOpen Option[string],
    // PendingClosures counts how many stale SessionFailed events we
    // expect per member name. Incremented by closeLiveSession when it
    // kills an in-flight subprocess; decremented by onSessionFailed
    // when a SessionFailed arrives. Non-zero counts cause that
    // SessionFailed to be treated as a no-op (the EOF is from the
    // process we just killed, not the fresh one). Without this, a
    // fast-double-submit's stale EOF removes the new session from
    // m.Sessions and the new turn's read pump can't re-arm.
    PendingClosures HashMap[string, int],
    // WorkElapsedNs tracks per-member cumulative time spent in a
    // working status (StWorking / StSlow / StStuck / StRecovering).
    // The sidebar shows this as the member's "work duration" — it
    // pauses when the member goes idle and resumes when they're put
    // back to work. Distinct from LastChunkAt which only feeds the
    // liveness FSM (StSlow / StStuck thresholds).
    WorkElapsedNs HashMap[string, int64],
    // WorkStartedAt is the timestamp the member most recently
    // entered a working status. Used to compute "current segment"
    // duration (now - WorkStartedAt) which is added to
    // WorkElapsedNs[name] to render the live timer. Removed from the
    // map when the member transitions back to idle.
    WorkStartedAt HashMap[string, Instant],
    // TokenUsage tallies cumulative input/output/cache-read tokens
    // per member across every claude turn this session has run.
    // Updated from result-event payloads as they arrive in onChunk;
    // surfaced in the header as a live total across the whole team.
    TokenUsage HashMap[string, ClaudeUsage],
    // CurrentTurnUsage is the in-flight cumulative usage from the
    // most recent assistant chunk per member. Live header tick uses
    // TokenUsage[name] + CurrentTurnUsage[name]. Replaced (not
    // added) on each assistant chunk because claude's per-chunk
    // usage is cumulative-for-this-turn. Cleared when the result
    // event commits the turn into TokenUsage.
    CurrentTurnUsage HashMap[string, ClaudeUsage],
    // TotalCostUsd is the sum of `total_cost_usd` across every
    // result event we've seen this session. Approximate (claude
    // computes it server-side); good enough for "did this turn
    // cost a quarter or a hundred dollars" awareness.
    TotalCostUsd float64,
    // Command-palette state. None when the overlay is closed; Some
    // when it's open with a live picker. Toggled by Ctrl+P (see
    // KeyTogglePalette) and PaletteEvent dispatches.
    Palette Option[Palette[AppMsg]],
    // ViewMode picks the top-level layout: the default split, a
    // fullscreen pipeline org chart (F4), a member-card grid (F3),
    // or focus mode that hides the sidebar (F2). Plain sealed type
    // (no generic params) so the default lowers to ViewDefault()
    // cleanly without the Option-of-generic-struct quirk.
    ViewMode ViewMode,
    Composer     string,                           // current draft prompt text
    // Cursor position (rune offset, 0..len(Composer in runes)) for
    // edit-in-place. Without this, every keystroke could only append
    // and Backspace could only chop the last character — no way to
    // fix mistakes mid-line. Left/Right/Home/End/Delete now use this
    // index to insert/remove anywhere in the draft.
    ComposerCursor int,
    Tick         int,                              // monotonic tick counter (drives spinners)
    LastError    Option[string],                   // most recent runtime error, footer
    // Open PRs accumulated this session (oldest first). Each successful
    // gh pr create appends a BatchPr. The list only grows — merging is
    // done by the user on GitHub, never by the app, so entries are
    // never consumed here. Surfaced so the user can review the batch
    // in GitHub when ready.
    OpenPrs      Array[BatchPr],
    // AutoApprove turns the per-PR approval gate off — see the policy
    // doc on Policy.AutoApprove. Seeded from policy.auto_approve at
    // startup, toggled mid-session via F7. Stored on the model so the
    // F7 toggle can flip it without rewriting team.yaml.
    AutoApprove  bool,
    // Resolved base ref for the PR this turn will eventually open.
    // None = the project's default branch (the gh pr create default).
    // Some(ref) is set when the TL emits an `@base <ref>` directive.
    // `previous` is resolved to the most recent OpenPrs entry's branch
    // at directive time, so this field always carries a literal branch
    // name. Cleared on every new user prompt, every Approval acceptance
    // (PR has been opened), and every Approval rejection.
    ActiveBase   Option[string],
    // Branch name of the PR currently being iterated on. Set on the
    // first PR opened in this session; subsequent approvals reuse
    // this branch so that user feedback → TL fix → re-approve UPDATES
    // the existing PR instead of cutting a fresh `gala_team/<proj>/pr/<sha>`
    // every time. Cleared on merge (PR shipped → next is a fresh
    // identity), on Start fresh / Ctrl+N (worktree wipe invalidates
    // the branch), and at each plan auto-continue boundary (each
    // step of a `@plan` is a separate PR by design). None when no
    // PR is currently open.
    ActivePrBranch Option[string],
    // Multi-PR plan queued by the TL via `@plan`. Plan is the full
    // ordered list of step prompts; PlanShipped counts how many of
    // them have already produced a PR. The step currently in
    // progress is `Plan.Get(PlanShipped)` (when PlanShipped <
    // Plan.Size()). Plan is "complete" when PlanShipped equals
    // Plan.Size().
    //
    // Auto-continuation fires on every PrCreated while AutoApprove
    // is on and PlanShipped is still less than Plan.Size() — the
    // next step is staged in Composer and a synthetic KeySubmit
    // re-enters onSubmit. The plan banner above the composer renders
    // the per-step status (✓ shipped / ▶ in progress / ☐ queued).
    //
    // Both fields are cleared on every user-issued KeySubmit so a
    // fresh prompt overrides any pending plan — EXCEPT when the
    // submit is the orchestrator's own plan-step continuation (see
    // PlanContinuing).
    Plan         Array[string],
    PlanShipped  int,
    // PlanContinuing flags the one synthetic KeySubmit that
    // onPrCreated fires to advance a multi-PR plan to its next step.
    // onSubmit reads it to SKIP the blanket Plan/PlanShipped reset
    // (a plan-continuation is not a fresh user prompt — it must keep
    // the plan alive) and clears it on the way through. Without this
    // the plan was wiped after the first hop, so a 4-PR plan only
    // ever shipped 2 steps even under AutoApprove. Defaults false so
    // legacy snapshots / .Copy() callers are unaffected.
    PlanContinuing bool = false,
    // Anchor of a conversation-pane selection. Set on a mouse press
    // inside the pane; preserved across a drag. None = no selection.
    SelectedEntry Option[int],
    // Focus of the selection — the current end of the range while a
    // drag is in progress, or the same value as SelectedEntry for a
    // bare click. The visible range is min(anchor, focus) ..
    // max(anchor, focus). When SelectedEntry is None this is None
    // too (the two fields move together). Updated continuously by
    // motion-while-held events during a drag.
    SelectionFocus Option[int],
    // True while the mouse button is held after a press inside the
    // conversation pane. Drives "should we keep updating
    // SelectionFocus on each motion event?" — once the user
    // releases, motion events outside the conversation pane stop
    // dragging the focus. Reset on release, on Esc, on
    // KeyEraseSession, and on every successful KeySubmit.
    Dragging bool,
    // Per-turn TL output accumulator. Reset on every KeySubmit. Used by
    // the chunk pump to detect newly-completed @consult blocks without
    // re-scanning the entire conversation log.
    TurnBuffer    string,
    // Count of @consult directives already dispatched in the current
    // turn. The directive parser returns directives in source order, so
    // anything past index `ConsultsFired` in the parsed list is new
    // and must be kicked off.
    ConsultsFired int,
    // Live cross-team consults keyed by registry name. Populated when
    // SpawnConsult succeeds; dropped when the matching ConsultEnded
    // fires. Drives the consult viewer modal.
    ActiveConsults HashMap[string, ConsultSession],
    // Per-consult accumulator of raw stdout lines (no `[consult/<name>]`
    // prefix). Drained by onConsultEnded for summary extraction, then
    // discarded. Also rendered live in the consult viewer modal.
    ConsultBuffers HashMap[string, Array[string]],
    // Toggled by Tab. When true, the main conversation pane is
    // replaced by the consult viewer overlay listing every active
    // consult and its last few streamed lines.
    ConsultViewerOpen bool,
    // Past sessions archived under .gala_team/sessions/archive/,
    // loaded once at startup. Browsable via Ctrl+H.
    Archives Array[session.SnapshotMeta],
    // Toggled by Ctrl+H. When true the main pane shows the history
    // browser; when an archive is selected, ViewingArchive carries
    // the loaded Snapshot for read-only display.
    HistoryMode    bool,
    ViewingArchive Option[session.Snapshot],
    // Cursor position into the archives list — clamped to
    // 0..Archives.Size()-1 by the navigation handlers.
    HistoryCursor int,
    // Names of members whose Claude subprocess was alive in the
    // prior session and should be re-spawned with `--continue` on
    // first use. Populated by primeFromSnapshot at startup; drained
    // by ensureSession as each recovered member is respawned.
    RecoveredMembers Array[string],
    // Per-member claude session id (UUID-shaped hex string). The
    // first spawn for a member generates a fresh id and records it
    // here; subsequent spawns pass it as `--resume` so claude
    // threads conversation context across turns. Persisted in the
    // snapshot so the ids survive a restart. Empty until the
    // member's first turn.
    SessionIds HashMap[string, string],
    // True when a session was restored from latest.json on launch.
    // Drives the "↻ Restored …" banner above the conversation pane.
    // Cleared by Esc (also wipes Conversation + RecoveredMembers
    // for a fresh start) or by the first chunk that arrives in a
    // recovered member's stream.
    RecoveryBannerVisible bool,
    QuitPending bool,
    // Two-press-confirmation flag for the erase-session shortcut
    // (Ctrl+N). First press arms; the footer flips to a yellow
    // "Erase session?" prompt; a second Ctrl+N within the next
    // few keystrokes performs the erase. Esc cancels.
    EraseSessionPending bool,
    // True while the async Start fresh / Ctrl+N wipe is running its
    // git ops in a Future (see runtime.WipeWorktreesFuture). The view
    // shows a "Wiping worktrees…" banner so the user knows the
    // (5-10s) freeze is expected progress, not a hang. Cleared by
    // the WorktreesWiped message handler.
    WipingWorktrees bool,
    // Which panel keystrokes target. FocusComposer is the default
    // (typing → composer); FocusSidebar redirects Up/Down to move
    // SidebarCursor and Space to fold/unfold the role group at the
    // cursor. Toggled by Ctrl+L; Esc always returns to composer.
    Focus FocusState,
    // Cursor index into the visible sidebar tree (0 = first row).
    // Only meaningful when Focus = FocusSidebar.
    SidebarCursor int,
    // Names of role groups currently collapsed in the team panel.
    // Default is empty (everything expanded). Toggled with Space
    // when SidebarCursor lands on a group header.
    CollapsedGroups Array[string],
    // Wall clock observed at the most recent TickMsg. Drives all
    // elapsed-time and countdown rendering in the sidebar / header
    // / toasts. UnixEpoch() until the first tick fires.
    NowAt Instant,
    // Per-member timestamp of the most recent ChunkArrived. Empty
    // for members with no activity yet. The heartbeat compares
    // (NowAt - LastChunkAt[name]) against thresholds to derive
    // StSlow / StStuck / StAbandoned transitions.
    LastChunkAt HashMap[string, Instant],
    // Per-member timestamp of when the orchestrator's next nudge
    // (TL relay turn) or auto-respawn fires. Sidebar shows
    // "nudge in 0:NN" / "retry in 0:NN" countdown when an entry
    // exists. Removed once the action fires.
    NudgeAt HashMap[string, Instant],
    // Wall clock observed when the FSM most recently transitioned.
    // Footer shows time-since-state-entered. UnixEpoch() at
    // construction; updated whenever Update() returns a model with
    // a different State.
    StateEnteredAt Instant,
    // Per-member crash retry counter. Incremented by onSessionFailed
    // for non-EOF errors; reset on successful chunk delivery. Used
    // by auto-recovery to escalate after maxRetries.
    RetryCount HashMap[string, int],
    // Transient notifications surfaced to the user when liveness
    // status escalates (member slow / stuck / crashed / recovered).
    // Pruned by onTick once each toast's TTL expires. Rendered via
    // gala_tui's ToastStackView in an overlay band above the
    // conversation pane.
    Toasts ToastQueue,
    // Per-member accumulator of streamed lines, mirrors the TL-side
    // TurnBuffer. Used by maybeHandleMemberDirectives to find newly-
    // completed @done / @help / @blocked blocks each chunk. Cleared
    // when the member's session ends.
    MemberBuffers HashMap[string, string],
    // Per-member raw-byte buffer for assembling complete claude
    // stream-json envelopes from chunked stdout. claude emits one
    // envelope per line in stream-json mode, but the runtime line
    // reader can split a giant envelope mid-content when the OS
    // flushes claude's stdout buffer at a sub-line boundary. We
    // accumulate every ChunkArrived line into this per-member buffer
    // and use brace-counted extraction to pull out only COMPLETE
    // `{...}` JSON objects before applying the whitelist. Fragments
    // are never processed — they sit in the buffer until their other
    // half arrives. Cleared on session end.
    MemberJsonBuf HashMap[string, string],
    // Per-member watermark of how many directives the buffer parser
    // has already dispatched. Same shape as ConsultsFired but for
    // member-emitted directives. The parser returns directives in
    // source order so anything past index N is new.
    MemberDirectivesFired HashMap[string, int],
    // Captured @done body per member from the most recent dispatched
    // turn. Drained by buildRelayPrompt when the orchestrator opens a
    // TL relay turn (#28). Empty string if a member finished via EOF
    // without an explicit @done block.
    MemberDoneBodies HashMap[string, string],
    // Captured @blocked reason per member from the most recent
    // dispatched turn. Populated by onMemberBlocked, consumed by
    // buildRelayPrompt + the proactive @blocked nudge so the TL
    // sees the WHY when handling the failure. Cleared on the same
    // beats as MemberDoneBodies (after relay or new user turn).
    MemberBlockedReasons HashMap[string, string],
    // Members that have already had their workflow.post_engineer_prompt
    // re-sent for the CURRENT dispatch cycle. The post-prompt is a
    // one-shot per engineer per dispatch: an engineer finishes + commits,
    // gets the prompt re-sent in-session once, then on the second finish
    // (post-prompt work also committed) drains to QA. Membership here is
    // the loop guard that distinguishes "first finish, send the prompt"
    // from "second finish, fall through to drain". Cleared per-member on
    // a fresh @dispatch so a brand-new task gets its own post-prompt
    // round; deliberately NOT cleared on crash/respawn/nudge so a
    // respawn mid-post-prompt cannot re-fire it.
    PostPromptSent HashSet[string],
    // Per-member counter of visible assistant chunks rendered in the
    // CURRENT turn. Used to deduplicate the result-event echo: when
    // claude streams text chunks AND emits a final `result.result`
    // field carrying the same text, we render the streamed version
    // and drop the echo. When the counter is 0 at result time
    // (e.g. claude ran without --output-format stream chunks), we
    // render result.result so the turn isn't silently empty.
    // Reset on every new turn open (onSubmit / spawnDispatchedMembers
    // / spawnQAReview / spawnTLNudge / @consult relay).
    TurnVisibleChunks HashMap[string, int],
    // Toggles the help overlay. Bound to `?` and to a clickable `?`
    // button in the header (DESIGN.md §8.5). The overlay is a
    // floating modal that auto-renders the key + mouse parity matrix.
    HelpVisible bool,
    // Toggles the project-info modal (Frame S). Opened via clicking
    // the project name in the header or the palette entry. Shows
    // project / repo / github / branch / team / config metadata.
    ProjectInfoOpen bool,
    // Toggles the guidance modal (§5.7). The 📚 header button + `g`
    // open this; lists every loaded guidance doc with sha + path +
    // loaded-at. Loaded data lives in m.Guidance.
    GuidanceOpen bool,
    // Recovery drives the §5.6 modal. None when the modal is closed;
    // Some(choice) when it's open with `choice` as the focused
    // button (Resume / Inspect / Start fresh). The recovery flow
    // sets this from primeFromSnapshot when a prior session is
    // detected.
    Recovery Option[RecoveryChoice],
    // ReadOnlyMode = true when the user picked "Inspect" on the
    // recovery modal — sessions don't spawn, the composer is locked,
    // PR-related shortcuts are no-ops. Used purely for read-only
    // audit of a prior session.
    ReadOnlyMode bool,
    // CompactSidebar toggles the team-panel layout between wide
    // (default, 28-cell rows) and compact (single-line rows, ~24
    // members visible). Bound to Ctrl+, / Ctrl+. — DESIGN.md §8.5.
    CompactSidebar bool,
    // ApprovalFocus is which button of the §6.1 approval modal
    // currently holds focus. Only meaningful when State = Approval(_).
    // Tab cycles ApproveFocus ↔ RejectFocus; Enter fires the focused
    // choice. The view derives the focused button's reverse-bold
    // styling from this. Defaults to ApproveFocus so first-Enter
    // still ships, matching prior behavior.
    ApprovalFocus ApprovalChoice,
    // PendingQuestion carries the in-flight `AskUserQuestion` tool
    // call from a member's claude subprocess. Set when the chunk
    // pump sees a `tool_use` block with name=AskUserQuestion; cleared
    // when the user submits an answer (Enter on the composer) or
    // dismisses (Esc). While set, composer Enter routes to
    // onAnswerPendingQuestion (which sends the user's text back as a
    // tool_result envelope) instead of onSubmit (which would queue a
    // fresh user prompt).
    PendingQuestion Option[PendingQuestion],
    // PendingSummaryDirs holds Iris's just-parsed turn directives
    // while the off-thread PR-readiness probe runs. The lead's
    // EOF handler (onSessionFailed clean-close path) parses dirs,
    // detects a provisional Approval transition, stashes the dirs
    // here, and fires SummaryReadyCmd. When SummaryReadyResult
    // lands, onSummaryReady reads the dirs back and completes the
    // FSM transition (or nudges the TL if checkPrReady reported
    // the lead branch wasn't shippable). Stays None outside this
    // window; reset by onSummaryReady to None before returning.
    //
    // Wrapped in a local PendingSummary struct rather than stored
    // as Option[Array[directive.Directive]] directly because gala
    // gen-code strips package qualifiers from None[Array[X]]{}'s
    // inner type parameter, which breaks the cross-package
    // construction in cmd/main's gen output. None[PendingSummary]
    // sidesteps the issue since PendingSummary is local to ui.
    PendingSummaryDirs Option[PendingSummary],
)

// PendingSummary wraps the parsed TL directives so AppModel's
// default-value emission can stay package-qualifier-free; see
// the PendingSummaryDirs comment above.
struct PendingSummary(
    Dirs Array[directive.Directive],
)

// PendingQuestion captures the state needed to answer one in-flight
// AskUserQuestion tool call. The matching subprocess is identified by
// `Member`; `ToolUseId` is the id from the assistant's tool_use block
// and must round-trip back unchanged in the tool_result envelope.
// `QuestionText` is the question body — extracted from the input JSON
// and rendered in the conversation log so the user can see what's
// being asked even when the model's surrounding chat narration was
// sparse.
struct PendingQuestion(
    Member       string,
    ToolUseId    string,
    QuestionText string,
)

// BatchPr is one PR opened during this session. Stored in
// AppModel.OpenPrs as the auto-approve / batch flow accumulates them.
// OpenedAt drives the "PR ready 2m ago" relative-time display in the
// open-PR list; Title is the first line of the @summary body so the
// user can identify each entry without clicking through.
struct BatchPr(
    Url      string,
    Branch   string,
    Title    string,
    OpenedAt Instant,
)

// RecoveryChoice tracks which option of the §5.6 recovery modal is
// currently focused. The buttons are clickable; Tab cycles; Enter
// fires the focused choice.
sealed type RecoveryChoice {
    case ResumeFocus
    case InspectFocus
    case StartFreshFocus
}

// ApprovalChoice tracks which button of the approval modal currently
// holds focus. Tab cycles between the two; Enter fires the focused
// choice. Mouse-clicks bypass focus and dispatch directly. Defaults
// to ApproveFocus on entry to the Approval state so a quick Enter
// still ships the PR (preserves the prior "press Enter to approve"
// muscle memory).
sealed type ApprovalChoice {
    case ApproveFocus
    case RejectFocus
}

// FocusState selects which panel handles directional / activation
// keys. Mouse and global shortcuts are unaffected.
sealed type FocusState {
    case FocusComposer
    case FocusSidebar
}

// ViewMode picks the top-level layout. ViewDefault is the launching
// split (sidebar + conversation); the others are fullscreen
// alternatives toggled via function keys (Frame M/N/O/P of the
// design). ViewActivity is the reverse-chronological event stream
// (DESIGN.md Frame P, F5).
sealed type ViewMode {
    case ViewDefault
    case ViewFocus
    case ViewGrid
    case ViewPipeline
    case ViewActivity
}


// InitialModel builds an AppModel for a freshly-loaded team.  All members
// start Idle, no pipeline, no sessions, empty composer. `registry`
// defaults to empty so existing tests don't need to pass one — only
// production startup (cmd/main.gala) loads a real registry from
// .gala_team/consults.yaml. The Teams list always contains at least
// the main team — set via InitialModelWithTeams when the caller has
// the full list.
func InitialModel(
    proj Project,
    team Team,
    workflow Workflow,
    policy Policy,
    registry Registry = EmptyRegistry(),
) AppModel = InitialModelWithTeams(proj, team, workflow, policy, registry, ArrayOf(team))

// InitialModelWithTeams is the multi-team-aware constructor used by
// production startup; tests use the simpler InitialModel above.
func InitialModelWithTeams(
    proj Project,
    team Team,
    workflow Workflow,
    policy Policy,
    registry Registry,
    teams Array[Team],
) AppModel = AppModel(
    Project      = proj,
    Guidance     = EmptyGuidance(),
    Team         = team,
    Teams        = teams,
    Workflow     = workflow,
    Policy       = policy,
    Registry     = registry,
    State        = Idle(),
    Statuses     = EmptyHashMap[string, Status](),
    Pipeline     = EmptyPipelineState(),
    Sessions     = EmptyHashMap[string, MemberSession](),
    Conversation = EmptyArray[session.ConversationLine](),
    ConversationOffset = 0,
    ConversationSticky = true,
    MemberDetailOpen = None[string](),
    PendingClosures = EmptyHashMap[string, int](),
    WorkElapsedNs = EmptyHashMap[string, int64](),
    WorkStartedAt = EmptyHashMap[string, Instant](),
    TokenUsage = EmptyHashMap[string, ClaudeUsage](),
    CurrentTurnUsage = EmptyHashMap[string, ClaudeUsage](),
    TotalCostUsd = 0.0,
    Palette = None[Palette[AppMsg]](),
    ViewMode = ViewDefault(),
    Composer     = "",
    ComposerCursor = 0,
    Tick         = 0,
    LastError    = None[string](),
    OpenPrs      = EmptyArray[BatchPr](),
    AutoApprove  = policy.AutoApprove,
    ActiveBase   = None[string](),
    ActivePrBranch = None[string](),
    Plan         = EmptyArray[string](),
    PlanShipped  = 0,
    SelectedEntry  = None[int](),
    SelectionFocus = None[int](),
    Dragging       = false,
    TurnBuffer    = "",
    ConsultsFired = 0,
    ActiveConsults = EmptyHashMap[string, ConsultSession](),
    ConsultBuffers = EmptyHashMap[string, Array[string]](),
    ConsultViewerOpen = false,
    Archives          = EmptyArray[session.SnapshotMeta](),
    HistoryMode       = false,
    ViewingArchive    = None[session.Snapshot](),
    HistoryCursor     = 0,
    RecoveredMembers  = EmptyArray[string](),
    RecoveryBannerVisible = false,
    QuitPending           = false,
    EraseSessionPending   = false,
    WipingWorktrees       = false,
    Focus                 = FocusComposer(),
    SidebarCursor         = 0,
    CollapsedGroups       = EmptyArray[string](),
    SessionIds            = EmptyHashMap[string, string](),
    NowAt                 = UnixEpoch(),
    LastChunkAt           = EmptyHashMap[string, Instant](),
    NudgeAt               = EmptyHashMap[string, Instant](),
    StateEnteredAt        = UnixEpoch(),
    RetryCount            = EmptyHashMap[string, int](),
    Toasts                = NewToastQueue(5),
    MemberBuffers         = EmptyHashMap[string, string](),
    MemberJsonBuf         = EmptyHashMap[string, string](),
    MemberDirectivesFired = EmptyHashMap[string, int](),
    MemberDoneBodies      = EmptyHashMap[string, string](),
    MemberBlockedReasons  = EmptyHashMap[string, string](),
    PostPromptSent        = EmptyHashSet[string](),
    TurnVisibleChunks     = EmptyHashMap[string, int](),
    HelpVisible           = false,
    ProjectInfoOpen       = false,
    GuidanceOpen          = false,
    Recovery              = None[RecoveryChoice](),
    ReadOnlyMode          = false,
    CompactSidebar        = false,
    ApprovalFocus         = ApproveFocus(),
    PendingQuestion       = None[PendingQuestion](),
    PendingSummaryDirs    = None[PendingSummary](),
)

// AppMsg is every event the UI dispatches through update().  Keyboard +
// tick events come from the gala-tui runtime; ChunkArrived /
// SessionFailed / WriteSent come from the runtime subprocess pump
// (app/runtime returns concurrent.Future[runtime.Msg], which the
// onSubmit / continuePump helpers wrap into FutureCmd[AppMsg]).
sealed type AppMsg {
    // Composer keyboard input
    case KeyChar(C rune)
    case KeyBackspace
    case KeyDelete                  // forward-delete (the rune at cursor)
    case KeyComposerLeft            // move cursor one rune left
    case KeyComposerRight           // move cursor one rune right
    case KeyComposerHome            // jump cursor to start of composer
    case KeyComposerEnd             // jump cursor to end of composer
    case KeySubmit                  // Enter: send composer to TL
    // Approval keys (only meaningful when State is Approval; otherwise
    // ignored). Routed by cmd/main.gala's keyToAppMsg from 'a'/'r'.
    case KeyApprove
    case KeyReject
    // Runtime subprocess events (mirrors runtime.Msg, lifted into the
    // app vocabulary so update() can dispatch on a single sealed type).
    case ChunkArrived(Member string, Line string)
    case SessionFailed(Member string, ErrText string)
    case WriteSent(Member string)
    // Approval pipeline outcomes. PreMergeHooksPassed kicks the actual
    // `gh pr create` after a clean hook run; PreMergeHooksFailed surfaces
    // the failure in LastError and leaves the PR uncut.
    case PreMergeHooksPassed(SummaryBody string)
    case PreMergeHooksFailed(ErrText string)
    case PrCreated(Url string, Branch string)
    case PrFailed(ErrText string)
    // OpenBrowser is dispatched by onPrCreated to defer the
    // side-effecting browser launch out of Update's pure
    // computation phase. A test that constructs Update(model,
    // PrCreated(url)) discards the returned Cmd and never sees
    // OpenBrowser fire — so unit tests with synthetic URLs don't
    // trigger real browser windows. Production runtime processes
    // the Cmd, dispatches OpenBrowser, and the Update branch
    // shells the OS launcher.
    case OpenBrowser(Url string)
    // Merge is intentionally NOT an app action. After a PR is opened
    // the user reviews and merges it on GitHub; the app's lifecycle
    // ends at "PR created". There is no KeyMerge / Merged /
    // post-merge-hook message — the orchestrator never runs
    // `gh pr merge`.
    // Cross-team consult outcomes. Dispatched when the TL emits a
    // `@consult(name) … @end` block; the runtime spawns a child
    // gala_team session and feeds the result back into the TL once
    // the child closes. ConsultCompleted carries the child's optional
    // @summary body; ConsultFailed carries an explanatory error string.
    case ConsultCompleted(Name string, Summary Option[string])
    case ConsultFailed(Name string, ErrText string)
    // Streaming events from a live ConsultSession. ConsultChunkArrived
    // is one stdout line from the child team-lead; the UI both logs it
    // and accumulates it in ConsultBuffers for end-of-stream summary
    // extraction. ConsultEnded fires once when the read pump terminates
    // and is internally translated into ConsultCompleted / ConsultFailed
    // so the back-to-TL forwarding handlers can stay reused.
    case ConsultChunkArrived(Name string, Line string)
    case ConsultEnded(Name string, ErrText Option[string])
    // WorktreesWiped fires when WipeWorktreesFuture completes the
    // async Start fresh / Ctrl+N IO. Handler clears the
    // WipingWorktrees banner and persists the cleared conversation
    // (the data-side reset already ran synchronously when freshSession
    // was called; this just acknowledges the IO half).
    case WorktreesWiped
    // Toggles the consult viewer modal overlay (Tab key).
    case KeyToggleConsultViewer
    // Toggles the session-history browser (Ctrl+H key). When opened
    // with no archive selected, shows the index. Esc / Ctrl+H again
    // returns to the live conversation.
    case KeyToggleHistory
    // Cursor navigation in the history index — Up / Down keys.
    case HistoryCursorUp
    case HistoryCursorDown
    // Selects the archive at HistoryCursor for read-only viewing.
    case HistorySelect
    // Drops the currently-viewing archive and returns to the index.
    case HistoryDeselect
    // Result of an asynchronous archive load — the path/savedAt is
    // looked up in m.Archives so the model can know which entry was
    // selected.
    case HistoryArchiveLoaded(Snap session.Snapshot)
    case HistoryArchiveFailed(ErrText string)
    // Mouse input. Fallback for clicks that miss every registered
    // gala-tui HitRegistry entry — the wrapped panels (sidebar /
    // composer) dispatch FocusSidebarClicked / FocusComposerClicked
    // / SidebarRowClicked through the framework's auto-routing,
    // so MouseAt only fires for clicks on the conversation pane
    // and other unwrapped regions. Currently a no-op there.
    // Mouse fallback. The runtime dispatches MouseAt for events that
    // don't hit a registered click target — releases (Pressed=false),
    // motion-while-held (Motion=true under ?1002 button-event tracking),
    // and presses on areas with no .OnClick handler. Drag-selection
    // in the conversation pane reads Motion to update its range
    // focus during a drag; click-on-entry continues to flow through
    // the dedicated ClickConversationEntry path (registered hit) so
    // single-click semantics aren't disturbed.
    case MouseAt(X int, Y int, Pressed bool, Motion bool)
    // Dispatched by gala-tui when the user clicks on the bordered
    // sidebar panel (anywhere — header, body, or border). Switches
    // Focus to FocusSidebar without disturbing the cursor.
    case FocusSidebarClicked
    // Dispatched per-row by gala-tui's OnPickRow on the team
    // panel. Brings focus to the sidebar AND moves the cursor to
    // the clicked row; group-header rows additionally toggle
    // fold/unfold (matches the keyboard Space binding).
    case SidebarRowClicked(VisibleIdx int)
    // Dispatched by gala-tui's per-entry OnDrag wrapper inside the
    // ConversationLogViewDrag widget across the press / motion-while-
    // held / release lifecycle. Idx is the conversation-line idx
    // (resolved from the underlying log entry's idx via the parallel
    // lineIdxByEntry map view.gala builds each render). Phase
    // distinguishes DragPress (anchor + focus = idx, Dragging=true),
    // DragOver (focus = idx; only fires for entries different from
    // the current focus to avoid redundant model copies), and
    // DragRelease (Dragging=false; anchor/focus preserved so Ctrl+Y
    // can read the range).
    case ConversationDragMsg(Idx int, Phase DragPhase)
    // Dispatched by gala-tui on a click in the composer's
    // bordered band — switches Focus back to FocusComposer.
    case FocusComposerClicked
    // Cycles Focus between Composer and Sidebar. Bound to Ctrl+L
    // ("left panel") in keymap.gala. When Focus=Sidebar, Up/Down
    // move SidebarCursor; Space toggles fold on a group header;
    // Esc returns to Composer.
    case KeyToggleFocus
    // Toggles fold state of the role group at SidebarCursor. Only
    // meaningful when Focus=Sidebar and the cursor lands on a
    // group header (not a member row).
    case KeySidebarToggleGroup
    // Erase the active session — Ctrl+N. Two-press confirmation:
    // first press flips EraseSessionPending; second press wipes the
    // conversation, member buffers, status, and persisted snapshot,
    // killing live subprocesses on the way out. Esc cancels.
    case KeyEraseSession
    // Yank the entire conversation to the system clipboard (Ctrl+Y)
    // via the terminal's OSC 52 escape sequence. Works around
    // PowerShell's mouse-mode-vs-shift-select gap — when gala-tui has
    // mouse tracking on, native shift-select is consumed by the app,
    // and PowerShell doesn't honour the standard shift-bypass.
    case KeyYankConversation
    // Scrollback navigation for the conversation pane. PgUp/PgDn move
    // by ~viewportH lines; Up/Down (when no history modal is open and
    // sidebar isn't focused — TODO) move by 1; End re-sticks to bottom.
    case KeyConvoScrollUp
    case KeyConvoScrollDown
    case KeyConvoPageUp
    case KeyConvoPageDown
    case KeyConvoStickToBottom
    // Member-detail modal: open shows the named member's transcript
    // in a centered modal; close dismisses it. Open is dispatched
    // when the user presses Enter on a sidebar member row; close is
    // dispatched on Esc / Ctrl+D toggle.
    case KeyOpenMemberDetail(Name string)
    case KeyCloseMemberDetail
    // Paste from system clipboard (Ctrl+V). Handler shells out to
    // the OS's clipboard reader (powershell Get-Clipboard on
    // Windows, pbpaste on macOS, xclip/xsel on Linux), strips
    // trailing newlines, and appends to Composer. Read errors land
    // in LastError so the user knows the paste didn't take.
    case KeyPasteClipboard
    // Command palette (Ctrl+P) — fuzzy-search action picker.
    // KeyTogglePalette opens/closes the overlay. While open, keys
    // route through KeyPaletteEvent; PalConfirm fires whatever
    // PaletteAction the user selected (its embedded AppMsg payload).
    case KeyTogglePalette
    case KeyPaletteEvent(Ev PaletteEvent)
    // Mouse click on a palette row at index Idx — sets the palette's
    // Selected field, then dispatches PalConfirm so a single click
    // picks-and-fires.
    case KeyPaletteRowClick(Idx int)
    // View-mode toggles. F2/F3/F4 set the named mode; the same key
    // pressed again returns to ViewDefault. F1 always goes back to
    // ViewDefault for predictability.
    case KeySetViewMode(Mode ViewMode)
    // Help overlay (`?` key, header `?` button). Toggles HelpVisible.
    case KeyToggleHelp
    // Toggles AutoApprove (the batch-PR mode). Bound to F7 + a palette
    // entry. When on, an @summary that passes the readiness + body
    // gates skips the manual-approve wait and runs approveAndKickHooks
    // directly; each PR accumulates in OpenPrs. See Policy.AutoApprove
    // for the full semantics.
    case KeyToggleAutoApprove
    // Project-info modal (Frame S). Toggled by clicking project name
    // in the header or palette → "Project info".
    case KeyToggleProjectInfo
    // Guidance modal (§5.7). Toggled by `g` key or 📚 header button.
    case KeyToggleGuidance
    // Compact-left toggle for the team panel (Ctrl+, / Ctrl+.).
    case KeyToggleCompactSidebar
    // Recovery modal navigation (§5.6). Tab cycles focus across
    // [Resume] / [Inspect] / [Start fresh]; Enter activates the
    // currently-focused button. The handlers map to in-place model
    // mutations (Inspect = ReadOnlyMode=true) plus the same effects
    // the legacy banner triggered.
    case KeyRecoveryCycle
    case KeyRecoveryConfirm
    // Mouse click on a specific recovery button — sets focus AND
    // confirms in one shot so a single click is enough to pick.
    case KeyRecoveryClick(Choice RecoveryChoice)
    // Stderr pump for live claude subprocesses. StderrArrived
    // surfaces the line as a warning toast + LastError so the user
    // sees auth / permission / install errors that would otherwise
    // look like "claude stuck". StderrEnded re-arms the pump if
    // the session is still alive — matches the stdout pump shape.
    case StderrArrived(Member string, Line string)
    case StderrEnded(Member string)
    // AskUserQuestion fires when the chunk pump sees a tool_use
    // block in `Member`'s stream with name=AskUserQuestion. Sets
    // m.PendingQuestion so composer Enter routes to the tool_result
    // path. `Id` is the tool_use_id that the eventual tool_result
    // must echo back to satisfy the model's blocking tool call.
    case AskUserQuestion(Member string, Id string, QuestionText string)
    // KeyQuestionDismiss is Esc while a question is pending — drops
    // PendingQuestion without sending an answer. The model sees the
    // subprocess exit before the tool_result arrives, which it
    // treats as a user dismissal. Same effect as the regression we
    // just fixed, but now an explicit user choice instead of an
    // unavoidable side effect of the stream-json plumbing.
    case KeyQuestionDismiss
    // Async-IO result messages. Each of these is the back-channel
    // for a synchronous subprocess that used to run on the UI
    // thread; the handler fires a concurrent.FutureApply that
    // returns one of these once the IO completes, so the gala-tui
    // event loop stays responsive (keys + ticks keep flowing) while
    // git / clipboard subprocesses are in flight. Past audits
    // caught a session that froze indefinitely after a
    // Delegating→QAGate transition because buildQAReviewPrompt's
    // git diff invocations blocked on a stale index.lock; the
    // queue of UI events stalled behind it.
    //
    // QAPromptReady carries the synthesised QA review prompt back
    // to applyQAPromptReady, which then runs the FoldLeft over QA
    // members that used to live inside spawnQAReview directly.
    case QAPromptReady(Prompt string)
    // ClipboardPasted / ClipboardFailed are the off-thread paste
    // result. Replaces the synchronous powershell.exe Get-Clipboard
    // shell-out that used to block the UI thread for the duration
    // of PowerShell startup (~200–1500ms on Windows).
    case ClipboardPasted(Text string)
    case ClipboardFailed(ErrText string)
    // UncommittedCheckResult carries the engineer's @finished body
    // plus the dirty/clean answer from the async git diff probe.
    // Replaces the inline hasUncommittedWork() call inside
    // onMemberDone — that one fired 2 sync git subprocesses on
    // every engineer @finished and could wedge on index.lock.
    case UncommittedCheckResult(Member string, Body string, Dirty bool)
    // ApprovalReadyResult carries the @summary body plus the
    // checkPrReady answer (None = ready, Some(reason) = blocked).
    // Replaces the inline checkPrReady() call inside
    // approveAndKickHooks — that one fired git rev-list + maybe
    // git rev-parse on every approve.
    case ApprovalReadyResult(Body string, Reason Option[string])
    // SummaryReadyResult carries the parsed TL turn's directives
    // back after the off-thread PR-readiness probe completes.
    // Replaces the inline checkPrReady() call in the TL @summary
    // chunk path — that one fired on every Iris @summary turn and
    // could freeze the UI mid-stream.
    case SummaryReadyResult(Member string, Reason Option[string])
    // Lifecycle
    case TickMsg
    case QuitMsg
    case NoOp
}
