// ============================================================================
// app/ui/update — Elm update() function.
//
// Dispatches AppMsg to the right handler:
//   - composer keys → buffer mutations
//   - KeySubmit → kicks the FSM (UserPrompted), spawns a TL session if
//     none is alive, sends the prompt, and starts the read pump
//   - ChunkArrived → appends to the conversation log and re-arms the
//     pump (one in-flight Future per active member)
//   - SessionFailed → records the error and stops that member's pump
//   - WriteSent → bookkeeping only; transcript already shows the user line
//   - TickMsg → bumps the tick counter (drives spinner animation)
//   - QuitMsg → QuitCmd
//
// Returns Tuple[AppModel, Cmd[AppMsg]] in the standard gala-tui shape.
// Pure paths (KeyChar, KeyBackspace, TickMsg) stay separate from the
// IO-bearing ones so they remain test-friendly without a real subprocess.
// ============================================================================

// Update wraps dispatchMsg with a generic state-change detector that
// updates StateEnteredAt whenever the FSM transitions. It also fires
// the **TL relay turn** on the specific Delegating → TLReview edge —
// that's the moment the orchestrator's bi-directional loop closes,
// when every dispatched member has reported and the lead needs to
// decide what comes next.
func Update(m AppModel, msg AppMsg) Tuple[AppModel, Cmd[AppMsg]] {
    val (m1, cmd) = dispatchMsg(m, msg)
    val sameTag = stateTag(m.State) == stateTag(m1.State)
    val m2 = if (sameTag) m1 else m1.Copy(StateEnteredAt = m1.NowAt)
    // Any transition INTO TLReview from a working state (Delegating,
    // QAGate, or TLNudging) fires the TL relay turn so the lead has a
    // chance to consolidate. Without QAGate→TLReview wired, a member
    // (e.g. QA Theo emitting @blocked) drains the pending set, the
    // FSM lands in TLReview, and nothing prompts the lead — the user
    // sees the QA verdict but no path forward.
    val priorTag = stateTag(m.State)
    if !sameTag && stateTag(m1.State) == "TLReview" &&
       (priorTag == "Delegating" || priorTag == "QAGate" || priorTag == "TLNudging") {
        val (m3, relayCmds) = spawnTLRelay(m2)
        return (m3, batchAll(ArrayOf[Cmd[AppMsg]](cmd).Append(batchAll(relayCmds))))
    }
    // Engineers finished and the policy requires QA → kick off QA review
    // sessions so the FSM doesn't sit forever in QAGate waiting on
    // members that were never spawned. Each QA member gets a synthesised
    // review prompt with the dispatched engineers' deliverables inlined
    // so they have material to evaluate.
    if !sameTag && stateTag(m.State) == "Delegating" && stateTag(m1.State) == "QAGate" {
        val (m3, qaCmd) = spawnQAReview(m2)
        return (m3, batchAll(ArrayOf[Cmd[AppMsg]](cmd, qaCmd)))
    }
    return (m2, cmd)
}

// spawnTLRelay opens a TL relay turn — synthesises a system prompt
// containing each dispatched member's @finished body and asks the lead
// to decide follow-up. After firing, MemberDoneBodies is cleared so
// the next round of dispatches starts with a clean slate.
func spawnTLRelay(m AppModel) Tuple[AppModel, Array[Cmd[AppMsg]]] {
    val prompt = buildRelayPrompt(m, m.Team.Members)
    val (m1, cmds) = spawnTLNudge(m, "relay", prompt)
    val m2 = m1.Copy(MemberDoneBodies = EmptyHashMap[string, string]())
    return (m2, cmds)
}

// buildRelayPrompt formats the per-member deliverable list. Members
// without an explicit @finished body (i.e. those that just hit EOF)
// are omitted from the bullet list — TL gets clear signal about who
// said what vs who silently exited. Falls back to a generic prompt
// when every member returned silently.
func buildRelayPrompt(m AppModel, members Array[Member]) string {
    val parts = members.FoldLeft(EmptyArray[string](), (acc, mem) => {
        val name = mem.Name
        if name == m.Team.Lead.Name { return acc }
        val body = m.MemberDoneBodies.Get(name).GetOrElse("")
        if body == "" { return acc }
        return acc.Append(s"  • ${name} said: ${body}")
    })
    if parts.IsEmpty() {
        return "System: dispatched members all reported back without explicit @finished bodies. Decide whether to @summary the turn for the user, or follow up with another @dispatch."
    }
    val joined = parts.MkString("\n")
    return s"System: dispatched members have reported back.\n${joined}\nDecide: send follow-up @dispatch(name) directives, request QA, or @summary the turn for the user."
}

// stateTag projects an AppState to a stable string so the wrapper can
// detect FSM transitions without comparing payloads (Pending HashSet
// shifts inside Delegating/QAGate are NOT transitions for our purposes
// — only top-level case changes count).
func stateTag(s AppState) string = s match {
    case Idle()         => "Idle"
    case TLThinking()   => "TLThinking"
    case Delegating(_)  => "Delegating"
    case QAGate(_)      => "QAGate"
    case TLReview()     => "TLReview"
    case TLNudging(_)   => "TLNudging"
    case Approval(_)    => "Approval"
}

// Heartbeat thresholds are now driven by m.Policy.Heartbeat (#29).
// The bandFor / livenessStatus helpers below take the typed Heartbeat
// argument so threshold tweaks per-team take effect on the next tick.

// onTick advances Tick + NowAt, prunes expired toasts, re-derives
// liveness statuses for every member currently in Working/Slow/Stuck,
// and — when a member newly transitions to Stuck or Failed — emits the
// matching FSM event (MemberStuck / MemberAbandoned) so the FSM moves
// from Delegating into TLNudging. Returns any Cmds produced (e.g. the
// TL nudge turn spawn) batched.
func onTick(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    val now = time_utils.Now()
    val pruned = pruneToasts(m.Toasts, now)
    val m1 = m.Copy(Tick = m.Tick + 1, NowAt = now, Toasts = pruned)
    val (m2, cmds) = updateLivenessStatuses(m1, m1.Team.Members, now)
    return (m2, batchAll(cmds))
}

// pruneToasts is a typed-arg shim around ToastQueue.Prune so the
// auto-unwrap from Immutable[ToastQueue] happens at the boundary.
func pruneToasts(q ToastQueue, now time_utils.Instant) ToastQueue = q.Prune(now)

// updateLivenessStatuses walks `members` and maps each to a derived
// status from LastChunkAt. On a band transition: (1) status flipped
// in m.Statuses; (2) toast pushed; (3) FSM event emitted so
// Delegating advances toward TLNudging (stuck) or past the dead
// member (abandoned).
//
// CRITICAL: TL nudges are batched at the END of the walk, not fired
// per-member. Without batching, when N engineers all hit the stuck
// threshold in the same tick (typical when the user runs a parallel
// dispatch fan-out and walks away), the orchestrator spawns N TL
// nudges back-to-back — each lands a separate claude turn at the
// lead, the user sees N "TL is working" toasts, and the team
// pipeline pile-on confuses everyone.
//
// Aggregated nudge: collect every newly-stuck member during the
// walk; afterwards, if any are present, emit ONE MemberStuck FSM
// transition + ONE spawnTLNudge with a prompt that lists every stuck
// member. Failed (abandoned) transitions are still per-member because
// they don't spawn a nudge turn — they only advance the pending set.
func updateLivenessStatuses(
    m AppModel, members Array[Member], now time_utils.Instant,
) Tuple[AppModel, Array[Cmd[AppMsg]]] {
    val seed = (m, EmptyArray[Cmd[AppMsg]](), EmptyArray[string]())
    val (m1, cmds, stuckNames) = members.FoldLeft(seed, (acc, mem) => {
        val (curM, curCmds, curStuck) = acc
        val name = mem.Name
        val current = curM.Statuses.Get(name).GetOrElse(StIdle())
        val derived = livenessStatus(curM, name, current, now)
        if statusTag(current) == statusTag(derived) { return (curM, curCmds, curStuck) }
        val withStatus = curM.Copy(
            Statuses = curM.Statuses.Put(name, derived),
            Toasts   = pushTransitionToast(curM.Toasts, name, derived, now),
        )
        return derived match {
            case StStuck() => (withStatus, curCmds, curStuck.Append(name))
            case StFailed(_) => {
                val nextState = Transition(withStatus.State, MemberAbandoned(MemberName = name), transitionContext(withStatus))
                return (withStatus.Copy(State = nextState), curCmds, curStuck)
            }
            case _ => (withStatus, curCmds, curStuck)
        }
    })
    if stuckNames.IsEmpty() { return (m1, cmds) }
    return spawnAggregatedStuckNudge(m1, stuckNames, cmds, now)
}

// spawnAggregatedStuckNudge fires a single TL nudge covering every
// newly-stuck member. Transitions the FSM via the FIRST stuck name
// (one MemberStuck event is enough — the FSM only tracks "are we
// nudging?" not which member) and builds an aggregated prompt.
func spawnAggregatedStuckNudge(
    m AppModel,
    stuck Array[string],
    cmds Array[Cmd[AppMsg]],
    now time_utils.Instant,
) Tuple[AppModel, Array[Cmd[AppMsg]]] {
    val first = stuck.Get(0)
    val nextState = Transition(m.State, MemberStuck(MemberName = first), transitionContext(m))
    val withState = m.Copy(State = nextState)
    val prompt = buildAggregatedStuckPrompt(withState, stuck, now)
    val (afterSpawn, spawnCmds) = spawnTLNudge(withState, s"stuck-batch-${stuck.Size()}", prompt)
    val merged = spawnCmds.FoldLeft(cmds, (a, c) => a.Append(c))
    return (afterSpawn, merged)
}

// buildAggregatedStuckPrompt formats a system message listing every
// stuck member in one block. Falls back to the single-member prompt
// when only one is stuck — the additional "members listed below"
// boilerplate is wasted cognitive load when there's just one.
func buildAggregatedStuckPrompt(m AppModel, stuck Array[string], now time_utils.Instant) string {
    if stuck.Size() == 1 {
        return buildStuckNudgePrompt(m, stuck.Get(0), now)
    }
    val rows = stuck.Map((name) => {
        val elapsed = m.LastChunkAt.Get(name) match {
            case None()   => int64(0)
            case Some(at) => elapsedSeconds(now, at)
        }
        return s"  • ${name} silent for ${elapsed}s"
    })
    val joined = rows.MkString("\n")
    return s"System: ${stuck.Size()} members went stuck simultaneously past the heartbeat threshold:\n${joined}\n\nDecide what to do — re-prompt them with a single @dispatch listing every stuck name, reassign to other members, or @summary the turn as-is and surface the failures."
}

// spawnTLNudge fires a fresh TL turn with the given system prompt.
// Reuses the existing ensureSession + sendAndPumpCmd path so the TL
// session is resumed (same SessionId) and the prompt is delivered as
// the next user turn. Failure to spawn lands in LastError; no retries
// — TL nudges that fail just leave the team paused until the user
// types another prompt.
func spawnTLNudge(m AppModel, reason string, prompt string) Tuple[AppModel, Array[Cmd[AppMsg]]] {
    val lead = m.Team.Lead
    return ensureSession(m, lead) match {
        case Left(err) => (m.Copy(LastError = Some(s"TL nudge spawn (${reason}): ${err}")), EmptyArray[Cmd[AppMsg]]())
        case Right(m1) => {
            val withStatus = setStatus(m1, lead.Name, StWorking())
            return (withStatus, ArrayOf[Cmd[AppMsg]](sendAndPumpCmd(withStatus, lead, prompt)))
        }
    }
}

// buildStuckNudgePrompt formats the system message the TL gets when
// a member goes stuck. Includes elapsed seconds so the lead can
// decide whether to re-prompt the same member, reassign the work, or
// abandon the task.
func buildStuckNudgePrompt(m AppModel, name string, now time_utils.Instant) string {
    val elapsed = m.LastChunkAt.Get(name) match {
        case None()   => int64(0)
        case Some(at) => elapsedSeconds(now, at)
    }
    return s"System: ${name} has been silent for ${elapsed}s past the stuck threshold. Decide what to do — re-prompt them via @dispatch(${name}), reassign the work to another member, or @summary the turn as-is. Reply with the directive(s) you want me to execute."
}

// pushTransitionToast maps a status escalation to a toast and pushes
// it onto the queue. StWorking is the baseline (no toast); only the
// upward bands surface to the user. Slow → 4s info, Stuck → 6s warn,
// Failed → 8s error. Recovery / Help / Done get their own toasts
// from the (future) protocol-level handlers — not from the heartbeat.
func pushTransitionToast(q ToastQueue, name string, derived Status, now time_utils.Instant) ToastQueue = derived match {
    case StSlow()    => q.PushInfo(s"${name} is slow", now, time_utils.Seconds(int64(4)))
    case StStuck()   => q.PushWarn(s"${name} stuck — TL will nudge", now, time_utils.Seconds(int64(6)))
    case StFailed(_) => q.PushError(s"${name} abandoned", now, time_utils.Seconds(int64(8)))
    case _           => q
}

// livenessStatus derives the next status from the current one + elapsed
// time since LastChunkAt. Only Working/Slow/Stuck escalate via the
// heartbeat; everything else is sticky and returned unchanged.
func livenessStatus(m AppModel, name string, current Status, now time_utils.Instant) Status = current match {
    case StWorking() => escalateByElapsed(m, name, now, StWorking())
    case StSlow()    => escalateByElapsed(m, name, now, StSlow())
    case StStuck()   => escalateByElapsed(m, name, now, StStuck())
    case _           => current
}

// escalateByElapsed returns Failed/Stuck/Slow when the member has been
// silent past the matching threshold. `fallback` is the current
// Working-family status to keep when below the slowness band.
// Thresholds come from m.Policy.Heartbeat — per-team configurable via
// the policy.heartbeat: yaml block (or defaults from DefaultHeartbeat).
func escalateByElapsed(m AppModel, name string, now time_utils.Instant, fallback Status) Status {
    val opt = m.LastChunkAt.Get(name)
    return opt match {
        case None()   => fallback
        case Some(at) => bandFor(elapsedSeconds(now, at), fallback, m.Policy.Heartbeat)
    }
}

// bandFor maps elapsed seconds to a status using the per-team
// heartbeat thresholds. Failed for >= AbandonAfterSeconds, Stuck for
// >= StuckAfterSeconds, Slow for >= SlowAfterSeconds, otherwise the
// caller's fallback (Working / Slow / Stuck preserved).
func bandFor(secs int64, fallback Status, hb policy.Heartbeat) Status {
    if secs >= hb.AbandonAfterSeconds { return StFailed(Reason = s"abandoned: silent ${hb.AbandonAfterSeconds}s+") }
    if secs >= hb.StuckAfterSeconds   { return StStuck() }
    if secs >= hb.SlowAfterSeconds    { return StSlow() }
    return fallback
}

func elapsedSeconds(now time_utils.Instant, last time_utils.Instant) int64 {
    val nanosNow = now.UnixNanos()
    val nanosLast = last.UnixNanos()
    if nanosNow <= nanosLast { return int64(0) }
    return (nanosNow - nanosLast) / int64(1000000000)
}

// statusTag projects Status to a stable string label so the heartbeat
// can detect transitions without comparing payloads (StRecovering's
// Attempt/Max bumps are NOT transitions for our purposes).
func statusTag(s Status) string = s match {
    case StIdle()           => "idle"
    case StQueued()         => "queued"
    case StWorking()        => "working"
    case StSlow()           => "slow"
    case StStuck()          => "stuck"
    case StRecovering(_) => "recovering"
    case StHelpWaiting(_)   => "help-waiting"
    case StDone()           => "done"
    case StFailed(_)        => "failed"
}

func dispatchMsg(m AppModel, msg AppMsg) Tuple[AppModel, Cmd[AppMsg]] {
    // Palette interception: when the command palette is open, route
    // typing/navigation keys through the palette state machine instead
    // of the composer. Other messages fall through. Plain bool flag
    // rather than Option[Tuple[...]] because gala 0.41.0 lowers
    // Option-of-generic-struct to a non-None default, which would
    // make the intercept fire even when the palette is closed.
    if m.PaletteVisible {
        val (handled, m1, cmd1) = interceptPaletteMsg(m, msg)
        if handled { return (m1, cmd1) }
    }
    // Recovery-modal interception: when the §5.6 modal is up, every
    // input goes to it. Tab cycles the focused button, Enter confirms
    // the focused choice, Esc cancels (handled below in HistoryDeselect).
    // Without this, the user lands on the modal and can neither dismiss
    // it nor pick a button — keys flow to the composer instead.
    if m.RecoveryModalOpen {
        val intercepted = recoveryIntercept(m, msg)
        if intercepted.IsDefined() {
            return intercepted.GetOrElse((m, NoCmd[AppMsg]()))
        }
    }
    return msg match {
    case KeyChar(c)                  => onKeyChar(m, c)
    case KeyBackspace()              => (m.Copy(Composer = trimLastRune(m.Composer)),  NoCmd[AppMsg]())
    case KeySubmit()                 => onSubmit(m)
    case KeyApprove()                => onApprove(m)
    case KeyReject()                 => onReject(m)
    case ChunkArrived(name, ln)      => onChunk(m, name, ln)
    case SessionFailed(name, e)      => onSessionFailed(m, name, e)
    case WriteSent(_)                => (m, NoCmd[AppMsg]())
    case StderrArrived(name, ln)     => onStderr(m, name, ln)
    case StderrEnded(_)              => (m, NoCmd[AppMsg]())
    case PreMergeHooksPassed(body)   => onPreMergeHooksPassed(m, body)
    case PreMergeHooksFailed(err)    => onPreMergeHooksFailed(m, err)
    case PrCreated(url)              => onPrCreated(m, url)
    case PrFailed(err)               => (m.Copy(LastError = Some(s"gh pr create: ${err}")), NoCmd[AppMsg]())
    case KeyMerge()                  => onMerge(m)
    case Merged(url)                 => onMerged(m, url)
    case MergeFailed(err)            => (m.Copy(LastError = Some(s"gh pr merge: ${err}")), NoCmd[AppMsg]())
    case PostMergeHooksPassed(url)   => onPostMergeHooksPassed(m, url)
    case PostMergeHooksFailed(err)   => (m.Copy(LastError = Some(s"post-merge hooks: ${err}")), NoCmd[AppMsg]())
    case ConsultCompleted(name, sum) => onConsultCompleted(m, name, sum)
    case ConsultFailed(name, err)    => onConsultFailed(m, name, err)
    case ConsultChunkArrived(n, ln)  => onConsultChunkArrived(m, n, ln)
    case ConsultEnded(name, err)     => onConsultEnded(m, name, err)
    case KeyToggleConsultViewer()    => (m.Copy(ConsultViewerOpen = !m.ConsultViewerOpen), NoCmd[AppMsg]())
    case KeyToggleHistory()          => onToggleHistory(m)
    case KeyToggleFocus()            => onToggleFocus(m)
    case KeySidebarToggleGroup()     => onSidebarToggleGroup(m)
    case HistoryCursorUp()           => onCursorMove(m, -1)
    case HistoryCursorDown()         => onCursorMove(m, 1)
    case HistorySelect()             => onHistorySelect(m)
    case HistoryDeselect()           => onEscOrDeselect(m)
    case HistoryArchiveLoaded(snap)  => (m.Copy(ViewingArchive = Some(snap)), NoCmd[AppMsg]())
    case HistoryArchiveFailed(err)   => (m.Copy(LastError = Some(s"history: ${err}")), NoCmd[AppMsg]())
    case MouseAt(_, _, _)            => (m, NoCmd[AppMsg]())
    case FocusSidebarClicked()       => (m.Copy(Focus = FocusSidebar()), NoCmd[AppMsg]())
    case FocusComposerClicked()      => (m.Copy(Focus = FocusComposer()), NoCmd[AppMsg]())
    case SidebarRowClicked(idx)      => onSidebarRowClicked(m, idx)
    case KeyEraseSession()           => onEraseSession(m)
    case KeyYankConversation()       => onYankConversation(m)
    case KeyPasteClipboard()         => onPasteClipboard(m)
    case KeyConvoScrollUp()          => onConvoScroll(m, -1)
    case KeyConvoScrollDown()        => onConvoScroll(m, 1)
    case KeyConvoPageUp()            => onConvoScroll(m, -conversationPageSize())
    case KeyConvoPageDown()          => onConvoScroll(m, conversationPageSize())
    case KeyConvoStickToBottom()     => (m.Copy(ConversationSticky = true), NoCmd[AppMsg]())
    case KeyOpenMemberDetail(n)      => (m.Copy(MemberDetailOpen = Some(n)), NoCmd[AppMsg]())
    case KeyCloseMemberDetail()      => (m.Copy(MemberDetailOpen = None[string]()), NoCmd[AppMsg]())
    case KeyTogglePalette()          => onTogglePalette(m)
    case KeyPaletteEvent(ev)         => onPaletteEvent(m, ev)
    case KeyPaletteRowClick(idx)     => onPaletteRowClick(m, idx)
    case KeySetViewMode(mode)        => onSetViewMode(m, mode)
    case KeyToggleHelp()             => (m.Copy(HelpVisible = !m.HelpVisible), NoCmd[AppMsg]())
    case KeyToggleProjectInfo()      => (m.Copy(ProjectInfoOpen = !m.ProjectInfoOpen), NoCmd[AppMsg]())
    case KeyToggleGuidance()         => (m.Copy(GuidanceOpen = !m.GuidanceOpen), NoCmd[AppMsg]())
    case KeyToggleCompactSidebar()   => (m.Copy(CompactSidebar = !m.CompactSidebar), NoCmd[AppMsg]())
    case KeyRecoveryCycle()          => onRecoveryCycle(m)
    case KeyRecoveryConfirm()        => onRecoveryConfirm(m)
    case KeyRecoveryClick(c)         => onRecoveryConfirm(m.Copy(RecoveryFocus = c))
    case TickMsg()                   => onTick(m)
    case QuitMsg()                   => onQuit(m)
    case NoOp()                      => (m, NoCmd[AppMsg]())
    }
}

// recoveryIntercept routes Tab → KeyRecoveryCycle and Enter →
// KeyRecoveryConfirm when the §5.6 modal is up. Returns Some when
// the message was consumed; None lets the regular dispatch handle
// it (so a click on the modal's button widget still fires
// KeyRecoveryClick via the normal path).
func recoveryIntercept(m AppModel, msg AppMsg) Option[Tuple[AppModel, Cmd[AppMsg]]] = msg match {
    case KeyToggleFocus() => Some(onRecoveryCycle(m))
    case KeySubmit()      => Some(onRecoveryConfirm(m))
    case _                => None[Tuple[AppModel, Cmd[AppMsg]]]()
}

// onRecoveryCycle advances the focus across the recovery modal's
// three buttons (Resume → Inspect → StartFresh → Resume). No-op when
// the modal isn't visible.
func onRecoveryCycle(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    if !m.RecoveryModalOpen { return (m, NoCmd[AppMsg]()) }
    val next = m.RecoveryFocus match {
        case ResumeFocus()     => InspectFocus()
        case InspectFocus()    => StartFreshFocus()
        case StartFreshFocus() => ResumeFocus()
    }
    return (m.Copy(RecoveryFocus = next), NoCmd[AppMsg]())
}

// onRecoveryConfirm dispatches the focused button's action.
//   Resume     → dismiss modal, conversation/state already loaded.
//   Inspect    → enter ReadOnlyMode, dismiss modal.
//   StartFresh → wipe Conversation + RecoveredMembers + worktrees,
//                dismiss modal. Worktrees are wiped per the user's
//                "blank slate" expectation — the design originally
//                preserved them with a follow-up `--reap` command;
//                shipping that as a separate flag was less ergonomic
//                than just deleting on Start fresh, since the user
//                already opted into starting over.
func onRecoveryConfirm(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    if !m.RecoveryModalOpen { return (m, NoCmd[AppMsg]()) }
    return m.RecoveryFocus match {
        case ResumeFocus() => (m.Copy(
            RecoveryModalOpen = false,
            RecoveryBannerVisible = false,
        ), NoCmd[AppMsg]())
        case InspectFocus() => (m.Copy(
            RecoveryModalOpen = false,
            RecoveryBannerVisible = false,
            ReadOnlyMode = true,
        ), NoCmd[AppMsg]())
        case StartFreshFocus() => {
            wipeMemberWorktrees(m)
            val empty = EmptyArray[session.ConversationLine]()
            val cleared = m.Copy(
                RecoveryModalOpen = false,
                RecoveryBannerVisible = false,
                Conversation = empty,
                RecoveredMembers = EmptyArray[string](),
            )
            // Persist the cleared conversation so the next launch
            // doesn't reload prior data via primeFromSnapshot.
            // Without this, "Start fresh → quit → reopen" silently
            // round-trips the old transcript back into view.
            return (persistConversation(cleared, empty), NoCmd[AppMsg]())
        }
    }
}

// onKeyChar dispatches typed characters. Default destination is
// the composer; while Focus=Sidebar, a literal Space (' ') folds
// or unfolds the role group at SidebarCursor instead — matches
// Midnight-Commander-style "tree pane" UX without burning another
// global shortcut.
func onKeyChar(m AppModel, c rune) Tuple[AppModel, Cmd[AppMsg]] = m.Focus match {
    case FocusSidebar() => if (c == ' ') onSidebarToggleGroup(m)
                           else          (m, NoCmd[AppMsg]())
    case FocusComposer() => (m.Copy(Composer = m.Composer + string(c)), NoCmd[AppMsg]())
}

// onCursorMove routes Up/Down to whichever cursor is "live": the
// sidebar cursor when Focus=Sidebar, otherwise the history index
// cursor (which itself no-ops outside HistoryMode). Keeps a single
// pair of arrow-key bindings doing the right thing in both modes.
func onCursorMove(m AppModel, delta int) Tuple[AppModel, Cmd[AppMsg]] = m.Focus match {
    case FocusSidebar()  => onSidebarCursorMove(m, delta)
    case FocusComposer() => onHistoryCursorMove(m, delta)
}

// onToggleFocus cycles between the composer and the sidebar.
// SidebarCursor resets to 0 on each *entry* into FocusSidebar so
// the user always lands on a predictable row instead of the
// position from the last visit.
func onToggleFocus(m AppModel) Tuple[AppModel, Cmd[AppMsg]] = m.Focus match {
    case FocusComposer() => (m.Copy(Focus = FocusSidebar(), SidebarCursor = 0), NoCmd[AppMsg]())
    case FocusSidebar()  => (m.Copy(Focus = FocusComposer()),                   NoCmd[AppMsg]())
}

// onSidebarCursorMove moves SidebarCursor by delta, clamped to
// [0, sidebarRowCount-1]. Group headers and member rows are both
// addressable; the cursor wraps neither end.
func onSidebarCursorMove(m AppModel, delta int) Tuple[AppModel, Cmd[AppMsg]] {
    val total = SidebarRowCount(m.Team, m.CollapsedGroups)
    if total == 0 { return (m, NoCmd[AppMsg]()) }
    val raw = m.SidebarCursor + delta
    val clamped = if (raw < 0) 0
                  else if (raw >= total) total - 1
                  else raw
    return (m.Copy(SidebarCursor = clamped), NoCmd[AppMsg]())
}

// onSidebarRowClicked handles a per-row click dispatched from
// gala-tui's OnPickRow registration on the team panel. The
// `visibleIdx` is the index within the currently-rendered window
// (which may be a sliced-and-scrolled view of the full row list);
// translating it to an absolute row index is left to the panel
// itself by passing the scroll offset through.
//
// Brings Focus to FocusSidebar, snaps the cursor to the clicked
// row, and — when the row is a group header — toggles fold so a
// click on "▼ Engineering" does the same as keyboard Space.
func onSidebarRowClicked(m AppModel, idx int) Tuple[AppModel, Cmd[AppMsg]] {
    val total = SidebarRowCount(m.Team, m.CollapsedGroups)
    if total == 0 { return (m.Copy(Focus = FocusSidebar()), NoCmd[AppMsg]()) }
    val clamped = if (idx < 0) 0
                  else if (idx >= total) total - 1
                  else idx
    val mFocused = m.Copy(Focus = FocusSidebar(), SidebarCursor = clamped)
    return SidebarGroupAt(m.Team, m.CollapsedGroups, clamped) match {
        case Some(_) => onSidebarToggleGroup(mFocused)
        case None()  => (mFocused, NoCmd[AppMsg]())
    }
}

// onSidebarToggleGroup folds or unfolds the role group at
// SidebarCursor. No-op when the cursor lands on a member row
// (only group headers are toggleable). After toggling, the cursor
// stays on the same header — which is reasonable since member
// rows below may have appeared/disappeared and re-anchoring would
// surprise the user.
func onSidebarToggleGroup(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    val name = SidebarGroupAt(m.Team, m.CollapsedGroups, m.SidebarCursor)
    return name match {
        case Some(g) => {
            val next = if (m.CollapsedGroups.Contains(g))
                           m.CollapsedGroups.FilterNot((x) => x == g)
                       else
                           m.CollapsedGroups.Append(g)
            return (m.Copy(CollapsedGroups = next), NoCmd[AppMsg]())
        }
        case None() => (m, NoCmd[AppMsg]())
    }
}

// onQuit handles Ctrl+C / Ctrl+Q. The first press arms
// QuitPending, which the footer turns into a "Press Ctrl+C again
// to confirm · Esc to cancel" prompt; sessions stay alive. The
// second press is the destructive path: CloseAllSessions
// synchronously (Kill-then-Wait, fast) before emitting QuitCmd.
// Synchronous close — rather than dispatching a Future-Cmd — is
// deliberate: the alternative races the runtime shutdown against
// the kill, which on Windows often leaves the child process group
// alive after the TUI's terminal restore.
//
// Failures are surfaced by appending one conversation line per
// failed close; the user sees which session leaked. We still let
// QuitCmd fire either way — refusing to quit because a kill failed
// would strand the user inside a half-broken UI.
func onQuit(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    if !m.QuitPending {
        return (m.Copy(QuitPending = true), NoCmd[AppMsg]())
    }
    val failures = CloseAllSessions(m.Sessions)
    if failures.IsEmpty() {
        return (m, QuitCmd[AppMsg]())
    }
    val withFailureLog = failures.FoldLeft(m, (acc, f) => acc.Copy(
        Conversation = acc.Conversation.Append(
            session.ConversationLine(Speaker = "shutdown", Text = s"close ${f.V1}: ${f.V2.Error()}"),
        ),
    ))
    return (withFailureLog, QuitCmd[AppMsg]())
}

// onEraseSession is the two-press confirmation handler for Ctrl+N
// ("new"). Mirrors the onQuit shape:
//   - first press → flip EraseSessionPending; footer shows yellow
//     "Erase session? Press Ctrl+N again to confirm · Esc to cancel"
//   - second press → wipe Conversation, MemberBuffers,
//     MemberDirectivesFired, MemberDoneBodies, RetryCount,
//     LastChunkAt, NudgeAt, RecoveredMembers, RecoveryBannerVisible,
//     and Sessions (kills any live subprocesses on the way out).
//     Resets every member's status to StIdle. Persists the cleared
//     transcript so a reload picks up the empty state.
//   - Esc cancels — handled separately by the existing QuitPending
//     reset path which will be extended below.
func onEraseSession(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    if !m.EraseSessionPending {
        return (m.Copy(EraseSessionPending = true), NoCmd[AppMsg]())
    }
    // Bump PendingClosures for every live session BEFORE we kill +
    // clear Sessions. Killed subprocesses still emit one final
    // ChunkArrived / SessionFailed event from their queued read
    // pumps; without the closure counter those events sneak past
    // and re-populate the just-cleared conversation. Same shape as
    // closeLiveSession (used by onSubmit's respawn path).
    val withPending = m.Sessions.FoldLeftKV(m.PendingClosures, (acc, name, _sess) => {
        val curr = acc.Get(name).GetOrElse(0)
        return acc.Put(name, curr + 1)
    })
    val _ = CloseAllSessions(m.Sessions)
    // Wipe the engineer / QA worktrees on disk so the next dispatch
    // lands in a clean checkout. Best-effort — IO errors leave the
    // stale dirs but the data reset proceeds. Worktrees are
    // recreated on the next `ensureSession` call (ensureWorktree
    // detects unregistered dirs and refreshes them).
    wipeMemberWorktrees(m)
    val cleared = clearSessionState(m.Copy(PendingClosures = withPending))
    val saved = persistConversation(cleared, cleared.Conversation)
    return (saved, NoCmd[AppMsg]())
}

// conversationPageSize is the line delta applied for PgUp / PgDn /
// wheel-burst events. 10 lines is roughly half a typical viewport on
// laptop terminals — small enough that the user keeps context, big
// enough that scrolling through a long log doesn't take 50 keystrokes.
func conversationPageSize() int = 10

// onConvoScroll moves the scroll offset by `delta` lines (positive =
// down, negative = up). Negative offset goes into "user scrolled up"
// territory: ConversationSticky flips off so subsequent appends don't
// yank the view back to the bottom while the user is reading. Once
// the user scrolls back past the conceptual bottom, sticky re-engages.
//
// We don't have a content-line count here (it depends on terminal
// width and per-line wrapping computed at view time) so the offset
// is allowed to grow unbounded — the view-side ConversationLogView
// clamps it back into range each frame. That's the "store loose,
// clamp on render" pattern.
func onConvoScroll(m AppModel, delta int) Tuple[AppModel, Cmd[AppMsg]] {
    val proposed = m.ConversationOffset + delta
    val clamped = if (proposed < 0) 0 else proposed
    // Any upward scroll unsticks; pure downward scroll keeps stickiness.
    val sticky = if (delta < 0) false else m.ConversationSticky
    return (m.Copy(ConversationOffset = clamped, ConversationSticky = sticky), NoCmd[AppMsg]())
}

// interceptPaletteMsg routes input through the open palette when one
// exists. Returns Some((m, cmd)) to short-circuit normal dispatch,
// None to let the message fall through (background events stay live).
//
// Only typing / navigation / Esc / Ctrl+P close are intercepted —
// chunk arrivals, ticks, mouse, and lifecycle messages continue to
// flow to their normal handlers so the orchestrator doesn't pause
// while the user picks an action.
func interceptPaletteMsg(m AppModel, msg AppMsg) Tuple3[bool, AppModel, Cmd[AppMsg]] = msg match {
    case KeyChar(c)            => fired(onPaletteEvent(m, PalChar(C = c)))
    case KeyBackspace()        => fired(onPaletteEvent(m, PalBackspace()))
    case HistoryCursorUp()     => fired(onPaletteEvent(m, PalPrev()))
    case HistoryCursorDown()   => fired(onPaletteEvent(m, PalNext()))
    case KeySubmit()           => fired(onPaletteEvent(m, PalConfirm()))
    case HistoryDeselect()     => (true, closePalette(m), NoCmd[AppMsg]())
    case KeyTogglePalette()    => (true, closePalette(m), NoCmd[AppMsg]())
    case _                     => (false, m, NoCmd[AppMsg]())
}

func fired(t Tuple[AppModel, Cmd[AppMsg]]) Tuple3[bool, AppModel, Cmd[AppMsg]] {
    val (m, c) = t
    return (true, m, c)
}

// onSetViewMode flips the top-level layout. Pressing the same F-key
// twice toggles back to ViewDefault — the user usually wants F3 to
// "open grid view" and the same key to "go back to normal" without
// needing to remember a separate F1.
func onSetViewMode(m AppModel, mode ViewMode) Tuple[AppModel, Cmd[AppMsg]] {
    val sameAsCurrent = viewModeTag(m.ViewMode) == viewModeTag(mode)
    val next = if (sameAsCurrent) ViewDefault() else mode
    return (m.Copy(ViewMode = next), NoCmd[AppMsg]())
}

// viewModeTag projects a ViewMode case to a stable string for ==
// comparison without writing a 4x4 nested match. Keeps onSetViewMode
// short.
func viewModeTag(v ViewMode) string = v match {
    case ViewDefault()  => "default"
    case ViewFocus()    => "focus"
    case ViewGrid()     => "grid"
    case ViewPipeline() => "pipeline"
    case ViewActivity() => "activity"
}

// onTogglePalette opens the palette with the freshly-built action
// list when closed, closes it when already open. Building actions
// each open keeps them in sync with the current model (member roster,
// archive list, etc.).
func onTogglePalette(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    if m.PaletteVisible {
        return (closePalette(m), NoCmd[AppMsg]())
    }
    val actions = paletteActions(m)
    return (m.Copy(PaletteVisible = true, Palette = NewPalette[AppMsg](actions)), NoCmd[AppMsg]())
}

// closePalette hides the palette overlay so the main UI regains focus.
func closePalette(m AppModel) AppModel = m.Copy(PaletteVisible = false)

// onPaletteEvent runs PaletteUpdate against the current palette and
// stitches the new state back into the model. On PalConfirm, the
// selected PaletteAction's Msg is dispatched as a regular AppMsg
// (closing the palette first) so the action runs through the normal
// pipeline — including its own Cmd return.
func onPaletteEvent(m AppModel, ev PaletteEvent) Tuple[AppModel, Cmd[AppMsg]] {
    if !m.PaletteVisible { return (m, NoCmd[AppMsg]()) }
    val isConfirm = ev match {
        case PalConfirm() => true
        case _            => false
    }
    if isConfirm {
        val pickedMsg = paletteSelectedMsg(m.Palette)
        val mClosed = closePalette(m)
        return pickedMsg match {
            case None()      => (mClosed, NoCmd[AppMsg]())
            case Some(amsg)  => Update(mClosed, amsg)
        }
    }
    val updated = PaletteUpdate[AppMsg](m.Palette, ev)
    return (m.Copy(Palette = updated), NoCmd[AppMsg]())
}

// onPaletteRowClick handles a mouse click on the palette's idx-th
// visible result row. The widget hands us the visible index; we
// nudge Selected via PalNext/PalPrev (PaletteUpdate doesn't expose a
// "set Selected" event) until it matches, then fire PalConfirm so a
// single click picks-and-confirms.
//
// Nudging is O(N) on the visible row count, but the palette caps at
// ~8 rows so this is a couple of iterations at worst.
func onPaletteRowClick(m AppModel, idx int) Tuple[AppModel, Cmd[AppMsg]] {
    if !m.PaletteVisible { return (m, NoCmd[AppMsg]()) }
    val pal = m.Palette
    val n = pal.FilteredIdx.Length()
    if n == 0 { return (m, NoCmd[AppMsg]()) }
    val target = if (idx < 0) 0 else if (idx >= n) n - 1 else idx
    var aligned = pal
    var safety = 0
    for aligned.Selected != target && safety < 64 {
        val ev = if (aligned.Selected < target) PalNext() else PalPrev()
        aligned = PaletteUpdate[AppMsg](aligned, ev)
        safety = safety + 1
    }
    return onPaletteEvent(m.Copy(Palette = aligned), PalConfirm())
}

// paletteSelectedMsg returns the AppMsg attached to the currently-
// highlighted PaletteAction, or None when the filter has no matches
// (Selected out of bounds).
func paletteSelectedMsg(p Palette[AppMsg]) Option[AppMsg] {
    val n = p.FilteredIdx.Length()
    if n == 0 { return None[AppMsg]() }
    val sel = if (p.Selected < 0) 0 else if (p.Selected >= n) n - 1 else p.Selected
    val actionIdx = p.FilteredIdx.Get(sel)
    if actionIdx < 0 || actionIdx >= p.Actions.Length() { return None[AppMsg]() }
    return Some(p.Actions.Get(actionIdx).Msg)
}

// paletteActions builds the live command-palette action list. Stable
// across opens (built fresh each time so member-roster changes appear
// immediately). Categories group related entries in the rendered
// panel.
// paletteActions builds the live action list. Trimmed to entries
// that don't have an obvious keyboard shortcut (so the palette is a
// power-user surface for one-off operations, not a redundant menu of
// hotkeys the footer already advertises).
func paletteActions(m AppModel) Array[PaletteAction[AppMsg]] {
    val base = ArrayOf(
        PaletteAction[AppMsg](Label = "Erase session", Category = "Session", Msg = KeyEraseSession()),
        PaletteAction[AppMsg](Label = "Yank conversation to clipboard", Category = "Session", Msg = KeyYankConversation()),
        PaletteAction[AppMsg](Label = "History browser", Category = "View", Msg = KeyToggleHistory()),
        PaletteAction[AppMsg](Label = "View: Default split (F1)", Category = "View", Msg = KeySetViewMode(Mode = ViewDefault())),
        PaletteAction[AppMsg](Label = "View: Focus mode (F2)", Category = "View", Msg = KeySetViewMode(Mode = ViewFocus())),
        PaletteAction[AppMsg](Label = "View: Member grid (F3)", Category = "View", Msg = KeySetViewMode(Mode = ViewGrid())),
        PaletteAction[AppMsg](Label = "View: Pipeline org chart (F4)", Category = "View", Msg = KeySetViewMode(Mode = ViewPipeline())),
        PaletteAction[AppMsg](Label = "View: Activity log (F5)", Category = "View", Msg = KeySetViewMode(Mode = ViewActivity())),
        PaletteAction[AppMsg](Label = "Toggle composer / sidebar focus", Category = "Navigate", Msg = KeyToggleFocus()),
        PaletteAction[AppMsg](Label = "Toggle consult viewer", Category = "Navigate", Msg = KeyToggleConsultViewer()),
        PaletteAction[AppMsg](Label = "Approve summary (open PR)", Category = "Approval", Msg = KeyApprove()),
        PaletteAction[AppMsg](Label = "Reject summary", Category = "Approval", Msg = KeyReject()),
        PaletteAction[AppMsg](Label = "Merge open PR", Category = "Approval", Msg = KeyMerge()),
        PaletteAction[AppMsg](Label = "Help (key + mouse parity)", Category = "Help", Msg = KeyToggleHelp()),
        PaletteAction[AppMsg](Label = "Project info", Category = "Project", Msg = KeyToggleProjectInfo()),
        PaletteAction[AppMsg](Label = "Guidance docs", Category = "Project", Msg = KeyToggleGuidance()),
        PaletteAction[AppMsg](Label = "Compact / wide left panel", Category = "View", Msg = KeyToggleCompactSidebar()),
        PaletteAction[AppMsg](Label = "Quit", Category = "App", Msg = QuitMsg()),
    )
    val members = m.Team.Members.Map((mem) =>
        PaletteAction[AppMsg](
            Label    = s"Open ${mem.Name} (${RoleName(mem.Role)})",
            Category = "Members",
            Msg      = KeyOpenMemberDetail(Name = mem.Name),
        )
    )
    return base.AppendAll(members)
}

// truncateForToast keeps a toast message to a single short line —
// strips embedded newlines and caps total length so a long @blocked
// reason or @help question doesn't wrap into the footer row and
// hide the keybind hint. The full text remains available via
// LastError and the conversation transcript.
func truncateForToast(s string) string {
    val parts = strings.SplitN(strings.TrimSpace(s), "\n", 2)
    val firstLine = parts[0]
    val cap = 80
    if len(firstLine) <= cap { return firstLine }
    // strings.SplitN with a length-1 separator is safe at byte
    // boundary `cap` since gala doesn't expose a clean substring op
    // — feeding the second part through Drop avoids the slice syntax.
    val tail = strings.TrimPrefix(firstLine, firstLine)
    val _ = tail
    return runesPrefix(firstLine, cap) + "…"
}

// runesPrefix returns the first `n` runes of `s` (or `s` itself if
// shorter). Built on ToRunes so emoji / multibyte characters don't
// get sliced mid-codepoint.
func runesPrefix(s string, n int) string {
    val rs = ToRunes(s)
    if len(rs) <= n { return s }
    var out = EmptyArray[string]()
    var i = 0
    for i < n {
        out = out.Append(string(rs[i]))
        i = i + 1
    }
    return out.MkString("")
}

// onPasteClipboard reads the system clipboard via the OS-native CLI
// and appends the result to the composer. Synchronous (a clipboard
// read is fast) — async would require a Cmd round-trip and a mid-
// clipboard-read snapshot would be a confusing UX.
//
// Newlines in the clipboard text are preserved (so multi-line code
// blocks paste correctly). Trailing whitespace after the final
// non-empty line is stripped because most clipboard tools tack on a
// stray newline. Read failures land in LastError so the user knows
// the paste didn't take instead of silently appending nothing.
func onPasteClipboard(m AppModel) Tuple[AppModel, Cmd[AppMsg]] = readClipboard() match {
    case Failure(err) => (m.Copy(LastError = Some(s"clipboard read: ${err.Error()}")), NoCmd[AppMsg]())
    case Success(txt) => {
        val clean = strings.TrimRight(txt, " \t\r\n")
        val toast = m.Toasts.PushInfo(s"pasted ${len(clean)} chars", time_utils.Now(), time_utils.Seconds(int64(2)))
        return (m.Copy(Composer = m.Composer + clean, Toasts = toast), NoCmd[AppMsg]())
    }
}

// readClipboard shells out to whichever clipboard CLI the host OS
// ships:
//   - Windows → powershell.exe Get-Clipboard
//   - macOS   → pbpaste
//   - Linux   → xclip / xsel (xclip first, xsel fallback)
// Returns Try[string] so an unsupported environment surfaces a clean
// error in LastError instead of a silent failure.
func readClipboard() Try[string] = Try[string](() => {
    val (cmd, args) = clipboardReadCmd()
    val opts = subprocess.NewSpawnOpts(cmd, args.ToGoSlice(), SliceEmpty[string](), ".")
    val proc = subprocess.Spawn(opts) match {
        case Success(p)   => p
        case Failure(err) => panic(s"spawn ${cmd}: ${err.Error()}")
    }
    var sb = EmptyArray[string]()
    for {
        val line = proc.ReadLine()
        if line.IsFailure() { break }
        sb = sb.Append(line.Get())
    }
    val code = proc.Wait().Get()
    if code != 0 { panic(s"${cmd} exited ${code}") }
    return sb.MkString("\n")
})

// clipboardReadCmd picks the right (cmd, args) pair for the host OS.
// runtime.GOOS is "windows" / "darwin" / "linux" — straightforward.
// Linux falls back to xsel only if xclip isn't installed; we just
// try xclip first since it's the more common default on modern
// distros (Wayland / X11 alike via xdotool wrappers).
func clipboardReadCmd() Tuple[string, Array[string]] {
    if runtime.GOOS == "windows" {
        return ("powershell.exe", ArrayOf("-NoProfile", "-Command", "Get-Clipboard -Raw"))
    }
    if runtime.GOOS == "darwin" {
        return ("pbpaste", EmptyArray[string]())
    }
    return ("xclip", ArrayOf("-selection", "clipboard", "-o"))
}

// onYankConversation copies the entire conversation transcript to the
// system clipboard via the terminal's OSC 52 escape sequence. The
// terminal — not gala_team — receives the escape and talks to the OS
// clipboard, so it works over SSH and across multiplexers like tmux
// (provided they pass OSC 52 through, which most do).
//
// Synchronous one-shot write: OSC 52 is a tiny out-of-band escape
// that doesn't interfere with the cell grid the renderer just drew,
// and we don't want a Cmd round-trip just for a clipboard copy.
//
// User feedback via toast: the only visible signal that the copy
// worked. Failure (no TTY, terminal doesn't support OSC 52) lands
// in LastError so the user knows it didn't take.
func onYankConversation(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    if m.Conversation.IsEmpty() {
        val toast = m.Toasts.PushInfo("nothing to copy — conversation is empty", time_utils.Now(), time_utils.Seconds(int64(3)))
        return (m.Copy(Toasts = toast), NoCmd[AppMsg]())
    }
    val rendered = m.Conversation.Map((cl session.ConversationLine) =>
        s"${cl.Speaker}: ${cl.Text}"
    ).MkString("\n")
    val (_, err) = CopyToClipboard(rendered)
    if err != nil {
        return (m.Copy(LastError = Some(s"clipboard copy failed: ${err.Error()}")), NoCmd[AppMsg]())
    }
    val n = m.Conversation.Size()
    val msg = if (n == 1) "copied 1 line to clipboard" else s"copied ${n} lines to clipboard"
    val toast = m.Toasts.PushInfo(msg, time_utils.Now(), time_utils.Seconds(int64(3)))
    return (m.Copy(Toasts = toast), NoCmd[AppMsg]())
}

// wipeMemberWorktrees removes every member's git worktree so a fresh
// session starts on a clean filesystem. Two-step process per member:
//   1. `git worktree remove --force` so git deregisters the worktree
//      and cleans `.git/worktrees/<member>`.
//   2. `git branch -D gala_team/<proj>/<member>` so the next dispatch
//      doesn't pick up the stale branch tip.
// Best-effort — IO failures are silently ignored. The user opted into
// "Start fresh = blank slate"; we don't want a partial cleanup to
// abort the wipe because of one stale lockfile.
//
// Skipped entirely when WorkspaceMode is Shared (no per-member
// worktrees exist to wipe).
func wipeMemberWorktrees(m AppModel) {
    val name = policy.WorkspaceModeName(m.Policy.WorkspaceMode)
    if name != "worktree-per-engineer" { return }
    m.Team.Members.ForEach((mem) => {
        val isLead = SameRole(mem.Role, TeamLead())
        if isLead { return }
        val _ = RemoveWorktree(m.Project, mem)
    })
}

// clearSessionState wipes every per-conversation field back to its
// initial state. Pure data reset — no IO. Status map gets a fresh
// StIdle for every team member so the sidebar shows a clean slate
// instead of stale "working" / "failed" pills.
//
// IMPORTANT: this function is intentionally IO-free. The worktree
// wipe lives in `wipeMemberWorktrees` (called separately) so unit
// tests can exercise the data-only reset without setting up a
// scratch git repo.
func clearSessionState(m AppModel) AppModel {
    val freshStatuses = m.Team.Members.FoldLeft(
        EmptyHashMap[string, Status](),
        (acc, mem) => acc.Put(mem.Name, StIdle()),
    )
    return m.Copy(
        Conversation          = EmptyArray[session.ConversationLine](),
        ConversationOffset    = 0,
        ConversationSticky    = true,
        Sessions              = EmptyHashMap[string, MemberSession](),
        SessionIds            = EmptyHashMap[string, string](),
        Statuses              = freshStatuses,
        WorkElapsedNs         = EmptyHashMap[string, int64](),
        WorkStartedAt         = EmptyHashMap[string, time_utils.Instant](),
        TokenUsage            = EmptyHashMap[string, ClaudeUsage](),
        CurrentTurnUsage      = EmptyHashMap[string, ClaudeUsage](),
        TotalCostUsd          = 0.0,
        TurnBuffer            = "",
        ConsultsFired         = 0,
        ActiveConsults        = EmptyHashMap[string, ConsultSession](),
        ConsultBuffers        = EmptyHashMap[string, Array[string]](),
        ConsultViewerOpen     = false,
        RecoveredMembers      = EmptyArray[string](),
        RecoveryBannerVisible = false,
        LastChunkAt           = EmptyHashMap[string, time_utils.Instant](),
        NudgeAt               = EmptyHashMap[string, time_utils.Instant](),
        RetryCount            = EmptyHashMap[string, int](),
        MemberBuffers         = EmptyHashMap[string, string](),
        MemberDirectivesFired = EmptyHashMap[string, int](),
        MemberDoneBodies      = EmptyHashMap[string, string](),
        EraseSessionPending   = false,
        QuitPending           = false,
        Composer              = "",
        LastError             = None[string](),
    )
}

// onSubmit drives the user's prompt into the team. It (a) kicks the FSM
// with UserPrompted, (b) ensures the Team Lead has a live claude session
// (spawns one if not), (c) appends the user line to the conversation
// transcript, (d) clears the composer, and (e) returns a Cmd that sends
// the prompt to the TL and starts the chunk-read pump.
//
// On spawn failure (claude binary missing, repo path wrong, …) the model
// records LastError and returns no Cmd, so the user sees a footer message
// rather than a hung UI.
//
// When the history browser is open, Enter is repurposed to "load the
// cursored archive" instead — matches the user's expectation that
// the visible cursor is the action target.
func onSubmit(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    if m.HistoryMode { return onHistorySelect(m) }
    // Enter while sidebar is focused on a member row opens that
    // member's detail modal (Frame I in the design). The composer
    // path stays untouched — submit only fires when focus is on the
    // composer or no member row is highlighted.
    val sidebarOpen = m.Focus match {
        case FocusSidebar() => true
        case FocusComposer() => false
    }
    if sidebarOpen {
        val picked = SidebarMemberAt(m.Team, m.CollapsedGroups, m.SidebarCursor)
        return picked match {
            case Some(name) => (m.Copy(MemberDetailOpen = Some(name)), NoCmd[AppMsg]())
            case None()     => (m, NoCmd[AppMsg]())
        }
    }
    if m.Composer == "" {
        return (m, NoCmd[AppMsg]())
    }
    val prompt = m.Composer
    val ctx = transitionContext(m)
    val nextState = Transition(m.State, UserPrompted(), ctx)
    val withState = m.Copy(
        State = nextState,
        Composer = "",
        Conversation = m.Conversation.Append(session.ConversationLine(Speaker = "you", Text = prompt)),
        // Sending a new message means the user is acting "now" — re-stick
        // to the bottom of the conversation so they see their own line
        // and the incoming response without having to press End.
        ConversationSticky = true,
        TurnBuffer    = "",
        ConsultsFired = 0,
        // First user prompt after a recovery dismisses the banner
        // automatically — the user has signaled they want to
        // continue, so the "type to resume · Esc to discard" hint
        // has done its job.
        RecoveryBannerVisible = false,
    )
    val lead = m.Team.Lead
    // First-turn detection keys on whether we have a SessionId for
    // the lead — claude with `--print` doesn't keep processes alive
    // across turns, so the SessionId map is the source of truth.
    val firstTurn = !m.SessionIds.Get(lead.Name).IsDefined()
    // Kill any in-flight lead subprocess BEFORE spawning a new one.
    // Without this, a fast-double-submit (user types, hits Enter, types
    // again, hits Enter while claude is still streaming) leaves the
    // first claude orphaned — its chunks keep arriving over the old
    // pipe but `m.Sessions[lead]` already points at the new spawn, so
    // the read pump for the OLD process is what's still scheduled, and
    // its EOF closes the new turn before any new chunks reach onChunk.
    val cleared = closeLiveSession(withState, lead.Name)
    return ensureSession(cleared, lead) match {
        case Left(err)  => (withState.Copy(LastError = Some(err)), NoCmd[AppMsg]())
        case Right(m1)  => {
            val (effectivePrompt, onboardingErr) =
                if (firstTurn) onboarding.WrapPromptSafe(m.Project, m.Team, lead, m.Policy.WorkspaceMode, prompt)
                else           (prompt, None[string]())
            val m2 = onboardingErr match {
                case Some(e) => m1.Copy(LastError = Some(s"onboarding: ${e}"))
                case None()  => m1
            }
            return (setStatus(m2, lead.Name, StWorking()), sendAndPumpCmd(m2, lead, effectivePrompt))
        }
    }
}

// accrueTokens folds a chunk's per-turn token payload into the model.
//
// Two paths:
//   - LiveTurn (assistant chunks): claude's usage block is
//     cumulative-for-the-active-turn, so we OVERWRITE
//     CurrentTurnUsage[name] with the latest snapshot. Header
//     reads TokenUsage[name] + CurrentTurnUsage[name] for the
//     live total — ticks up as the turn streams.
//   - FinalTurn (result events): commit by adding to TokenUsage
//     and clearing CurrentTurnUsage. Cost folds into TotalCostUsd
//     here, since claude only stamps total_cost_usd on the result.
func accrueTokens(m AppModel, name string, chunk ClaudeChunk) AppModel {
    val m1 = chunk.LiveTurn match {
        case None()    => m
        case Some(usg) => m.Copy(CurrentTurnUsage = m.CurrentTurnUsage.Put(name, usg))
    }
    return chunk.FinalTurn match {
        case None()    => m1
        case Some(usg) => {
            val prior = m1.TokenUsage.Get(name).GetOrElse(zeroUsage())
            val combined = ClaudeUsage(
                InputTokens          = prior.InputTokens + usg.InputTokens,
                OutputTokens         = prior.OutputTokens + usg.OutputTokens,
                CacheReadInputTokens = prior.CacheReadInputTokens + usg.CacheReadInputTokens,
            )
            return m1.Copy(
                TokenUsage       = m1.TokenUsage.Put(name, combined),
                CurrentTurnUsage = m1.CurrentTurnUsage.Remove(name),
                TotalCostUsd     = m1.TotalCostUsd + chunk.CostUsd,
            )
        }
    }
}

func zeroUsage() ClaudeUsage = ClaudeUsage(
    InputTokens          = 0,
    OutputTokens         = 0,
    CacheReadInputTokens = 0,
)

// TotalTokenUsage sums per-member usage across the whole team,
// including any in-flight current-turn snapshots so the header
// ticks live during streaming. Committed turns sit in TokenUsage;
// the active assistant chunk's cumulative count sits in
// CurrentTurnUsage and gets folded in on every render.
func TotalTokenUsage(m AppModel) ClaudeUsage {
    val committed = m.TokenUsage.Values().FoldLeft(zeroUsage(), (acc, u) => ClaudeUsage(
        InputTokens          = acc.InputTokens + u.InputTokens,
        OutputTokens         = acc.OutputTokens + u.OutputTokens,
        CacheReadInputTokens = acc.CacheReadInputTokens + u.CacheReadInputTokens,
    ))
    return m.CurrentTurnUsage.Values().FoldLeft(committed, (acc, u) => ClaudeUsage(
        InputTokens          = acc.InputTokens + u.InputTokens,
        OutputTokens         = acc.OutputTokens + u.OutputTokens,
        CacheReadInputTokens = acc.CacheReadInputTokens + u.CacheReadInputTokens,
    ))
}

// onStderr handles a single stderr line from a claude subprocess.
// Surfaces it as a warning toast + LastError so the user sees
// "claude stuck" patterns (auth prompts, permission denials, model
// not found) that would otherwise look like a hung member.
//
// Empty / pure-whitespace lines are skipped (claude periodically
// flushes them). The pump is re-armed on every line so we keep
// draining until the subprocess closes.
func onStderr(m AppModel, name string, line string) Tuple[AppModel, Cmd[AppMsg]] {
    val trimmed = strings.TrimSpace(line)
    val pumpCmd = m.Sessions.Get(name) match {
        case Some(s) => runtimeFutureToCmd(NextStderrFuture(s))
        case None()  => NoCmd[AppMsg]()
    }
    if trimmed == "" { return (m, pumpCmd) }
    val short = truncateForToast(trimmed)
    val toast = m.Toasts.PushWarn(s"${name} (stderr): ${short}", time_utils.Now(), time_utils.Seconds(int64(8)))
    val m1 = m.Copy(
        Toasts    = toast,
        LastError = Some(s"${name} stderr: ${trimmed}"),
    )
    return (m1, pumpCmd)
}

// closeLiveSession kills any in-flight subprocess for `name` and
// drops it from m.Sessions. Best-effort: a Kill failure is ignored
// (the process is probably already gone) — what matters is that the
// model state no longer thinks `name` has a live pipe to read from.
//
// Used by onSubmit before respawning the lead so a fast-double-submit
// doesn't leave the first turn's claude orphaned and racing the second
// turn's pump on EOF.
func closeLiveSession(m AppModel, name string) AppModel {
    return m.Sessions.Get(name) match {
        case None()    => m
        case Some(s)   => {
            val _ = CloseSession(s)
            // Bump the pending-closures counter so the inevitable
            // SessionFailed event from the killed subprocess is
            // recognized as stale and dropped (instead of removing
            // the fresh session we're about to spawn).
            val curr = m.PendingClosures.Get(name).GetOrElse(0)
            return m.Copy(
                Sessions        = m.Sessions.Remove(name),
                PendingClosures = m.PendingClosures.Put(name, curr + 1),
            )
        }
    }
}

// ensureSession spawns a fresh claude turn for `member`. Each spawn
// is one-shot — claude with `--print` exits after responding, so
// the runtime treats every prompt as its own subprocess and threads
// conversation context across turns via the per-member session id
// in `m.SessionIds`.
//
//   - First turn: generate a new session id, pass it as
//     `--session-id <id>`; record the id so future turns resume it.
//   - Subsequent turns: look up the recorded id, pass it as
//     `--resume <id>`. claude reloads the prior conversation.
//
// The cwd comes from EnsureWorkspace, which honours
// Policy.WorkspaceMode — Shared puts every member in proj.Repo;
// WorktreePerEngineer creates `.gala_team/worktrees/<name>` for
// non-lead members on first spawn. Returns Right(updatedModel) on
// success, Left(errorString) on spawn or workspace-creation
// failure.
//
// Note: this function ALWAYS spawns. claude with `--print` exits
// after responding, so there's never a live process to reuse —
// every prompt is a fresh subprocess threading conversation
// context across turns via the per-member session id.
func ensureSession(m AppModel, member Member) Either[string, AppModel] {
    return EnsureWorkspace(m.Project, member, m.Policy.WorkspaceMode) match {
        case Failure(e)  => Left[string, AppModel](s"workspace ${member.Name}: ${e.Error()}")
        case Success(ws) => {
            val existingSid = m.SessionIds.Get(member.Name)
            val sid = existingSid.GetOrElse(NewSessionId())
            val isNew = !existingSid.IsDefined()
            return SpawnSession(m.Project, member, ws, m.Team.DangerouslySkipPermissions, sid, isNew) match {
                case Success(s) => {
                    val nextRecovered = m.RecoveredMembers.FilterNot((n) => n == member.Name)
                    return Right[string, AppModel](m.Copy(
                        Sessions              = m.Sessions.Put(member.Name, s),
                        SessionIds            = m.SessionIds.Put(member.Name, sid),
                        RecoveredMembers      = nextRecovered,
                        RecoveryBannerVisible = m.RecoveryBannerVisible && nextRecovered.Size() > 0,
                    ))
                }
                case Failure(e) => Left[string, AppModel](s"spawn ${member.Name}: ${e.Error()}")
            }
        }
    }
}

// sendAndPumpCmd batches: (1) write the prompt to claude's stdin
// AND close stdin (the combined "write then close" is what makes
// `--print` actually start producing output — claude reads stdin
// to EOF before responding); (2) start the read pump that
// produces ChunkArrived per stdout line.
func sendAndPumpCmd(m AppModel, member Member, prompt string) Cmd[AppMsg] {
    return m.Sessions.Get(member.Name) match {
        case Some(s) => Batch[AppMsg](
            runtimeFutureToCmd(SendFuture(s, prompt)),
            runtimeFutureToCmd(NextChunkFuture(s)),
            runtimeFutureToCmd(NextStderrFuture(s)),
        )
        case None() => NoCmd[AppMsg]()
    }
}

// onChunk records a streamed line under the speaker's name, persists
// the updated transcript via app/session, and re-arms the pump for the
// same member (one in-flight Future per active member). If the session
// has been closed (e.g. SessionFailed already swept it out of
// m.Sessions) the pump is not restarted.
//
// When the chunk came from the Team Lead, the line is also appended to
// `TurnBuffer` and the directive parser is rerun against the buffer;
// any newly-completed `@consult(name) … @end` blocks past the
// `ConsultsFired` watermark are dispatched as RunConsultFuture and
// batched into the returned Cmd alongside the next chunk pull.
//
// Save runs synchronously: the file is small, the write is fast, and
// pushing it through a Future would lose the exactly-after-this-chunk
// ordering guarantee the user expects (close terminal → reopen → see
// the same transcript). Failures are stuck in LastError so the user
// notices but the TUI keeps running.
func onChunk(m AppModel, name string, line string) Tuple[AppModel, Cmd[AppMsg]] {
    // Stale-event drop: closeLiveSession bumps PendingClosures by 1
    // for each kill so the inevitable EOF (or any in-flight chunk)
    // from the OLD pipe is treated as drained, not appended to the
    // fresh session's transcript. We decrement on ANY first event
    // (chunk OR SessionFailed) and return without re-arming the pump
    // — the new session's pump was already armed by ensureSession.
    //
    // Decrementing on ChunkArrived (not just SessionFailed) is what
    // keeps subsequent fresh chunks landing once the stale-event
    // budget is spent. Without this, a relay-spawn followed by a
    // user resubmit (closeLiveSession again) leaves the counter at
    // 1 with no real EOF coming to drain it (in test mode, or in
    // production when the kill was clean enough that no straggler
    // chunk was ever emitted), and every fresh chunk is silently
    // dropped — see live_audit2.sh:18_autoscroll_blocked.
    val pending = m.PendingClosures.Get(name).GetOrElse(0)
    if pending > 0 {
        return (m.Copy(PendingClosures = m.PendingClosures.Put(name, pending - 1)), NoCmd[AppMsg]())
    }
    val chunk = filterClaudeStreamJsonFor(name, line)
    // Fold token + cost totals from result events into the model.
    // Done before any visible-text branching so even drop-only
    // chunks (success result with no rendered text) still accrue.
    val mAccrued = accrueTokens(m, name, chunk)
    val displayText = chunk.Visible
    // Surface claude error events (rate-limit, max-turns, etc.) as a
    // toast + LastError instead of into the transcript — the chat
    // pane is for conversation, not error frames.
    val withErrSurface = if (chunk.ErrorText == "") mAccrued else {
        val toast = mAccrued.Toasts.PushError(s"${name}: ${chunk.ErrorText}", time_utils.Now(), time_utils.Seconds(int64(8)))
        mAccrued.Copy(Toasts = toast, LastError = Some(s"${name}: ${chunk.ErrorText}"))
    }
    if displayText == "" {
        // Init/result/tool-use chunks are noise — keep the read pump
        // alive but don't append to the transcript.
        val pumpCmd = withErrSurface.Sessions.Get(name) match {
            case Some(s) => runtimeFutureToCmd(NextChunkFuture(s))
            case None()  => NoCmd[AppMsg]()
        }
        return (withErrSurface.Copy(LastChunkAt = withErrSurface.LastChunkAt.Put(name, time_utils.Now())), pumpCmd)
    }
    // Hide bare directive marker lines (@dispatch/@consult/@summary/@end/
    // @done/@finished/@help/@blocked openings + the matching @end) from the
    // user-facing transcript — they're orchestration glue, not chat. The
    // body text between markers is kept so users still see the substance.
    // The directive parser still walks the full text via the unfiltered
    // path below.
    val visible = formatDirectiveMarkers(displayText)
    val nextConvo = if (visible == "") {
        withErrSurface.Conversation
    } else {
        withErrSurface.Conversation.Append(session.ConversationLine(Speaker = name, Text = visible))
    }
    val withLastSeen = withErrSurface.Copy(
        LastChunkAt = withErrSurface.LastChunkAt.Put(name, time_utils.Now()),
        RetryCount  = withErrSurface.RetryCount.Remove(name),
    )
    // Only flip to StWorking if the member isn't already in a sticky
    // "needs attention" state. StFailed (after retries / @blocked) and
    // StHelpWaiting (paused awaiting TL clarification) must persist
    // even if a stray late chunk arrives — otherwise the UI silently
    // moves on past the user's blocker.
    val current = withLastSeen.Statuses.Get(name).GetOrElse(StIdle())
    val nextStatus = if (isStickyStatus(current)) current else mkWorkingStatus()
    val withLine = setStatus(persistConversation(withLastSeen, nextConvo), name, nextStatus)
    // Use the filtered display text — not the raw stream-json wrapper —
    // when feeding the per-turn directive buffers. The JSON wrapper hides
    // the @summary / @dispatch / @end opening tags inside an escaped
    // string, so Parse() against the raw line yields no directives and
    // the TL turn never transitions to Approval / Delegating.
    val (m1, consultCmds) = maybeDispatchConsults(withLine, name, displayText)
    val (m2, memberCmds)  = maybeHandleMemberDirectives(m1, name, displayText)
    val pumpCmd = m2.Sessions.Get(name) match {
        case Some(s) => runtimeFutureToCmd(NextChunkFuture(s))
        case None()  => NoCmd[AppMsg]()
    }
    val allCmds = memberCmds.FoldLeft(consultCmds, (a, c) => a.Append(c)).Append(pumpCmd)
    return (m2, batchAll(allCmds))
}

// maybeHandleMemberDirectives parses non-TL streams for newly-completed
// @done / @help / @blocked blocks (the member-emitted directives). The
// TL has its own block-handling path (maybeDispatchConsults); this is
// the symmetric path for downstream members. Same buffer / watermark
// shape so directives fire exactly once per stream regardless of how
// chunks arrive.
//
// @done captures the body for the eventual TL relay turn (#28); status
// flips to StIdle so the heartbeat doesn't keep escalating timers.
// @help pauses the member (StHelpWaiting) and (in #28) opens a TL
// clarification turn. @blocked surfaces a user-visible failure.
func maybeHandleMemberDirectives(m AppModel, speaker string, line string) Tuple[AppModel, Array[Cmd[AppMsg]]] {
    if speaker == m.Team.Lead.Name {
        return (m, EmptyArray[Cmd[AppMsg]]())
    }
    val priorBuffer = m.MemberBuffers.Get(speaker).GetOrElse("")
    val nextBuffer = if (priorBuffer == "") line else priorBuffer + "\n" + line
    // ParseClosed: don't fire member-side directives until @end is seen.
    // Streamed chunks arrive line-by-line; firing on the bare opening
    // tag would emit a Blocked/Help/Finished with empty body before the
    // user's actual reason / question / deliverable text arrived.
    val dirs = ParseClosed(nextBuffer)
    val total = dirs.Size()
    val fired = m.MemberDirectivesFired.Get(speaker).GetOrElse(0)
    val withBuffer = m.Copy(
        MemberBuffers         = m.MemberBuffers.Put(speaker, nextBuffer),
        MemberDirectivesFired = m.MemberDirectivesFired.Put(speaker, total),
    )
    if total <= fired {
        return (withBuffer, EmptyArray[Cmd[AppMsg]]())
    }
    return dirs.Drop(fired).FoldLeft(
        (withBuffer, EmptyArray[Cmd[AppMsg]]()),
        (acc, d) => {
            val (m1, cmd) = applyMemberDirective(acc.V1, speaker, d)
            return (m1, acc.V2.Append(cmd))
        },
    )
}

// applyMemberDirective handles one parsed member directive. @consult
// and @dispatch from members are ignored (only the TL emits those);
// @summary too — members can't summarise the user-facing turn.
//
// The Help / Blocked cases are routed via the partial-function `Collect`
// shape rather than direct match because gala's analyzer mis-resolves
// the bare `Done` extractor name in this file (collides with some
// internal `state.Done` reference). Splitting into per-case helpers
// keeps each match arm small enough that gala's resolver lands on the
// directive package.
func applyMemberDirective(m AppModel, speaker string, d Directive) Tuple[AppModel, Cmd[AppMsg]] {
    val doneBody = extractDoneBody(d)
    val helpQ    = extractHelpQuestion(d)
    val blocked  = extractBlockedReason(d)
    if doneBody.IsDefined() { return onMemberDone(m, speaker, doneBody.GetOrElse("")) }
    if helpQ.IsDefined()    { return onMemberHelp(m, speaker, helpQ.GetOrElse("")) }
    if blocked.IsDefined()  { return onMemberBlocked(m, speaker, blocked.GetOrElse("")) }
    return (m, NoCmd[AppMsg]())
}

func extractDoneBody(d Directive) Option[string] = d match {
    case Finished(body) => Some(body)
    case _              => None[string]()
}

func extractHelpQuestion(d Directive) Option[string] = d match {
    case Help(q) => Some(q)
    case _       => None[string]()
}

func extractBlockedReason(d Directive) Option[string] = d match {
    case Blocked(r) => Some(r)
    case _          => None[string]()
}

// onMemberDone records the @done body for the relay turn (#28) and
// drops the member back to StIdle without raising LastError. EOF on
// the underlying session is the actual session-handle cleanup; this
// just captures the deliverable text.
func onMemberDone(m AppModel, name string, body string) Tuple[AppModel, Cmd[AppMsg]] {
    val toast = m.Toasts.PushSuccess(s"${name} done", time_utils.Now(), time_utils.Seconds(int64(3)))
    // Kill the member's claude subprocess once they've reported back —
    // anything they emit AFTER @finished is just trailing tool calls
    // / thinking that shouldn't land in the conversation. Same shape
    // as closeLiveSession in onSubmit; PendingClosures drops the
    // stale chunks the read pump still has queued.
    val closed = closeLiveSession(m, name)
    val m1 = closed.Copy(
        MemberDoneBodies = closed.MemberDoneBodies.Put(name, body),
        Toasts           = toast,
    )
    return (setStatus(m1, name, StIdle()), NoCmd[AppMsg]())
}

// onMemberHelp pauses the member and opens a TL clarification turn
// with the member's question synthesised into a system prompt. The
// TL's response is parsed normally — it can re-dispatch with new
// instructions, abandon the task, or escalate further.
func onMemberHelp(m AppModel, name string, question string) Tuple[AppModel, Cmd[AppMsg]] {
    val nextState = Transition(m.State, MemberHelpRequested(MemberName = name, Question = question), transitionContext(m))
    val toast = m.Toasts.PushInfo(s"${name} needs help", time_utils.Now(), time_utils.Seconds(int64(5)))
    // Kill the member's subprocess once they've asked for help — any
    // post-@help output is the model rambling rather than waiting.
    // The TL's nudge turn brings them back via a fresh dispatch.
    val closed = closeLiveSession(m, name)
    val m1 = closed.Copy(State = nextState, Toasts = toast)
    val m2 = setStatus(m1, name, mkHelpWaitingStatus(question))
    val (m3, cmds) = spawnTLNudge(m2, s"help-${name}", buildHelpNudgePrompt(name, question))
    return (m3, batchAll(cmds))
}

// buildHelpNudgePrompt formats the system message the TL gets when a
// member emits @help. The lead is asked to issue a follow-up
// @dispatch with an answer — TL is the source of truth for cross-
// member clarification.
func buildHelpNudgePrompt(name string, question string) string =
    s"System: ${name} requested clarification — they asked: \"${question}\". Reply with a follow-up @dispatch(${name}) directive containing the guidance, or @summary if the team should abandon the task."

// mkHelpWaitingStatus widens StHelpWaiting to Status (FIX-013
// workaround — multi-arg sealed cases need a typed helper).
func mkHelpWaitingStatus(question string) Status = StHelpWaiting(question)

// onMemberBlocked surfaces the external-environment failure as a
// chat entry the user can scroll, plus a short toast for transient
// awareness. Status flips to StFailed; FSM advances as if the
// member completed so the rest of the team doesn't deadlock.
//
// We deliberately don't set LastError here — the footer's
// LastError-takes-precedence path would render the multi-paragraph
// @blocked body over the keybind hints and the user couldn't see
// the hotkeys. The full reason already lives in the conversation
// (members' @blocked block streams through onChunk just like any
// other text), and the StFailed sidebar badge keeps the situation
// glanceable.
func onMemberBlocked(m AppModel, name string, reason string) Tuple[AppModel, Cmd[AppMsg]] {
    val nextState = Transition(m.State, MemberBlocked(MemberName = name, Reason = reason), transitionContext(m))
    val toast = m.Toasts.PushError(s"${name} blocked", time_utils.Now(), time_utils.Seconds(int64(5)))
    val failedStatus Status = StFailed(Reason = truncateForToast(reason))
    // Kill the subprocess on @blocked — keeping it alive lets late
    // chunks (tool-use, thinking content blocks, etc.) sneak into
    // the transcript even though the member has self-marked failed.
    // PendingClosures drops the queued reads the pump still owns.
    val closed = closeLiveSession(m, name)
    val m1 = closed.Copy(
        State  = nextState,
        Toasts = toast,
    )
    return (setStatus(m1, name, failedStatus), NoCmd[AppMsg]())
}

// maybeDispatchConsults inspects the latest TL chunk for newly-
// completed `@consult(name) … @end` blocks. Returns the updated model
// (with `TurnBuffer`, `ConsultsFired`, ActiveConsults, ConsultBuffers
// advanced) plus an array of Cmds — one re-armed event-pump per
// successfully-spawned consult, plus an immediate MsgCmd for any
// consult whose SpawnConsult failed pre-stream.
//
// Non-TL chunks are no-ops; the per-turn buffer only tracks the lead
// since other members never emit `@consult`.
func maybeDispatchConsults(m AppModel, speaker string, line string) Tuple[AppModel, Array[Cmd[AppMsg]]] {
    if speaker != m.Team.Lead.Name {
        return (m, EmptyArray[Cmd[AppMsg]]())
    }
    val nextBuffer = if (m.TurnBuffer == "") line else m.TurnBuffer + "\n" + line
    val dirs = Parse(nextBuffer)
    val consults = dirs.Collect({
        case Consult(target, _, body) => (target, body)
    })
    val total = consults.Size()
    if total <= m.ConsultsFired {
        return (m.Copy(TurnBuffer = nextBuffer), EmptyArray[Cmd[AppMsg]]())
    }
    val withBuffer = m.Copy(TurnBuffer = nextBuffer, ConsultsFired = total)
    return consults.Drop(m.ConsultsFired).FoldLeft(
        (withBuffer, EmptyArray[Cmd[AppMsg]]()),
        (acc, c) => {
            val (m1, cmd) = dispatchOneConsult(acc.V1, c.V1, c.V2)
            return (m1, acc.V2.Append(cmd))
        },
    )
}

// dispatchOneConsult fires off one `@consult(target)` block. Routes
// through DispatchConsult which prefers an in-project sibling team
// (declared alongside the main team in team.yaml) over a cross-repo
// registry entry. On success registers the live ConsultSession +
// initial empty buffer and re-arms the event pump; on failure emits
// an immediate ConsultFailed via MsgCmd so the existing failure
// handler logs and forwards to the TL.
func dispatchOneConsult(m AppModel, target string, body string) Tuple[AppModel, Cmd[AppMsg]] {
    val withDispatchLog = m.Copy(
        Conversation = m.Conversation.Append(session.ConversationLine(
            Speaker = "consult",
            Text    = s"dispatching → ${target}",
        )),
    )
    val mainKey = m.Team.Key
    val siblings = m.Teams.Filter((t) => t.Key != mainKey)
    return DispatchConsult(siblings, m.Project, m.Registry, target, body) match {
        case Failure(e) => {
            val cmd = MsgCmd[AppMsg](Msg = ConsultFailed(Name = target, ErrText = e.Error()))
            return (withDispatchLog, cmd)
        }
        case Success(s) => {
            val m1 = withDispatchLog.Copy(
                ActiveConsults = withDispatchLog.ActiveConsults.Put(target, s),
                ConsultBuffers = withDispatchLog.ConsultBuffers.Put(target, EmptyArray[string]()),
            )
            return (m1, consultEventFutureCmd(s))
        }
    }
}

// consultEventFutureCmd lifts the next ConsultEvent read into the
// AppMsg vocabulary so the chunk pump can be re-armed cleanly between
// chunks.
func consultEventFutureCmd(s ConsultSession) Cmd[AppMsg] =
    FutureCmd[AppMsg](Fut = NextConsultEventFuture(s).Map(consultEventToAppMsg))

func consultEventToAppMsg(ev ConsultEvent) AppMsg = ev match {
    case ConsultChunk(name, line) => ConsultChunkArrived(Name = name, Line = line)
    case ConsultEnd(name, errOpt) => ConsultEnded(
        Name    = name,
        ErrText = errOpt.Map[string]((e) => e.Error()),
    )
}

// batchAll wraps a list of Cmds into a single BatchCmd. Empty list →
// NoCmd; single-element list → that element directly (no need for an
// outer Batch wrapper).
func batchAll(cmds Array[Cmd[AppMsg]]) Cmd[AppMsg] {
    val n = cmds.Size()
    if n == 0 { return NoCmd[AppMsg]() }
    if n == 1 { return cmds.Get(0) }
    return cmds.FoldLeft(NoCmd[AppMsg](), (acc, c) => Batch[AppMsg](acc, c))
}

// activeMemberNames returns the names of every member with a live
// Claude subprocess. Persisted alongside the conversation so the
// next launch can spawn those members with `--continue` and pick up
// their prior in-process state.
func activeMemberNames(m AppModel) Array[string] =
    m.Sessions.FoldLeftKV(EmptyArray[string](), (acc, name, _) => acc.Append(name))

// persistConversation writes the new conversation log to disk under
// m.Project.Repo and returns the updated model. Save failures only set
// LastError — the in-memory transcript stays canonical.
func persistConversation(m AppModel, nextConvo Array[session.ConversationLine]) AppModel = session.Save(m.Project.Repo, m.Project.Name, nextConvo, activeMemberNames(m)) match {
    case Success(_)   => m.Copy(Conversation = nextConvo)
    case Failure(err) => m.Copy(Conversation = nextConvo, LastError = Some(s"session save: ${err.Error()}"))
}

// MaxAutoRetries is sourced from m.Policy.Heartbeat.MaxRetries (#29).
// Kept as a function shim so call sites stay readable.
func maxAutoRetriesOf(m AppModel) int = m.Policy.Heartbeat.MaxRetries

// onSessionFailed handles the read pump's terminal event.
//
//   - EOF: normal turn completion (claude with --print exits when
//     finished). Status flips to StIdle; SessionId persists for
//     the next --resume turn.
//
//   - Non-EOF + RetryCount[name] < MaxAutoRetries: the runtime
//     died unexpectedly (network blip, claude segfault, etc.).
//     Auto-respawn via the same SpawnSession+SendFuture path,
//     send a "Continue your previous task." prompt over the
//     resumed session id so claude picks up where it left off.
//     Status flips to StRecovering(attempt, max) for the duration.
//
//   - Non-EOF + retries exhausted: give up. Surface the original
//     error in LastError, mark member StFailed.
//
// RetryCount resets on the next successful ChunkArrived (in onChunk),
// so transient crashes don't permanently stick a member in the
// retry-budget penalty box.
func onSessionFailed(m AppModel, name string, err string) Tuple[AppModel, Cmd[AppMsg]] {
    // Stale-event drop: if closeLiveSession recently killed an
    // in-flight process for `name`, the SessionFailed we're seeing
    // now is its EOF — not the fresh session's. Drain one count from
    // PendingClosures and return without touching the model. The
    // fresh session's own SessionFailed will eventually drive the
    // FSM transition normally.
    val pending = m.PendingClosures.Get(name).GetOrElse(0)
    if pending > 0 {
        return (m.Copy(PendingClosures = m.PendingClosures.Put(name, pending - 1)), NoCmd[AppMsg]())
    }
    val cleaned = m.Copy(Sessions = m.Sessions.Remove(name))
    if isCleanCloseError(err) {
        // Clean turn end. Two shapes depending on who finished:
        //   - Team Lead → TLDone(directives parsed from the lead's
        //     accumulated TurnBuffer). FSM uses these to route the
        //     turn (Approval on @summary, Delegating on @dispatch,
        //     Idle on plain chat).
        //   - Other member → MemberDone(name, body). FSM drains the
        //     pending set and advances to QAGate / TLReview / relay.
        if name == cleaned.Team.Lead.Name {
            val dirs = Parse(cleaned.TurnBuffer)
            val nextState = Transition(cleaned.State, TLDone(Directives = dirs), transitionContext(cleaned))
            val withState = setStatus(cleaned.Copy(State = nextState), name, StIdle())
            // If the new state is Delegating, fan out: spawn each
            // dispatched member's session with their per-target body
            // as the prompt. Without this, members stay StIdle forever
            // and the user sees "Pipeline (no active turn)" while the
            // sidebar agents never flip from idle.
            if (stateTag(nextState) == "Delegating") {
                return spawnDispatchedMembers(withState, dirs)
            }
            return (withState, NoCmd[AppMsg]())
        }
        val body = cleaned.MemberDoneBodies.Get(name).GetOrElse("")
        val nextState = Transition(cleaned.State, MemberDone(MemberName = name, Body = body), transitionContext(cleaned))
        return (setStatus(cleaned.Copy(State = nextState), name, StIdle()), NoCmd[AppMsg]())
    }
    val maxRetries = maxAutoRetriesOf(m)
    val retries = m.RetryCount.Get(name).GetOrElse(0)
    if retries >= maxRetries {
        val withFailure = setStatus(
            cleaned.Copy(LastError = Some(s"${name}: ${err} (gave up after ${retries} retries)")),
            name,
            StFailed(Reason = err),
        )
        return (withFailure, NoCmd[AppMsg]())
    }
    val attempt = retries + 1
    val recovering = cleaned.Copy(
        RetryCount = cleaned.RetryCount.Put(name, attempt),
        LastError  = Some(s"${name}: ${err} — retry ${attempt}/${maxRetries}"),
    )
    val withStatus = setStatus(recovering, name, mkRecoveringStatus(attempt, maxRetries))
    return respawnMember(withStatus, name)
}

// respawnMember performs the actual auto-respawn: looks up the Member
// record by name, calls ensureSession (which creates a fresh subprocess
// using the saved SessionId for `--resume`), and fires a "continue"
// prompt to wake claude back up. Synchronous failure (e.g. workspace
// missing) lands in LastError without further retries — we only retry
// the same path once per crash event.
func respawnMember(m AppModel, name string) Tuple[AppModel, Cmd[AppMsg]] {
    return findMemberByName(m.Team.Members, name) match {
        case None() => (m, NoCmd[AppMsg]())
        case Some(mem) => ensureSession(m, mem) match {
            case Left(err)  => (m.Copy(LastError = Some(s"respawn ${name}: ${err}")), NoCmd[AppMsg]())
            case Right(m1)  => (setStatus(m1, name, StWorking()), sendAndPumpCmd(m1, mem, "Continue your previous task."))
        }
    }
}

// spawnDispatchedMembers fans out a TL @dispatch turn: walks every
// Dispatch directive in `dirs`, spawns each target member's claude
// subprocess via ensureSession, sends the per-target body as the
// prompt, and flips the member's status to StWorking so the sidebar
// timer starts ticking.
//
// Members named in @dispatch but not in the team roster are skipped
// silently — the FSM has already added them to the Pending set, so
// they'll naturally drain on the next MemberDone. We just don't have
// a Member record to spawn against.
//
// ensureSession failures land in LastError per-member; we keep going
// rather than aborting the whole fanout so a typo'd member name
// doesn't strand the rest of the dispatch.
func spawnDispatchedMembers(m AppModel, dirs Array[Directive]) Tuple[AppModel, Cmd[AppMsg]] {
    val targets = dirs.Collect({
        case Dispatch(name, body) => (name, body)
    })
    val seed = (m, EmptyArray[Cmd[AppMsg]]())
    val (after, cmds) = targets.FoldLeft(seed, (acc, t) => {
        val (curM, curCmds) = acc
        val (name, body) = t
        return findMemberByName(curM.Team.Members, name) match {
            case None() => (curM, curCmds)
            case Some(mem) => ensureSession(curM, mem) match {
                case Left(err)  => (curM.Copy(LastError = Some(s"dispatch ${name}: ${err}")), curCmds)
                case Right(m1)  => {
                    val withStatus = setStatus(m1, name, StWorking())
                    // First-turn detection mirrors onSubmit's pattern: if
                    // we don't yet have a session id for this member, this
                    // is their first claude session and the body needs
                    // the role / protocol / onboarding wrap. Subsequent
                    // dispatches in the same TUI run reuse the prior
                    // session via --resume so the model already has the
                    // role context in conversation history; the bare body
                    // is enough.
                    val firstTurn = !curM.SessionIds.Get(name).IsDefined()
                    val wrapped = if (firstTurn) {
                        val (w, _) = onboarding.WrapPromptSafe(curM.Project, curM.Team, mem, curM.Policy.WorkspaceMode, body)
                        w
                    } else {
                        body
                    }
                    val cmd = sendAndPumpCmd(withStatus, mem, wrapped)
                    return (withStatus, curCmds.Append(cmd))
                }
            }
        }
    })
    return (after, batchAll(cmds))
}

// spawnQAReview kicks off a QA review session for every QA member on
// the team. Mirrors spawnDispatchedMembers but for the QA role: the
// review body is a synthesised "review these deliverables" prompt
// composed of every engineer's @finished body.
//
// QA members are first-turn from the orchestrator's perspective even
// when subsequent turns happen — claude --print is one-shot per
// invocation; SessionIds picks up the existing session id and
// switches to --resume on the second QA pass automatically.
func spawnQAReview(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    val qa = MembersOf(m.Team, QA())
    if qa.IsEmpty() { return (m, NoCmd[AppMsg]()) }
    val reviewBody = buildQAReviewPrompt(m)
    val seed = (m, EmptyArray[Cmd[AppMsg]]())
    val (after, cmds) = qa.FoldLeft(seed, (acc, mem) => {
        val (curM, curCmds) = acc
        val firstTurn = !curM.SessionIds.Get(mem.Name).IsDefined()
        return ensureSession(curM, mem) match {
            case Left(err)  => (curM.Copy(LastError = Some(s"qa ${mem.Name}: ${err}")), curCmds)
            case Right(m1)  => {
                val withStatus = setStatus(m1, mem.Name, StWorking())
                val wrapped = if (firstTurn) {
                    val (w, _) = onboarding.WrapPromptSafe(curM.Project, curM.Team, mem, curM.Policy.WorkspaceMode, reviewBody)
                    w
                } else {
                    reviewBody
                }
                return (withStatus, curCmds.Append(sendAndPumpCmd(withStatus, mem, wrapped)))
            }
        }
    })
    return (after, batchAll(cmds))
}

// buildQAReviewPrompt assembles the review prompt seen by every QA
// member. Lists each engineer's @finished body PLUS the concrete
// workspace pointers QA needs to read the work — without these, QA
// can't find engineer files when WorkspaceMode = WorktreePerEngineer
// (their checkouts live under .gala_team/worktrees/<name>) and they
// fall back to guessing. Engineers who exited without an explicit
// @finished block get a generic line so QA still sees their existence.
//
// The "Deliverable manifest" block at the top is the file-exchange
// protocol QA reads first: for each engineer, name + role + cwd +
// branch + the suggested `git diff` command that lists their changed
// files. QA's instructions point at it so the review is grounded in
// actual diffs, not just engineer summaries.
func buildQAReviewPrompt(m AppModel) string {
    val engineers = MembersOf(m.Team, Engineer())
    val manifest = buildDeliverableManifest(m, engineers)
    val sections = engineers.Map((eng) => {
        val body = m.MemberDoneBodies.Get(eng.Name).GetOrElse("")
        if body == "" {
            return s"## ${eng.Name}\n\n(no explicit @finished block — review the engineer's transcript directly if needed)"
        }
        return s"## ${eng.Name} reported:\n\n${body}"
    })
    val joined = sections.MkString("\n\n")
    return s"# QA review\n\nThe engineers have reported back. Review their deliverables for correctness, edge cases, and adherence to the brief.\n\n${manifest}\n\n# Engineer reports\n\n${joined}\n\n# Sign-off protocol\n\nWhen you're done, reply with:\n\n- `@finished ... @end` if the work passes review. Body = a 1-3 line approval note PLUS, on its own line, `Files reviewed: <comma-separated relative paths>` so the TL knows what you actually inspected.\n- `@blocked ... @end` if there are issues that block sign-off. Body = the issues prioritised; cite each engineer + file path so the TL can route fixes."
}

// buildDeliverableManifest renders the per-engineer workspace pointers
// QA needs to read engineer files. For Shared workspace mode the cwd
// is the project repo for every engineer; for WorktreePerEngineer it
// points at each engineer's isolated worktree. The diff command is
// suggested so QA doesn't have to invent it.
//
// Branch resolution is delegated to policy.BranchForMember (which we
// added so update.gala doesn't have to dot-import the policy package
// just to pattern-match on WorkspaceMode here).
// buildDeliverableManifest now does the aggregation legwork for QA:
// for each engineer it shells out to `git diff --name-only` and inlines
// the actual file list. Without this, QA has to know git, run the
// command, parse the output — that's an aggregator's job, not a
// reviewer's. Per the user's note "QA might not necessarily be trained
// to handle this", the orchestrator does it on QA's behalf and hands
// over a flat list of paths to inspect.
func buildDeliverableManifest(m AppModel, engineers Array[Member]) string {
    val rows = engineers.Map((eng) => {
        val cwd = onboarding.WorkspacePathFor(m.Project, eng, m.Policy.WorkspaceMode)
        val branch = manifestBranchFor(m, eng)
        val files = listChangedFiles(cwd, m.Project.DefaultBranch)
        val filesBlock = if (files.IsEmpty())
            "  - files:  (none — engineer didn't commit any changes)"
        else
            s"  - files:\n${files.Map((f) => s"      ${f}").MkString("\n")}"
        return s"- **${eng.Name}** (${RoleName(eng.Role)})\n  - cwd:    ${cwd}\n  - branch: ${branch}\n${filesBlock}"
    })
    return s"# Deliverable manifest\n\nEach engineer's workspace + branch + the files they actually changed (pre-aggregated by the orchestrator — read directly, no need to run git yourself).\n\n${rows.MkString("\n")}"
}

// listChangedFiles returns the file list git would print for
// `git diff --name-only <default>..HEAD` in `cwd`. Empty array on any
// failure (cwd doesn't exist, default branch missing, no commits). The
// "fail soft" policy keeps the QA prompt from blowing up because of a
// stale worktree — the manifest just says "(none)" and QA falls back
// to the engineer reports. Failure modes ARE legitimate: an engineer
// might emit @finished without committing if their work is purely
// analytical (a recommendation, not a code change).
func listChangedFiles(cwd string, defaultBranch string) Array[string] {
    if defaultBranch == "" { return EmptyArray[string]() }
    val opts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("diff", "--name-only", defaultBranch + "..HEAD").ToGoSlice(),
        SliceEmpty[string](),
        cwd,
    )
    val procTry = subprocess.Spawn(opts)
    if procTry.IsFailure() { return EmptyArray[string]() }
    val proc = procTry.Get()
    var out = EmptyArray[string]()
    var stopped = false
    for !stopped {
        val ln = proc.ReadLine()
        if ln.IsFailure() {
            stopped = true
        } else {
            val t = strings.TrimSpace(ln.Get())
            if t != "" { out = out.Append(t) }
        }
    }
    val codeTry = proc.Wait()
    if codeTry.IsFailure() { return EmptyArray[string]() }
    if codeTry.Get() != 0 { return EmptyArray[string]() }
    return out
}

// manifestBranchFor picks the branch each engineer's work lives on.
// Worktree mode → `gala_team/<proj>/<member>`; shared mode → the
// project's default branch (no per-engineer branching). Lifted out of
// buildDeliverableManifest so update.gala can stay free of a dot-
// imported `policy` (which conflicts with the local `policy` symbol
// used elsewhere in this file).
func manifestBranchFor(m AppModel, eng Member) string {
    val name = policy.WorkspaceModeName(m.Policy.WorkspaceMode)
    if name == "worktree-per-engineer" {
        return WorktreeBranchFor(m.Project, eng)
    }
    return m.Project.DefaultBranch
}

// findMemberByName scans the team for a Member whose Name matches.
// Typed-array param so auto-unwrap fires at the call boundary.
func findMemberByName(members Array[Member], name string) Option[Member] =
    members.Find((mem) => mem.Name == name)

// isStickyStatus identifies "don't auto-overwrite me" states. A late
// stray chunk arriving while a member is StFailed (e.g. @blocked) or
// StHelpWaiting (paused for TL guidance) shouldn't silently demote
// them to StWorking — the user needs the original signal to persist
// until the orchestrator (or TL) explicitly resolves it.
func isStickyStatus(s Status) bool = s match {
    case StFailed(_)      => true
    case StHelpWaiting(_) => true
    case _                => false
}

// mkWorkingStatus is a typed shim — wrapping case construction in a
// return-typed helper sidesteps the FIX-013 widening regression for
// any future cases that need it.
func mkWorkingStatus() Status = StWorking()

// ----------------------------------------------------------------------------
// Claude stream-json filtering — typed Codec[T] decode.
// gala 0.41.0+'s Codec[T] supports Array[Struct] field decode and
// silently drops unknown JSON fields, so we model the only shapes we
// care about (assistant message text, result error) and let the
// codec do the heavy lifting. Decode failures land as Try.Failure
// which we trap into emptyChunk() — no raw-JSON leaks ever.
//
// What we explicitly do NOT do anymore:
//   - sanitise the extracted assistant text. The prior heuristic
//     scanned for envelope markers ("\"stop_reason\":", "\"usage\":",
//     etc.) and truncated everything after the first match. That
//     silently dropped legitimate response text whenever claude was
//     asked to explain its own stream-json format (the response would
//     literally contain those substrings). User: "we shouldn't truncate
//     any text, we should extract text carefully" — so we trust whatever
//     the codec returned and render it verbatim. If the codec ever
//     over-runs on a long string literal again, the fix is in gala's
//     JSON decoder, not a downstream truncator.
//   - drop pre-fragment lines based on JSON-token heuristics. The
//     original looksLikeJsonFragment() was a workaround for gala
//     0.41.0's bufio.Scanner buffer being too small (64KB default,
//     long thinking parts split across reads). gala_simple's
//     subprocess now sizes the buffer to 4 MiB (maxLineBytes in
//     subprocess.go) so that fragmentation cause is gone. We keep
//     only the cleanest tail patterns — a line that is JUST `}` or
//     `]}` (after trim) — as a tiny defence against the very rare
//     malformed line. Anything else, even if it looks JSON-shaped, is
//     rendered verbatim. Better to occasionally show an ugly token
//     than silently drop a multi-paragraph response.
//
// Optional diagnostic: setting GALA_TEAM_TRACE_DIR=<dir> tees every
// (raw line, parsed result) pair into per-member JSONL files. See
// app/runtime/trace.gala for the format.
// ----------------------------------------------------------------------------

// ClaudePart is one element of an assistant message's content[]
// array. Claude emits `text`, `tool_use`, `tool_result`, `thinking`,
// etc.; we only render `text`. The Type discriminator is the field
// the dispatcher reads.
struct ClaudePart(Type string, Text string)

// ClaudeAssistantMsg is the inner `message` object. Usage is the
// per-turn cumulative count claude attaches to every assistant
// chunk (it grows monotonically through the turn until the result
// event delivers the final tally). Decoding it here lets us tick
// the header live during streaming instead of waiting for the
// turn-end result.
struct ClaudeAssistantMsg(
    Content Array[ClaudePart],
    Usage   ClaudeUsage,
)

// ClaudeAssistantEvent is the outer event for a `type=assistant`
// stream-json line.
struct ClaudeAssistantEvent(Type string, Message ClaudeAssistantMsg)

// ClaudeUsage is the token / cost accounting block claude attaches to
// every result event. We tally these into AppModel.TokenUsage so the
// header can show running totals across the team.
struct ClaudeUsage(
    InputTokens          int,
    OutputTokens         int,
    CacheReadInputTokens int,
)

// ClaudeResultEvent is the outer event for a `type=result` line.
// IsError + Result let us surface rate-limit / max-turns errors as
// toasts; Usage + TotalCostUsd feed the header token counter.
struct ClaudeResultEvent(
    Type         string,
    IsError      bool,
    Result       string,
    TotalCostUsd float64,
    Usage        ClaudeUsage,
)

// Package-level codecs. Codec[T] instances are immutable and safe to
// share across calls; building one per chunk would just waste work.
val claudeAssistantCodec = json.Codec[ClaudeAssistantEvent](json.SnakeCase())
val claudeResultCodec    = json.Codec[ClaudeResultEvent](json.SnakeCase())

// ClaudeChunk is the parsed shape of one stream-json line.
//   Visible:    the user-facing text to append to the transcript
//               (may be "" when the line is pure orchestration noise)
//   ErrorText:  a non-empty value means claude reported an error
//               (rate limit, max-turns exhausted, etc.) — onChunk
//               surfaces this via toast + LastError instead of the
//               transcript so the chat stays clean.
//   LiveTurn:   Some(usage) when an assistant chunk landed mid-turn.
//               Claude's assistant.message.usage is cumulative for the
//               IN-PROGRESS turn; we mirror it into m.CurrentTurnUsage
//               (overwrite, not add) so the header ticks live.
//   FinalTurn:  Some(usage) on the per-turn `result` event. Commits
//               the in-flight count to TokenUsage[name] and clears
//               CurrentTurnUsage so the next turn starts clean.
//   CostUsd:    running cost from result.total_cost_usd (only set on
//               the final turn event). Summed into m.TotalCostUsd.
struct ClaudeChunk(
    Visible   string,
    ErrorText string,
    LiveTurn  Option[ClaudeUsage],
    FinalTurn Option[ClaudeUsage],
    CostUsd   float64,
)

// emptyChunk is the "drop this line" marker.
func emptyChunk() ClaudeChunk = ClaudeChunk(
    Visible   = "",
    ErrorText = "",
    LiveTurn  = None[ClaudeUsage](),
    FinalTurn = None[ClaudeUsage](),
    CostUsd   = 0.0,
)

// filterClaudeStreamJsonFor is the chunk classifier. The `member`
// name is forwarded to the GALA_TEAM_TRACE_DIR diagnostic; pass "" if
// you don't have one (tests, no-context callers — see the bare
// filterClaudeStreamJson alias below).
//
// Plain non-JSON lines (the test harness occasionally injects bare
// strings) pass through as Visible. JSON lines go through two attempts:
//   1. Decode as ClaudeAssistantEvent — Codec drops unknown fields
//      so result/system/user JSON also "succeeds" but with Type set
//      to a non-"assistant" value. We dispatch on Type after.
//   2. Decode as ClaudeResultEvent for is_error surfacing.
// Anything that decodes to an unrecognised Type is silently dropped
// (never rendered raw — stream-json metadata in the chat pane is the
// worst possible UX).
//
// Trust-the-codec policy: whatever the codec returns as the joined
// `text` parts is rendered verbatim. No post-processing. If gala's
// JSON decoder produces dirty output, the fix is in the decoder.
func filterClaudeStreamJsonFor(member string, line string) ClaudeChunk {
    val trimmed = strings.TrimSpace(line)
    if trimmed == "" {
        return emptyChunk()
    }
    if !strings.HasPrefix(trimmed, "{") {
        // Plain text — render verbatim unless the line is a bare JSON
        // closer (`}` / `]}`). Those bare closers are the only stream
        // shape we still drop, on the premise that real assistant
        // text basically never trims to a single closing brace and
        // a malformed claude stdout line that *was* the second half
        // of a JSON envelope would otherwise leak into the chat.
        // False positives (e.g. an assistant turn that genuinely ends
        // with the literal token "}") are accepted as the lesser evil
        // versus the silent-drop bug we just removed.
        if isBareJsonCloser(trimmed) {
            TraceClaudeLine(member, line, "", "", true, "non-json bare closer")
            return emptyChunk()
        }
        TraceClaudeLine(member, line, line, "", false, "")
        return ClaudeChunk(
            Visible   = line,
            ErrorText = "",
            LiveTurn  = None[ClaudeUsage](),
            FinalTurn = None[ClaudeUsage](),
            CostUsd   = 0.0,
        )
    }
    val asAssistant = claudeAssistantCodec.Decode(trimmed)
    asAssistant match {
        case Success(evt) => {
            if evt.Type == "assistant" {
                val chunk = assistantEventChunk(evt)
                // Assistant chunks with no text parts (thinking-only,
                // tool_use-only) produce empty Visible. They're not
                // dropped from the orchestration stream — onChunk still
                // sees the chunk and accrues usage tokens — but from
                // a "where did the text go?" debugging perspective they
                // contributed nothing visible. Mark as dropped with a
                // reason so the trace makes the distinction clear.
                val dropped = chunk.Visible == ""
                val reason = if (dropped) "assistant chunk with no text parts" else ""
                TraceClaudeLine(member, line, chunk.Visible, "", dropped, reason)
                return chunk
            }
            // result / user / system / control_request / etc — fall
            // through to the result codec which can pull the error
            // text. The codec doesn't fail on these; it just decodes
            // a no-op assistant event with empty Content.
        }
        case Failure(_) => {}
    }
    val asResult = claudeResultCodec.Decode(trimmed)
    return asResult match {
        case Success(evt) => {
            val chunk = resultEventChunk(evt)
            // The result codec also accepts unknown event types
            // (system / rate_limit_event / control_request — Codec[T]
            // ignores unknown fields). Their Type field is intact, so
            // the trace reason explicitly carries it for post-mortem.
            val typeStr = if (evt.Type == "") "<empty>" else evt.Type
            val dropped = chunk.Visible == "" && chunk.ErrorText == ""
            val reason = if (!dropped) "" else if (evt.Type == "result") "result event with no error" else s"non-rendering event type: ${typeStr}"
            TraceClaudeLine(member, line, chunk.Visible, chunk.ErrorText, dropped, reason)
            return chunk
        }
        case Failure(_) => {
            TraceClaudeLine(member, line, "", "", true, "json decoded as neither assistant nor result")
            return emptyChunk()
        }
    }
}

// filterClaudeStreamJson preserves the no-member entry point used by
// existing tests and ad-hoc callers. Tracing under "" lands in
// $GALA_TEAM_TRACE_DIR/_/<stamp>.jsonl after sanitisation.
func filterClaudeStreamJson(line string) ClaudeChunk =
    filterClaudeStreamJsonFor("", line)

// isBareJsonCloser detects lines that, after trim, are JUST `}` or
// `]}`. The bufio buffer is large enough (4 MiB, see
// gala_simple/subprocess/subprocess.go:maxLineBytes) that real
// stream-json fragmentation effectively does not happen, so we no
// longer need the broader marker-substring heuristics that the prior
// looksLikeJsonFragment() used. Keeping just the bare-closer check
// covers the rare leftover case where the OS pipe delivers a JSON
// trailer on its own without the opening brace.
//
// We do NOT special-case lines that *contain* the substrings
// "stop_reason" / "usage" / "session_id" / "input_tokens" — those
// are real words an assistant might use when explaining claude's
// stream-json format, and the previous suffix-truncation against
// them was the bug we just removed.
func isBareJsonCloser(s string) bool {
    if s == "}"  { return true }
    if s == "]}" { return true }
    return false
}

// assistantEventChunk extracts the joined text from an assistant
// event's content[]. Filters parts to `text` only — tool_use,
// tool_result, thinking parts are dropped (the sidebar spinner
// already conveys "tools are running" without flooding the chat).
//
// Tokens carry the message.usage block so accrueTokens can update
// the header live during streaming. Cost stays 0 here because
// claude only reports total_cost_usd on the final result event;
// the cost field updates once at turn end.
//
// Safety net (TWO layers — the codec is the first defence, this is
// the second):
//   1. If the text TRIMS to a stream-json envelope opener, drop it.
//   2. If the text CONTAINS one of the trailing-envelope markers
//      (`"stop_reason":`, `"session_id":`, `"usage":{"input_tokens`),
//      truncate at the first marker. This covers the real-world bug
//      where the codec extracted the legitimate `text` field but
//      ALSO swallowed the trailing envelope (seen with long base64
//      payloads — gala json's string-termination heuristic gets
//      confused by certain characters in the value).
func assistantEventChunk(evt ClaudeAssistantEvent) ClaudeChunk {
    val texts = evt.Message.Content.Collect({
        case ClaudePart(kind, text) if kind == "text" => text
    })
    val joined = texts.MkString("\n")
    val safe = sanitizeAssistantText(joined)
    return ClaudeChunk(
        Visible   = safe,
        ErrorText = "",
        LiveTurn  = Some(evt.Message.Usage),
        FinalTurn = None[ClaudeUsage](),
        CostUsd   = 0.0,
    )
}

// sanitizeAssistantText runs both leak guards in order. If the whole
// text is recognisably a stream-json envelope, drop it; otherwise
// truncate at the first leaked-envelope marker so legitimate prose
// up to the leak is still rendered. Empty input passes through.
func sanitizeAssistantText(text string) string {
    if text == "" { return "" }
    if looksLikeStreamJson(text) { return "" }
    return truncateAtEnvelopeMarker(text)
}

// looksLikeStreamJson is the whole-envelope guard: matches when the
// trimmed text starts with `{"` AND carries a stream-json field
// marker. Conservative — real prose that happens to start with `{`
// won't be dropped unless one of the marker substrings is present.
func looksLikeStreamJson(text string) bool {
    val t = strings.TrimSpace(text)
    if !strings.HasPrefix(t, "{\"") { return false }
    return strings.Contains(t, "\"type\":\"assistant\"") ||
           strings.Contains(t, "\"type\":\"tool_use\"") ||
           strings.Contains(t, "\"type\":\"tool_result\"") ||
           strings.Contains(t, "\"stop_reason\":") ||
           strings.Contains(t, "\"session_id\":")
}

// truncateAtEnvelopeMarker is the partial-leak guard: when the text
// contains a stream-json envelope marker partway through (the codec
// ate the legitimate text PLUS the closing envelope), cut at the
// first marker so the user sees clean prose up to the leak point.
//
// Markers chosen for low false-positive rate: real assistant prose
// almost never contains literal `"stop_reason":` or `"usage":{"input_tokens`
// — they'd have to be inside a code block, in which case they'd be
// fenced and likely escaped. Acceptable cost of false-positive: a
// rare assistant message about claude's API gets clipped at a
// substring; we'd rather under-render than leak.
//
// Uses strings.SplitN(prefix-only) per marker rather than slicing —
// gala doesn't allow s[0:cut] on raw strings.
func truncateAtEnvelopeMarker(text string) string {
    val markers = ArrayOf(
        "\"stop_reason\":",
        "\"stop_sequence\":",
        "\"session_id\":",
        "\"usage\":{\"input_tokens",
        "\"usage\":{\"output_tokens",
        "\"parent_tool_use_id\":",
        "}],\"stop_reason\"",
        "}],\"usage\":",
    )
    var truncated = text
    var i = 0
    val n = markers.Size()
    for i < n {
        val parts = strings.SplitN(truncated, markers.Get(i), 2)
        if len(parts) > 1 {
            truncated = parts[0]
        }
        i = i + 1
    }
    return strings.TrimRight(truncated, " \t\n\"}],")
}

// resultEventChunk dispatches result events: errors surface as
// ErrorText (toast + LastError); successes drop entirely. Both paths
// stamp FinalTurn + CostUsd so onChunk commits the in-flight turn
// count and bumps total cost.
func resultEventChunk(evt ClaudeResultEvent) ClaudeChunk {
    if evt.Type != "result" { return emptyChunk() }
    val tokens = Some(evt.Usage)
    if evt.IsError {
        val msg = if (evt.Result == "") "claude reported an error" else evt.Result
        return ClaudeChunk(
            Visible   = "",
            ErrorText = msg,
            LiveTurn  = None[ClaudeUsage](),
            FinalTurn = tokens,
            CostUsd   = evt.TotalCostUsd,
        )
    }
    // Render the `result` field as visible text on a clean turn. Two
    // claude output shapes ship to us:
    //   (a) Streaming: many `assistant.message.text` chunks during the
    //       turn + a final `result` event whose Result field echoes the
    //       full text. In this case the assistant chunks already
    //       populated the transcript; we drop the result echo.
    //   (b) Bulk: zero assistant chunks, only one `result` event whose
    //       Result field IS the entire turn. Without rendering it the
    //       transcript stays empty and the user sees no response.
    //
    // We can't tell (a) from (b) at this layer (the per-member
    // streaming-text accumulator is in onChunk, not here). Render the
    // result text whenever it's substantive AND looks like prose, not
    // a stream-json envelope re-encoding. Duplicate display in case (a)
    // is the lesser evil vs. silent drop in case (b) — DESIGN.md says
    // "we'd rather under-format than under-render".
    val visibleResult = sanitizeAssistantText(evt.Result)
    return ClaudeChunk(
        Visible   = visibleResult,
        ErrorText = "",
        LiveTurn  = None[ClaudeUsage](),
        FinalTurn = tokens,
        CostUsd   = evt.TotalCostUsd,
    )
}

// formatDirectiveMarkers rewrites orchestration markers in the chunk
// text so the user-facing transcript shows WHO each directive routes
// to. Replaces directive openers with a labelled arrow:
//
//   @dispatch(Felix)         →  "→ Felix:"
//   @consult(transpiler)     →  "→ team transpiler:"
//   @summary                 →  "Summary:"
//   @help                    →  "Help needed:"
//   @blocked                 →  "Blocked:"
//   @finished | @done        →  "Done:"
//   @end                     →  (dropped)
//
// Same-line body after the opener is preserved (left of `@end`). The
// arrow form makes a TL turn that fans out to multiple members read as
// a small dispatch summary instead of a wall of unattributed prose.
func formatDirectiveMarkers(text string) string {
    if text == "" { return "" }
    val lines = strings.Split(text, "\n")
    var kept = EmptyArray[string]()
    var i = 0
    val n = len(lines)
    for i < n {
        val ln = lines[i]
        val replacement = rewriteMarkerLine(ln)
        if replacement != "" {
            kept = kept.Append(replacement)
        }
        i = i + 1
    }
    return kept.MkString("\n")
}

// rewriteMarkerLine returns the user-facing form of a single line:
//   - "" if the line is `@end` (drop it entirely)
//   - the original line if it isn't a marker (passthrough)
//   - "→ <Target>:" / "Summary:" / etc. if the line opens a directive
//     (the same-line tail is appended after the colon when present)
func rewriteMarkerLine(line string) string {
    val trimmed = strings.TrimSpace(line)
    if trimmed == "" { return line }
    if trimmed == "@end" || strings.HasPrefix(trimmed, "@end ") { return "" }
    if strings.HasPrefix(trimmed, "@dispatch(") {
        val (target, rest) = parseTargetMarker(trimmed, "@dispatch(")
        return formatRoutedMarker(s"→ ${target}", rest)
    }
    if strings.HasPrefix(trimmed, "@consult(") {
        val (target, rest) = parseTargetMarker(trimmed, "@consult(")
        return formatRoutedMarker(s"→ team ${target}", rest)
    }
    if strings.HasPrefix(trimmed, "@summary") {
        return formatRoutedMarker("Summary", strings.TrimSpace(strings.TrimPrefix(trimmed, "@summary")))
    }
    if strings.HasPrefix(trimmed, "@finished") {
        return formatRoutedMarker("Done", strings.TrimSpace(strings.TrimPrefix(trimmed, "@finished")))
    }
    if strings.HasPrefix(trimmed, "@done") {
        return formatRoutedMarker("Done", strings.TrimSpace(strings.TrimPrefix(trimmed, "@done")))
    }
    if strings.HasPrefix(trimmed, "@help") {
        return formatRoutedMarker("Help needed", strings.TrimSpace(strings.TrimPrefix(trimmed, "@help")))
    }
    if strings.HasPrefix(trimmed, "@blocked") {
        return formatRoutedMarker("Blocked", strings.TrimSpace(strings.TrimPrefix(trimmed, "@blocked")))
    }
    return line
}

// parseTargetMarker splits "@dispatch(Felix) tail..." into ("Felix",
// "tail..."). The closing paren is mandatory; if it's missing (the
// chunk arrived mid-stream), returns the everything-after-prefix as
// the target so the rendered line at least shows a partial label.
func parseTargetMarker(trimmed string, prefix string) Tuple[string, string] {
    val afterOpen = strings.TrimPrefix(trimmed, prefix)
    // SplitN(afterOpen, ")", 2) yields [target, rest] when the close
    // paren exists, [afterOpen] when it doesn't (mid-stream chunk).
    val parts = strings.SplitN(afterOpen, ")", 2)
    if len(parts) < 2 {
        return (strings.TrimSpace(afterOpen), "")
    }
    return (strings.TrimSpace(parts[0]), strings.TrimSpace(parts[1]))
}

// formatRoutedMarker stitches the label and the same-line body. Empty
// body → just the label with a colon ("Summary:"). Non-empty body →
// "label: body" so `@summary done.` renders as `Summary: done.`.
func formatRoutedMarker(label string, body string) string {
    if body == "" { return s"  ${label}:" }
    return s"  ${label}: ${body}"
}

// isCleanCloseError matches errors that mean "the subprocess finished
// naturally" rather than "the subprocess crashed". On Windows, when
// claude exits cleanly its stdin pipe closes, and any in-flight write
// from gala_team's SendFuture surfaces as `write |1: The pipe has been
// ended.` even though nothing is actually broken — claude already
// produced its output and exited. Treating these errors the same as
// EOF avoids spurious auto-retry loops.
func isCleanCloseError(err string) bool {
    if err == "EOF"                                            { return true }
    if strings.Contains(err, "The pipe has been ended")        { return true }
    if strings.Contains(err, "broken pipe")                    { return true }
    if strings.Contains(err, "file already closed")            { return true }
    // bufio.Scanner returns "Read returned impossible count"
    // when the underlying pipe Read violates the io.Reader
    // contract (Windows stdout occasionally hits this on very
    // long stream-json lines). Retrying just spawns another
    // claude that hits the same OS-level glitch, so we treat
    // this as a terminal-but-clean turn end and let the FSM
    // advance via TLDone like a normal EOF.
    if strings.Contains(err, "impossible count")               { return true }
    return false
}

// mkRecoveringStatus constructs a StRecovering case and returns it
// typed as the parent Status. Sealed-case widening fires on `return`
// statements (FIX-007) but not on function-call argument sites for
// multi-arg cases — wrapping the construction in a return-typed
// helper sidesteps that. Same workaround for any other multi-arg
// sealed-case argument site.
// FIX-013 workaround: positional construction widens to parent type
// where named (`StRecovering(Attempt = a, Max = m)`) does not.
// Pre-formatting the note string to "N/M" sidesteps multi-arg cases.
func mkRecoveringStatus(attempt int, max int) Status = StRecovering(s"${attempt}/${max}")

// onApprove is the Phase-1 approval flow: when the FSM is in Approval,
// the user pressed Ctrl+A. We transition the FSM via ApprovalAccepted,
// log "/approve", and gate the PR-create on the team's pre-merge hooks
// (Policy.PreMerge). On a clean hook run, PreMergeHooksPassed fires
// onPreMergeHooksPassed which finally spawns `gh pr create`. On the
// first failure, PreMergeHooksFailed lands in LastError and no PR is
// opened.
//
// When the policy has no pre-merge hooks (the default), we skip the
// hook step and go straight to `gh pr create` — same shape as before
// the policy gate landed.
//
// In any other state the key is a no-op so users don't accidentally
// open PRs.
func onApprove(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    return m.State match {
        case Approval(body) => approveAndKickHooks(m, body)
        case _              => (m, NoCmd[AppMsg]())
    }
}

// setStatus updates m.Statuses[name] AND folds the work-elapsed
// counter so the sidebar timer reflects total work duration (paused
// while idle) instead of "time since last chunk" (which was a
// liveness signal that confused users into thinking the timer was a
// stopwatch).
//
//   - Transition idle → working: stamp WorkStartedAt[name] = now.
//   - Transition working → idle: add (now - WorkStartedAt[name]) to
//     WorkElapsedNs[name] and clear WorkStartedAt[name].
//   - Working → working (within working bucket): no-op; the segment
//     keeps running.
//
// LastChunkAt is left untouched — the liveness FSM in onTick still
// reads it to decide StSlow / StStuck thresholds.
func setStatus(m AppModel, name string, st Status) AppModel {
    val prior = m.Statuses.Get(name).GetOrElse(StIdle())
    val wasWorking = isWorkingStatus(prior)
    val nowWorking = isWorkingStatus(st)
    if !wasWorking && nowWorking {
        return m.Copy(
            Statuses      = m.Statuses.Put(name, st),
            WorkStartedAt = m.WorkStartedAt.Put(name, m.NowAt),
        )
    }
    if wasWorking && !nowWorking {
        val started = m.WorkStartedAt.Get(name)
        val priorAccum = m.WorkElapsedNs.Get(name).GetOrElse(int64(0))
        val seg = started match {
            case None()    => int64(0)
            case Some(at)  => {
                val a = m.NowAt.UnixNanos()
                val b = at.UnixNanos()
                if (a > b) a - b else int64(0)
            }
        }
        return m.Copy(
            Statuses      = m.Statuses.Put(name, st),
            WorkElapsedNs = m.WorkElapsedNs.Put(name, priorAccum + seg),
            WorkStartedAt = m.WorkStartedAt.Remove(name),
        )
    }
    return m.Copy(Statuses = m.Statuses.Put(name, st))
}

// isWorkingStatus returns true for any status that should accrue
// time on the sidebar timer. StRecovering is included because the
// member is still in a turn (just retrying); StFailed / StHelpWaiting
// are excluded because the user is meant to act on them.
func isWorkingStatus(s Status) bool = s match {
    case StWorking()      => true
    case StSlow()          => true
    case StStuck()         => true
    case StRecovering(_)   => true
    case _                 => false
}

// resetAllStatuses sets every team member back to StIdle. Called
// after a successful merge — the team's pipeline is done, the next
// prompt starts fresh.
func resetAllStatuses(m AppModel) AppModel {
    var statuses = m.Statuses
    val members = m.Team.Members
    var i = 0
    val n = members.Size()
    for i < n {
        statuses = statuses.Put(members.Get(i).Name, StIdle())
        i = i + 1
    }
    return m.Copy(Statuses = statuses)
}

func approveAndKickHooks(m AppModel, body string) Tuple[AppModel, Cmd[AppMsg]] {
    // PR-readiness pre-check: refuse to launch `gh pr create` when the
    // current branch has no commits ahead of the default branch.
    // Without this, hitting Ctrl+A on a chat-only summary (or before
    // engineers' worktree commits have landed on the lead's branch)
    // crashes `gh` with an opaque "no commits" error and the user is
    // left wondering why the PR didn't open.
    val readiness = checkPrReady(m.Project)
    if readiness.IsDefined() {
        val reason = readiness.GetOrElse("")
        return (m.Copy(
            LastError    = Some(s"approval: ${reason}"),
            Conversation = m.Conversation.Append(
                session.ConversationLine(Speaker = "policy", Text = s"approval blocked: ${reason}"),
            ),
        ), NoCmd[AppMsg]())
    }
    val nextState = Transition(m.State, ApprovalAccepted(), transitionContext(m))
    val withState = m.Copy(
        State        = nextState,
        Conversation = m.Conversation.Append(session.ConversationLine(Speaker = "you", Text = "/approve")),
    )
    if m.Policy.PreMerge.IsEmpty() {
        return (withState, runtimeFutureToCmd(GhPrCreateFuture(m.Project, body)))
    }
    val noted = withState.Copy(
        Conversation = withState.Conversation.Append(
            session.ConversationLine(Speaker = "policy", Text = s"running ${m.Policy.PreMerge.Size()} pre-merge hook(s)…"),
        ),
    )
    return (noted, hooksFutureCmd(m.Project, m.Policy.PreMerge, body))
}

// checkPrReady returns Some(reason) when the project's current branch
// is NOT in a state that `gh pr create` will accept. Returns None when
// it looks safe to fire the PR-creation pipeline. Reasons we surface
// (instead of letting `gh` crash with an opaque message):
//   - HEAD == defaultBranch (no diverged work, nothing to PR)
//   - HEAD has zero commits ahead of defaultBranch
// We deliberately do NOT call out to the network (`gh repo view`,
// `git fetch`) — the check should be quick and offline-safe so the
// approval banner stays responsive.
func checkPrReady(proj Project) Option[string] {
    if proj.DefaultBranch == "" { return None[string]() }
    val opts = subprocess.NewSpawnOpts(
        "git",
        ArrayOf("rev-list", "--count", proj.DefaultBranch + "..HEAD").ToGoSlice(),
        SliceEmpty[string](),
        proj.Repo,
    )
    val procTry = subprocess.Spawn(opts)
    if procTry.IsFailure() { return None[string]() }
    val proc = procTry.Get()
    var lastLine = ""
    var stopped = false
    for !stopped {
        val ln = proc.ReadLine()
        if ln.IsFailure() {
            stopped = true
        } else {
            val t = strings.TrimSpace(ln.Get())
            if t != "" { lastLine = t }
        }
    }
    val codeTry = proc.Wait()
    if codeTry.IsFailure() { return None[string]() }
    val code = codeTry.Get()
    if code != 0 {
        // `git rev-list <branch>..HEAD` failed — probably the default
        // branch ref doesn't exist locally. Don't block the approval;
        // let `gh pr create` produce its own error.
        return None[string]()
    }
    if lastLine == "0" {
        return Some(s"no commits ahead of ${proj.DefaultBranch} — nothing to PR")
    }
    return None[string]()
}

// hooksFutureCmd lifts policy.RunHooksFuture into a Cmd[AppMsg]. The
// future resolves to Try[bool]; we map Success(_) to
// PreMergeHooksPassed(body) (carrying the summary so the PR-create
// step has it) and Failure(err) to PreMergeHooksFailed(err.Error()).
func hooksFutureCmd(proj Project, hooks Array[policy.Hook], body string) Cmd[AppMsg] =
    FutureCmd[AppMsg](Fut = policy.RunHooksFuture(proj, hooks).Map((res Try[bool]) => res match {
        case Success(_)   => PreMergeHooksPassed(SummaryBody = body)
        case Failure(err) => PreMergeHooksFailed(ErrText = err.Error())
    }))

// onPreMergeHooksPassed appends a confirmation line to the transcript
// and finally fires `gh pr create` with the original summary body.
func onPreMergeHooksPassed(m AppModel, body string) Tuple[AppModel, Cmd[AppMsg]] {
    val withLog = m.Copy(
        Conversation = m.Conversation.Append(
            session.ConversationLine(Speaker = "policy", Text = "pre-merge hooks: ✓ all green, opening PR"),
        ),
    )
    return (withLog, runtimeFutureToCmd(GhPrCreateFuture(m.Project, body)))
}

// onPreMergeHooksFailed records the first failing hook's error and
// stops the approval pipeline. The PR is not opened; the user can
// inspect LastError, redirect the team to fix whatever the hook
// flagged, and re-approve.
func onPreMergeHooksFailed(m AppModel, err string) Tuple[AppModel, Cmd[AppMsg]] {
    return (m.Copy(
        LastError    = Some(s"pre-merge hooks: ${err}"),
        Conversation = m.Conversation.Append(
            session.ConversationLine(Speaker = "policy", Text = s"pre-merge hooks: ✗ ${err}"),
        ),
    ), NoCmd[AppMsg]())
}

// onReject mirrors onApprove but transitions the FSM via
// ApprovalRejected and emits no Cmd (no PR is created). The user is
// expected to type a follow-up prompt to redirect the team.
func onReject(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    return m.State match {
        case Approval(_) => rejectAndIdle(m)
        case _           => (m, NoCmd[AppMsg]())
    }
}

// rejectAndIdle clears the approval banner and surfaces a short hint
// directing the user to type a follow-up prompt explaining what TL
// should change. We don't auto-spawn a TL turn here — the user owns
// the rejection reason; pre-filling the composer would leak our
// opinion into theirs. The hint goes through the conversation log so
// the audit trail captures what was rejected.
func rejectAndIdle(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    val nextState = Transition(m.State, ApprovalRejected(), transitionContext(m))
    val withState = m.Copy(
        State = nextState,
        Conversation = m.Conversation
            .Append(session.ConversationLine(Speaker = "you", Text = "/reject"))
            .Append(session.ConversationLine(
                Speaker = "system",
                Text = "Approval rejected. Type a prompt to redirect the team — the lead picks it up as the next turn.",
            )),
    )
    return (withState, NoCmd[AppMsg]())
}

// onPrCreated records the URL in LastPrUrl + the conversation log so
// the user has a copy-paste-friendly link AND a hint for Ctrl+M to
// trigger the merge step. We don't auto-open the browser (no browser
// in headless / CI contexts) and don't auto-merge (the user always
// gets a confirmation step).
func onPrCreated(m AppModel, url string) Tuple[AppModel, Cmd[AppMsg]] {
    // Wrap the URL in OSC 8 so terminals that support it (Windows
    // Terminal / iTerm2 / kitty / modern xterm) render it as a real
    // clickable hyperlink. Terminals that don't recognise the escape
    // drop it silently and the URL still renders inline.
    val linkified = prOscOpen(url) + url + prOscClose()
    val toast = m.Toasts.PushInfo(s"PR ready · ${url}", time_utils.Now(), time_utils.Seconds(int64(8)))
    return (m.Copy(
        LastPrUrl    = Some(url),
        Toasts       = toast,
        Conversation = m.Conversation
            .Append(session.ConversationLine(Speaker = "gh", Text = s"PR created: ${linkified}"))
            .Append(session.ConversationLine(Speaker = "gh", Text = s"Press Ctrl+M to merge with --${policy.MergeRuleName(m.Policy.MergeRule)}.")),
    ), NoCmd[AppMsg]())
}

// prOscOpen / prOscClose emit the OSC 8 escape sequence pair. The gala-tui
// package exports its own oscOpen/oscClose names so we prefix to avoid
// the dot-import collision. \x1b]8;;<url>\x1b\\ opens; \x1b]8;;\x1b\\
// closes. We can't reuse gala-tui's Link helper here (it returns a
// Widget; this code path needs to embed raw chars in a string field
// that flows through ConversationLog), so we duplicate the byte
// sequence — same shape as the gala-tui implementation.
func prOscOpen(url string) string {
    val esc = string(rune(27))
    return s"${esc}]8;;${url}${esc}\\"
}

func prOscClose() string {
    val esc = string(rune(27))
    return s"${esc}]8;;${esc}\\"
}

// onMerge fires when the user presses Ctrl+M after a PrCreated. Only
// acts when LastPrUrl is set; outside that, the key is a no-op (the
// user can't merge what hasn't been opened).
func onMerge(m AppModel) Tuple[AppModel, Cmd[AppMsg]] = m.LastPrUrl match {
    case None()    => (m, NoCmd[AppMsg]())
    case Some(url) => mergeAndKickPostMerge(m, url)
}

func mergeAndKickPostMerge(m AppModel, url string) Tuple[AppModel, Cmd[AppMsg]] {
    val withLog = m.Copy(
        Conversation = m.Conversation.Append(
            session.ConversationLine(Speaker = "you", Text = "/merge"),
        ),
    )
    return (withLog, runtimeFutureToCmd(GhPrMergeFuture(m.Project, url, m.Policy.MergeRule)))
}

// onMerged echoes the URL into the conversation, clears LastPrUrl
// (the same PR can't be merged twice), resets every member's status
// to Idle (the pipeline is done — next prompt starts fresh), kicks
// any PostMerge hooks, and snapshots the now-immutable conversation
// log into .gala_team/sessions/archive/ so future `Ctrl+H` runs can
// pull it back up. On a clean hook run, PostMergeHooksPassed
// appends the final "✓ all green" line.
func onMerged(m AppModel, url string) Tuple[AppModel, Cmd[AppMsg]] {
    val _ = session.ArchiveLatest(m.Project.Repo, "merged")  // best-effort; failure is silent
    val withMerge = resetAllStatuses(m.Copy(
        LastPrUrl    = None[string](),
        Conversation = m.Conversation.Append(
            session.ConversationLine(Speaker = "gh", Text = s"merged: ${url}"),
        ),
    ))
    if m.Policy.PostMerge.IsEmpty() {
        return (withMerge, NoCmd[AppMsg]())
    }
    val noted = withMerge.Copy(
        Conversation = withMerge.Conversation.Append(
            session.ConversationLine(Speaker = "policy", Text = s"running ${m.Policy.PostMerge.Size()} post-merge hook(s)…"),
        ),
    )
    return (noted, postMergeHooksFutureCmd(m.Project, m.Policy.PostMerge, url))
}

func postMergeHooksFutureCmd(proj Project, hooks Array[policy.Hook], url string) Cmd[AppMsg] =
    FutureCmd[AppMsg](Fut = policy.RunHooksFuture(proj, hooks).Map((res Try[bool]) => res match {
        case Success(_)   => PostMergeHooksPassed(Url = url)
        case Failure(err) => PostMergeHooksFailed(ErrText = err.Error())
    }))

func onPostMergeHooksPassed(m AppModel, url string) Tuple[AppModel, Cmd[AppMsg]] {
    return (m.Copy(
        Conversation = m.Conversation.Append(
            session.ConversationLine(Speaker = "policy", Text = s"post-merge hooks: ✓ all green (${url})"),
        ),
    ), NoCmd[AppMsg]())
}

// onConsultChunkArrived appends one streamed line from the child team
// to the conversation log under a `consult/<name>` speaker, and
// accumulates the raw line into ConsultBuffers so the eventual
// onConsultEnded can extract the @summary block from the full child
// transcript. Re-arms the event pump for that consult; if the
// session has been swept out (e.g. ConsultEnded already fired) the
// pump is not restarted.
func onConsultChunkArrived(m AppModel, name string, line string) Tuple[AppModel, Cmd[AppMsg]] {
    val newConvo = m.Conversation.Append(session.ConversationLine(
        Speaker = s"consult/${name}",
        Text    = line,
    ))
    val priorBuffer = m.ConsultBuffers.Get(name).GetOrElse(EmptyArray[string]())
    val newBuffers  = m.ConsultBuffers.Put(name, priorBuffer.Append(line))
    val withChunk   = m.Copy(Conversation = newConvo, ConsultBuffers = newBuffers)
    return withChunk.ActiveConsults.Get(name) match {
        case Some(s) => (withChunk, consultEventFutureCmd(s))
        case None()  => (withChunk, NoCmd[AppMsg]())
    }
}

// onConsultEnded fires once the child team's TL closes its stdout.
// Drains the per-consult buffer, parses it for an `@summary` block,
// drops the live session + buffer, and re-emits a ConsultCompleted /
// ConsultFailed so the existing back-to-TL forwarding handlers stay
// the single source of truth for "what does the lead see when a
// consult finishes". A best-effort CloseConsultSession runs to reap
// the subprocess; failure is silent (the kernel will reap the zombie
// when the parent exits).
func onConsultEnded(m AppModel, name string, errText Option[string]) Tuple[AppModel, Cmd[AppMsg]] {
    val priorBuffer = m.ConsultBuffers.Get(name).GetOrElse(EmptyArray[string]())
    val cleaned = m.ActiveConsults.Get(name) match {
        case Some(s) => {
            val _ = CloseConsultSession(s)
            return m.Copy(ActiveConsults = m.ActiveConsults.Remove(name))
        }
        case None() => m
    }
    val finalModel = cleaned.Copy(ConsultBuffers = cleaned.ConsultBuffers.Remove(name))
    val nextMsg = errText match {
        case None()    => ConsultCompleted(Name = name, Summary = extractConsultSummary(priorBuffer))
        case Some(err) => if (err == "EOF") ConsultCompleted(Name = name, Summary = extractConsultSummary(priorBuffer))
                          else              ConsultFailed(Name = name, ErrText = err)
    }
    return (finalModel, MsgCmd[AppMsg](Msg = nextMsg))
}

// extractConsultSummary scans the accumulated raw stdout lines from
// the child team's TL for the first `@summary` block and returns its
// body. Mirrors headless.extractSummary but operates on Array[string]
// so we don't need to wrap each line in a ConversationLine just to
// unwrap it for parsing.
func extractConsultSummary(lines Array[string]) Option[string] =
    Parse(lines.MkString("\n"))
        .Collect({ case Summary(body) => body })
        .HeadOption()

// onConsultCompleted records the consult outcome in the conversation
// log and forwards it to the TL's stdin so the TL can incorporate the
// result into its next response. Summary may be None when the consulted
// team didn't emit `@summary`; we surface that explicitly so the user
// (and the TL) can tell apart "no summary" from "summary said nothing".
func onConsultCompleted(m AppModel, name string, summary Option[string]) Tuple[AppModel, Cmd[AppMsg]] {
    val body = summary match {
        case Some(s) => s
        case None()  => "(no @summary block — see project log for full transcript)"
    }
    val withLog = m.Copy(
        Conversation = m.Conversation
            .Append(session.ConversationLine(
                Speaker = "consult",
                Text    = s"${name} ✓",
            ))
            .Append(session.ConversationLine(
                Speaker = name,
                Text    = body,
            )),
    )
    return (withLog, sendConsultBackToLead(withLead(m), name, body, true))
}

// onConsultFailed records the failure in the conversation log and
// forwards a brief notice to the TL so it can react (e.g. retry, fall
// back to its own knowledge).
func onConsultFailed(m AppModel, name string, errText string) Tuple[AppModel, Cmd[AppMsg]] {
    val withLog = m.Copy(
        LastError    = Some(s"consult ${name}: ${errText}"),
        Conversation = m.Conversation.Append(session.ConversationLine(
            Speaker = "consult",
            Text    = s"${name} ✗ ${errText}",
        )),
    )
    return (withLog, sendConsultBackToLead(withLead(m), name, errText, false))
}

// withLead returns the team lead's MemberSession if alive — otherwise
// None — so the consult-result-forwarding Cmd can be a no-op when the
// TL has died or never spawned.
func withLead(m AppModel) Option[MemberSession] = m.Sessions.Get(m.Team.Lead.Name)

// sendConsultBackToLead wraps the consult outcome as a single
// `[consult/<name>] <body>` line on the TL's stdin so the TL can read
// it back as part of the conversation. We don't re-arm the chunk pump
// here — onChunk is already in flight for the lead; this just feeds
// new context so its next thought has the consult result available.
func sendConsultBackToLead(lead Option[MemberSession], name string, body string, ok bool) Cmd[AppMsg] = lead match {
    case None()    => NoCmd[AppMsg]()
    case Some(s)   => {
        val tag = if (ok) "consult-ok" else "consult-err"
        val msg = s"[${tag}/${name}] ${body}"
        return runtimeFutureToCmd(SendFuture(s, msg))
    }
}

// runtimeFutureToCmd lifts a runtime.Msg-typed Future into the AppMsg
// vocabulary so it can be returned as a Cmd from update(). The mapping
// is one-to-one over the three runtime.Msg variants.
func runtimeFutureToCmd(fut concurrent.Future[Msg]) Cmd[AppMsg] =
    FutureCmd[AppMsg](Fut = fut.Map(runtimeToAppMsg))

// runtimeToAppMsg lifts a runtime.Msg into the AppMsg sealed type. The
// runtime cases are prefixed `Rt` so they don't collide with the AppMsg
// names when both sealed types are dot-imported. SessionFailed and
// PrFailed carry an error at the runtime boundary; we materialize the
// message here so AppMsg stays string-only.
func runtimeToAppMsg(rm Msg) AppMsg = rm match {
    case RtChunkArrived(name, line) => ChunkArrived(Member = name, Line = line)
    case RtSessionFailed(name, err) => SessionFailed(Member = name, ErrText = err.Error())
    case RtWriteSent(name)          => WriteSent(Member = name)
    case RtStderrArrived(name, line) => StderrArrived(Member = name, Line = line)
    case RtStderrEnded(name)        => StderrEnded(Member = name)
    case RtPrCreated(url)           => PrCreated(Url = url)
    case RtPrFailed(err)            => PrFailed(ErrText = err.Error())
    case RtMerged(url)              => Merged(Url = url)
    case RtMergeFailed(err)         => MergeFailed(ErrText = err.Error())
}

// transitionContext extracts the per-team facts the FSM needs from the
// current model.  Pure; doesn't touch IO.
func transitionContext(m AppModel) TransitionContext = TransitionContext(
    QAMembers  = MembersOf(m.Team, QA()).Map((member) => member.Name),
    QARequired = m.Workflow.QARequired,
)

// trimLastRune removes the final rune from `s`. Returns "" if `s` is
// already empty.  Goes via []rune so we trim grapheme-cleanly instead
// of byte-fiddling at the UTF-8 level.
//
// SliceTo (from go_interop) gives us the rune slice; string(...) is
// Go's native []rune → string conversion (the inverse direction
// without a helper is not supported by GALA's parser).
func trimLastRune(s string) string {
    val rs = ToRunes(s)
    val n = len(rs)
    return if (n == 0) "" else string(SliceTo(rs, n - 1))
}

// ----------------------------------------------------------------------------
// History browser handlers
// ----------------------------------------------------------------------------

// onEscOrDeselect routes Esc by precedence: the quit-confirmation
// prompt wins (any-key would be too aggressive — only Esc cancels
// it, matching the footer hint); then the recovery banner; then
// FocusSidebar pops back to FocusComposer so the user can resume
// typing; then HistoryDeselect closes a viewed archive; otherwise
// no-op.
//
// Dismissing the recovery banner clears Conversation +
// RecoveredMembers so the user gets a clean slate, matching the
// banner's "Esc to discard" hint.
func onEscOrDeselect(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    if m.QuitPending {
        return (m.Copy(QuitPending = false), NoCmd[AppMsg]())
    }
    if m.EraseSessionPending {
        return (m.Copy(EraseSessionPending = false), NoCmd[AppMsg]())
    }
    // Modal stack closes in reverse z-order: help is topmost, then
    // recovery, guidance, project-info, member-detail, archive view.
    if m.HelpVisible {
        return (m.Copy(HelpVisible = false), NoCmd[AppMsg]())
    }
    if m.RecoveryModalOpen {
        // Esc on the recovery modal = "discard prior session" — same
        // semantics as the Start fresh button, so wipe worktrees too
        // for consistency. Without this, Esc would silently leave
        // stale worktrees on disk while the rest of the prior
        // session was wiped, creating the same staleness bug.
        wipeMemberWorktrees(m)
        val empty = EmptyArray[session.ConversationLine]()
        val cleared = m.Copy(
            RecoveryModalOpen     = false,
            RecoveryBannerVisible = false,
            RecoveredMembers      = EmptyArray[string](),
            Conversation          = empty,
            ConversationOffset    = 0,
            ConversationSticky    = true,
        )
        // Persist the cleared conversation so the NEXT launch doesn't
        // load stale data from .gala_team/sessions/latest.json.
        // Without this, "discard → quit → reopen" round-trips the
        // prior conversation back in via primeFromSnapshot.
        return (persistConversation(cleared, empty), NoCmd[AppMsg]())
    }
    if m.GuidanceOpen {
        return (m.Copy(GuidanceOpen = false), NoCmd[AppMsg]())
    }
    if m.ProjectInfoOpen {
        return (m.Copy(ProjectInfoOpen = false), NoCmd[AppMsg]())
    }
    if m.MemberDetailOpen.IsDefined() {
        return (m.Copy(MemberDetailOpen = None[string]()), NoCmd[AppMsg]())
    }
    if m.RecoveryBannerVisible {
        return (m.Copy(
            RecoveryBannerVisible = false,
            RecoveredMembers      = EmptyArray[string](),
            Conversation          = EmptyArray[session.ConversationLine](),
            ConversationOffset    = 0,
            ConversationSticky    = true,
        ), NoCmd[AppMsg]())
    }
    val focusedSidebar = m.Focus match {
        case FocusSidebar()  => true
        case FocusComposer() => false
    }
    if focusedSidebar {
        return (m.Copy(Focus = FocusComposer()), NoCmd[AppMsg]())
    }
    return (m.Copy(ViewingArchive = None[session.Snapshot]()), NoCmd[AppMsg]())
}

// onToggleHistory flips HistoryMode and resets the cursor + viewing
// state when entering. Closing the browser does NOT clear Archives —
// they were loaded once at startup and don't go stale during a
// session (new merges add to the list but the index is rebuilt on
// next launch).
func onToggleHistory(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    val opening = !m.HistoryMode
    val next = m.Copy(
        HistoryMode    = opening,
        HistoryCursor  = if (opening) 0 else m.HistoryCursor,
        ViewingArchive = None[session.Snapshot](),
    )
    return (next, NoCmd[AppMsg]())
}

// onHistoryCursorMove shifts the cursor by `delta` (clamped to a
// valid range) when the history browser is open and no archive is
// being viewed. Outside that mode it's a no-op so accidental
// arrow-key presses during normal chat don't disturb the model.
func onHistoryCursorMove(m AppModel, delta int) Tuple[AppModel, Cmd[AppMsg]] {
    val canMove = m.HistoryMode && !m.ViewingArchive.IsDefined() && m.Archives.Size() > 0
    if !canMove { return (m, NoCmd[AppMsg]()) }
    val raw = m.HistoryCursor + delta
    val clamped = if (raw < 0) 0
                  else if (raw >= m.Archives.Size()) m.Archives.Size() - 1
                  else raw
    return (m.Copy(HistoryCursor = clamped), NoCmd[AppMsg]())
}

// onHistorySelect kicks off an asynchronous LoadArchive for the
// currently-cursored entry. The result lands as
// HistoryArchiveLoaded / HistoryArchiveFailed so the loader doesn't
// block the UI thread on slow disks.
func onHistorySelect(m AppModel) Tuple[AppModel, Cmd[AppMsg]] {
    val canSelect = m.HistoryMode && !m.ViewingArchive.IsDefined() && m.HistoryCursor < m.Archives.Size()
    if !canSelect { return (m, NoCmd[AppMsg]()) }
    val meta = m.Archives.Get(m.HistoryCursor)
    return (m, archiveLoadCmd(meta.Path))
}

// archiveLoadCmd wraps LoadArchive in a Future so the disk read runs
// off the UI thread; result is mapped to a HistoryArchiveLoaded /
// HistoryArchiveFailed AppMsg.
func archiveLoadCmd(path string) Cmd[AppMsg] =
    FutureCmd[AppMsg](Fut = concurrent.FutureApply[AppMsg](() => session.LoadArchive(path) match {
        case Success(snap) => HistoryArchiveLoaded(Snap = snap)
        case Failure(err)  => HistoryArchiveFailed(ErrText = err.Error())
    }))
