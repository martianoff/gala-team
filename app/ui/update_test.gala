package main

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "github.com/martianoff/gala_team/app/fsm"
    . "github.com/martianoff/gala_team/app/team"
    . "github.com/martianoff/gala_team/app/ui"
)

func sampleTeam() Team {
    val iris = Member(
        Name = "Iris", Role = TeamLead{}.Apply(),
        Personality = "calm",
        Model = None[string]{}.Apply(), Extra = "",
    )
    val felix = Member(
        Name = "Felix", Role = Engineer{}.Apply(),
        Personality = "terse",
        Model = None[string]{}.Apply(), Extra = "",
    )
    return Team(
        Name    = "Skunkworks",
        Members = ArrayOf[Member](iris, felix),
        Lead    = iris,
    )
}

func sampleModel() AppModel = InitialModel(sampleTeam(), DefaultWorkflow())

func TestKeyChar_AppendsToComposer(t T) T {
    val (m1, _) = Update(sampleModel(), KeyChar(C = 'h'))
    val (m2, _) = Update(m1, KeyChar(C = 'i'))
    return Eq(t, m2.Composer, "hi")
}

func TestKeyBackspace_TrimsLastRune(t T) T {
    val (m1, _) = Update(sampleModel(), KeyChar(C = 'h'))
    val (m2, _) = Update(m1, KeyChar(C = 'i'))
    val (m3, _) = Update(m2, KeyBackspace{}.Apply())
    return Eq(t, m3.Composer, "h")
}

func TestKeyBackspace_OnEmpty_NoOp(t T) T {
    val (m, _) = Update(sampleModel(), KeyBackspace{}.Apply())
    return Eq(t, m.Composer, "")
}

func TestKeySubmit_NonEmpty_AdvancesFsmAndClearsComposer(t T) T {
    val seed = sampleModel().Copy(Composer = "hello")
    val (m, _) = Update(seed, KeySubmit{}.Apply())
    val t1 = Eq(t, m.Composer, "")
    return m.State match {
        case TLThinking() => IsTrue(t1, true)
        case _            => IsTrue(t1, false)
    }
}

func TestKeySubmit_Empty_NoOp(t T) T {
    val (m, _) = Update(sampleModel(), KeySubmit{}.Apply())
    val t1 = Eq(t, m.Composer, "")
    return m.State match {
        case Idle() => IsTrue(t1, true)
        case _      => IsTrue(t1, false)
    }
}

func TestTickMsg_BumpsCounter(t T) T {
    val (m1, _) = Update(sampleModel(), TickMsg{}.Apply())
    val (m2, _) = Update(m1, TickMsg{}.Apply())
    return Eq(t, m2.Tick, 2)
}
