// sampleBatchPr builds a stub BatchPr for the merge / batch-list
// tests. Stable shape (canned title, Unix-epoch timestamp) so
// snapshot-style assertions stay deterministic across runs.
func sampleBatchPr(url string) BatchPr = BatchPr(
    Url      = url,
    Branch   = "feat/x",
    Title    = "ship the metrics endpoint",
    OpenedAt = time_utils.UnixEpoch(),
)

// sampleProject points Repo at a fresh temp dir so onChunk's auto-save
// has somewhere to write without polluting the cwd. Each call returns a
// new dir so tests don't share state.
func sampleProject() Project {
    val dir, err = os.MkdirTemp("", "gala_team_update_test_")
    if err != nil { panic(s"MkdirTemp: ${err.Error()}") }
    return Project(
        Name = "demo", Repo = dir,
        Github = None[string](),
        DefaultBranch = "main",
    )
}

func sampleTeam() Team {
    val iris = Member(
        Name = "Iris", Role = TeamLead(),
        Personality = "calm",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val felix = Member(
        Name = "Felix", Role = Engineer(),
        Personality = "terse",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    return Team(
        Key                        = "main",
        Name                       = "Skunkworks",
        Description                = "",
        Members                    = ArrayOf[Member](iris, felix),
        Lead                       = iris,
        Onboarding                 = EmptyArray[string](),
        DangerouslySkipPermissions = false,
    )
}

func sampleModel() AppModel = InitialModel(sampleProject(), sampleTeam(), DefaultWorkflow(), DefaultPolicy())

func TestKeyChar_AppendsToComposer(t T) T {
    val (m1, _) = Update(sampleModel(), KeyChar(C = 'h'))
    val (m2, _) = Update(m1, KeyChar(C = 'i'))
    return Eq(t, m2.Composer, "hi")
}

func TestKeyBackspace_TrimsLastRune(t T) T {
    val (m1, _) = Update(sampleModel(), KeyChar(C = 'h'))
    val (m2, _) = Update(m1, KeyChar(C = 'i'))
    val (m3, _) = Update(m2, KeyBackspace())
    return Eq(t, m3.Composer, "h")
}

func TestKeyBackspace_OnEmpty_NoOp(t T) T {
    val (m, _) = Update(sampleModel(), KeyBackspace())
    return Eq(t, m.Composer, "")
}

func TestKeySubmit_NonEmpty_AdvancesFsmAndClearsComposer(t T) T {
    val seed = sampleModel().Copy(Composer = "hello")
    val (m, _) = Update(seed, KeySubmit())
    val t1 = Eq(t, m.Composer, "")
    return m.State match {
        case TLThinking() => IsTrue(t1, true)
        case _            => IsTrue(t1, false)
    }
}

func TestKeySubmit_Empty_NoOp(t T) T {
    val (m, _) = Update(sampleModel(), KeySubmit())
    val t1 = Eq(t, m.Composer, "")
    return m.State match {
        case Idle() => IsTrue(t1, true)
        case _      => IsTrue(t1, false)
    }
}

// Plain-chat TL response (no @dispatch / @summary directives) must
// still transition the FSM to Idle. Without this, an audit reading
// events.jsonl saw a fresh UserPrompted event pop from "nowhere"
// because the prior turn's TLThinking→Idle hop was assigned
// directly to State, bypassing transitionLogged. Now the empty-
// dispatch path routes through transitionLogged so the audit log
// is complete.
func TestSessionFailed_PlainChatTLResponse_LandsBackInIdle(t T) T {
    val seed = sampleModel().Copy(
        State      = TLThinking(),
        TurnBuffer = "I'll wait for your direction before dispatching.",
    )
    val (m, _) = Update(seed, SessionFailed(Member = "Iris", ErrText = "EOF"))
    return m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
}

func TestTickMsg_BumpsCounter(t T) T {
    val (m1, _) = Update(sampleModel(), TickMsg())
    val (m2, _) = Update(m1, TickMsg())
    return Eq(t, m2.Tick, 2)
}

// ---------------------------------------------------------------------------
// Runtime subprocess events. We don't spawn a real claude here — the pump
// codepaths (ensureSession, sendAndPumpCmd) are exercised via integration
// against the real CLI when cmd/main.gala is run. These unit tests cover
// the pure model transitions ChunkArrived / SessionFailed / WriteSent
// drive without needing a subprocess.
// ---------------------------------------------------------------------------

func TestChunkArrived_AppendsToConversationLog(t T) T {
    val (m, _) = Update(sampleModel(), ChunkArrived(Member = "Iris", Line = "hello world"))
    val t1 = Eq(t, m.Conversation.Size(), 1)
    val first = m.Conversation.Get(0)
    val t2 = Eq(t1, first.Speaker, "Iris")
    return Eq(t2, first.Text, "hello world")
}

func TestChunkArrived_PreservesEarlierLines(t T) T {
    val (m1, _) = Update(sampleModel(), ChunkArrived(Member = "Iris", Line = "first"))
    val (m2, _) = Update(m1,           ChunkArrived(Member = "Iris", Line = "second"))
    val t1 = Eq(t, m2.Conversation.Size(), 2)
    return Eq(t1, m2.Conversation.Get(1).Text, "second")
}

func TestSessionFailed_SetsLastErrorAndDropsSession(t T) T {
    // Sessions starts empty; SessionFailed should leave it empty (Remove of
    // a missing key is a no-op) and set LastError. With auto-retry (#26)
    // the LastError now also carries "retry N/M" so the user sees the
    // orchestrator is working through the recovery, not silently swallowing.
    val (m, _) = Update(sampleModel(), SessionFailed(Member = "Iris", ErrText = "stream closed"))
    return m.LastError match {
        case Some(s) => IsTrue(t, s == "Iris: stream closed — retry 1/2")
        case None()  => IsTrue(t, false)
    }
}

func TestWriteSent_LeavesModelUnchanged(t T) T {
    val seed = sampleModel().Copy(Composer = "draft", Tick = 7)
    val (m, _) = Update(seed, WriteSent(Member = "Iris"))
    val t1 = Eq(t, m.Composer, "draft")
    val t2 = Eq(t1, m.Tick, 7)
    return Eq(t2, m.Conversation.Size(), 0)
}

func TestNoOp_LeavesModelUnchanged(t T) T {
    val seed = sampleModel().Copy(Composer = "x", Tick = 3)
    val (m, _) = Update(seed, NoOp())
    val t1 = Eq(t, m.Composer, "x")
    return Eq(t1, m.Tick, 3)
}

// Approval flow ---------------------------------------------------------------

func TestKeyApprove_OutsideApproval_NoOp(t T) T {
    val seed = sampleModel()  // Idle state
    val (m, _) = Update(seed, KeyApprove())
    return m.State match {
        case Idle() => Eq(t, m.Conversation.Size(), 0)  // no log entry
        case _      => IsTrue(t, false)
    }
}

func TestKeyApprove_InApproval_TransitionsToIdleAndLogs(t T) T {
    val seed = sampleModel().Copy(State = Approval(SummaryBody = "ship it"))
    val m = resolveApprovalReady(seed, KeyApprove())
    val t1 = m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
    val t2 = Eq(t1, m.Conversation.Size(), 1)
    return Eq(t2, m.Conversation.Get(0).Text, "/approve")
}

// Reject now logs the user's `/reject` line PLUS a one-line system
// hint reminding the user to type a follow-up prompt for the lead.
// The audit trail shows both what was rejected and what the
// orchestrator is now waiting on.
func TestKeyReject_InApproval_TransitionsToIdleAndLogs(t T) T {
    val seed = sampleModel().Copy(State = Approval(SummaryBody = "ship it"))
    val (m, _) = Update(seed, KeyReject())
    val t1 = m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
    val t2 = Eq(t1, m.Conversation.Size(), 2)
    val t3 = Eq(t2, m.Conversation.Get(0).Text, "/reject")
    return Eq(t3, m.Conversation.Get(1).Speaker, "system")
}

func TestKeyReject_OutsideApproval_NoOp(t T) T {
    val seed = sampleModel().Copy(Tick = 5)
    val (m, _) = Update(seed, KeyReject())
    return Eq(t, m.Tick, 5)  // unchanged
}

// ----------------------------------------------------------------------------
// Approval modal — input handling: keyboard, Tab focus cycle, and the
// click path. The widget layer (ButtonClick on the Yes / No buttons in
// view.gala::approvalButtonRow) emits KeyApprove / KeyReject AppMsgs
// directly when clicked. These tests dispatch the same messages so a
// regression in the modal's click wiring surfaces as a test failure
// rather than as a "the No button is clickable but does nothing" bug
// the user has to discover by trial.
// ----------------------------------------------------------------------------

// Tab cycles ApprovalFocus from ApproveFocus → RejectFocus while the
// modal is open. KeyToggleFocus is the Tab message; approvalIntercept
// routes it to onApprovalCycle when State = Approval.
func TestApprovalModal_TabCyclesApproveToReject(t T) T {
    val seed = sampleModel().Copy(
        State         = Approval(SummaryBody = "ship it"),
        ApprovalFocus = ApproveFocus(),
    )
    val (m, _) = Update(seed, KeyToggleFocus())
    val a = m.State match {
        case Approval(_) => IsTrue(t, true)   // modal still up
        case _           => IsTrue(t, false)
    }
    return m.ApprovalFocus match {
        case RejectFocus() => IsTrue(a, true)
        case _             => IsTrue(a, false)
    }
}

// Tab from RejectFocus wraps back to ApproveFocus.
func TestApprovalModal_TabCyclesRejectToApprove(t T) T {
    val seed = sampleModel().Copy(
        State         = Approval(SummaryBody = "ship it"),
        ApprovalFocus = RejectFocus(),
    )
    val (m, _) = Update(seed, KeyToggleFocus())
    return m.ApprovalFocus match {
        case ApproveFocus() => IsTrue(t, true)
        case _              => IsTrue(t, false)
    }
}

// Enter (KeySubmit with empty composer) dispatches the focused button.
// With ApproveFocus, that's KeyApprove → State transitions to Idle and
// "/approve" is logged.
func TestApprovalModal_EnterFiresApproveFocus(t T) T {
    val seed = sampleModel().Copy(
        State         = Approval(SummaryBody = "ship it"),
        ApprovalFocus = ApproveFocus(),
        Composer      = "",
    )
    val m = resolveApprovalReady(seed, KeySubmit())
    val t1 = m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
    val t2 = Eq(t1, m.Conversation.Size(), 1)
    return Eq(t2, m.Conversation.Get(0).Text, "/approve")
}

// Enter with RejectFocus fires the rejection path: state → Idle, log
// shows "/reject" + the system "type a prompt to redirect" hint. This
// is the test that proves Tab+Enter is a real path to "no" — without
// it, users were stuck with mouse / Ctrl+R / 'n'.
func TestApprovalModal_EnterFiresRejectFocus(t T) T {
    val seed = sampleModel().Copy(
        State         = Approval(SummaryBody = "ship it"),
        ApprovalFocus = RejectFocus(),
        Composer      = "",
    )
    val (m, _) = Update(seed, KeySubmit())
    val t1 = m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
    val t2 = Eq(t1, m.Conversation.Size(), 2)
    val t3 = Eq(t2, m.Conversation.Get(0).Text, "/reject")
    return Eq(t3, m.Conversation.Get(1).Speaker, "system")
}

// Mouse click on the Yes button: ButtonClick wires KeyApprove() onto
// the click region for that button. Dispatching KeyApprove() directly
// must drive the same approval flow regardless of where focus sits —
// a mouse click bypasses the focus state entirely. RejectFocus on the
// model here proves that "click overrides focus" semantics.
func TestApprovalModal_MouseClickYesApprovesEvenWhenFocusOnNo(t T) T {
    val seed = sampleModel().Copy(
        State         = Approval(SummaryBody = "ship it"),
        ApprovalFocus = RejectFocus(),
    )
    val m = resolveApprovalReady(seed, KeyApprove())
    val t1 = m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
    return Eq(t1, m.Conversation.Get(0).Text, "/approve")
}

// Mouse click on the No button: same shape, opposite direction. The
// ButtonClick on the No widget emits KeyReject(). Even with ApproveFocus
// (default), the click drives the rejection flow.
func TestApprovalModal_MouseClickNoRejectsEvenWhenFocusOnYes(t T) T {
    val seed = sampleModel().Copy(
        State         = Approval(SummaryBody = "ship it"),
        ApprovalFocus = ApproveFocus(),
    )
    val (m, _) = Update(seed, KeyReject())
    val t1 = m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
    return Eq(t1, m.Conversation.Get(0).Text, "/reject")
}

// y/Y still routes to KeyApprove independent of focus — the
// focus-bypass keyboard shortcut for terminals that eat Ctrl+A.
func TestApprovalModal_YShortcutApprovesEvenWhenFocusOnNo(t T) T {
    val seed = sampleModel().Copy(
        State         = Approval(SummaryBody = "ship it"),
        ApprovalFocus = RejectFocus(),
    )
    val m = resolveApprovalReady(seed, KeyChar(C = 'y'))
    val t1 = m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
    return Eq(t1, m.Conversation.Get(0).Text, "/approve")
}

// n/N → KeyReject, regardless of focus.
func TestApprovalModal_NShortcutRejectsEvenWhenFocusOnYes(t T) T {
    val seed = sampleModel().Copy(
        State         = Approval(SummaryBody = "ship it"),
        ApprovalFocus = ApproveFocus(),
    )
    val (m, _) = Update(seed, KeyChar(C = 'n'))
    val t1 = m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
    return Eq(t1, m.Conversation.Get(0).Text, "/reject")
}

// Entering Approval from a non-Approval state resets ApprovalFocus to
// ApproveFocus, even when a residual RejectFocus from a prior approval
// cycle is still on the model. Without the reset, the second time a
// user lands on the modal in one session they'd land on the No button
// without any visible signal — surprise rejection is the worst kind.
func TestApprovalModal_FocusResetsOnReentry(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "gala_team/demo/lead"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "lead work"))
    val goodBody = "## What\n- shipped the thing\n\n## Why\nthe user asked for it\n\n## Follow-ups\nnone"
    val seed = InitialModel(proj, sampleTeam(), DefaultWorkflow(), DefaultPolicy()).Copy(
        State         = TLThinking(),
        TurnBuffer    = "@summary\n" + goodBody + "\n@end",
        ApprovalFocus = RejectFocus(),  // residue from a prior approval cycle
    )
    val m = resolveSummaryReady(seed, SessionFailed(Member = "Iris", ErrText = "EOF"))
    val t1 = m.State match {
        case Approval(_) => IsTrue(t, true)
        case _           => IsTrue(t, false)
    }
    return m.ApprovalFocus match {
        case ApproveFocus() => IsTrue(t1, true)
        case _              => IsTrue(t1, false)
    }
}

// ----------------------------------------------------------------------------
// Conversation scroll — PgUp from a sticky bottom must NOT jump to top.
//
// Regression for "after resume, PgUp scrolls me far away from latest".
// Before the fix, onConvoScroll did `proposed = m.ConversationOffset +
// delta` which, when sticky was true, treated the stale stored offset
// (typically 0) as the current top — adding delta and clamping to 0
// meant any upward scroll landed at the TOP of the log.
// ----------------------------------------------------------------------------

// Build a long conversation so total lines comfortably exceeds any
// plausible viewport. ~80 entries × ~1 line each = ~80 rows; viewport
// is min 4 (TermSize-12 in tests typically 0 → clamped to 4). Even on
// a wide test terminal, total - viewport stays positive.
func longConversation(lines int) Array[session.ConversationLine] {
    var convo = EmptyArray[session.ConversationLine]()
    var i = 0
    for i < lines {
        convo = convo.Append(session.ConversationLine(
            Speaker = "you",
            Text    = s"prompt line ${i}",
        ))
        i = i + 1
    }
    return convo
}

// PgUp from a sticky bottom should land near the bottom (offset ≈
// total - height - delta), not at offset 0 which would mean "top of
// log". We assert the resulting offset is strictly greater than 0
// for any conversation longer than the viewport — that's the bug
// signature: pre-fix the offset stayed at 0.
func TestConvoPageUp_FromStickyDoesNotJumpToTop(t T) T {
    val seed = sampleModel().Copy(
        Conversation       = longConversation(80),
        ConversationOffset = 0,
        ConversationSticky = true,
    )
    val (m, _) = Update(seed, KeyConvoPageUp())
    // Sticky must flip off after an upward scroll.
    val t1 = IsFalse(t, m.ConversationSticky)
    // The new offset must be strictly above 0 — the regression's bug
    // signature is offset=0 = "top of log".
    return IsTrue(t1, m.ConversationOffset > 0)
}

// PgDn from a non-sticky position toward the bottom should land at
// the max offset and re-engage sticky. Defends the symmetric path:
// "user scrolled up, then scrolled back down" must restore the
// auto-follow-bottom behavior so new chunks remain visible.
func TestConvoPageDown_AtBottomReengagesSticky(t T) T {
    val seed = sampleModel().Copy(
        Conversation       = longConversation(80),
        ConversationOffset = 0,
        ConversationSticky = false,
    )
    // Scroll way past the bottom — clamp + sticky should engage.
    val (m, _) = Update(seed, KeyConvoPageDown())
    val (m2, _) = Update(m, KeyConvoPageDown())
    val (m3, _) = Update(m2, KeyConvoPageDown())
    val (m4, _) = Update(m3, KeyConvoPageDown())
    val (m5, _) = Update(m4, KeyConvoPageDown())
    val (m6, _) = Update(m5, KeyConvoPageDown())
    val (m7, _) = Update(m6, KeyConvoPageDown())
    val (m8, _) = Update(m7, KeyConvoPageDown())
    val (m9, _) = Update(m8, KeyConvoPageDown())
    return IsTrue(t, m9.ConversationSticky)
}

// Single-line scroll up from sticky still lands "near bottom" —
// boundary check that the fix handles small deltas (KeyConvoScrollUp)
// the same way as page deltas (KeyConvoPageUp).
func TestConvoScrollUp_FromStickyDoesNotJumpToTop(t T) T {
    val seed = sampleModel().Copy(
        Conversation       = longConversation(80),
        ConversationOffset = 0,
        ConversationSticky = true,
    )
    val (m, _) = Update(seed, KeyConvoScrollUp())
    val t1 = IsFalse(t, m.ConversationSticky)
    return IsTrue(t1, m.ConversationOffset > 0)
}

// Empty / short conversation: PgUp on a log shorter than the viewport
// just stays at offset 0 with sticky off. Verifies the maxOffset = 0
// branch doesn't regress to "negative offset, blank screen".
func TestConvoPageUp_ShortConversation_StaysAtZero(t T) T {
    val short = EmptyArray[session.ConversationLine]()
        .Append(session.ConversationLine(Speaker = "you", Text = "hi"))
    val seed = sampleModel().Copy(
        Conversation       = short,
        ConversationOffset = 0,
        ConversationSticky = true,
    )
    val (m, _) = Update(seed, KeyConvoPageUp())
    return Eq(t, m.ConversationOffset, 0)
}

// runGitInTmp shells out to `git` inside `dir` for one command. Tests
// use it to set up tiny fixture repos for the PR-readiness path,
// since checkPrReady actually runs `git rev-list --count`.
func runGitInTmp(dir string, args Array[string]) {
    val opts = subprocess.NewSpawnOpts(
        "git",
        args.ToGoSlice(),
        SliceEmpty[string](),
        dir,
    )
    val proc = subprocess.Spawn(opts).Get()
    val _ = proc.Wait().Get()
}

// resolveSummaryReady is a test helper that runs the TL @summary
// path end-to-end. The production code splits the path in two —
// SessionFailed parks the parsed dirs on PendingSummaryDirs and
// fires an off-thread checkPrReady probe; the result lands as
// SummaryReadyResult and drives the actual FSM transition. Tests
// want to assert against the final model, so we synthesise the
// readiness probe by calling checkPrReady inline (the test fixture
// has a real git repo, so it returns the same answer the Future
// would) and feed the result back through Update.
//
// Past audits caught the synchronous version of this path freezing
// the TUI when git wedged on index.lock contention. The Update-
// twice shape preserves the prior behaviour for assertion purposes
// while keeping the production hot path off the UI thread.
func resolveSummaryReady(seed AppModel, msg AppMsg) AppModel {
    val (m1, _) = Update(seed, msg)
    if !m1.PendingSummaryDirs.IsDefined() { return m1 }
    val leadName = m1.Team.Lead.Name
    val reason = checkPrReady(m1.Project)
    val (m2, _) = Update(m1, SummaryReadyResult(Member = leadName, Reason = reason))
    return m2
}

// resolveApprovalReady mirrors resolveSummaryReady but for the
// Ctrl+A / KeyApprove path. seed must already be in Approval(body)
// — that's the precondition the production path enforces too.
// Pulls body out of seed.State so we can rebuild the
// ApprovalReadyResult after KeyApprove returns the off-thread
// readiness probe.
func resolveApprovalReady(seed AppModel, msg AppMsg) AppModel {
    val body = seed.State match {
        case Approval(b) => b
        case _           => ""
    }
    val (m1, _) = Update(seed, msg)
    val reason = checkPrReady(m1.Project)
    val (m2, _) = Update(m1, ApprovalReadyResult(Body = body, Reason = reason))
    return m2
}

// emptyLeadBranchProject returns a Project whose repo is a real git
// init'd dir with HEAD == main + zero commits ahead. Triggers
// checkPrReady's Some(reason) early return — the precondition for
// the Bug 1 nudge path. Test fixture only; no network, no branches
// other than main.
func emptyLeadBranchProject() Project {
    val dir, err = os.MkdirTemp("", "gala_team_pr_ready_test_")
    if err != nil { panic(s"MkdirTemp: ${err.Error()}") }
    runGitInTmp(dir, ArrayOf("init", "-q", "-b", "main"))
    runGitInTmp(dir, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                             "commit", "--allow-empty", "-q", "-m", "base"))
    return Project(
        Name = "demo", Repo = dir,
        Github = None[string](),
        DefaultBranch = "main",
    )
}

// Bug 1 regression: when the TL emits @summary but the lead branch
// has zero commits ahead of master, the FSM must NOT enter Approval
// — that would dead-end the user on a modal that can only be
// dismissed (Ctrl+A → "no commits to PR"). Instead, the orchestrator
// nudges the TL with the recovery-paths prompt and stays in the
// prior FSM state.
//
// Setup: real git fixture with HEAD == main + 0 commits ahead, TL
// session active, TurnBuffer holds an @summary directive. On
// SessionFailed("Iris", "EOF") the TLDone path fires.
//
// Asserts:
//   - State did NOT become Approval
//   - Conversation does NOT contain "/approve" (Approval branch
//     would have appended it).
func TestTLSummary_BlocksApprovalWhenLeadBranchEmpty(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    val seedConvo = EmptyArray[session.ConversationLine]()
    val seed = InitialModel(proj, sampleTeam(), DefaultWorkflow(), DefaultPolicy()).Copy(
        State        = TLThinking(),
        TurnBuffer   = "@summary\nship it\n@end",
        Conversation = seedConvo,
    )
    val m = resolveSummaryReady(seed, SessionFailed(Member = "Iris", ErrText = "EOF"))
    val notApproval = m.State match {
        case Approval(_) => IsTrue(t, false)
        case _           => IsTrue(t, true)
    }
    val noApproveLine = m.Conversation.ForAll((cl) => cl.Text != "/approve")
    return IsTrue(notApproval, noApproveLine)
}

// Companion: when the lead branch DOES have commits ahead, the
// @summary path must enter Approval as before. Same fixture except
// we add a divergent commit so checkPrReady returns None.
func TestTLSummary_EntersApprovalWhenLeadBranchHasCommits(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    // Create the actual lead branch with commits — checkPrReady
    // probes the explicit `gala_team/<proj-slug>/lead` ref, not HEAD.
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "gala_team/demo/lead"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "lead work"))
    val goodBody = "## What\n- shipped the thing\n\n## Why\nthe user asked for it\n\n## Follow-ups\nnone"
    val seed = InitialModel(proj, sampleTeam(), DefaultWorkflow(), DefaultPolicy()).Copy(
        State      = TLThinking(),
        TurnBuffer = "@summary\n" + goodBody + "\n@end",
    )
    val m = resolveSummaryReady(seed, SessionFailed(Member = "Iris", ErrText = "EOF"))
    return m.State match {
        case Approval(body) => Eq(t, body, goodBody)
        case _              => IsTrue(t, false)
    }
}

// Regression for the "TL says orchestrator won't let me PR" bug.
// The lead branch has commits past master, but the user's HEAD
// (the cwd of `proj.Repo`) is on master with no work. The earlier
// checkPrReady probed `master..HEAD` from proj.Repo, saw 0 commits,
// and rejected the @summary. Now it probes the explicit lead ref
// so HEAD location is irrelevant — the same lead state is visible
// regardless of which worktree the user has checked out.
func TestTLSummary_LeadHasCommitsButHeadOnMasterStillEntersApproval(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    // Create lead branch with a commit, then check the user back to master.
    // proj.Repo's HEAD is now on master (zero commits past master),
    // but the lead BRANCH has work — the bug was treating these as the
    // same thing.
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "gala_team/demo/lead"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "lead work on its branch"))
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "main"))
    val goodBody = "## What\n- shipped the thing\n\n## Why\nthe user asked for it\n\n## Follow-ups\nnone"
    val seed = InitialModel(proj, sampleTeam(), DefaultWorkflow(), DefaultPolicy()).Copy(
        State      = TLThinking(),
        TurnBuffer = "@summary\n" + goodBody + "\n@end",
    )
    val m = resolveSummaryReady(seed, SessionFailed(Member = "Iris", ErrText = "EOF"))
    return m.State match {
        case Approval(body) => Eq(t, body, goodBody)
        case _              => IsTrue(t, false)
    }
}

// PR-quality gate: when @summary body lacks ## What/## Why/## Follow-ups
// sections, the FSM must NOT enter Approval — instead, it nudges the
// TL with buildBadSummaryBodyNudge and respawns the lead session.
// The reason: that body becomes the PR description verbatim, and a
// reader-facing chat-recap PR is exactly what the user is trying to
// avoid by putting this gate in place.
func TestTLSummary_NudgesWhenBodyLacksSections(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "feature"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "feature work"))
    val seed = InitialModel(proj, sampleTeam(), DefaultWorkflow(), DefaultPolicy()).Copy(
        State      = TLThinking(),
        TurnBuffer = "@summary\nshipped the thing, all good\n@end",
    )
    val m = resolveSummaryReady(seed, SessionFailed(Member = "Iris", ErrText = "EOF"))
    val notApproval = m.State match {
        case Approval(_) => IsTrue(t, false)
        case _           => IsTrue(t, true)
    }
    return notApproval
}

// PR-quality gate: when @summary body name-drops a team member, the
// FSM nudges the TL to rewrite. The body has the right sections so
// the section gate doesn't fire — only the member-name detector
// should reject it.
func TestTLSummary_NudgesWhenBodyMentionsMemberName(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "feature"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "feature work"))
    val seed = InitialModel(proj, sampleTeam(), DefaultWorkflow(), DefaultPolicy()).Copy(
        State      = TLThinking(),
        TurnBuffer = "@summary\n## What\nFelix added the parser\n\n## Why\nbug\n\n## Follow-ups\nnone\n@end",
    )
    val m = resolveSummaryReady(seed, SessionFailed(Member = "Iris", ErrText = "EOF"))
    return m.State match {
        case Approval(_) => IsTrue(t, false)
        case _           => IsTrue(t, true)
    }
}

// Async wipe: Start fresh / Ctrl+N must set WipingWorktrees=true
// (so the view's "Wiping…" banner shows) and return a Cmd that
// drives the future. The data side clears synchronously; the IO
// runs off-thread. The previous synchronous wipe froze the TUI
// for 5-10s while git fetched + reset + per-engineer worktrees
// were removed serially.
func TestEraseSession_SecondPressSetsWipingFlag(t T) T {
    val seed = sampleModel().Copy(EraseSessionPending = true)
    val (m, _) = Update(seed, KeyEraseSession())
    return IsTrue(t, m.WipingWorktrees)
}

// WorktreesWiped (the future's resolution message) must clear the
// WipingWorktrees flag so the banner disappears.
func TestWorktreesWiped_ClearsWipingFlag(t T) T {
    val seed = sampleModel().Copy(WipingWorktrees = true)
    val (m, _) = Update(seed, WorktreesWiped())
    return IsTrue(t, !m.WipingWorktrees)
}

// Regression for the "QA abandoned milliseconds after dispatch"
// bug. setStatus(idle→working) must reset LastChunkAt to NowAt so
// the heartbeat FSM doesn't immediately escalate to StFailed because
// of a stale prior-turn timestamp. The pattern: a QA member's
// LastChunkAt from a prior review is many minutes stale by the
// time they're re-dispatched, and elapsed > AbandonAfterSeconds
// triggers MemberAbandoned on the next tick before the new claude
// can produce any output.
func TestSetStatus_ResetsLastChunkAtOnIdleToWorking(t T) T {
    val seed = sampleModel()
    val staleTime = time_utils.FromUnixSeconds(int64(1000))
    val nowTime   = time_utils.FromUnixSeconds(int64(9999))
    val withStale = seed.Copy(
        Statuses    = seed.Statuses.Put("Felix", StIdle()),
        LastChunkAt = seed.LastChunkAt.Put("Felix", staleTime),
        NowAt       = nowTime,
    )
    val after = setStatus(withStale, "Felix", StWorking())
    return after.LastChunkAt.Get("Felix") match {
        case Some(at) => Eq(t, at.UnixNanos(), nowTime.UnixNanos())
        case None()   => IsTrue(t, false)
    }
}

// Working→working keeps LastChunkAt untouched (only reset on the
// transition INTO working, not on every status update during the
// same turn). Without this guarantee, a re-poll of an already-
// working member would mask the heartbeat clock.
func TestSetStatus_KeepsLastChunkAtOnWorkingToWorking(t T) T {
    val seed = sampleModel()
    val chunkTime = time_utils.FromUnixSeconds(int64(5000))
    val nowTime   = time_utils.FromUnixSeconds(int64(9999))
    val withWorking = seed.Copy(
        Statuses    = seed.Statuses.Put("Felix", StWorking()),
        LastChunkAt = seed.LastChunkAt.Put("Felix", chunkTime),
        NowAt       = nowTime,
    )
    val after = setStatus(withWorking, "Felix", StWorking())
    return after.LastChunkAt.Get("Felix") match {
        case Some(at) => Eq(t, at.UnixNanos(), chunkTime.UnixNanos())
        case None()   => IsTrue(t, false)
    }
}

// Direct unit test for dedupTargetsByName — first occurrence wins,
// order preserved. Defends against a TL claude stream emitting one
// logical turn as two identical chunks: without dedup, TurnBuffer
// would accumulate duplicate @dispatch blocks and the FoldLeft in
// spawnDispatchedMembers would spawn each member twice.
func TestDedupTargetsByName_DropsDuplicates(t T) T {
    val targets = ArrayOf(
        ("Felix", "body F"),
        ("Mira",  "body M"),
        ("Felix", "body F duplicate"),
        ("Mira",  "body M duplicate"),
    )
    val out = dedupTargetsByName(targets)
    val a = Eq(t, out.Size(), 2)
    val b = Eq(a, out.Get(0).V1, "Felix")
    val c = Eq(b, out.Get(0).V2, "body F")            // first occurrence body kept
    val d = Eq(c, out.Get(1).V1, "Mira")
    return Eq(d, out.Get(1).V2, "body M")
}

func TestDedupTargetsByName_PassesUniqueThrough(t T) T {
    val targets = ArrayOf(("Felix", "F"), ("Mira", "M"), ("Theo", "T"))
    val out = dedupTargetsByName(targets)
    val a = Eq(t, out.Size(), 3)
    return Eq(a, out.Get(2).V1, "Theo")
}

func TestDedupTargetsByName_EmptyInputReturnsEmpty(t T) T {
    val out = dedupTargetsByName(EmptyArray[Tuple[string, string]]())
    return Eq(t, out.Size(), 0)
}

// Stale-session-id detection — claude returns this when --resume
// points at an id it doesn't recognise. Detection is case-insensitive
// substring so wording variations across claude versions all match.
func TestLooksLikeStaleSessionError_MatchesNoConversationFound(t T) T {
    val err = "No conversation found with session ID: 36870845-bff8-45a6-beb8-6d93f5f6f631"
    return IsTrue(t, looksLikeStaleSessionError(err))
}

func TestLooksLikeStaleSessionError_MatchesSessionNotFound(t T) T {
    return IsTrue(t, looksLikeStaleSessionError("Error: session not found"))
}

func TestLooksLikeStaleSessionError_RejectsUnrelatedError(t T) T {
    return IsTrue(t, !looksLikeStaleSessionError("rate limit exceeded"))
}

func TestLooksLikeStaleSessionError_RejectsEmpty(t T) T {
    return IsTrue(t, !looksLikeStaleSessionError(""))
}

// Direct unit test for validatePrBody — empty body is rejected.
func TestValidatePrBody_RejectsEmpty(t T) T {
    val result = validatePrBody("", sampleTeam())
    return IsTrue(t, result.IsDefined())
}

// Direct unit test for validatePrBody — well-formed body passes.
func TestValidatePrBody_AcceptsWellFormed(t T) T {
    val body = "## What\n- did the thing\n\n## Why\nuser asked\n\n## Follow-ups\nnone"
    val result = validatePrBody(body, sampleTeam())
    return IsTrue(t, !result.IsDefined())
}

// Direct unit test for validatePrBody — body without sections rejected.
func TestValidatePrBody_RejectsMissingSections(t T) T {
    val body = "we shipped the thing today, lots of work but it's done"
    val result = validatePrBody(body, sampleTeam())
    return IsTrue(t, result.IsDefined())
}

// Direct unit test for validatePrBody — orchestration phrase detected.
func TestValidatePrBody_RejectsOrchestrationPhrase(t T) T {
    val body = "## What\n- did stuff\n\n## Why\nI dispatched the engineer to do it"
    val result = validatePrBody(body, sampleTeam())
    return IsTrue(t, result.IsDefined())
}

// Regression: a TL once pasted "please run git -C
// ...\.gala_team\worktrees\_lead log..." escalation prose as the
// @summary body. Internal orchestration paths would leak into the
// public PR description. The path-leak guard catches `.gala_team`,
// lead worktree paths, and orchestration vocabulary that means
// nothing to PR reviewers.
func TestValidatePrBody_RejectsGalaTeamPath(t T) T {
    val body = "## What\nFix something\n\n## Why\nPlease run git -C /workdir/.gala_team/worktrees/_lead log to verify"
    val result = validatePrBody(body, sampleTeam())
    return IsTrue(t, result.IsDefined())
}

func TestValidatePrBody_RejectsWorktreeLeadMention(t T) T {
    val body = "## What\nfix\n\n## Why\nThe lead worktree at worktrees/_lead has the commits"
    val result = validatePrBody(body, sampleTeam())
    return IsTrue(t, result.IsDefined())
}

func TestValidatePrBody_RejectsPreFlightCheckMention(t T) T {
    val body = "## What\nblocked\n\n## Why\nThe pre-flight check disagrees with the actual lead state"
    val result = validatePrBody(body, sampleTeam())
    return IsTrue(t, result.IsDefined())
}

func TestValidatePrBody_RejectsOrchestratorMention(t T) T {
    val body = "## What\nfix\n\n## Why\nThe orchestrator's bookkeeping went wrong"
    val result = validatePrBody(body, sampleTeam())
    return IsTrue(t, result.IsDefined())
}

func TestValidatePrBody_AcceptsCleanBody(t T) T {
    val body = "## What\nAdd HMAC to crypto package\n\n## Why\nNeeded for JWT signing\n\n## Follow-ups\nHKDF deferred to follow-up PR"
    val result = validatePrBody(body, sampleTeam())
    return IsTrue(t, !result.IsDefined())
}

// Direct unit test for containsWord — substring inside identifier
// must NOT trigger a false positive (the whole point of word-boundary
// matching). 'felix' inside 'felix-config.yaml' is a word match (dash
// is non-word); 'felix' inside 'FelixValidate' is NOT (case-folded,
// surrounded by word chars).
func TestContainsWord_RespectsWordBoundaries(t T) T {
    val a = IsTrue(t, containsWord("hello Felix world", "Felix"))
    val b = IsTrue(a, containsWord("path/felix-config.yaml here", "felix"))
    val c = IsTrue(b, !containsWord("FelixValidate fired", "felix"))
    val d = IsTrue(c, !containsWord("HelloFelixWorld", "felix"))
    return d
}

// ----------------------------------------------------------------------------
// Resume → recoverApprovalIfReady
//
// On resume, if the prior session ended with the lead emitting an
// @summary AND the lead branch is still PR-ready (commits ahead of
// master), the user should land back in Approval rather than Idle.
// Otherwise resume drops them in Idle and they have to re-prompt
// the TL just to re-enter the same Approval modal they had open
// when they quit.
// ----------------------------------------------------------------------------

// Helper: build an AppModel as if the user just resumed a session.
// The recovery modal is open with focus = ResumeFocus, conversation
// is populated from the snapshot. Pressing Enter / clicking Resume
// goes through onRecoveryConfirm which calls recoverApprovalIfReady.
func resumedModel(proj Project, convo Array[session.ConversationLine]) AppModel =
    InitialModel(proj, sampleTeam(), DefaultWorkflow(), DefaultPolicy()).Copy(
        Conversation          = convo,
        RecoveryBannerVisible = true,
        Recovery              = Some(ResumeFocus()),
    )

// ----------------------------------------------------------------------------
// Recovery modal — input handling
//
// The modal is opened on app start when a previous session's snapshot
// exists. While it's up, the dispatchMsg layer must intercept Tab
// (cycle focus) and Enter (confirm) so they don't leak to the composer
// or the FSM. Mouse clicks on the buttons emit KeyRecoveryClick(c)
// which sets focus + confirms in one step.
//
// These tests are the regression net for the "doesn't get any input"
// bug — they assert the message → state transitions directly, so any
// future refactor that breaks the intercept layer surfaces here
// instead of in a manual session.
// ----------------------------------------------------------------------------

// Tab cycles ResumeFocus → InspectFocus while the modal is open.
// KeyToggleFocus is the Tab/Ctrl+L message; recoveryIntercept routes
// it to onRecoveryCycle when the modal is up.
func TestRecoveryModal_TabCyclesResumeToInspect(t T) T {
    val seed = resumedModel(sampleProject(), EmptyArray[session.ConversationLine]())
    val (m, _) = Update(seed, KeyToggleFocus())
    val a = IsTrue(t, m.Recovery.IsDefined())  // modal still up
    return m.Recovery match {
        case Some(InspectFocus()) => IsTrue(a, true)
        case _                    => IsTrue(a, false)
    }
}

// Tab from InspectFocus advances to StartFreshFocus.
func TestRecoveryModal_TabCyclesInspectToStartFresh(t T) T {
    val seed = resumedModel(sampleProject(), EmptyArray[session.ConversationLine]())
        .Copy(Recovery = Some(InspectFocus()))
    val (m, _) = Update(seed, KeyToggleFocus())
    return m.Recovery match {
        case Some(StartFreshFocus()) => IsTrue(t, true)
        case _                       => IsTrue(t, false)
    }
}

// Tab from StartFreshFocus wraps back to ResumeFocus.
func TestRecoveryModal_TabWrapsStartFreshToResume(t T) T {
    val seed = resumedModel(sampleProject(), EmptyArray[session.ConversationLine]())
        .Copy(Recovery = Some(StartFreshFocus()))
    val (m, _) = Update(seed, KeyToggleFocus())
    return m.Recovery match {
        case Some(ResumeFocus()) => IsTrue(t, true)
        case _                   => IsTrue(t, false)
    }
}

// Enter (KeySubmit) on the open modal closes it via the focused
// choice. ResumeFocus on an empty conversation lands in Idle (no
// summary to recover) and the modal flag clears.
func TestRecoveryModal_EnterConfirmsClosesModal(t T) T {
    val seed = resumedModel(sampleProject(), EmptyArray[session.ConversationLine]())
    val (m, _) = Update(seed, KeySubmit())
    return IsFalse(t, m.Recovery.IsDefined())
}

// Mouse click on the Inspect button emits KeyRecoveryClick(InspectFocus).
// That should set focus + confirm in one step → modal closes,
// ReadOnlyMode flips on.
func TestRecoveryModal_ClickInspectClosesModalAndReadOnly(t T) T {
    val seed = resumedModel(sampleProject(), EmptyArray[session.ConversationLine]())
    val (m, _) = Update(seed, KeyRecoveryClick(Choice = InspectFocus()))
    val a = IsFalse(t, m.Recovery.IsDefined())
    return IsTrue(a, m.ReadOnlyMode)
}

// Mouse click on the Start fresh button → freshSession path. Modal
// closes, conversation is wiped.
func TestRecoveryModal_ClickStartFreshClosesAndWipes(t T) T {
    val convo = EmptyArray[session.ConversationLine]()
        .Append(session.ConversationLine(Speaker = "you", Text = "old prompt"))
    val seed = resumedModel(sampleProject(), convo)
    val (m, _) = Update(seed, KeyRecoveryClick(Choice = StartFreshFocus()))
    val a = IsFalse(t, m.Recovery.IsDefined())
    return IsTrue(a, m.Conversation.IsEmpty())
}

// Composer input must NOT leak through while the modal is up — typing
// 'x' should be swallowed (or ignored) instead of appending to Composer.
// The intercept currently returns None for KeyChar, which means it
// FALLS THROUGH to onKeyChar → composer append. That's the regression:
// any character keypress goes into the composer behind the modal.
func TestRecoveryModal_KeyCharDoesNotLeakToComposer(t T) T {
    val seed = resumedModel(sampleProject(), EmptyArray[session.ConversationLine]())
    val (m, _) = Update(seed, KeyChar(C = 'x'))
    return Eq(t, m.Composer, "")
}

// Resume into Approval when conversation ends with lead @summary
// AND lead branch has commits ahead of master AND the body passes
// the PR-quality gate. Fixture: branch off main and commit so
// checkPrReady returns None; body has the required ## What/## Why
// sections so validatePrBody passes.
func TestResume_RecoversApprovalWhenSummaryAndCommitsExist(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "gala_team/demo/lead"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "lead work"))
    val goodBody = "## What\nShip the crypto package\n\n## Why\nUser asked\n\n## Follow-ups\nnone"
    val convo = EmptyArray[session.ConversationLine]()
        .Append(session.ConversationLine(Speaker = "you", Text = "ship the crypto package"))
        .Append(session.ConversationLine(Speaker = "Iris", Text = "@summary\n" + goodBody + "\n@end"))
    val seed = resumedModel(proj, convo)
    val (m, _) = Update(seed, KeyRecoveryConfirm())
    return m.State match {
        case Approval(body) => Eq(t, body, goodBody)
        case _              => IsTrue(t, false)
    }
}

// Regression: resume must NOT enter Approval when the snapshotted
// @summary fails the PR-quality gate. Without this guard, a stale
// "I give up — please run git -C ...\.gala_team\..." escalation
// body would resume straight into Approval and the user's next
// Ctrl+A would ship it to GitHub. Instead, recovery spawns a TL
// nudge so the lead rewrites @summary properly before Approval
// re-engages.
func TestResume_RecoveryRejectsBadSummaryAndStaysOutOfApproval(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "gala_team/demo/lead"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "lead work"))
    val badBody = "Blocked: pre-flight check disagrees with `git -C /workdir/.gala_team/worktrees/_lead log` — please verify"
    val convo = EmptyArray[session.ConversationLine]()
        .Append(session.ConversationLine(Speaker = "Iris", Text = "@summary\n" + badBody + "\n@end"))
    val seed = resumedModel(proj, convo)
    val (m, _) = Update(seed, KeyRecoveryConfirm())
    val notApproval = m.State match {
        case Approval(_) => IsTrue(t, false)
        case _           => IsTrue(t, true)
    }
    return notApproval
}

// Resume stays Idle when lead branch is empty even if conversation
// has a stale @summary — checkPrReady gate prevents dead-ending in
// the same modal that's stuck.
func TestResume_StaysIdleWhenLeadBranchEmpty(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    val convo = EmptyArray[session.ConversationLine]()
        .Append(session.ConversationLine(Speaker = "Iris", Text = "@summary\nold work\n@end"))
    val seed = resumedModel(proj, convo)
    val (m, _) = Update(seed, KeyRecoveryConfirm())
    return m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
}

// Resume stays Idle when no @summary exists in conversation.
// Conversation has only chat / dispatch text, no terminal summary.
// (PR-readiness is also satisfied — checkout a feature branch with
// a commit so the only thing distinguishing this from the recovery
// case is the absence of @summary.)
func TestResume_StaysIdleWhenNoSummary(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "gala_team/demo/lead"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "lead work"))
    val convo = EmptyArray[session.ConversationLine]()
        .Append(session.ConversationLine(Speaker = "Iris", Text = "Let me think about that"))
    val seed = resumedModel(proj, convo)
    val (m, _) = Update(seed, KeyRecoveryConfirm())
    return m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
}

// When multiple @summary lines exist (e.g. the user rejected an
// older one and the TL produced a newer one), the MOST RECENT must
// win. The body recovered should be the latest summary's body.
func TestResume_LatestSummaryWinsWhenMultiple(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "gala_team/demo/lead"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "lead work"))
    val olderBody = "## What\nold proposal\n\n## Why\nfirst attempt"
    val newerBody = "## What\nnewer proposal\n\n## Why\nrevised"
    val convo = EmptyArray[session.ConversationLine]()
        .Append(session.ConversationLine(Speaker = "Iris", Text = "@summary\n" + olderBody + "\n@end"))
        .Append(session.ConversationLine(Speaker = "you",  Text = "/reject"))
        .Append(session.ConversationLine(Speaker = "Iris", Text = "@summary\n" + newerBody + "\n@end"))
    val seed = resumedModel(proj, convo)
    val (m, _) = Update(seed, KeyRecoveryConfirm())
    return m.State match {
        case Approval(body) => Eq(t, body, newerBody)
        case _              => IsTrue(t, false)
    }
}

// In production the persisted conversation contains the RENDERED
// summary ("Summary:\n<body>") not the raw directive — formatDirective-
// Markers strips the @summary/@end markers before we save. Recovery
// must recognize this rendered form too, otherwise resume after a
// real session never recovers Approval.
func TestResume_RecoversApprovalFromRenderedSummary(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "gala_team/demo/lead"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "lead work"))
    val rendered = "Picking path C.\n  Summary:\n## What\nReady-to-ship change\n\n## Why\nUser asked to ship\n\n## Follow-ups\nnone"
    val convo = EmptyArray[session.ConversationLine]()
        .Append(session.ConversationLine(Speaker = "Iris", Text = rendered))
    val seed = resumedModel(proj, convo)
    val (m, _) = Update(seed, KeyRecoveryConfirm())
    return m.State match {
        case Approval(body) => IsTrue(t, strings.Contains(body, "Ready-to-ship change"))
        case _              => IsTrue(t, false)
    }
}

// @summary spoken by a non-lead member (e.g. an engineer pasting
// the directive in their report) must NOT trigger recovery — only
// the lead's voice opens Approval. Branch+commit fixture so PR
// readiness alone isn't what's blocking recovery.
func TestResume_IgnoresSummaryFromNonLead(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "gala_team/demo/lead"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "lead work"))
    val convo = EmptyArray[session.ConversationLine]()
        .Append(session.ConversationLine(Speaker = "Felix", Text = "@summary\nengineer's faux summary\n@end"))
    val seed = resumedModel(proj, convo)
    val (m, _) = Update(seed, KeyRecoveryConfirm())
    return m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
}

// onPrCreated also appends a "Press Ctrl+M to merge" hint line, so
// the conversation has 2 entries — TestPrCreated_AppendsBothLogLines
// covers the count; this one focuses on the URL line itself.
// The PR-created log line embeds an OSC 8 escape so terminals that
// support it render the URL as a clickable hyperlink. Tests check for
// the URL substring rather than equality so the escape wrapping
// doesn't make the assertion brittle.
func TestPrCreated_AppendsUrlToConversationLog(t T) T {
    val (m, _) = Update(sampleModel(), PrCreated(Url = "https://github.com/x/y/pull/1", Branch = "gala_team/x/pr/abc"))
    val first = m.Conversation.Get(0)
    val t1 = Eq(t, first.Speaker, "gh")
    val t2 = IsTrue(t1, strings.HasPrefix(first.Text, "PR created: "))
    return IsTrue(t2, strings.Contains(first.Text, "https://github.com/x/y/pull/1"))
}

func TestPrFailed_SetsLastErrorWithGhPrefix(t T) T {
    val (m, _) = Update(sampleModel(), PrFailed(ErrText = "auth required"))
    return m.LastError match {
        case Some(s) => Eq(t, s, "gh pr create: auth required")
        case None()  => IsTrue(t, false)
    }
}

// Pre-merge hook integration ---------------------------------------------

func TestApprove_WithEmptyHooks_GoesStraightToPr(t T) T {
    // Default policy has no pre-merge hooks; approval should advance the
    // FSM and emit the gh pr create Cmd directly. We can't observe the
    // Cmd's effect in a unit test, but we can confirm the model side:
    // exactly one "/approve" line was logged and no policy line.
    //
    // Drives the message twice — KeyApprove kicks the off-thread
    // PR-readiness probe; ApprovalReadyResult lands with the answer
    // (None, because sampleProject's temp dir isn't a git repo so
    // checkPrReady's subprocess exits non-zero and falls through to
    // None). resolveApprovalReady wraps both steps.
    val seed = sampleModel().Copy(State = Approval(SummaryBody = "ship it"))
    val m = resolveApprovalReady(seed, KeyApprove())
    val t1 = Eq(t, m.Conversation.Size(), 1)
    return Eq(t1, m.Conversation.Get(0).Text, "/approve")
}

func TestApprove_WithHooks_LogsRunningBanner(t T) T {
    // With a non-empty PreMerge list, onApprove should log the
    // "/approve" line plus a policy "running N pre-merge hook(s)…"
    // banner before kicking the runner Future.
    val pol = DefaultPolicy().Copy(PreMerge = ArrayOf(
        Hook(Name = "lint", Cmd = "git", Args = ArrayOf("--version")),
    ))
    val seed = InitialModel(sampleProject(), sampleTeam(), DefaultWorkflow(), pol)
        .Copy(State = Approval(SummaryBody = "ship it"))
    val m = resolveApprovalReady(seed, KeyApprove())
    val t1 = Eq(t, m.Conversation.Size(), 2)
    val t2 = Eq(t1, m.Conversation.Get(0).Speaker, "you")
    val t3 = Eq(t2, m.Conversation.Get(0).Text, "/approve")
    val t4 = Eq(t3, m.Conversation.Get(1).Speaker, "policy")
    return Eq(t4, m.Conversation.Get(1).Text, "running 1 pre-merge hook(s)…")
}

func TestPreMergeHooksPassed_LogsAndKicksPr(t T) T {
    val seed = sampleModel().Copy(State = Idle())
    val (m, _) = Update(seed, PreMergeHooksPassed(SummaryBody = "ship it"))
    val t1 = Eq(t, m.Conversation.Size(), 1)
    val t2 = Eq(t1, m.Conversation.Get(0).Speaker, "policy")
    return Eq(t2, m.Conversation.Get(0).Text, "pre-merge hooks: ✓ all green, opening PR")
}

func TestPreMergeHooksFailed_StopsPipelineWithError(t T) T {
    val (m, _) = Update(sampleModel(), PreMergeHooksFailed(ErrText = "lint exited with code 1: 3 issues"))
    val t1 = m.LastError match {
        case Some(s) => Eq(t, s, "pre-merge hooks: lint exited with code 1: 3 issues")
        case None()  => IsTrue(t, false)
    }
    val t2 = Eq(t1, m.Conversation.Size(), 1)
    return Eq(t2, m.Conversation.Get(0).Text, "pre-merge hooks: ✗ lint exited with code 1: 3 issues")
}

// ---------------------------------------------------------------------------
// Merge flow — Ctrl+M after PrCreated
// ---------------------------------------------------------------------------

func TestPrCreated_AppendsToOpenPrs(t T) T {
    val (m, _) = Update(sampleModel(), PrCreated(Url = "https://x/y/pull/7", Branch = "gala_team/x/pr/def7"))
    val t1 = Eq(t, m.OpenPrs.Size(), 1)
    return Eq(t1, m.OpenPrs.Get(0).Url, "https://x/y/pull/7")
}

func TestPrCreated_AppendsBothLogLines(t T) T {
    val (m, _) = Update(sampleModel(), PrCreated(Url = "https://x/y/pull/7", Branch = "gala_team/x/pr/def7"))
    val t1 = Eq(t, m.Conversation.Size(), 2)
    val t2 = IsTrue(t1, strings.Contains(m.Conversation.Get(0).Text, "https://x/y/pull/7"))
    return IsTrue(t2, m.Conversation.Get(1).Text == "Press Ctrl+M to merge with --squash.")
}

func TestKeyMerge_WithoutPriorPr_NoOp(t T) T {
    val seed = sampleModel()  // OpenPrs is empty
    val (m, _) = Update(seed, KeyMerge())
    val t1 = Eq(t, m.Conversation.Size(), 0)
    return IsTrue(t1, m.OpenPrs.IsEmpty())
}

func TestKeyMerge_WithOpenPr_LogsMergeIntent(t T) T {
    val seed = sampleModel().Copy(OpenPrs = ArrayOf(sampleBatchPr("https://x/y/pull/7")))
    val (m, _) = Update(seed, KeyMerge())
    val t1 = Eq(t, m.Conversation.Size(), 1)
    return Eq(t1, m.Conversation.Get(0).Text, "/merge")
}

func TestMerged_DropsMatchingPrAndLogs(t T) T {
    val seed = sampleModel().Copy(OpenPrs = ArrayOf(sampleBatchPr("https://x/y/pull/7")))
    val (m, _) = Update(seed, Merged(Url = "https://x/y/pull/7"))
    val t1 = IsTrue(t, m.OpenPrs.IsEmpty())
    val t2 = Eq(t1, m.Conversation.Size(), 1)
    return Eq(t2, m.Conversation.Get(0).Text, "merged: https://x/y/pull/7")
}

func TestMerged_BatchMode_OnlyDropsMatchingEntry(t T) T {
    val seed = sampleModel().Copy(OpenPrs = ArrayOf(
        sampleBatchPr("https://x/y/pull/7"),
        sampleBatchPr("https://x/y/pull/8"),
    ))
    val (m, _) = Update(seed, Merged(Url = "https://x/y/pull/8"))
    val t1 = Eq(t, m.OpenPrs.Size(), 1)
    return Eq(t1, m.OpenPrs.Get(0).Url, "https://x/y/pull/7")
}

func TestMerged_WithPostMergeHooks_LogsBanner(t T) T {
    val pol = DefaultPolicy().Copy(PostMerge = ArrayOf(
        Hook(Name = "notify", Cmd = "echo", Args = ArrayOf("done")),
    ))
    val seed = InitialModel(sampleProject(), sampleTeam(), DefaultWorkflow(), pol)
        .Copy(OpenPrs = ArrayOf(sampleBatchPr("https://x/y/pull/7")))
    val (m, _) = Update(seed, Merged(Url = "https://x/y/pull/7"))
    val t1 = Eq(t, m.Conversation.Size(), 2)
    val t2 = Eq(t1, m.Conversation.Get(0).Speaker, "gh")
    return Eq(t2, m.Conversation.Get(1).Text, "running 1 post-merge hook(s)…")
}

func TestPostMergeHooksPassed_LogsConfirmation(t T) T {
    val (m, _) = Update(sampleModel(), PostMergeHooksPassed(Url = "https://x/y/pull/7"))
    val t1 = Eq(t, m.Conversation.Size(), 1)
    val t2 = Eq(t1, m.Conversation.Get(0).Speaker, "policy")
    return IsTrue(t2, m.Conversation.Get(0).Text == "post-merge hooks: ✓ all green (https://x/y/pull/7)")
}

func TestMergeFailed_SetsLastErrorWithGhPrefix(t T) T {
    val (m, _) = Update(sampleModel(), MergeFailed(ErrText = "merge conflict"))
    return m.LastError match {
        case Some(s) => Eq(t, s, "gh pr merge: merge conflict")
        case None()  => IsTrue(t, false)
    }
}

func TestPostMergeHooksFailed_SetsLastError(t T) T {
    val (m, _) = Update(sampleModel(), PostMergeHooksFailed(ErrText = "notify exited 1"))
    return m.LastError match {
        case Some(s) => Eq(t, s, "post-merge hooks: notify exited 1")
        case None()  => IsTrue(t, false)
    }
}

// ---------------------------------------------------------------------------
// Conversation-entry selection (click → SelectedEntry → Ctrl+Y copies
// just that entry; Esc clears).
// ---------------------------------------------------------------------------

// Helper: a tiny sample conversation for the selection tests.
func sampleConversation() Array[session.ConversationLine] = ArrayOf(
    session.ConversationLine(Speaker = "you",  Text = "ship the metrics endpoint"),
    session.ConversationLine(Speaker = "Iris", Text = "on it — dispatching Felix."),
    session.ConversationLine(Speaker = "Felix", Text = "done. Histogram + counter, lints clean."),
)

func TestDragPress_SetsSelectedEntry(t T) T {
    val seed = sampleModel().Copy(Conversation = sampleConversation())
    val (m, _) = Update(seed, ConversationDragMsg(Idx = 1, Phase = DragPress()))
    return m.SelectedEntry match {
        case Some(idx) => Eq(t, idx, 1)
        case None()    => IsTrue(t, false)
    }
}

// Press out of range clamps to the last entry — guards against a
// stale event during a fast append.
func TestDragPress_OutOfRange_Clamped(t T) T {
    val seed = sampleModel().Copy(Conversation = sampleConversation())
    val (m, _) = Update(seed, ConversationDragMsg(Idx = 99, Phase = DragPress()))
    return m.SelectedEntry match {
        case Some(idx) => Eq(t, idx, 2)  // clamped to last entry
        case None()    => IsTrue(t, false)
    }
}

// DragPress on an empty conversation is a no-op.
func TestDragPress_EmptyConversation_NoOp(t T) T {
    val (m, _) = Update(sampleModel(), ConversationDragMsg(Idx = 0, Phase = DragPress()))
    return IsFalse(t, m.SelectedEntry.IsDefined())
}

// Esc clears a live selection (precedence: after MemberDetailOpen,
// before RecoveryBannerVisible).
func TestEsc_ClearsSelectedEntry(t T) T {
    val seed = sampleModel().Copy(
        Conversation  = sampleConversation(),
        SelectedEntry = Some(0),
    )
    val (m, _) = Update(seed, HistoryDeselect())
    return IsFalse(t, m.SelectedEntry.IsDefined())
}

// Ctrl+Y with a selection copies JUST that entry's "Speaker: Text"
// rather than the full transcript. Toast text reflects the entry
// path so the user knows which copy fired.
func TestCtrlY_WithSelection_CopiesSingleEntry(t T) T {
    val seed = sampleModel().Copy(
        Conversation  = sampleConversation(),
        SelectedEntry = Some(2),  // Felix's done line
    )
    val (m, _) = Update(seed, KeyYankConversation())
    val toasts = m.Toasts
    val t1 = IsTrue(t, toasts.Length() > 0)
    val msg = toasts.Items.Get(0).Message
    return IsTrue(t1, strings.Contains(msg, "Felix"))
}

// Ctrl+Y without a selection still yanks the full transcript (V1
// behavior preserved).
func TestCtrlY_NoSelection_StillYanksFullTranscript(t T) T {
    val seed = sampleModel().Copy(Conversation = sampleConversation())
    val (m, _) = Update(seed, KeyYankConversation())
    val msg = m.Toasts.Items.Get(0).Message
    return IsTrue(t, strings.Contains(msg, "3 lines"))
}

// New user prompt drops a stale selection — the conversation grows
// underneath it and the recorded index would point at the wrong row.
func TestKeySubmit_ClearsSelectedEntry(t T) T {
    val seed = sampleModel().Copy(
        Conversation  = sampleConversation(),
        SelectedEntry = Some(1),
        Composer      = "next prompt",
    )
    val (m, _) = Update(seed, KeySubmit())
    val t1 = IsFalse(t, m.SelectedEntry.IsDefined())
    val t2 = IsFalse(t1, m.SelectionFocus.IsDefined())
    return IsFalse(t2, m.Dragging)
}

// ---------------------------------------------------------------------------
// V2 drag selection — click sets anchor + focus + Dragging; motion
// while-held updates focus; release clears Dragging while preserving
// the range so Ctrl+Y can copy it.
// ---------------------------------------------------------------------------

// DragPress sets anchor=focus=idx and engages Dragging so subsequent
// DragOver events extend the range.
func TestDragPress_EngagesDragging(t T) T {
    val seed = sampleModel().Copy(Conversation = sampleConversation())
    val (m, _) = Update(seed, ConversationDragMsg(Idx = 1, Phase = DragPress()))
    val anchor = m.SelectedEntry.GetOrElse(-1)
    val focus  = m.SelectionFocus.GetOrElse(-1)
    val t1 = Eq(t,  anchor, 1)
    val t2 = Eq(t1, focus,  1)
    return IsTrue(t2, m.Dragging)
}

// DragOver moves SelectionFocus to the new entry while leaving
// SelectedEntry (the anchor) put.
func TestDragOver_UpdatesFocusKeepsAnchor(t T) T {
    val seed = sampleModel().Copy(
        Conversation   = sampleConversation(),
        SelectedEntry  = Some(0),
        SelectionFocus = Some(0),
        Dragging       = true,
    )
    val (m, _) = Update(seed, ConversationDragMsg(Idx = 2, Phase = DragOver()))
    val t1 = Eq(t, m.SelectedEntry.GetOrElse(-1), 0)
    return Eq(t1, m.SelectionFocus.GetOrElse(-1), 2)
}

// DragOver on the same line as the current focus is a no-op (avoids
// model copies on horizontal mouse wiggles inside one row).
func TestDragOver_SameLine_NoOp(t T) T {
    val seed = sampleModel().Copy(
        Conversation   = sampleConversation(),
        SelectedEntry  = Some(1),
        SelectionFocus = Some(1),
        Dragging       = true,
    )
    val (m, _) = Update(seed, ConversationDragMsg(Idx = 1, Phase = DragOver()))
    return Eq(t, m.SelectionFocus.GetOrElse(-1), 1)
}

// DragRelease clears Dragging without touching anchor / focus —
// the user has finished the drag but the range stays selected so
// Ctrl+Y can still copy it.
func TestDragRelease_ClearsDraggingPreservesRange(t T) T {
    val seed = sampleModel().Copy(
        Conversation   = sampleConversation(),
        SelectedEntry  = Some(0),
        SelectionFocus = Some(2),
        Dragging       = true,
    )
    val (m, _) = Update(seed, ConversationDragMsg(Idx = 2, Phase = DragRelease()))
    val t1 = IsFalse(t, m.Dragging)
    val t2 = Eq(t1, m.SelectedEntry.GetOrElse(-1),  0)
    return Eq(t2, m.SelectionFocus.GetOrElse(-1), 2)
}

// Ctrl+Y on a multi-line range copies the joined "Speaker: Text"
// of the inclusive range. Toast text reflects the line count.
func TestCtrlY_WithRange_CopiesJoinedRange(t T) T {
    val seed = sampleModel().Copy(
        Conversation   = sampleConversation(),
        SelectedEntry  = Some(0),
        SelectionFocus = Some(2),
    )
    val (m, _) = Update(seed, KeyYankConversation())
    val msg = m.Toasts.Items.Get(0).Message
    return IsTrue(t, strings.Contains(msg, "3 lines"))
}

// Ctrl+Y with anchor==focus still goes through the single-entry
// path, not the range path (toast says "X's entry", not "N lines").
func TestCtrlY_AnchorEqualsFocus_TreatsAsSingleEntry(t T) T {
    val seed = sampleModel().Copy(
        Conversation   = sampleConversation(),
        SelectedEntry  = Some(2),
        SelectionFocus = Some(2),
    )
    val (m, _) = Update(seed, KeyYankConversation())
    val msg = m.Toasts.Items.Get(0).Message
    return IsTrue(t, strings.Contains(msg, "Felix"))
}

// Esc clears all three selection fields together — anchor + focus +
// Dragging. Required so Ctrl+Y after Esc falls back to full
// transcript.
func TestEsc_ClearsAllSelectionFields(t T) T {
    val seed = sampleModel().Copy(
        Conversation   = sampleConversation(),
        SelectedEntry  = Some(0),
        SelectionFocus = Some(2),
        Dragging       = true,
    )
    val (m, _) = Update(seed, HistoryDeselect())
    val t1 = IsFalse(t,  m.SelectedEntry.IsDefined())
    val t2 = IsFalse(t1, m.SelectionFocus.IsDefined())
    return IsFalse(t2, m.Dragging)
}

// ---------------------------------------------------------------------------
// Status state machine — Statuses HashMap reflects who's currently
// doing what. Sidebar widget reads these.
// ---------------------------------------------------------------------------

func TestSubmit_MarksTeamLeadWorking(t T) T {
    val seed = sampleModel().Copy(Composer = "ship it")
    val (m, _) = Update(seed, KeySubmit())
    return m.Statuses.Get("Iris") match {
        case Some(StWorking()) => IsTrue(t, true)
        case _                 => IsTrue(t, false)
    }
}

func TestChunkArrived_MarksSpeakerWorking(t T) T {
    val (m, _) = Update(sampleModel(), ChunkArrived(Member = "Iris", Line = "thinking"))
    return m.Statuses.Get("Iris") match {
        case Some(StWorking()) => IsTrue(t, true)
        case _                 => IsTrue(t, false)
    }
}

func TestSessionFailed_MarksMemberFailedWithReason(t T) T {
    // With auto-retry (#26) a single SessionFailed event now produces
    // StRecovering(1, 2) — the orchestrator is mid-respawn. After
    // exhausting retries, the next failure escalates to StFailed. This
    // test exercises the after-exhaustion path by seeding RetryCount.
    val seed = sampleModel().Copy(RetryCount = EmptyHashMap[string, int]().Put("Iris", 2))
    val (m, _) = Update(seed, SessionFailed(Member = "Iris", ErrText = "stream closed"))
    return m.Statuses.Get("Iris") match {
        case Some(StFailed(reason)) => Eq(t, reason, "stream closed")
        case _                      => IsTrue(t, false)
    }
}

// Heartbeat-driven liveness regression: a member who goes silent
// past AbandonAfterSeconds should be RESPAWNED (not buried) while
// the retry budget allows. Previously the heartbeat fired
// MemberAbandoned the moment LastChunkAt crossed the threshold,
// permanently taking the silent member out of the FSM. Past
// sessions caught a parallel @dispatch where one engineer hung
// after a few file reads — the heartbeat dropped them and the TL
// had to take over their entire scope from the lead worktree.
//
// With the respawn path: status flips to StRecovering, RetryCount
// bumps, FSM stays in Delegating (member still pending). The fresh
// claude subprocess --resumes the prior session id and a "Continue
// your previous task." prompt picks up where the silent one stalled.
func TestOnTick_LivenessSilence_BelowMaxRetries_RespawnsInsteadOfAbandoning(t T) T {
    val pending = EmptyHashSet[string]().Add("Felix")
    // staleTime sits 1 second after Unix epoch — many years before
    // any real time_utils.Now(), so elapsed always exceeds
    // AbandonAfterSeconds without depending on the test clock.
    val staleTime = time_utils.FromUnixSeconds(int64(1))
    val seed = sampleModel()
    val seeded = seed.Copy(
        State       = Delegating(Pending = pending),
        Statuses    = seed.Statuses.Put("Felix", StWorking()),
        LastChunkAt = seed.LastChunkAt.Put("Felix", staleTime),
    )
    val (m, _) = Update(seeded, TickMsg())
    // Status should NOT be StFailed. ensureSession may have flipped
    // back to StWorking (spawn succeeded) or stayed at StRecovering
    // (spawn failed); both are acceptable outcomes of the respawn
    // attempt — what matters is that the heartbeat didn't bury Felix.
    val statusOk = m.Statuses.Get("Felix") match {
        case Some(StRecovering(_, _)) => true
        case Some(StWorking())        => true
        case _                        => false
    }
    val t1 = IsTrue(t, statusOk)
    // FSM still in Delegating with Felix pending — NOT advanced past.
    val fsmOk = m.State match {
        case Delegating(p) => p.Contains("Felix")
        case _             => false
    }
    val t2 = IsTrue(t1, fsmOk)
    // RetryCount for Felix should have been bumped to 1 by the
    // respawn helper before delegating to ensureSession (so the
    // increment holds even if the synchronous spawn failed).
    return Eq(t2, m.RetryCount.Get("Felix").GetOrElse(0), 1)
}

// Once the respawn budget is exhausted (RetryCount == MaxRetries
// at the moment the heartbeat fires), the next silence escalation
// genuinely abandons the member: status flips to StFailed and the
// FSM advances past them so the rest of the team can drain. Mirrors
// the after-exhaustion semantics of the crash-recovery path
// (TestSessionFailed_MarksMemberFailedWithReason). Felix was the
// only Pending member, so Delegating drains all the way through to
// TLReview.
func TestOnTick_LivenessSilence_AfterMaxRetries_FiresMemberAbandoned(t T) T {
    val hb = DefaultHeartbeat()
    val pending = EmptyHashSet[string]().Add("Felix")
    val staleTime = time_utils.FromUnixSeconds(int64(1))
    val seed = sampleModel()
    val seeded = seed.Copy(
        State       = Delegating(Pending = pending),
        Statuses    = seed.Statuses.Put("Felix", StWorking()),
        LastChunkAt = seed.LastChunkAt.Put("Felix", staleTime),
        RetryCount  = seed.RetryCount.Put("Felix", hb.MaxRetries),
    )
    val (m, _) = Update(seeded, TickMsg())
    val statusOk = m.Statuses.Get("Felix") match {
        case Some(StFailed(_)) => true
        case _                 => false
    }
    val t1 = IsTrue(t, statusOk)
    return m.State match {
        case TLReview() => IsTrue(t1, true)
        case _          => IsTrue(t1, false)
    }
}

func TestMerged_ResetsAllMembersToIdle(t T) T {
    // Seed every member as something other than Idle so reset has work
    // to do. Felix StFailed; Iris StWorking. After Merged, both Idle.
    val seedStatuses = EmptyHashMap[string, Status]()
        .Put("Iris",  StWorking())
        .Put("Felix", StFailed(Reason = "boom"))
    val seed = sampleModel().Copy(
        OpenPrs  = ArrayOf(sampleBatchPr("https://x/y/pull/9")),
        Statuses = seedStatuses,
    )
    val (m, _) = Update(seed, Merged(Url = "https://x/y/pull/9"))
    val t1 = m.Statuses.Get("Iris") match {
        case Some(StIdle()) => IsTrue(t, true)
        case _              => IsTrue(t, false)
    }
    return m.Statuses.Get("Felix") match {
        case Some(StIdle()) => IsTrue(t1, true)
        case _              => IsTrue(t1, false)
    }
}

// Subsequent ChunkArrived from a different speaker doesn't downgrade
// the original speaker — only the new sender's status is touched.
func TestChunkArrived_OnlyMutatesSpeakerStatus(t T) T {
    val (m1, _) = Update(sampleModel(), ChunkArrived(Member = "Iris",  Line = "1"))
    val (m2, _) = Update(m1,            ChunkArrived(Member = "Felix", Line = "2"))
    val t1 = m2.Statuses.Get("Iris") match {
        case Some(StWorking()) => IsTrue(t, true)
        case _                 => IsTrue(t, false)
    }
    return m2.Statuses.Get("Felix") match {
        case Some(StWorking()) => IsTrue(t1, true)
        case _                 => IsTrue(t1, false)
    }
}

// ---------------------------------------------------------------------------
// Keyboard edge cases
// ---------------------------------------------------------------------------

// Multi-byte UTF-8 (emoji) typed into the composer should render as a
// single visual character. Critical because backspace below relies on
// rune-aware trimming, not byte-fiddling.
func TestKeyChar_AcceptsMultiByteRune(t T) T {
    val (m, _) = Update(sampleModel(), KeyChar(C = '🚀'))
    return Eq(t, m.Composer, "🚀")
}

// Backspace must trim *one rune*, not one byte — otherwise a multi-byte
// emoji would leave a trailing UTF-8 continuation byte and corrupt the
// composer string.
func TestKeyBackspace_TrimsOneRuneNotOneByte(t T) T {
    val (m1, _) = Update(sampleModel(),  KeyChar(C = 'x'))
    val (m2, _) = Update(m1,             KeyChar(C = '🚀'))
    val t1 = Eq(t, m2.Composer, "x🚀")
    val (m3, _) = Update(m2, KeyBackspace())
    return Eq(t1, m3.Composer, "x")
}

// Accented Latin-1 letters (é, ñ) round-trip through KeyChar. Sanity
// check that the rune-based path doesn't lose information for the
// common European-text case.
func TestKeyChar_PreservesAccentedLatin(t T) T {
    val (m1, _) = Update(sampleModel(), KeyChar(C = 'é'))
    val (m2, _) = Update(m1,            KeyChar(C = 'ñ'))
    return Eq(t, m2.Composer, "éñ")
}

// Space comes through as KeyChar(' '), not a separate variant.
func TestKeyChar_SpaceIsRegularChar(t T) T {
    val (m1, _) = Update(sampleModel(), KeyChar(C = 'a'))
    val (m2, _) = Update(m1,            KeyChar(C = ' '))
    val (m3, _) = Update(m2,            KeyChar(C = 'b'))
    return Eq(t, m3.Composer, "a b")
}

// Tick should bump only the counter, never touch the composer or the
// conversation log. Catches accidental field-stomp regressions in the
// Copy() chain.
func TestTickMsg_DoesNotStompComposerOrConversation(t T) T {
    val seed = sampleModel().Copy(
        Composer     = "draft",
        Conversation = ArrayOf(session.ConversationLine(Speaker = "you", Text = "earlier")),
    )
    val (m, _) = Update(seed, TickMsg())
    val t1 = Eq(t, m.Composer, "draft")
    val t2 = Eq(t1, m.Conversation.Size(), 1)
    return Eq(t2, m.Tick, 1)
}

// Submitting the same prompt twice in a row only logs once into the
// conversation when the second submit happens with an empty composer
// (the first one cleared it).
func TestKeySubmit_DoubleSubmitIsIdempotentOnEmpty(t T) T {
    val seed = sampleModel().Copy(Composer = "hello")
    val (m1, _) = Update(seed, KeySubmit())
    val (m2, _) = Update(m1,   KeySubmit())  // composer is empty now
    return Eq(t, m2.Conversation.Size(), 1)
}

// SessionFailed for a member that's not in m.Sessions should not
// crash; Remove on a missing key is a no-op and LastError still
// gets the wrapped message.
func TestSessionFailed_OnUnknownMember_LogsAnyway(t T) T {
    // EOF is now the normal turn-end success signal — doesn't log.
    // Use a real error so the unknown-member-still-logs path is
    // exercised. With auto-retry (#26) the LastError appends the
    // retry counter.
    val (m, _) = Update(sampleModel(), SessionFailed(Member = "Ghost", ErrText = "stream closed"))
    return m.LastError match {
        case Some(s) => IsTrue(t, s == "Ghost: stream closed — retry 1/2")
        case None()  => IsTrue(t, false)
    }
}

// Two ChunkArrived messages for different speakers append in order
// and don't collapse / dedupe.
func TestChunkArrived_DifferentSpeakersInterleave(t T) T {
    val (m1, _) = Update(sampleModel(), ChunkArrived(Member = "Iris",  Line = "line A"))
    val (m2, _) = Update(m1,            ChunkArrived(Member = "Felix", Line = "line B"))
    val t1 = Eq(t,  m2.Conversation.Size(),                2)
    val t2 = Eq(t1, m2.Conversation.Get(0).Speaker,         "Iris")
    return Eq(t2, m2.Conversation.Get(1).Speaker,           "Felix")
}

// PrCreated after a session failure leaves the prior LastError intact —
// the success line is appended to the conversation, but the error
// surface (LastError → red footer) doesn't get cleared by an unrelated
// success.
func TestPrCreated_DoesNotClearPriorLastError(t T) T {
    val seed = sampleModel().Copy(LastError = Some("session save: disk full"))
    val (m, _) = Update(seed, PrCreated(Url = "https://x/y/pull/1", Branch = "gala_team/x/pr/aaa1"))
    return m.LastError match {
        case Some(s) => Eq(t, s, "session save: disk full")
        case None()  => IsTrue(t, false)
    }
}

// ---------------------------------------------------------------------------
// Mouse plumbing
// ---------------------------------------------------------------------------

// Mouse events are routed but currently no-op — Phase 1 has no
// clickable hit-targets. Locks in that the model is unchanged so a
// future component-level dispatcher can replace the body of MouseAt
// without ambiguity.
func TestMouseAt_IsNoopOnModel(t T) T {
    val seed = sampleModel().Copy(Composer = "keep me", Tick = 4)
    val (m, _) = Update(seed, MouseAt(X = 10, Y = 5, Pressed = true, Motion = false))
    val t1 = Eq(t, m.Composer, "keep me")
    val t2 = Eq(t1, m.Tick, 4)
    return Eq(t2, m.Conversation.Size(), 0)
}

func TestMouseAt_ReleaseAlsoNoop(t T) T {
    val (m, _) = Update(sampleModel(), MouseAt(X = 0, Y = 0, Pressed = false, Motion = false))
    return Eq(t, m.Composer, "")
}

// ---------------------------------------------------------------------------
// @consult dispatch from chunk pump
// ---------------------------------------------------------------------------

// Plain TL chatter — no @consult — only updates TurnBuffer; ConsultsFired
// and Conversation reflect the single chunk and nothing more.
func TestChunkArrived_TLChatter_BuffersWithoutDispatch(t T) T {
    val (m, _) = Update(sampleModel(), ChunkArrived(Member = "Iris", Line = "just thinking out loud"))
    val t1 = Eq(t,  m.TurnBuffer, "just thinking out loud")
    val t2 = Eq(t1, m.ConsultsFired, 0)
    return Eq(t2, m.Conversation.Size(), 1)
}

// Non-TL chunks do not advance TurnBuffer — only the lead's output is
// scanned for @consult directives.
func TestChunkArrived_NonLeadDoesNotBuffer(t T) T {
    val (m, _) = Update(sampleModel(), ChunkArrived(Member = "Felix", Line = "engineer chatter"))
    val t1 = Eq(t,  m.TurnBuffer, "")
    return Eq(t1, m.ConsultsFired, 0)
}

// A chunk completing a `@consult(name) ... @end` block bumps
// ConsultsFired and appends a "consult: dispatching → name" line.
// The directive parser treats the buffer-end as a directive
// terminator (so `@end` is not strictly required for detection);
// in practice the lead emits the closing tag before going idle.
func TestChunkArrived_LeadConsultBlock_KicksOneDispatch(t T) T {
    val seed = sampleModel()
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = "@consult(transpiler) help\n@end"))
    val t1 = Eq(t, m.ConsultsFired, 1)
    val last = m.Conversation.Get(m.Conversation.Size() - 1)
    val t2 = Eq(t1, last.Speaker, "consult")
    return IsTrue(t2, last.Text == "dispatching → transpiler")
}

// A second @consult block in the same turn fires a second dispatch
// without re-firing the first (ConsultsFired guards against that).
func TestChunkArrived_TwoConsults_FireInSequence(t T) T {
    val seed = sampleModel()
    val msg = "@consult(a) one\n@end\n@consult(b) two\n@end"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = msg))
    return Eq(t, m.ConsultsFired, 2)
}

// KeySubmit resets the per-turn buffer and consult counter — the next
// turn can re-detect @consult blocks by name without inheriting state.
func TestKeySubmit_ResetsTurnBufferAndConsultsFired(t T) T {
    val seed = sampleModel().Copy(
        Composer      = "next turn",
        TurnBuffer    = "stale",
        ConsultsFired = 3,
    )
    val (m, _) = Update(seed, KeySubmit())
    val t1 = Eq(t,  m.TurnBuffer, "")
    return Eq(t1, m.ConsultsFired, 0)
}

// ConsultCompleted appends the result body under the consulted team's
// name and a "✓" status line under "consult".
func TestConsultCompleted_AppendsResultToConversation(t T) T {
    val (m, _) = Update(sampleModel(), ConsultCompleted(Name = "transpiler", Summary = Some("fix landed")))
    val n = m.Conversation.Size()
    val tickLine = m.Conversation.Get(n - 2)
    val bodyLine = m.Conversation.Get(n - 1)
    val t1 = Eq(t,  tickLine.Speaker, "consult")
    val t2 = IsTrue(t1, tickLine.Text == "transpiler ✓")
    val t3 = Eq(t2, bodyLine.Speaker, "transpiler")
    return Eq(t3, bodyLine.Text, "fix landed")
}

// ConsultCompleted with no summary surfaces an explicit placeholder so
// the user / TL can tell apart "no @summary block" from "summary said
// nothing".
func TestConsultCompleted_NoSummary_LogsPlaceholder(t T) T {
    val (m, _) = Update(sampleModel(), ConsultCompleted(Name = "transpiler", Summary = None[string]()))
    val last = m.Conversation.Get(m.Conversation.Size() - 1)
    return IsTrue(t, last.Text != "")
}

// ConsultFailed records the error in LastError and appends a "✗ <err>"
// line under "consult".
func TestConsultFailed_RecordsErrorAndConvoLine(t T) T {
    val (m, _) = Update(sampleModel(), ConsultFailed(Name = "transpiler", ErrText = "no registry entry"))
    val t1 = m.LastError match {
        case Some(e) => IsTrue(t, e == "consult transpiler: no registry entry")
        case None()  => IsTrue(t, false)
    }
    val last = m.Conversation.Get(m.Conversation.Size() - 1)
    val t2 = Eq(t1, last.Speaker, "consult")
    return IsTrue(t2, last.Text == "transpiler ✗ no registry entry")
}

// ---------------------------------------------------------------------------
// QuitMsg lifecycle
// ---------------------------------------------------------------------------

// QuitMsg with no live sessions: model passes through untouched, the
// returned Cmd is the runtime's QuitCmd. We don't introspect the Cmd
// shape here (gala-tui's Cmd sealed type is opaque to update_test) —
// the contract we care about is that the model is left clean.
func TestQuitMsg_NoSessions_ModelStableAndConversationUntouched(t T) T {
    val seed = sampleModel().Copy(
        Composer = "draft",
        Tick     = 9,
        Conversation = EmptyArray[session.ConversationLine]().Append(
            session.ConversationLine(Speaker = "you", Text = "earlier"),
        ),
    )
    val (m, _) = Update(seed, QuitMsg())
    val t1 = Eq(t,  m.Composer, "draft")
    val t2 = Eq(t1, m.Tick, 9)
    return Eq(t2, m.Conversation.Size(), 1)
}

// QuitMsg never falls through to a panic on an empty model — guards
// the no-failures path of CloseAllSessions where FoldLeftKV runs over
// an empty HashMap.
func TestQuitMsg_OnFreshModel_DoesNotPanic(t T) T {
    val (m, _) = Update(sampleModel(), QuitMsg())
    return Eq(t, m.Conversation.Size(), 0)
}

// First Ctrl+C arms the quit-confirmation prompt rather than
// immediately exiting; sessions stay alive until the second press.
func TestQuitMsg_FirstPress_ArmsConfirmation(t T) T {
    val (m, _) = Update(sampleModel(), QuitMsg())
    return IsTrue(t, m.QuitPending)
}

// Second consecutive Ctrl+C is the destructive path — model still
// carries QuitPending=true (we don't clear it on the way out, the
// process is exiting) but the action has executed.
func TestQuitMsg_SecondPress_StaysArmedAndQuits(t T) T {
    val (m1, _) = Update(sampleModel(), QuitMsg())
    val (m2, _) = Update(m1, QuitMsg())
    return IsTrue(t, m2.QuitPending)
}

// Esc cancels the confirmation — the user hit Ctrl+C by accident
// and now wants to keep working. HistoryDeselect is the AppMsg
// keymap.gala emits for Esc.
func TestQuitMsg_EscCancelsConfirmation(t T) T {
    val (m1, _) = Update(sampleModel(), QuitMsg())
    val t1 = IsTrue(t, m1.QuitPending)
    val (m2, _) = Update(m1, HistoryDeselect())
    return IsFalse(t1, m2.QuitPending)
}

// A typed char must NOT cancel the prompt — auto-dismiss on any
// keystroke would let a stray buffered key silently re-enable a
// dangerous quit. Only Esc or a confirming Ctrl+C resolves it.
func TestQuitMsg_KeyCharLeavesConfirmationArmed(t T) T {
    val (m1, _) = Update(sampleModel(), QuitMsg())
    val (m2, _) = Update(m1, KeyChar(C = 'x'))
    return IsTrue(t, m2.QuitPending)
}

// TickMsg is background and must not silently dismiss the prompt
// while the user is reading it.
func TestQuitMsg_TickDoesNotCancelConfirmation(t T) T {
    val (m1, _) = Update(sampleModel(), QuitMsg())
    val (m2, _) = Update(m1, TickMsg())
    return IsTrue(t, m2.QuitPending)
}

// ---------------------------------------------------------------------------
// Sidebar focus + fold/unfold (Ctrl+L flow)
// ---------------------------------------------------------------------------

// Default focus is the composer; KeyChar lands in the composer
// text rather than triggering a sidebar action.
func TestFocus_Default_IsComposer_KeyCharGoesToComposer(t T) T {
    val (m, _) = Update(sampleModel(), KeyChar(C = 'a'))
    return Eq(t, m.Composer, "a")
}

// Ctrl+L (KeyToggleFocus) flips focus into the sidebar; the
// SidebarCursor resets to 0 so the user lands on the first row.
func TestFocus_Toggle_EntersSidebarAndResetsCursor(t T) T {
    val seed = sampleModel().Copy(SidebarCursor = 5)
    val (m, _) = Update(seed, KeyToggleFocus())
    val t1 = m.Focus match {
        case FocusSidebar()  => IsTrue(t, true)
        case FocusComposer() => IsTrue(t, false)
    }
    return Eq(t1, m.SidebarCursor, 0)
}

// Two presses round-trip back to the composer.
func TestFocus_TogglesBackToComposer(t T) T {
    val (m1, _) = Update(sampleModel(), KeyToggleFocus())
    val (m2, _) = Update(m1, KeyToggleFocus())
    return m2.Focus match {
        case FocusComposer() => IsTrue(t, true)
        case FocusSidebar()  => IsTrue(t, false)
    }
}

// While Focus=Sidebar, typed characters do NOT extend the
// composer — keystrokes belong to the panel that has focus.
func TestFocus_Sidebar_KeyCharDoesNotTouchComposer(t T) T {
    val seed = sampleModel().Copy(Focus = FocusSidebar())
    val (m, _) = Update(seed, KeyChar(C = 'z'))
    return Eq(t, m.Composer, "")
}

// Esc returns the user to the composer from the sidebar without
// affecting any other modal state.
func TestFocus_Sidebar_EscReturnsToComposer(t T) T {
    val seed = sampleModel().Copy(Focus = FocusSidebar())
    val (m, _) = Update(seed, HistoryDeselect())
    return m.Focus match {
        case FocusComposer() => IsTrue(t, true)
        case FocusSidebar()  => IsTrue(t, false)
    }
}

// Up/Down move SidebarCursor, clamped at 0 / row count.
func TestFocus_Sidebar_DownAdvancesCursor(t T) T {
    val seed = sampleModel().Copy(Focus = FocusSidebar(), SidebarCursor = 0)
    val (m, _) = Update(seed, HistoryCursorDown())
    return Eq(t, m.SidebarCursor, 1)
}

func TestFocus_Sidebar_UpClampsAtZero(t T) T {
    val seed = sampleModel().Copy(Focus = FocusSidebar(), SidebarCursor = 0)
    val (m, _) = Update(seed, HistoryCursorUp())
    return Eq(t, m.SidebarCursor, 0)
}

// Space on a group header collapses the group; pressing Space
// again expands it back. SampleModel's first row (cursor=0) is
// the "Lead" group header.
func TestFocus_Sidebar_SpaceTogglesGroupCollapse(t T) T {
    val seed = sampleModel().Copy(Focus = FocusSidebar(), SidebarCursor = 0)
    val (m1, _) = Update(seed, KeyChar(C = ' '))
    val t1 = IsTrue(t, m1.CollapsedGroups.Contains("Lead"))
    val (m2, _) = Update(m1, KeyChar(C = ' '))
    return IsFalse(t1, m2.CollapsedGroups.Contains("Lead"))
}

// Space on a member row is a no-op for the collapse set —
// only group headers respond. SampleModel row 1 is "Iris" (the
// only Lead) so row 2 is a member row of Engineering... actually
// let's land on row 1 which is the lead member.
func TestFocus_Sidebar_SpaceOnMemberRow_NoOp(t T) T {
    val seed = sampleModel().Copy(Focus = FocusSidebar(), SidebarCursor = 1)
    val (m, _) = Update(seed, KeyChar(C = ' '))
    return Eq(t, m.CollapsedGroups.Size(), 0)
}

// End-to-end focus journey: Tab cycles Composer → Sidebar →
// Composer; Esc from Sidebar pops back; KeyChar lands in the
// active panel (composer when default, sidebar fold-toggle when
// the cursor is on a header). One test exercises the whole
// flow because the state-machine interactions are easy to
// regress one at a time.
func TestFocusFlow_EndToEnd(t T) T {
    val seed = sampleModel()

    // Start: composer is the default focus.
    val composerFocused = seed.Focus match {
        case FocusComposer() => true
        case FocusSidebar()  => false
    }
    val t1 = IsTrue(t, composerFocused)

    // Type 'h' — composer accepts it.
    val (m1, _) = Update(seed, KeyChar(C = 'h'))
    val t2 = Eq(t1, m1.Composer, "h")

    // Tab → sidebar focused, cursor at row 0 (Lead header).
    val (m2, _) = Update(m1, KeyToggleFocus())
    val sidebarFocused = m2.Focus match {
        case FocusSidebar()  => true
        case FocusComposer() => false
    }
    val t3 = IsTrue(t2, sidebarFocused)
    val t4 = Eq(t3, m2.SidebarCursor, 0)

    // Composer text from before is preserved across the focus toggle.
    val t5 = Eq(t4, m2.Composer, "h")

    // Down moves cursor; Space at row 0 (Lead group header)
    // would toggle fold — but we're now at row 1, so Space is
    // a no-op for the collapse set.
    val (m3, _) = Update(m2, HistoryCursorDown())
    val t6 = Eq(t5, m3.SidebarCursor, 1)
    val (m4, _) = Update(m3, KeyChar(C = ' '))
    val t7 = Eq(t6, m4.CollapsedGroups.Size(), 0)
    // Composer untouched — Space in sidebar mode never reaches it.
    val t8 = Eq(t7, m4.Composer, "h")

    // Esc returns to composer focus.
    val (m5, _) = Update(m4, HistoryDeselect())
    val backToComposer = m5.Focus match {
        case FocusComposer() => true
        case FocusSidebar()  => false
    }
    val t9 = IsTrue(t8, backToComposer)

    // After returning to composer, typed chars resume landing
    // there — confirming the state machine didn't get stuck.
    val (m6, _) = Update(m5, KeyChar(C = 'i'))
    return Eq(t9, m6.Composer, "hi")
}

// Tab from sidebar takes the user back to the composer (round-trip).
func TestFocusFlow_TabRoundTripsBackToComposer(t T) T {
    val (m1, _) = Update(sampleModel(), KeyToggleFocus())
    val (m2, _) = Update(m1, KeyToggleFocus())
    return m2.Focus match {
        case FocusComposer() => IsTrue(t, true)
        case FocusSidebar()  => IsTrue(t, false)
    }
}

// ---------------------------------------------------------------------------
// Mouse hit-testing — gala-tui's HitRegistry auto-routes clicks
// to the bordered sidebar / composer panels (FocusSidebarClicked
// / FocusComposerClicked) and to per-row hits inside the sidebar
// (SidebarRowClicked). Apps don't compute coordinates; the tests
// here exercise the AppMsg-level handlers the framework dispatches
// to.
// ---------------------------------------------------------------------------

// SidebarRowClicked at row 0 (the "Lead" group header) focuses
// the sidebar, moves the cursor, AND toggles fold — mirroring
// the keyboard Space binding.
func TestSidebarRowClicked_OnGroupHeader_FocusesAndToggles(t T) T {
    val seed = sampleModel()
    val (m, _) = Update(seed, SidebarRowClicked(VisibleIdx = 0))
    val t1 = m.Focus match {
        case FocusSidebar()  => IsTrue(t, true)
        case FocusComposer() => IsTrue(t, false)
    }
    return IsTrue(t1, m.CollapsedGroups.Contains("Lead"))
}

// SidebarRowClicked on a member row (idx 1 = "Iris") focuses the
// sidebar and moves the cursor, but doesn't touch the fold set.
func TestSidebarRowClicked_OnMemberRow_FocusesWithoutCollapsing(t T) T {
    val seed = sampleModel()
    val (m, _) = Update(seed, SidebarRowClicked(VisibleIdx = 1))
    val t1 = m.Focus match {
        case FocusSidebar()  => IsTrue(t, true)
        case FocusComposer() => IsTrue(t, false)
    }
    val t2 = Eq(t1, m.SidebarCursor, 1)
    return Eq(t2, m.CollapsedGroups.Size(), 0)
}

// FocusComposerClicked snaps focus back to the composer (used by
// the framework when the user clicks the composer panel from
// FocusSidebar).
func TestFocusComposerClicked_ReturnsFocusToComposer(t T) T {
    val seed = sampleModel().Copy(Focus = FocusSidebar(), SidebarCursor = 2)
    val (m, _) = Update(seed, FocusComposerClicked())
    return m.Focus match {
        case FocusComposer() => IsTrue(t, true)
        case FocusSidebar()  => IsTrue(t, false)
    }
}

// FocusSidebarClicked focuses the sidebar without moving the
// cursor — a click on the bordered panel itself (above/below the
// rows) should land here.
func TestFocusSidebarClicked_FocusesWithoutCursorChange(t T) T {
    val seed = sampleModel().Copy(SidebarCursor = 5)
    val (m, _) = Update(seed, FocusSidebarClicked())
    val t1 = m.Focus match {
        case FocusSidebar()  => IsTrue(t, true)
        case FocusComposer() => IsTrue(t, false)
    }
    return Eq(t1, m.SidebarCursor, 5)
}

// MouseAt is now the no-op fallback for clicks that miss every
// registered HitRegistry entry. Render shouldn't change.
func TestMouseAt_FallthroughIsNoOp(t T) T {
    val seed = sampleModel().Copy(Focus = FocusSidebar(), SidebarCursor = 3)
    val (m, _) = Update(seed, MouseAt(X = 50, Y = 8, Pressed = true, Motion = false))
    val t1 = m.Focus match {
        case FocusSidebar()  => IsTrue(t, true)
        case FocusComposer() => IsTrue(t, false)
    }
    return Eq(t1, m.SidebarCursor, 3)
}

// ---------------------------------------------------------------------------
// State × key matrix gaps
// ---------------------------------------------------------------------------

// KeySubmit while in Approval is allowed (the FSM keeps Approval state
// since `_ => state` matches non-Accepted/Rejected events) — the prompt
// is logged so the user has a record of what they tried to send. They
// must Ctrl+R first to redirect the team.
func TestKeySubmit_InApproval_StaysInApprovalAndLogs(t T) T {
    val seed = sampleModel().Copy(
        Composer = "redirect please",
        State    = Approval(SummaryBody = "ship it"),
    )
    val (m, _) = Update(seed, KeySubmit())
    val t1 = m.State match {
        case Approval(_) => IsTrue(t, true)
        case _           => IsTrue(t, false)
    }
    return Eq(t1, m.Composer, "")
}

// KeySubmit while TLThinking is currently allowed — the lead is busy
// but the prompt still gets queued. We document that the FSM stays in
// TLThinking and the message is appended to conversation.
func TestKeySubmit_InTLThinking_StaysInTLThinking(t T) T {
    val seed = sampleModel().Copy(
        Composer = "extra context",
        State    = TLThinking(),
    )
    val (m, _) = Update(seed, KeySubmit())
    return m.State match {
        case TLThinking() => IsTrue(t, true)
        case _            => IsTrue(t, false)
    }
}

// KeyMerge with no open PR is a strict no-op even if PrFailed has
// already populated LastError — we never let Ctrl+M re-fire after a
// failed PR-create attempt.
func TestKeyMerge_AfterPrFailed_NoOp(t T) T {
    val seed = sampleModel().Copy(LastError = Some("gh pr create: auth required"))
    val (m, _) = Update(seed, KeyMerge())
    val t1 = Eq(t, m.Conversation.Size(), 0)
    return IsTrue(t1, m.OpenPrs.IsEmpty())
}

// KeyApprove from each non-Approval state must stay in that state and
// emit no conversation entry.
func TestKeyApprove_InEveryNonApprovalState_NoOp(t T) T {
    val states = ArrayOf[AppState](
        Idle(),
        TLThinking(),
        TLReview(),
        Delegating(Pending = EmptyHashSet[string]()),
        QAGate(Pending = EmptyHashSet[string]()),
    )
    return states.FoldLeft(t, (acc, st) => {
        val (m, _) = Update(sampleModel().Copy(State = st), KeyApprove())
        return Eq(acc, m.Conversation.Size(), 0)
    })
}

// KeyReject from each non-Approval state must stay in that state and
// emit no conversation entry.
func TestKeyReject_InEveryNonApprovalState_NoOp(t T) T {
    val states = ArrayOf[AppState](
        Idle(),
        TLThinking(),
        TLReview(),
        Delegating(Pending = EmptyHashSet[string]()),
        QAGate(Pending = EmptyHashSet[string]()),
    )
    return states.FoldLeft(t, (acc, st) => {
        val (m, _) = Update(sampleModel().Copy(State = st), KeyReject())
        return Eq(acc, m.Conversation.Size(), 0)
    })
}

// ---------------------------------------------------------------------------
// Consult dispatch corner cases
// ---------------------------------------------------------------------------

// A chunk containing an unbalanced @consult( open with no matching `)`
// is not a valid directive and must not bump ConsultsFired.
func TestChunkArrived_MalformedConsultOpener_NoDispatch(t T) T {
    val (m, _) = Update(sampleModel(), ChunkArrived(Member = "Iris", Line = "@consult(broken"))
    return Eq(t, m.ConsultsFired, 0)
}

// ConsultCompleted with a dead lead session (no entry in m.Sessions)
// still appends the result lines but produces no SendFuture-shaped
// Cmd — the conversation log is the user-visible record either way.
func TestConsultCompleted_DeadLeadSession_LogsResultSilently(t T) T {
    val (m, _) = Update(sampleModel(), ConsultCompleted(Name = "transpiler", Summary = Some("done")))
    val n = m.Conversation.Size()
    val tickLine = m.Conversation.Get(n - 2)
    val bodyLine = m.Conversation.Get(n - 1)
    val t1 = IsTrue(t,  tickLine.Text == "transpiler ✓")
    return IsTrue(t1, bodyLine.Text == "done")
}

// Two consult dispatches in the same chunk advance ConsultsFired by 2
// AND append two distinct "dispatching → name" lines (one per target).
func TestChunkArrived_TwoConsults_AppendsTwoDispatchLines(t T) T {
    val seed = sampleModel()
    val msg = "@consult(a) one\n@end\n@consult(b) two\n@end"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = msg))
    val n = m.Conversation.Size()
    val l1 = m.Conversation.Get(n - 2)
    val l2 = m.Conversation.Get(n - 1)
    val t1 = IsTrue(t,  l1.Text == "dispatching → a")
    return IsTrue(t1, l2.Text == "dispatching → b")
}

// ---------------------------------------------------------------------------
// Streaming consult events (Phase 2.4)
// ---------------------------------------------------------------------------

// ConsultChunkArrived appends a `consult/<name>: <line>` entry to the
// conversation log AND accumulates the raw line in ConsultBuffers
// keyed by the consult name. No session needs to be live in
// ActiveConsults for the model update to succeed (the pump just
// won't re-arm in that case — a no-op Cmd).
func TestConsultChunkArrived_AppendsAndBuffers(t T) T {
    val (m, _) = Update(sampleModel(), ConsultChunkArrived(Name = "transpiler", Line = "thinking..."))
    val last = m.Conversation.Get(m.Conversation.Size() - 1)
    val t1 = Eq(t,  last.Speaker, "consult/transpiler")
    val t2 = Eq(t1, last.Text, "thinking...")
    return Eq(t2, m.ConsultBuffers.Get("transpiler").GetOrElse(EmptyArray[string]()).Size(), 1)
}

// Multiple chunks for the same consult accumulate in source order
// — the buffer is what onConsultEnded scans for the @summary block.
func TestConsultChunkArrived_AccumulatesInOrder(t T) T {
    val (m1, _) = Update(sampleModel(), ConsultChunkArrived(Name = "transpiler", Line = "first"))
    val (m2, _) = Update(m1,            ConsultChunkArrived(Name = "transpiler", Line = "second"))
    val buffer = m2.ConsultBuffers.Get("transpiler").GetOrElse(EmptyArray[string]())
    val t1 = Eq(t,  buffer.Size(), 2)
    val t2 = Eq(t1, buffer.Get(0), "first")
    return Eq(t2, buffer.Get(1), "second")
}

// Two interleaved consults must stay isolated — chunks for one don't
// land in the other's buffer.
func TestConsultChunkArrived_BuffersAreIsolatedPerName(t T) T {
    val (m1, _) = Update(sampleModel(), ConsultChunkArrived(Name = "a", Line = "1"))
    val (m2, _) = Update(m1,            ConsultChunkArrived(Name = "b", Line = "2"))
    val (m3, _) = Update(m2,            ConsultChunkArrived(Name = "a", Line = "3"))
    val ba = m3.ConsultBuffers.Get("a").GetOrElse(EmptyArray[string]())
    val bb = m3.ConsultBuffers.Get("b").GetOrElse(EmptyArray[string]())
    val t1 = Eq(t,  ba.Size(), 2)
    return Eq(t1, bb.Size(), 1)
}

// ConsultEnded with no error and a buffer containing an @summary block
// drops the session and the buffer from the model. The MsgCmd returned
// is opaque to update_test — but the model-side cleanup is what we
// verify here.
func TestConsultEnded_CleanFinish_DropsBufferAndSession(t T) T {
    val seed = sampleModel().Copy(
        ConsultBuffers = EmptyHashMap[string, Array[string]]()
            .Put("transpiler", ArrayOf("@summary", "fix landed", "@end")),
    )
    val (m, _) = Update(seed, ConsultEnded(Name = "transpiler", ErrText = None[string]()))
    val t1 = IsTrue(t, !m.ConsultBuffers.Get("transpiler").IsDefined())
    return IsTrue(t1, !m.ActiveConsults.Get("transpiler").IsDefined())
}

// ConsultEnded with ErrText="EOF" is treated as a clean finish (the
// runtime's NextChunkFuture wraps EOF as a Failure(io.EOF), but EOF
// is the natural terminator for a child team that's done thinking).
func TestConsultEnded_EOFTreatedAsCleanFinish(t T) T {
    val seed = sampleModel().Copy(
        ConsultBuffers = EmptyHashMap[string, Array[string]]()
            .Put("transpiler", EmptyArray[string]()),
    )
    val (m, _) = Update(seed, ConsultEnded(Name = "transpiler", ErrText = Some("EOF")))
    return IsTrue(t, !m.ConsultBuffers.Get("transpiler").IsDefined())
}

// ConsultEnded with a non-EOF error fires the failure path. We can't
// observe the chained MsgCmd directly here, but we verify that the
// model's per-consult state is dropped regardless of error or success.
func TestConsultEnded_RealErrorAlsoCleansState(t T) T {
    val seed = sampleModel().Copy(
        ConsultBuffers = EmptyHashMap[string, Array[string]]()
            .Put("transpiler", ArrayOf("partial output")),
    )
    val (m, _) = Update(seed, ConsultEnded(Name = "transpiler", ErrText = Some("broken pipe")))
    return IsTrue(t, !m.ConsultBuffers.Get("transpiler").IsDefined())
}

// ConsultEnded for an unknown consult (no live session, no buffer) is
// a strict no-op on existing state — defensive against stale
// duplicate event delivery.
func TestConsultEnded_UnknownConsult_NoOp(t T) T {
    val seed = sampleModel().Copy(
        Conversation = EmptyArray[session.ConversationLine]().Append(
            session.ConversationLine(Speaker = "you", Text = "earlier"),
        ),
    )
    val (m, _) = Update(seed, ConsultEnded(Name = "ghost", ErrText = None[string]()))
    return Eq(t, m.Conversation.Size(), 1)
}

// ---------------------------------------------------------------------------
// Consult viewer modal toggle (Phase 2.3)
// ---------------------------------------------------------------------------

// Tab toggles ConsultViewerOpen on/off. Pressing it twice returns the
// model to the original closed state.
func TestKeyToggleConsultViewer_FlipsOpenFlag(t T) T {
    val (m1, _) = Update(sampleModel(), KeyToggleConsultViewer())
    val t1 = IsTrue(t, m1.ConsultViewerOpen)
    val (m2, _) = Update(m1,            KeyToggleConsultViewer())
    return IsFalse(t1, m2.ConsultViewerOpen)
}

// Toggling the viewer must not touch any of the existing model fields
// — composer, conversation, sessions, statuses are all preserved.
func TestKeyToggleConsultViewer_LeavesOtherStateAlone(t T) T {
    val seed = sampleModel().Copy(
        Composer     = "draft",
        Tick         = 5,
        Conversation = EmptyArray[session.ConversationLine]().Append(
            session.ConversationLine(Speaker = "you", Text = "earlier"),
        ),
    )
    val (m, _) = Update(seed, KeyToggleConsultViewer())
    val t1 = Eq(t,  m.Composer, "draft")
    val t2 = Eq(t1, m.Tick, 5)
    return Eq(t2, m.Conversation.Size(), 1)
}

// ---------------------------------------------------------------------------
// History browser (Phase 3)
// ---------------------------------------------------------------------------

// Ctrl+H toggles HistoryMode and resets the cursor on open.
func TestKeyToggleHistory_FlipsMode(t T) T {
    val seed = sampleModel().Copy(HistoryCursor = 5)
    val (m1, _) = Update(seed, KeyToggleHistory())
    val t1 = IsTrue(t, m1.HistoryMode)
    val t2 = Eq(t1, m1.HistoryCursor, 0)
    val (m2, _) = Update(m1, KeyToggleHistory())
    return IsFalse(t2, m2.HistoryMode)
}

// Up / Down outside HistoryMode are strict no-ops on the cursor.
func TestHistoryCursor_OutsideHistoryMode_NoOp(t T) T {
    val seed = sampleModel().Copy(HistoryCursor = 3)
    val (m, _) = Update(seed, HistoryCursorUp())
    return Eq(t, m.HistoryCursor, 3)
}

// Cursor navigates within the bounds of the loaded archives list.
func TestHistoryCursor_ClampsAtBounds(t T) T {
    val a1 = sampleArchive(1, "merged")
    val a2 = sampleArchive(2, "merged")
    val seed = sampleModel().Copy(
        HistoryMode = true,
        Archives    = ArrayOf(a1, a2),
    )
    val (m1, _) = Update(seed, HistoryCursorDown())
    val t1 = Eq(t, m1.HistoryCursor, 1)
    val (m2, _) = Update(m1, HistoryCursorDown())  // already at end — no further advance
    val t2 = Eq(t1, m2.HistoryCursor, 1)
    val (m3, _) = Update(m2, HistoryCursorUp())
    val t3 = Eq(t2, m3.HistoryCursor, 0)
    val (m4, _) = Update(m3, HistoryCursorUp())  // already at top — no further retreat
    return Eq(t3, m4.HistoryCursor, 0)
}

// HistoryDeselect drops the in-view archive — used by Esc to back out
// of the detail view to the index.
func TestHistoryDeselect_ClearsViewingArchive(t T) T {
    val snap = makeSnap()
    val seed = sampleModel().Copy(
        HistoryMode    = true,
        ViewingArchive = Some(snap),
    )
    val (m, _) = Update(seed, HistoryDeselect())
    return IsFalse(t, m.ViewingArchive.IsDefined())
}

// HistoryArchiveLoaded populates ViewingArchive — the asynchronous
// arm of HistorySelect → archiveLoadCmd → HistoryArchiveLoaded.
func TestHistoryArchiveLoaded_StoresSnapshot(t T) T {
    val snap = makeSnap()
    val (m, _) = Update(sampleModel(), HistoryArchiveLoaded(Snap = snap))
    return IsTrue(t, m.ViewingArchive.IsDefined())
}

// HistoryArchiveFailed lands a tagged "history: …" entry in LastError
// so the footer surfaces the disk read failure.
func TestHistoryArchiveFailed_TagsLastError(t T) T {
    val (m, _) = Update(sampleModel(), HistoryArchiveFailed(ErrText = "broken json"))
    return m.LastError match {
        case Some(s) => IsTrue(t, s == "history: broken json")
        case None()  => IsTrue(t, false)
    }
}

// KeySubmit while HistoryMode is open is repurposed to "load the
// cursored archive" (matches the user's expectation that the visible
// cursor is what Enter acts on).
func TestKeySubmit_InHistoryMode_RoutesToSelect(t T) T {
    val seed = sampleModel().Copy(
        HistoryMode  = true,
        Archives     = ArrayOf(sampleArchive(1, "merged")),
        HistoryCursor = 0,
        Composer     = "ignored draft",
    )
    val (m, _) = Update(seed, KeySubmit())
    // Submit shouldn't have cleared the composer (it would for a normal
    // submit) — that's our signal that the Enter was redirected.
    return Eq(t, m.Composer, "ignored draft")
}

// Helpers ---

func sampleArchive(savedAt int64, label string) session.SnapshotMeta = session.SnapshotMeta(
    Path        = s"/fake/archive/${label}-${savedAt}.json",
    Label       = label,
    ProjectName = "demo",
    SavedAt     = savedAt,
    LineCount   = 0,
)

// makeSnap builds a Snapshot for tests.
func makeSnap() session.Snapshot {
    val convo = EmptyArray[session.ConversationLine]()
    return session.Snapshot(
        ProjectName   = "demo",
        SavedAt       = int64(12345),
        Conversation  = convo,
        ActiveMembers = EmptyArray[string](),
    )
}

// ---------------------------------------------------------------------------
// Multi-team / in-project consult plumbing (Phase 4c)
// ---------------------------------------------------------------------------

// AppModel.Teams defaults to a single-entry list containing the main
// team when InitialModel is used without an explicit teams argument.
func TestInitialModel_TeamsListContainsMainTeam(t T) T {
    val m = sampleModel()
    val t1 = Eq(t,  m.Teams.Size(), 1)
    return Eq(t1, m.Teams.Get(0).Key, "main")
}

// F5 (KeySetViewMode(ViewActivity)) and F6 (KeyToggleHelp) plumbed
// through dispatchMsg. Regression: live mode reported neither
// responding because the keymap wired them but the dispatcher had no
// case before this commit landed (and after).
func TestKeySetViewMode_F5_TogglesViewActivity(t T) T {
    val seed = sampleModel()
    val (m, _) = Update(seed, KeySetViewMode(Mode = ViewActivity()))
    return m.ViewMode match {
        case ViewActivity() => IsTrue(t, true)
        case _              => IsTrue(t, false)
    }
}

func TestKeySetViewMode_F5_Twice_TogglesBackToDefault(t T) T {
    val seed = sampleModel()
    val (m1, _) = Update(seed, KeySetViewMode(Mode = ViewActivity()))
    val (m2, _) = Update(m1, KeySetViewMode(Mode = ViewActivity()))
    return m2.ViewMode match {
        case ViewDefault() => IsTrue(t, true)
        case _             => IsTrue(t, false)
    }
}

func TestKeyToggleHelp_F6_FlipsHelpVisible(t T) T {
    val seed = sampleModel()
    val (m1, _) = Update(seed, KeyToggleHelp())
    val t1 = IsTrue(t, m1.HelpVisible)
    val (m2, _) = Update(m1, KeyToggleHelp())
    return IsFalse(t1, m2.HelpVisible)
}

// Real-claude regression suite: each fixture is a trimmed real
// stream-json line captured from `claude --output-format stream-json
// --verbose --print` against gala_simple. The matrix covers EVERY
// type the claude CLI emits so a future codec / filter regression
// trips a failing test instead of leaking the envelope into the
// transcript. Run `claude --print --output-format stream-json
// --verbose <prompt>` against any project to capture more shapes.
//
// Pattern: each test injects ONE captured line via ChunkArrived,
// asserts on whether anything landed in the conversation, and (for
// the assistant-text case) asserts the visible text is clean prose
// without envelope markers.

func TestRealClaude_SystemInit_IsDropped(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/workdir\",\"session_id\":\"abc\",\"tools\":[\"Task\",\"Bash\",\"Read\"],\"model\":\"claude-opus-4-7\"}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    return Eq(t, m.Conversation.Filter((cl) => cl.Speaker == "Iris").Size(), 0)
}

func TestRealClaude_AssistantThinking_IsDropped(t T) T {
    // Claude's `thinking` content blocks have no user-facing text;
    // they should drop without leaking the thinking signature.
    val seed = sampleModel()
    val line = "{\"type\":\"assistant\",\"message\":{\"model\":\"claude-opus-4-7\",\"id\":\"msg_01\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"thinking\",\"thinking\":\"\",\"signature\":\"abc==\"}],\"usage\":{\"input_tokens\":5,\"output_tokens\":1,\"cache_read_input_tokens\":0}}}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    return Eq(t, m.Conversation.Filter((cl) => cl.Speaker == "Iris").Size(), 0)
}

// `tool_use` chunks no longer surface a per-tool line in the chat —
// the audit-suggested "using <Tool>" rows were noise. Instead, the
// chunk flips the member's status back to StWorking so the sidebar
// timer keeps ticking and the heartbeat doesn't escalate to
// Slow/Stuck. The conversation stays clean.
func TestRealClaude_AssistantToolUse_FlipsStatusButNoTranscriptLine(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"assistant\",\"message\":{\"model\":\"claude-opus-4-7\",\"id\":\"msg_02\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01\",\"name\":\"Bash\",\"input\":{\"command\":\"ls\",\"description\":\"list files\"},\"caller\":{\"type\":\"direct\"}}],\"usage\":{\"input_tokens\":5,\"output_tokens\":48,\"cache_read_input_tokens\":0}}}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    // No entry in chat — keep the transcript clean.
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Iris")
    val t1 = Eq(t, entries.Size(), 0)
    // Status flipped to Working — the heartbeat sees activity.
    val st = m.Statuses.Get("Iris").GetOrElse(StIdle())
    return st match {
        case StWorking() => IsTrue(t1, true)
        case _           => IsTrue(t1, false)
    }
}

func TestRealClaude_UserToolResult_IsDropped(t T) T {
    // claude wraps tool results as `type:"user"` envelopes. These are
    // claude-internal scaffolding, not user-visible.
    val seed = sampleModel()
    val line = "{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01\",\"type\":\"tool_result\",\"content\":\"BUGS.MD\\nBUILD.bazel\\nCLAUDE.MD\"}]},\"parent_tool_use_id\":null,\"session_id\":\"abc\",\"uuid\":\"x\"}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    return Eq(t, m.Conversation.Filter((cl) => cl.Speaker == "Iris").Size(), 0)
}

func TestRealClaude_AssistantText_RendersCleanProse(t T) T {
    // The one shape that SHOULD render — assistant text content.
    val seed = sampleModel()
    val line = "{\"type\":\"assistant\",\"message\":{\"model\":\"claude-opus-4-7\",\"id\":\"msg_03\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"The project root is a Bazel-managed Go monorepo.\"}],\"usage\":{\"input_tokens\":5,\"output_tokens\":20,\"cache_read_input_tokens\":0}}}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Iris")
    val t1 = Eq(t, entries.Size(), 1)
    val text = entries.Get(0).Text
    val t2 = IsTrue(t1, strings.Contains(text, "Bazel-managed Go monorepo"))
    val t3 = IsFalse(t2, strings.Contains(text, "input_tokens"))
    val t4 = IsFalse(t3, strings.Contains(text, "session_id"))
    return IsFalse(t4, strings.Contains(text, "stop_reason"))
}

func TestRealClaude_ResultSuccess_RendersResultBody(t T) T {
    // result event with non-empty `result` field should render
    // (covers bulk-mode claude that doesn't stream).
    val seed = sampleModel()
    val line = "{\"type\":\"result\",\"subtype\":\"success\",\"is_error\":false,\"duration_ms\":9638,\"num_turns\":2,\"result\":\"The project root is a Bazel-managed Go monorepo.\",\"session_id\":\"abc\",\"total_cost_usd\":0.12,\"usage\":{\"input_tokens\":5,\"output_tokens\":20,\"cache_read_input_tokens\":0}}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Iris")
    val t1 = Eq(t, entries.Size(), 1)
    val text = entries.Get(0).Text
    val t2 = IsTrue(t1, strings.Contains(text, "Bazel-managed Go monorepo"))
    return IsFalse(t2, strings.Contains(text, "session_id"))
}

func TestRealClaude_AssistantWithMixedContent_RendersOnlyText(t T) T {
    // content[] mixing thinking + tool_use + text — only text part
    // should render, no envelope tail.
    val seed = sampleModel()
    val line = "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"thinking\",\"thinking\":\"plan\"},{\"type\":\"tool_use\",\"id\":\"t1\",\"name\":\"Bash\",\"input\":{\"command\":\"pwd\"}},{\"type\":\"text\",\"text\":\"hello world\"}],\"usage\":{\"input_tokens\":1,\"output_tokens\":1,\"cache_read_input_tokens\":0}}}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Iris")
    val t1 = Eq(t, entries.Size(), 1)
    val text = entries.Get(0).Text
    val t2 = IsTrue(t1, strings.Contains(text, "hello world"))
    val t3 = IsFalse(t2, strings.Contains(text, "tool_use"))
    return IsFalse(t3, strings.Contains(text, "thinking"))
}

func TestRealClaude_ControlRequest_IsDropped(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"control_request\",\"request\":{\"action\":\"interrupt\"},\"session_id\":\"abc\"}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    return Eq(t, m.Conversation.Filter((cl) => cl.Speaker == "Iris").Size(), 0)
}

func TestRealClaude_ToolUseResultStandalone_IsDropped(t T) T {
    // Some claude versions emit tool_use_result as a standalone
    // envelope rather than wrapping in user.message.
    val seed = sampleModel()
    val line = "{\"type\":\"tool_use_result\",\"tool_use_result\":{\"stdout\":\"file1\\nfile2\",\"is_error\":false},\"parent_tool_use_id\":null,\"session_id\":\"abc\",\"uuid\":\"x\"}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    return Eq(t, m.Conversation.Filter((cl) => cl.Speaker == "Iris").Size(), 0)
}

// Non-renderable stream-json event types must be dropped entirely.
// Each test injects a real-world line shape pulled from claude
// stream-json output. None of these should land in Conversation.
func TestOnChunk_RateLimitEvent_IsDropped(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"rate_limit_event\",\"rate_limit_info\":{\"status\":\"allowed\",\"resetsAt\":1777750200},\"uuid\":\"cc0\",\"session_id\":\"abc\"}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Iris")
    return Eq(t, entries.Size(), 0)
}

func TestOnChunk_ToolUseResult_IsDropped(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"tool_use_result\",\"tool_use_result\":{\"stdout\":\"file1\\nfile2\",\"is_error\":false},\"parent_tool_use_id\":null,\"session_id\":\"abc\",\"uuid\":\"x\"}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Iris")
    return Eq(t, entries.Size(), 0)
}

func TestOnChunk_UserToolResult_IsDropped(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"x\",\"type\":\"tool_result\",\"content\":\"ls output here\"}]}}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Iris")
    return Eq(t, entries.Size(), 0)
}

func TestOnChunk_SystemEvent_IsDropped(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/x\",\"session_id\":\"abc\",\"tools\":[\"Read\",\"Bash\"]}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Iris")
    return Eq(t, entries.Size(), 0)
}

// Legitimate prose that happens to contain JSON-shaped substrings
// (e.g. the lead explaining stream-json format to engineers) must
// pass through UNTRUNCATED. Earlier filter aggressively chopped at
// `"stop_reason":` regardless of context, leaving the user with
// empty entries when prose continued past such substrings.
func TestOnChunk_LegitimateProseWithJsonSubstrings_PassesThrough(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"To parse claude output, look for the field named stop_reason — it tells you why the turn ended.\"}],\"usage\":{\"input_tokens\":5,\"output_tokens\":20,\"cache_read_input_tokens\":0}}}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Iris")
    val t1 = Eq(t, entries.Size(), 1)
    return IsTrue(t1, strings.Contains(entries.Get(0).Text, "stop_reason — it tells you"))
}

// dispatchOneConsult must filter the main team out of the in-project
// team list before passing to DispatchConsult — otherwise a lead's
// `@consult(<own-key>)` would loop back to itself instead of
// surfacing as an unknown registry name.
func TestDispatchOneConsult_DoesNotLoopBackToMainTeam(t T) T {
    // Two-team model where the main team's key is "main"; a chunk
    // emitting `@consult(main)` should fall through to the registry
    // (which is empty) and fire a ConsultFailed via MsgCmd.
    val seed = sampleModel()
    val (m, _) = Update(seed, ChunkArrived(
        Member = "Iris",
        Line   = "@consult(main) loop\n@end",
    ))
    // ConsultsFired bumps regardless — the dispatch attempt happened.
    // What we want to verify is that the main team isn't picked as
    // the in-project sibling, which would have spawned a real claude
    // session and crashed the test (no claude binary on PATH).
    return Eq(t, m.ConsultsFired, 1)
}

// ---------------------------------------------------------------------------
// Composer cursor: insert / delete / cursor moves
// ---------------------------------------------------------------------------

func TestComposerInsertAt_AtEnd(t T) T {
    val (next, cur) = composerInsertAt("hello", 5, "!")
    val t1 = Eq(t, next, "hello!")
    return Eq(t1, cur, 6)
}

func TestComposerInsertAt_InMiddle(t T) T {
    val (next, cur) = composerInsertAt("helo", 2, "l")
    val t1 = Eq(t, next, "hello")
    return Eq(t1, cur, 3)
}

func TestComposerInsertAt_AtStart(t T) T {
    val (next, cur) = composerInsertAt("world", 0, "hello ")
    val t1 = Eq(t, next, "hello world")
    return Eq(t1, cur, 6)
}

func TestComposerInsertAt_NegativeCursorClamps(t T) T {
    val (next, cur) = composerInsertAt("x", -5, "y")
    val t1 = Eq(t, next, "yx")
    return Eq(t1, cur, 1)
}

func TestComposerInsertAt_PastEndClamps(t T) T {
    val (next, cur) = composerInsertAt("ab", 99, "c")
    val t1 = Eq(t, next, "abc")
    return Eq(t1, cur, 3)
}

func TestComposerDeleteBefore_AtCursor(t T) T {
    val (next, cur) = composerDeleteBefore("hello", 3)
    val t1 = Eq(t, next, "helo")
    return Eq(t1, cur, 2)
}

func TestComposerDeleteBefore_AtStart_NoOp(t T) T {
    val (next, cur) = composerDeleteBefore("hi", 0)
    val t1 = Eq(t, next, "hi")
    return Eq(t1, cur, 0)
}

func TestComposerDeleteAt_Forward(t T) T {
    val (next, cur) = composerDeleteAt("hello", 0)
    val t1 = Eq(t, next, "ello")
    return Eq(t1, cur, 0)
}

func TestComposerDeleteAt_AtEnd_NoOp(t T) T {
    val (next, cur) = composerDeleteAt("hi", 2)
    val t1 = Eq(t, next, "hi")
    return Eq(t1, cur, 2)
}

func TestComposer_FullEditCycle_FixMidLineMistake(t T) T {
    // User types "abdc" then realises the d/c are swapped. Recovery
    // pattern: arrow-left twice (cursor 4→2), Delete the d, jump End,
    // type d. Result: "abcd". This is the regression scenario the
    // user reported — without cursor support every keystroke just
    // appended.
    val m0 = sampleModel().Copy(Composer = "abdc", ComposerCursor = 4)
    val (m1, _) = onComposerCursor(m0, -1)
    val (m2, _) = onComposerCursor(m1, -1)
    val (m3, _) = onComposerDelete(m2)
    val t1 = Eq(t, m3.Composer, "abc")
    val t2 = Eq(t1, m3.ComposerCursor, 2)
    val (m4, _) = onComposerEndKey(m3)
    val (m5, _) = onKeyChar(m4, 'd')
    val t3 = Eq(t2, m5.Composer, "abcd")
    return Eq(t3, m5.ComposerCursor, 4)
}

func TestComposerHome_JumpsCursorToZero(t T) T {
    val m0 = sampleModel().Copy(Composer = "hello", ComposerCursor = 5)
    val (m1, _) = onComposerCursorJump(m0, 0)
    return Eq(t, m1.ComposerCursor, 0)
}

func TestComposerBackspace_RemovesBeforeCursor(t T) T {
    val m0 = sampleModel().Copy(Composer = "abXc", ComposerCursor = 3)
    val (m1, _) = onComposerBackspace(m0)
    val t1 = Eq(t, m1.Composer, "abc")
    return Eq(t1, m1.ComposerCursor, 2)
}

// ---------------------------------------------------------------------------
// Composer Up/Down vertical navigation. Hard \n-separated lines only —
// soft-wrapped rows aren't navigated row-by-row. A single-line composer
// jumps to start/end on Up/Down (closest sensible destination).
// ---------------------------------------------------------------------------

// "abcd\nefgh", cursor at index 2 (between 'b' and 'c'), Down moves to
// the same column (2) on line 2 — between 'f' and 'g'. Column preserved.
func TestComposerVerticalMove_Down_PreservesColumn(t T) T {
    val next = composerVerticalMove("abcd\nefgh", 2, 1)
    return Eq(t, next, 7)  // 'a','b','c','d','\n','e','f' — index 7 is between f and g
}

// Mirror of the above: from line 2 col 2, Up goes to line 1 col 2.
func TestComposerVerticalMove_Up_PreservesColumn(t T) T {
    val next = composerVerticalMove("abcd\nefgh", 7, -1)
    return Eq(t, next, 2)
}

// Target line shorter than the source column → cursor lands at the
// end of the target line (clamped column).
func TestComposerVerticalMove_Down_ClampsToShorterLine(t T) T {
    val next = composerVerticalMove("abcdef\nxy", 5, 1)  // col 5 on line 1
    return Eq(t, next, 9)  // line 2 only has 2 chars, end of "xy"
}

// Single-line composer: Up jumps to start.
func TestComposerVerticalMove_Up_SingleLine_JumpsToStart(t T) T {
    val next = composerVerticalMove("hello", 5, -1)
    return Eq(t, next, 0)
}

// Single-line composer: Down jumps to end.
func TestComposerVerticalMove_Down_SingleLine_JumpsToEnd(t T) T {
    val next = composerVerticalMove("hello", 0, 1)
    return Eq(t, next, 5)
}

// Already at the first line, Up clamps to 0 (stay at top).
func TestComposerVerticalMove_Up_FromFirstLine_ClampsToZero(t T) T {
    val next = composerVerticalMove("abc\ndef\nghi", 1, -1)
    return Eq(t, next, 0)
}

// Already at the last line, Down clamps to end (stay at bottom).
func TestComposerVerticalMove_Down_FromLastLine_ClampsToEnd(t T) T {
    val next = composerVerticalMove("abc\ndef\nghi", 9, 1)  // 'g','h' col 1 on last line
    return Eq(t, next, 11)  // total length
}

// Empty composer: any vertical move is a no-op (cursor stays at 0).
func TestComposerVerticalMove_Empty_NoOp(t T) T {
    val up = composerVerticalMove("", 0, -1)
    val down = composerVerticalMove("", 0, 1)
    val t1 = Eq(t, up, 0)
    return Eq(t1, down, 0)
}

// Up arrow when composer has focus and history modal is closed:
// cursor moves between hard lines instead of being routed to the
// no-op history navigation.
func TestUpArrow_ComposerFocus_MovesCursorBetweenHardLines(t T) T {
    val m0 = sampleModel().Copy(Composer = "hello\nworld", ComposerCursor = 8)  // col 2 on line 2
    val (m1, _) = Update(m0, HistoryCursorUp())
    return Eq(t, m1.ComposerCursor, 2)
}

// History modal open: Up arrow still drives the modal cursor, not
// the composer text cursor — the modal owns the keyboard.
func TestUpArrow_HistoryMode_DoesNotMoveComposerCursor(t T) T {
    val m0 = sampleModel().Copy(
        Composer = "hello\nworld",
        ComposerCursor = 8,
        HistoryMode = true,
    )
    val (m1, _) = Update(m0, HistoryCursorUp())
    return Eq(t, m1.ComposerCursor, 8)  // unchanged
}

// ---------------------------------------------------------------------------
// AutoApprove (batch-PR mode) — F7 toggle + PrCreated wiring
// ---------------------------------------------------------------------------

// F7 flips AutoApprove from its initial value (false, per DefaultPolicy)
// and pushes a confirmation toast so the mode change is visible.
func TestKeyToggleAutoApprove_FlipsAndToasts(t T) T {
    val seed = sampleModel()
    val t0 = IsFalse(t, seed.AutoApprove)
    val (m1, _) = Update(seed, KeyToggleAutoApprove())
    val t1 = IsTrue(t0, m1.AutoApprove)
    val t2 = IsTrue(t1, m1.Toasts.Length() > 0)
    val (m2, _) = Update(m1, KeyToggleAutoApprove())
    return IsFalse(t2, m2.AutoApprove)
}

// AutoApprove seeds from policy.auto_approve at startup so a team.yaml
// declaring `auto_approve: true` boots the model already in batch
// mode. The F7 toggle still flips it from there.
func TestInitialModel_SeedsAutoApproveFromPolicy(t T) T {
    val pol = DefaultPolicy().Copy(AutoApprove = true)
    val m = InitialModel(sampleProject(), sampleTeam(), DefaultWorkflow(), pol)
    return IsTrue(t, m.AutoApprove)
}

// In auto-approve mode the second log line invites batch-review in
// GitHub instead of suggesting Ctrl+M, so the user knows the next
// prompt won't block on a manual merge.
func TestPrCreated_AutoApprove_SkipsCtrlMHint(t T) T {
    val seed = sampleModel().Copy(AutoApprove = true)
    val (m, _) = Update(seed, PrCreated(Url = "https://x/y/pull/7", Branch = "gala_team/x/pr/def7"))
    val t1 = Eq(t, m.Conversation.Size(), 2)
    val first = m.Conversation.Get(0).Text
    val second = m.Conversation.Get(1).Text
    val t2 = IsTrue(t1, strings.Contains(first, "https://x/y/pull/7"))
    val t3 = IsTrue(t2, strings.Contains(second, "queued in batch"))
    return IsFalse(t3, strings.Contains(second, "Ctrl+M"))
}

// Manual-approve mode (default) still surfaces the Ctrl+M hint — this
// guards against the AutoApprove branch accidentally swallowing the
// non-auto path.
func TestPrCreated_ManualApprove_KeepsCtrlMHint(t T) T {
    val (m, _) = Update(sampleModel(), PrCreated(Url = "https://x/y/pull/7", Branch = "gala_team/x/pr/def7"))
    val second = m.Conversation.Get(1).Text
    return IsTrue(t, strings.Contains(second, "Ctrl+M"))
}

// AutoApprove accumulates: each PrCreated grows OpenPrs without
// resetting prior entries. Mirrors the user-visible "(N open)" badge.
func TestPrCreated_AutoApprove_AccumulatesOpenPrs(t T) T {
    val seed = sampleModel().Copy(AutoApprove = true)
    val (m1, _) = Update(seed, PrCreated(Url = "https://x/y/pull/1", Branch = "gala_team/x/pr/aaa1"))
    val (m2, _) = Update(m1,   PrCreated(Url = "https://x/y/pull/2", Branch = "gala_team/x/pr/bbb2"))
    val (m3, _) = Update(m2,   PrCreated(Url = "https://x/y/pull/3", Branch = "gala_team/x/pr/ccc3"))
    val t1 = Eq(t, m3.OpenPrs.Size(), 3)
    val t2 = Eq(t1, m3.OpenPrs.Get(0).Url, "https://x/y/pull/1")
    return Eq(t2, m3.OpenPrs.Get(2).Url, "https://x/y/pull/3")
}

// ---------------------------------------------------------------------------
// @base directive (V2 stacking)
// ---------------------------------------------------------------------------

// @base previous resolves to the most recent open PR's branch. With
// at least one OpenPrs entry, the resolver returns Some(branch) and
// applyBaseDirective stores that on the model. The Base directive is
// stripped from the returned dirs so the FSM routing layer doesn't
// see it.
func TestApplyBase_Previous_ResolvesToLastOpenBranch(t T) T {
    val seed = sampleModel().Copy(OpenPrs = ArrayOf(
        sampleBatchPr("https://x/y/pull/7").Copy(Branch = "gala_team/x/pr/abc7"),
        sampleBatchPr("https://x/y/pull/8").Copy(Branch = "gala_team/x/pr/def8"),
    ))
    val dirs = ArrayOf[Directive](Base(Ref = "previous"), Dispatch(Target = "Felix", Body = "go"))
    val (next, rest) = applyBaseDirective(seed, dirs)
    val t1 = next.ActiveBase match {
        case Some(b) => Eq(t, b, "gala_team/x/pr/def8")
        case None()  => IsTrue(t, false)
    }
    return Eq(t1, rest.Size(), 1)  // Base stripped, Dispatch survives
}

// @base main is treated as "no override" so ActiveBase stays None and
// gh pr create falls back to the project's default branch.
func TestApplyBase_Main_LeavesActiveBaseNone(t T) T {
    val dirs = ArrayOf[Directive](Base(Ref = "main"))
    val (next, _) = applyBaseDirective(sampleModel(), dirs)
    return IsFalse(t, next.ActiveBase.IsDefined())
}

// @base previous on the very first prompt — OpenPrs is empty — falls
// back to None instead of dead-ending. The PR opens against the
// default branch as if @base had been omitted.
func TestApplyBase_PreviousWithEmptyOpenPrs_FallsBackToNone(t T) T {
    val dirs = ArrayOf[Directive](Base(Ref = "previous"))
    val (next, _) = applyBaseDirective(sampleModel(), dirs)
    return IsFalse(t, next.ActiveBase.IsDefined())
}

// A literal ref is passed through verbatim so TLs can pin a base
// branch outside the main / previous shorthands.
func TestApplyBase_LiteralRef_Passes(t T) T {
    val dirs = ArrayOf[Directive](Base(Ref = "release/2026-q1"))
    val (next, _) = applyBaseDirective(sampleModel(), dirs)
    return next.ActiveBase match {
        case Some(b) => Eq(t, b, "release/2026-q1")
        case None()  => IsTrue(t, false)
    }
}

// First Base wins when a TL emits multiple. (Should be rare; the
// onboarding doc says "emit once at the top of the turn".)
func TestApplyBase_FirstWins(t T) T {
    val dirs = ArrayOf[Directive](
        Base(Ref = "feat/a"),
        Base(Ref = "feat/b"),
    )
    val (next, _) = applyBaseDirective(sampleModel(), dirs)
    return next.ActiveBase match {
        case Some(b) => Eq(t, b, "feat/a")
        case None()  => IsTrue(t, false)
    }
}

// PrCreated records the snapshot branch on the BatchPr entry, so a
// later @base previous resolves to the right ref instead of the
// generic lead-branch placeholder.
func TestPrCreated_RecordsSnapshotBranch(t T) T {
    val seed = sampleModel()
    val (m, _) = Update(seed, PrCreated(Url = "https://x/y/pull/9", Branch = "gala_team/x/pr/snap9"))
    return Eq(t, m.OpenPrs.Get(0).Branch, "gala_team/x/pr/snap9")
}

// PrCreated clears ActiveBase. The next user prompt starts fresh —
// the TL must re-emit @base if stacking is wanted again.
func TestPrCreated_ClearsActiveBase(t T) T {
    val seed = sampleModel().Copy(ActiveBase = Some("gala_team/x/pr/abc"))
    val (m, _) = Update(seed, PrCreated(Url = "https://x/y/pull/9", Branch = "gala_team/x/pr/snap9"))
    return IsFalse(t, m.ActiveBase.IsDefined())
}

// New user prompt resets ActiveBase. Without this, a stale base from
// a prior turn would silently apply to the next, unrelated PR.
func TestKeySubmit_ClearsActiveBase(t T) T {
    val seed = sampleModel().Copy(
        Composer = "next task",
        ActiveBase = Some("gala_team/x/pr/abc"),
    )
    val (m, _) = Update(seed, KeySubmit())
    return IsFalse(t, m.ActiveBase.IsDefined())
}

// ---------------------------------------------------------------------------
// @plan directive (V3 multi-PR auto-continuation)
// ---------------------------------------------------------------------------

// Ingest stores the FULL items list on m.Plan and resets
// PlanShipped. The current turn ships the first item; subsequent
// PrCreated events advance PlanShipped and auto-fire the next.
func TestApplyPlan_StoresFullListAndResetsShipped(t T) T {
    val seed = sampleModel().Copy(PlanShipped = 99)  // stale value
    val dirs = ArrayOf[Directive](Plan(Items = ArrayOf("step1", "step2", "step3")))
    val (next, rest) = applyBaseDirective(seed, dirs)
    val t1 = Eq(t, next.Plan.Size(), 3)
    val t2 = Eq(t1, next.Plan.Get(0), "step1")
    val t3 = Eq(t2, next.PlanShipped, 0)
    return Eq(t3, rest.Size(), 0)  // Plan directive stripped from FSM-visible dirs
}

// First @plan wins when a TL emits multiple. Onboarding says "emit
// once at the top of the turn"; this guards against confused chains.
func TestApplyPlan_FirstWins(t T) T {
    val dirs = ArrayOf[Directive](
        Plan(Items = ArrayOf("a", "b")),
        Plan(Items = ArrayOf("c", "d", "e")),
    )
    val (next, _) = applyBaseDirective(sampleModel(), dirs)
    val t1 = Eq(t, next.Plan.Size(), 2)
    return Eq(t1, next.Plan.Get(0), "a")
}

// PrCreated with an active plan + AutoApprove + idle composer:
// advances PlanShipped and stages the next step in Composer. The
// synthetic KeySubmit Cmd is dropped by the unit-test harness; we
// just assert the model changes.
func TestPrCreated_WithPlan_AutoContinues(t T) T {
    val seed = sampleModel().Copy(
        AutoApprove = true,
        Plan        = ArrayOf("webhook handler", "refund flow"),
    )
    val (m, _) = Update(seed, PrCreated(Url = "https://x/y/pull/1", Branch = "gala_team/x/pr/aaa1"))
    val t1 = Eq(t, m.PlanShipped, 1)
    return Eq(t1, m.Composer, "refund flow")
}

// Plan reaches its end after the last step's PR. PlanShipped
// equals Plan.Size(); no auto-continue; Composer untouched.
func TestPrCreated_PlanLastStep_CompletesQuietly(t T) T {
    val seed = sampleModel().Copy(
        AutoApprove = true,
        Plan        = ArrayOf("only step"),
    )
    val (m, _) = Update(seed, PrCreated(Url = "https://x/y/pull/1", Branch = "gala_team/x/pr/aaa1"))
    val t1 = Eq(t, m.PlanShipped, 1)
    val t2 = Eq(t1, m.Composer, "")
    // Last conversation line is the "plan: complete" notice.
    val lastLine = m.Conversation.Get(m.Conversation.Size() - 1).Text
    return IsTrue(t2, strings.Contains(lastLine, "plan: complete"))
}

// PrCreated with empty Plan does NOT touch Composer. Auto-approve
// drops back to the existing batch-queued behavior (V1 shape).
func TestPrCreated_NoPlan_LeavesComposerUntouched(t T) T {
    val seed = sampleModel().Copy(AutoApprove = true, Composer = "user typed this")
    val (m, _) = Update(seed, PrCreated(Url = "https://x/y/pull/1", Branch = "gala_team/x/pr/aaa1"))
    return Eq(t, m.Composer, "user typed this")
}

// PrCreated with Plan but Composer non-empty (user mid-typing) does
// NOT auto-continue — we never overwrite user text. PlanShipped
// still advances so the visualization reflects the PR that just
// landed; the next user submit clears the plan.
func TestPrCreated_PlanButComposerInUse_StallsPlan(t T) T {
    val seed = sampleModel().Copy(
        AutoApprove = true,
        Plan        = ArrayOf("step1", "step2"),
        Composer    = "wait — different ask",
    )
    val (m, _) = Update(seed, PrCreated(Url = "https://x/y/pull/1", Branch = "gala_team/x/pr/aaa1"))
    val t1 = Eq(t, m.Composer, "wait — different ask")
    return Eq(t1, m.PlanShipped, 1)
}

// PrCreated with a plan but AutoApprove off does NOT auto-continue —
// manual mode would dead-end on the Ctrl+M / Ctrl+A wait anyway.
func TestPrCreated_PlanWithoutAutoApprove_DoesNotContinue(t T) T {
    val seed = sampleModel().Copy(
        AutoApprove = false,
        Plan        = ArrayOf("step1", "step2"),
    )
    val (m, _) = Update(seed, PrCreated(Url = "https://x/y/pull/1", Branch = "gala_team/x/pr/aaa1"))
    return Eq(t, m.Composer, "")
}

// User-issued KeySubmit clears any pending Plan + PlanShipped —
// typing a fresh prompt overrides the queued multi-PR sequence.
func TestKeySubmit_ClearsPlanAndShipped(t T) T {
    val seed = sampleModel().Copy(
        Composer    = "redirect",
        Plan        = ArrayOf("a", "b", "c"),
        PlanShipped = 1,
    )
    val (m, _) = Update(seed, KeySubmit())
    val t1 = IsTrue(t, m.Plan.IsEmpty())
    return Eq(t1, m.PlanShipped, 0)
}

// planProgressGlyphs renders ✓/▶/☐ per step.
func TestPlanProgressGlyphs(t T) T {
    val t1 = Eq(t,  planProgressGlyphs(0, 3), "▶ ☐ ☐")
    val t2 = Eq(t1, planProgressGlyphs(1, 3), "✓ ▶ ☐")
    val t3 = Eq(t2, planProgressGlyphs(2, 3), "✓ ✓ ▶")
    return Eq(t3, planProgressGlyphs(3, 3), "✓ ✓ ✓")
}

// pendingPrTitle pulls the most recent user prompt out of the
// conversation log so each batch entry has a human-readable handle.
// Falls back to the lead branch when no user line exists.
func TestPendingPrTitle_PicksLatestUserPrompt(t T) T {
    val seed = sampleModel().Copy(Conversation = ArrayOf(
        session.ConversationLine(Speaker = "you",  Text = "ship the metrics endpoint"),
        session.ConversationLine(Speaker = "Iris", Text = "on it"),
        session.ConversationLine(Speaker = "you",  Text = "add a histogram too"),
    ))
    return Eq(t, pendingPrTitle(seed), "add a histogram too")
}

func TestPendingPrTitle_SkipsSlashCommands(t T) T {
    val seed = sampleModel().Copy(Conversation = ArrayOf(
        session.ConversationLine(Speaker = "you", Text = "ship the metrics endpoint"),
        session.ConversationLine(Speaker = "you", Text = "/approve"),
        session.ConversationLine(Speaker = "you", Text = "/merge"),
    ))
    return Eq(t, pendingPrTitle(seed), "ship the metrics endpoint")
}

// ---------------------------------------------------------------------------
// QA auto-spawn guard: if the lead @dispatches a QA member directly
// when qa_required is true, spawnDispatchedMembers drops it. Engineers
// in the same fan-out still go through.
// ---------------------------------------------------------------------------

func teamWithQa() Team {
    val iris  = Member(Name = "Iris",  Role = TeamLead(), Personality = "", Model = None[string](), Extra = "", Onboarding = EmptyArray[string]())
    val felix = Member(Name = "Felix", Role = Engineer(), Personality = "", Model = None[string](), Extra = "", Onboarding = EmptyArray[string]())
    val mira  = Member(Name = "Mira",  Role = Engineer(), Personality = "", Model = None[string](), Extra = "", Onboarding = EmptyArray[string]())
    val theo  = Member(Name = "Theo",  Role = QA(),       Personality = "", Model = None[string](), Extra = "", Onboarding = EmptyArray[string]())
    return Team(
        Key                        = "main",
        Name                       = "Skunkworks",
        Description                = "",
        Members                    = ArrayOf[Member](iris, felix, mira, theo),
        Lead                       = iris,
        Onboarding                 = EmptyArray[string](),
        DangerouslySkipPermissions = false,
    )
}

func TestPartitionQaTargets_DropsQaKeepsEngineers(t T) T {
    val tm = teamWithQa()
    val targets = ArrayOf[Tuple[string, string]](
        ("Felix", "build the parser"),
        ("Theo",  "review please"),
        ("Mira",  "build the validator"),
    )
    val (allowed, dropped) = partitionQaTargets(targets, tm)
    val t1 = Eq(t, allowed.Size(), 2)
    val t2 = Eq(t1, dropped.Size(), 1)
    val t3 = Eq(t2, dropped.Get(0), "Theo")
    val keptNames = allowed.Map((p) => firstOfStringPair(p))
    return IsTrue(t3, keptNames.Contains("Felix") && keptNames.Contains("Mira"))
}

func firstOfStringPair(p Tuple[string, string]) string = p match {
    case (n, _) => n
    case _      => ""
}

func TestPartitionQaTargets_AllEngineers_Untouched(t T) T {
    val tm = teamWithQa()
    val targets = ArrayOf[Tuple[string, string]](
        ("Felix", "x"),
        ("Mira",  "y"),
    )
    val (allowed, dropped) = partitionQaTargets(targets, tm)
    val t1 = Eq(t, allowed.Size(), 2)
    return IsTrue(t1, dropped.IsEmpty())
}

func TestQaAutoSpawnNudge_SingularPlural(t T) T {
    val one = buildQaAutoSpawnNudge(ArrayOf("Theo"))
    val two = buildQaAutoSpawnNudge(ArrayOf("Theo", "Aria"))
    val t1 = IsTrue(t, strings.Contains(one, "Theo is a QA member"))
    return IsTrue(t1, strings.Contains(two, "Theo, Aria are a QA member"))
}

// ---------------------------------------------------------------------------
// JSON buffer-and-extract regression — the actual leak from the live
// session screenshot (Felix's tool_result content for a Read of a
// BUILD.bazel file). Split into two chunks at a sub-line boundary
// inside the envelope's `content` string. The tail chunk has zero
// `{` characters (BUILD.bazel uses parens) — the previous fast-path
// would have rendered it as plain prose.
// ---------------------------------------------------------------------------

func TestJsonExtract_SplitToolResult_TailDoesNotLeakAsProse(t T) T {
    val seed = sampleModel()
    // Chunk 1: open envelope + first half of content string.
    val chunk1 = "{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01\",\"type\":\"tool_result\",\"content\":\"gala_bootstrap_transpile(\\n  name = \\\"naming_go\\\",\\n  src = \\\"naming.g"
    // Chunk 2: tail of content + envelope close. Has ZERO `{`.
    val chunk2 = "ala\\\",\\n  out = \\\"naming.gen.go\\\",\\n)\",\"numLines\":67}]},\"session_id\":\"abc\"}"
    val (m1, _) = Update(seed, ChunkArrived(Member = "Felix", Line = chunk1))
    val (m2, _) = Update(m1,   ChunkArrived(Member = "Felix", Line = chunk2))
    // Expect: zero conversation lines from Felix. The whole thing is
    // a `type:"user"` envelope which the whitelist drops.
    val felixLines = m2.Conversation.Filter((cl) => cl.Speaker == "Felix")
    return Eq(t, felixLines.Size(), 0)
}

func TestJsonExtract_BraceCountedExtraction_PullsCompleteEnvelope(t T) T {
    val ext = extractCompleteEnvelopes("{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"hi\"}],\"usage\":{\"input_tokens\":1,\"output_tokens\":1,\"cache_read_input_tokens\":0}}}\n")
    val t1 = Eq(t, ext.Envelopes.Size(), 1)
    return Eq(t1, ext.Leftover, "")
}

func TestJsonExtract_PartialEnvelope_HeldInLeftover(t T) T {
    // Open envelope, no close — should produce zero envelopes and
    // hold the entire input as leftover for the next chunk.
    val ext = extractCompleteEnvelopes("{\"type\":\"assistant\",\"message\":{\"content\":[{")
    val t1 = Eq(t, ext.Envelopes.Size(), 0)
    return IsTrue(t1, len(ext.Leftover) > 0)
}

func TestJsonExtract_BraceInsideString_DoesNotConfuseCounter(t T) T {
    // Content string contains literal `{` and `}` — must NOT be
    // counted by the brace tracker. Use a real Claude-shape
    // envelope (`{"type":...}` prefix) since looksLikeClaudeEnvelope
    // now drops anything else as buffer-state garbage.
    val ext = extractCompleteEnvelopes("{\"type\":\"assistant\",\"x\":\"{nested}\"}\n")
    return Eq(t, ext.Envelopes.Size(), 1)
}

func TestJsonExtract_EscapedQuoteInsideString_StillTracksProperly(t T) T {
    // Escaped quote inside a string must NOT close the string.
    // Use Claude-shape envelope to satisfy the shape gate.
    val ext = extractCompleteEnvelopes("{\"type\":\"assistant\",\"x\":\"a\\\"b\"}\n")
    return Eq(t, ext.Envelopes.Size(), 1)
}

// ----------------------------------------------------------------------------
// AskUserQuestion forwarding — regression net for the "TL asks but the
// user never gets the question" bug. The stream-json subprocess emits a
// tool_use block with name=AskUserQuestion, the orchestrator must:
//   1. Detect the tool_use in the assistant content[]
//   2. Set m.PendingQuestion (with member + tool_use_id + question text)
//   3. Append a "waiting for your answer" system line to the transcript
//   4. NOT close the subprocess's stdin (turn isn't done yet)
// On the user's reply via the composer:
//   5. Format the answer as a tool_result envelope
//   6. Write it to the originating member's stdin (does NOT spawn a new
//      claude --resume — the existing subprocess unblocks and continues
//      its in-flight turn)
//   7. Clear PendingQuestion and re-render the composer hint
// On Esc:
//   8. Drop PendingQuestion + log a dismissal line (mirrors the prior
//      involuntary behavior but as an explicit user choice)
// ----------------------------------------------------------------------------

// Sample stream-json envelope carrying an AskUserQuestion tool_use,
// pulled to a constant so each test reads as the shape it asserts on.
// The single-line layout mirrors what claude actually writes — one
// envelope per line, no embedded newlines.
val askUserQuestionEnvelope =
    "{\"type\":\"assistant\",\"message\":{\"model\":\"claude-opus-4-7\",\"id\":\"msg_ask\",\"type\":\"message\",\"role\":\"assistant\"," +
    "\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_ask_01\",\"name\":\"AskUserQuestion\"," +
    "\"input\":{\"questions\":[{\"question\":\"Should the new fs/streaming.gala be a separate package?\",\"header\":\"Scope\",\"multiSelect\":false," +
    "\"options\":[{\"label\":\"Yes — new package\",\"description\":\"keeps fs/fs.gala stable\"}," +
    "{\"label\":\"No — extend fs\",\"description\":\"single package, more cohesion\"}]}]}}]," +
    "\"usage\":{\"input_tokens\":10,\"output_tokens\":80,\"cache_read_input_tokens\":0}}}"

// 1+2: parsing the assistant envelope with an AskUserQuestion tool_use
// populates PendingQuestion with the member name, the tool_use_id, and
// the extracted first-question text.
func TestAskUserQuestion_StreamJsonChunk_SetsPendingQuestion(t T) T {
    val seed = sampleModel()
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = askUserQuestionEnvelope))
    return m.PendingQuestion match {
        case None() => IsTrue(t, false)
        case Some(pending) => {
            val t1 = Eq(t, pending.Member, "Iris")
            val t2 = Eq(t1, pending.ToolUseId, "toolu_ask_01")
            return IsTrue(t2, strings.Contains(pending.QuestionText, "Should the new fs/streaming.gala"))
        }
    }
}

// 3: the transcript gets a system line announcing the wait so the user
// notices the question (alongside the model's own chat narration).
func TestAskUserQuestion_StreamJsonChunk_AppendsSystemHint(t T) T {
    val seed = sampleModel()
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = askUserQuestionEnvelope))
    val systemLines = m.Conversation.Filter((cl) => cl.Speaker == "system")
    val t1 = IsTrue(t, systemLines.Size() >= 1)
    val last = systemLines.Get(systemLines.Size() - 1).Text
    return IsTrue(t1, strings.Contains(last, "waiting for your answer"))
}

// Direct AppMsg dispatch (test path) sets the same state as the
// stream-json arrival. Lets future test authors exercise the modal /
// answer flow without building a synthetic envelope.
func TestAskUserQuestion_AppMsg_SetsPendingQuestion(t T) T {
    val seed = sampleModel()
    val (m, _) = Update(seed, AskUserQuestion(
        Member       = "Felix",
        Id           = "toolu_xyz",
        QuestionText = "Pick streaming or batched?",
    ))
    return m.PendingQuestion match {
        case Some(p) => Eq(t, p.ToolUseId, "toolu_xyz")
        case None()  => IsTrue(t, false)
    }
}

// 5+6+7: composer Enter routes a pending-question answer through
// onAnswerPendingQuestion. The pending state clears AND the composer
// empties — the user's text is the ANSWER, not a fresh user prompt.
// The "you" line is logged to the transcript verbatim (no speaker
// prefix) for the audit trail. The answer is re-delivered to the
// asking member as a fresh `--resume` turn (verified by the dedicated
// re-delivery tests below); the model-level guarantee here is that no
// new top-level TL turn is *promoted* — the FSM is untouched.
func TestAskUserQuestion_ComposerSubmit_RoutesToAnswerRedelivery(t T) T {
    val seeded = sampleModel().Copy(
        PendingQuestion = Some(PendingQuestion(
            Member       = "Iris",
            ToolUseId    = "toolu_42",
            QuestionText = "Continue?",
        )),
        Composer       = "yes, extend fs",
        ComposerCursor = 14,
    )
    val (m, _) = Update(seeded, KeySubmit())
    val t1 = IsFalse(t, m.PendingQuestion.IsDefined())
    val t2 = Eq(t1, m.Composer, "")
    // "you" line carries the answer text — audit trail of what we sent.
    val youLines = m.Conversation.Filter((cl) => cl.Speaker == "you")
    val t3 = IsTrue(t2, youLines.Size() >= 1)
    val text = youLines.Get(youLines.Size() - 1).Text
    return Eq(t3, text, "yes, extend fs")
}

// 8: KeyQuestionDismiss (also bound to Esc via onEscOrDeselect) drops
// the pending question and surfaces it as an explicit dismissal in
// the transcript. The subprocess gets stdin closed via the runtime
// Cmd; we don't assert on the Cmd shape (handled at runtime test
// boundary), only that the model state is cleared.
func TestAskUserQuestion_Dismiss_ClearsPending(t T) T {
    val seeded = sampleModel().Copy(
        PendingQuestion = Some(PendingQuestion(
            Member       = "Iris",
            ToolUseId    = "toolu_99",
            QuestionText = "Continue?",
        )),
    )
    val (m, _) = Update(seeded, KeyQuestionDismiss())
    val t1 = IsFalse(t, m.PendingQuestion.IsDefined())
    val systemLines = m.Conversation.Filter((cl) => cl.Speaker == "system")
    val t2 = IsTrue(t1, systemLines.Size() >= 1)
    return IsTrue(t2, strings.Contains(systemLines.Get(systemLines.Size() - 1).Text, "dismissed"))
}

// extractFirstQuestionText pulls the first `"question":"…"` value out
// of a raw stream-json envelope. Used by the AskUserQuestion parser
// to surface the question body in the conversation log. JSON
// string-escape rules: `\"` inside a string must NOT close the
// string; `\n` decodes back to a literal newline.
func TestExtractFirstQuestionText_SimpleQuestion(t T) T {
    val env = askUserQuestionEnvelope
    return IsTrue(t, strings.Contains(extractFirstQuestionText(env), "Should the new fs/streaming.gala"))
}

func TestExtractFirstQuestionText_NoQuestionKey_ReturnsEmpty(t T) T {
    val env = "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"hi\"}]}}"
    return Eq(t, extractFirstQuestionText(env), "")
}

func TestExtractFirstQuestionText_EscapedQuoteInsideQuestion(t T) T {
    // A backslash-quote inside the JSON string must NOT terminate the
    // extraction — common in questions that quote a code identifier
    // like `"Should I rename \"Foo\" to \"Bar\"?"`.
    val env = "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"id\":\"x\",\"name\":\"AskUserQuestion\"," +
              "\"input\":{\"questions\":[{\"question\":\"Should I rename \\\"Foo\\\" to \\\"Bar\\\"?\"}]}}]}}"
    val got = extractFirstQuestionText(env)
    return IsTrue(t, strings.Contains(got, "Foo"))
}

// Non-AskUserQuestion tools still drop silently — preserves the prior
// behavior so the regression net for "Bash tool_use isn't visible"
// (TestRealClaude_AssistantToolUse_IsDropped) keeps holding. This
// test is the contrapositive: only the AskUserQuestion name triggers
// the pending-question state; other tool names don't.
func TestAskUserQuestion_OtherToolUse_NoPendingQuestion(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_b\",\"name\":\"Bash\",\"input\":{\"command\":\"ls\"}}]," +
               "\"usage\":{\"input_tokens\":1,\"output_tokens\":1,\"cache_read_input_tokens\":0}}}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = line))
    return IsFalse(t, m.PendingQuestion.IsDefined())
}

// ----------------------------------------------------------------------------
// stream-json envelope wire-format — runtime contract guards for the
// tool_use_id round-trip. Drift in any of these field names breaks
// claude's tool-call join (the model would block forever on stdin),
// so each test doubles as runtime-protocol documentation.
// ----------------------------------------------------------------------------

func TestEncodeUserPromptEnvelope_WireFormat(t T) T {
    val line = EncodeUserPromptEnvelopeForTest("hello")
    val t1 = IsTrue(t, strings.Contains(line, "\"type\":\"user\""))
    val t2 = IsTrue(t1, strings.Contains(line, "\"role\":\"user\""))
    val t3 = IsTrue(t2, strings.Contains(line, "hello"))
    return IsFalse(t3, strings.Contains(line, "\n"))
}

func TestEncodeToolResultEnvelope_WireFormat(t T) T {
    val line = EncodeToolResultEnvelopeForTest("toolu_abc", "use option 2")
    val t1 = IsTrue(t, strings.Contains(line, "\"type\":\"user\""))
    val t2 = IsTrue(t1, strings.Contains(line, "\"role\":\"user\""))
    val t3 = IsTrue(t2, strings.Contains(line, "\"type\":\"tool_result\""))
    val t4 = IsTrue(t3, strings.Contains(line, "\"tool_use_id\":\"toolu_abc\""))
    val t5 = IsTrue(t4, strings.Contains(line, "use option 2"))
    return IsFalse(t5, strings.Contains(line, "\n"))
}

func TestEncodeToolResultEnvelope_IncludesIsErrorFalse(t T) T {
    val line = EncodeToolResultEnvelopeForTest("toolu_1", "yes")
    return IsTrue(t, strings.Contains(line, "\"is_error\":false"))
}

func TestEncodeToolResultEnvelope_MultilineAnswer_IsSingleLine(t T) T {
    val answer = "line one\nline two with a \"quote\" in it"
    val line = EncodeToolResultEnvelopeForTest("toolu_ml", answer)
    val t1 = IsFalse(t, strings.Contains(line, "\n"))
    val t2 = IsTrue(t1, strings.Contains(line, "line one"))
    return IsTrue(t2, strings.Contains(line, "line two"))
}

// onApprove / onReject / KeyApprove from the approval modal must NOT
// fire when a question is pending — different state, different intent.
// The composer's Enter routes to onAnswerPendingQuestion before any
// of the FSM-state branches run. Verifies the precedence by seeding
// both states: a pending question wins, and the FSM doesn't transition.
func TestAskUserQuestion_TakesPrecedenceOverApproval(t T) T {
    val seeded = sampleModel().Copy(
        State           = Approval(SummaryBody = "draft summary"),
        PendingQuestion = Some(PendingQuestion(
            Member       = "Iris",
            ToolUseId    = "toolu_pre",
            QuestionText = "Continue?",
        )),
        Composer        = "yes",
        ComposerCursor  = 3,
    )
    val (m, _) = Update(seeded, KeySubmit())
    val t1 = IsFalse(t, m.PendingQuestion.IsDefined())
    // FSM stayed in Approval — composer text was NOT promoted to a
    // user-prompt-then-transition; it was a tool_result instead.
    return m.State match {
        case Approval(_) => IsTrue(t1, true)
        case _           => IsTrue(t1, false)
    }
}

// ----------------------------------------------------------------------------
// First-turn-with-AskUserQuestion regression — reproduces the user-reported
// "doesn't work anymore" symptom (PR #21 build): typing a fresh prompt,
// pressing Enter, getting an empty-member "is no longer running — answer
// not delivered" toast plus a saved transcript line whose Text contains
// a literal "you: " prefix. The story below walks the exact state the
// user hit; each step asserts the invariant we expect.
//
// Story:
//   1. Idle model, no sessions, no PendingQuestion.
//   2. User types "update gala to 0.49.0..." into the composer.
//   3. User presses Enter (KeySubmit).
//   4. The first conversation entry MUST be a "you" line whose Text
//      equals the composer string verbatim. No "you:" speaker prefix
//      may leak into the Text field — that's the symptom the user
//      saw in latest.json after the failure.
//   5. PendingQuestion is None at this point: no chunk has arrived yet.
// ----------------------------------------------------------------------------

func TestFirstTurn_PromptText_HasNoSpeakerPrefix(t T) T {
    val seeded = sampleModel().Copy(
        Composer       = "update gala to 0.49.0...",
        ComposerCursor = 24,
    )
    val (m, _) = Update(seeded, KeySubmit())
    val youLines = m.Conversation.Filter((cl) => cl.Speaker == "you")
    val t1 = IsTrue(t, youLines.Size() >= 1)
    val text = youLines.Get(0).Text
    // The text MUST be the raw composer string. Any "you: " prefix
    // means we routed through onAnswerPendingQuestion against a
    // stale PendingQuestion, OR the renderer leaked the speaker
    // prefix back into the model — both are the regression.
    val t2 = IsFalse(t1, strings.HasPrefix(text, "you:"))
    return Eq(t2, text, "update gala to 0.49.0...")
}

// 5 (cont'd): after the first KeySubmit the model must NOT have a
// PendingQuestion — nothing in the chunk pump has fired yet. The
// regression on the user's build had `PendingQuestion = Some(empty)`
// at this point, which then trapped the *next* KeySubmit into
// onAnswerPendingQuestion.
func TestFirstTurn_NoPendingQuestionImmediatelyAfterSubmit(t T) T {
    val seeded = sampleModel().Copy(
        Composer       = "hello there",
        ComposerCursor = 11,
    )
    val (m, _) = Update(seeded, KeySubmit())
    return IsFalse(t, m.PendingQuestion.IsDefined())
}

// 6. After an AskUserQuestion chunk arrives, PendingQuestion must
// carry the MEMBER NAME from the chunk — not "" — so the
// follow-up onAnswerPendingQuestion lookup hits the live session
// instead of falling through to the "is no longer running" toast
// with an empty member in its format string.
func TestFirstTurn_AskUserQuestion_PendingHasNonEmptyMember(t T) T {
    val seed = sampleModel()
    val (m, _) = Update(seed, ChunkArrived(Member = "Vesper", Line = askUserQuestionEnvelope))
    return m.PendingQuestion match {
        case None() => IsTrue(t, false)
        case Some(p) => {
            val t1 = IsTrue(t, p.Member != "")
            return Eq(t1, p.Member, "Vesper")
        }
    }
}

// 7. After AskUserQuestion is set AND the user types an answer + Enter,
// onAnswerPendingQuestion appends a "you" line whose Text equals the
// composer verbatim. No speaker prefix leak. The session lookup will
// fail in this test (no live session) and surface a toast — the
// invariant under test is the TEXT, not the toast.
func TestFirstTurn_AnswerText_HasNoSpeakerPrefix(t T) T {
    val seeded = sampleModel().Copy(
        PendingQuestion = Some(PendingQuestion(
            Member       = "Vesper",
            ToolUseId    = "toolu_x",
            QuestionText = "Continue?",
        )),
        Composer       = "extend fs",
        ComposerCursor = 9,
    )
    val (m, _) = Update(seeded, KeySubmit())
    val youLines = m.Conversation.Filter((cl) => cl.Speaker == "you")
    val t1 = IsTrue(t, youLines.Size() >= 1)
    val text = youLines.Get(youLines.Size() - 1).Text
    val t2 = IsFalse(t1, strings.HasPrefix(text, "you:"))
    return Eq(t2, text, "extend fs")
}

// 8. A pending question whose member isn't reachable must never
// surface the old scary "answer not delivered" wording. The answer is
// re-delivered via a fresh `--resume` turn; only a genuine routing
// failure flags the line (with a clearer "flagged below / re-send to
// retry" toast). Regression net so the original lost-prompt toast
// phrasing never comes back.
func TestFirstTurn_NoLiveSession_NoAnswerNotDeliveredToast(t T) T {
    val seeded = sampleModel().Copy(
        PendingQuestion = Some(PendingQuestion(
            Member       = "Vesper",
            ToolUseId    = "toolu_x",
            QuestionText = "Continue?",
        )),
        Composer       = "extend fs",
        ComposerCursor = 9,
    )
    val (m, _) = Update(seeded, KeySubmit())
    val anyDeliverToast = m.Toasts.Items.Exists((tt) => strings.Contains(tt.Message, "answer not delivered"))
    return IsFalse(t, anyDeliverToast)
}

// 9. KEY REGRESSION: a pending question whose subprocess is gone must
// still produce a verbatim, audit-logged "you" line and clear the
// pending state — the user's text is never swallowed behind an
// "answer not delivered" toast and never silently lost. (Under the
// corrected design the answer is re-delivered via a fresh `--resume`
// turn rather than treated as an unrelated new prompt; the invariants
// asserted here — pending cleared, verbatim text, composer cleared,
// no scary toast — hold either way and are the regression net.)
func TestFirstTurn_PendingWithNoSession_AnswerLoggedNotSwallowed(t T) T {
    val seeded = sampleModel().Copy(
        // PendingQuestion set, but Sessions has NO entry for "Vesper".
        // This is the state the user landed in: stale pending from a
        // crashed / completed prior session.
        PendingQuestion = Some(PendingQuestion(
            Member       = "Vesper",
            ToolUseId    = "toolu_old",
            QuestionText = "scope?",
        )),
        Composer       = "update gala to 0.49.0",
        ComposerCursor = 20,
    )
    val (m, _) = Update(seeded, KeySubmit())
    // Pending is cleared (onAnswerPendingQuestion clears it on the
    // way through).
    val t1 = IsFalse(t, m.PendingQuestion.IsDefined())
    // The conversation logs the user's text verbatim — never
    // swallowed. Speaker="you", text matches the composer exactly
    // (no "you: " prefix from a stale code path).
    val youLines = m.Conversation.Filter((cl) => cl.Speaker == "you")
    val t2 = IsTrue(t1, youLines.Size() >= 1)
    val lastYou = youLines.Get(youLines.Size() - 1).Text
    val t3 = Eq(t2, lastYou, "update gala to 0.49.0")
    // Composer is cleared, ready for the next message.
    val t4 = Eq(t3, m.Composer, "")
    // No "answer not delivered" toast — that's the user-visible
    // signal that the regression came back.
    val noDeliverToast = !m.Toasts.Items.Exists((tt) => strings.Contains(tt.Message, "answer not delivered"))
    return IsTrue(t4, noDeliverToast)
}

// 10. KEY REGRESSION (variant): defensively guard against
// PendingQuestion being set with an empty member name. The user's
// screenshot showed " is no longer running" — leading space from
// an empty `${pending.Member}` interpolation. Even if we never set
// it that way intentionally, a snapshot import / future refactor
// could land us in that state; the routing should ignore an
// invalid pending rather than swallow user input behind a
// confusing toast.
func TestFirstTurn_PendingWithEmptyMember_FallsThroughToNormalSubmit(t T) T {
    val seeded = sampleModel().Copy(
        PendingQuestion = Some(PendingQuestion(
            Member       = "",
            ToolUseId    = "toolu_z",
            QuestionText = "?",
        )),
        Composer       = "real prompt",
        ComposerCursor = 11,
    )
    val (m, _) = Update(seeded, KeySubmit())
    val t1 = IsFalse(t, m.PendingQuestion.IsDefined())
    val youLines = m.Conversation.Filter((cl) => cl.Speaker == "you")
    val t2 = IsTrue(t1, youLines.Size() >= 1)
    val lastYou = youLines.Get(youLines.Size() - 1).Text
    val t3 = Eq(t2, lastYou, "real prompt")
    // No empty-member toast.
    val noEmptyMemberToast = !m.Toasts.Items.Exists((tt) => strings.HasPrefix(tt.Message, " is no longer running"))
    return IsTrue(t3, noEmptyMemberToast)
}

// ----------------------------------------------------------------------------
// AskUserQuestion answer re-delivery — the "TL is confused" bug.
//
// Past sessions captured this exact failure: the lead asked an
// AskUserQuestion; the user answered ("switch to gala 0.49.1"); the
// answer was appended to the transcript but NEVER reached the model
// (no events.jsonl user_input, no tool_result consumed — the
// `claude --print` subprocess had already exited). The lead later
// resumed, saw its own unanswered question, and re-explained
// everything. These tests pin the corrected contract: an answer to a
// pending question is always re-delivered via a fresh `--resume`
// turn, always audit-logged, and only flagged Undelivered when it
// genuinely can't be routed.
// ----------------------------------------------------------------------------

// A pending question for a REAL team member: composer Enter clears the
// pending state, appends a verbatim "you" line that is NOT flagged
// Undelivered (we attempted re-delivery), and does NOT mutate the FSM
// (answering a question must not promote the turn out of its state —
// e.g. an Approval that was up stays up). Whether the underlying spawn
// succeeds depends on the test environment; the model-level invariants
// asserted here hold regardless.
func TestAnswerPending_RealMember_ClearsPendingNoFsmJump(t T) T {
    val seeded = sampleModel().Copy(
        State           = Approval(SummaryBody = "draft"),
        PendingQuestion = Some(PendingQuestion(
            Member       = "Felix",
            ToolUseId    = "toolu_a",
            QuestionText = "Which gala version?",
        )),
        Composer       = "use gala 0.49.1",
        ComposerCursor = 15,
    )
    val (m, _) = Update(seeded, KeySubmit())
    val t1 = IsFalse(t, m.PendingQuestion.IsDefined())
    val t2 = Eq(t1, m.Composer, "")
    // FSM untouched — answering is not a top-level new turn.
    val t3 = m.State match {
        case Approval(_) => IsTrue(t2, true)
        case _           => IsTrue(t2, false)
    }
    val youLines = m.Conversation.Filter((cl) => cl.Speaker == "you")
    val t4 = IsTrue(t3, youLines.Size() >= 1)
    return Eq(t4, youLines.Get(youLines.Size() - 1).Text, "use gala 0.49.1")
}

// When the pending member is not on the team roster, the answer can't
// be routed anywhere — the "you" line MUST be flagged Undelivered so
// the view renders it bold-red instead of letting it vanish. This is
// the highlight that makes the whole bug class visible.
func TestAnswerPending_UnroutableMember_FlagsLineUndelivered(t T) T {
    val seeded = sampleModel().Copy(
        PendingQuestion = Some(PendingQuestion(
            Member       = "Ghost",
            ToolUseId    = "toolu_g",
            QuestionText = "scope?",
        )),
        Composer       = "do the thing",
        ComposerCursor = 12,
    )
    val (m, _) = Update(seeded, KeySubmit())
    val youLines = m.Conversation.Filter((cl) => cl.Speaker == "you")
    val t1 = IsTrue(t, youLines.Size() >= 1)
    val last = youLines.Get(youLines.Size() - 1)
    val t2 = Eq(t1, last.Text, "do the thing")
    // The decisive assertion: the dropped message is flagged, not lost.
    return IsTrue(t2, last.Undelivered)
}

// Legacy snapshots predate the Undelivered field; the codec fills the
// missing value with the bool zero (false), which MUST read as
// "delivered" so old transcripts don't all light up red on reload.
func TestConversationLine_DefaultUndeliveredIsFalse(t T) T {
    val cl = session.ConversationLine(Speaker = "you", Text = "hi")
    return IsFalse(t, cl.Undelivered)
}

// ----------------------------------------------------------------------------
// Turn-end-with-pending-question deadlock.
//
// Past sessions captured a total freeze: the lead called
// AskUserQuestion (the harness denies it — the orchestrator owns the
// dialog), the model got the denial, said "the question was declined,
// I'll make the call", emitted `@dispatch` + `@end`, and the turn
// completed. But the old code only closed claude's stdin on turn-end
// when NO question was pending — so stdin stayed open, claude
// (stream-json) idled forever, no EOF reached onSessionFailed, the
// `@dispatch` sat unparsed in the TurnBuffer, and the FSM froze in
// TLThinking. The user saw nothing for ~1h.
//
// Contract now: a turn that ends with a pending question still
// finalizes (onSessionFailed parses the buffer → FSM advances) AND
// the pending question survives so the user can still answer it
// (delivered via a fresh `--resume` turn; Esc dismisses).
// ----------------------------------------------------------------------------

// The deadlock repro: FSM TLThinking, a pending question for the
// lead, and a `@dispatch` sitting in the TurnBuffer. The clean EOF
// that follows the (now unconditional) stdin close must finalize the
// turn — FSM advances to Delegating — and must NOT drop the pending.
func TestTurnEnd_WithPendingQuestion_FinalizesAndKeepsAnswerable(t T) T {
    val seeded = sampleModel().Copy(
        State           = TLThinking(),
        TurnBuffer      = "@dispatch(Felix)\nbuild the thing\n@end",
        PendingQuestion = Some(PendingQuestion(
            Member       = "Iris",
            ToolUseId    = "toolu_q",
            QuestionText = "which approach?",
        )),
    )
    val (m, _) = Update(seeded, SessionFailed(Member = "Iris", ErrText = "EOF"))
    // Turn finalized — the @dispatch was parsed, FSM is no longer
    // frozen in TLThinking.
    val t1 = m.State match {
        case Delegating(p) => IsTrue(t, p.Contains("Felix"))
        case _             => IsTrue(t, false)
    }
    // The pending question survived turn-end — the user can still
    // answer it instead of it vanishing the instant the turn closed.
    return m.PendingQuestion match {
        case Some(p) => Eq(t1, p.ToolUseId, "toolu_q")
        case None()  => IsTrue(t1, false)
    }
}

// Variant: the lead asked a question and ended the turn WITHOUT any
// directive (it was genuinely waiting on the user). The turn must
// still finalize — FSM lands in Idle, not frozen in TLThinking — and
// the question stays answerable.
func TestTurnEnd_PendingNoDirectives_LandsIdleNotFrozen(t T) T {
    val seeded = sampleModel().Copy(
        State           = TLThinking(),
        TurnBuffer      = "I need a decision before I can proceed.",
        PendingQuestion = Some(PendingQuestion(
            Member       = "Iris",
            ToolUseId    = "toolu_w",
            QuestionText = "scope?",
        )),
    )
    val (m, _) = Update(seeded, SessionFailed(Member = "Iris", ErrText = "EOF"))
    val t1 = m.State match {
        case Idle() => IsTrue(t, true)
        case _      => IsTrue(t, false)
    }
    return m.PendingQuestion match {
        case Some(_) => IsTrue(t1, true)
        case None()  => IsTrue(t1, false)
    }
}

// ----------------------------------------------------------------------------
// Orchestrator dispatch bugs uncovered in the 0.49.0-migration audit log
// (gala_team .gala_team/sessions/debug/events.jsonl, 04:55–05:37 UTC):
//   - Duplicate MemberDone fired twice for Lyra within 54 ms.
//   - Stuck-nudge cascade re-dispatched both engineers 5× even though
//     only one was stuck; the healthy one lost in-flight work each cycle.
//   - Freshly-respawned member marked stuck within 50 ms because
//     LastChunkAt still held the prior subprocess's stale timestamp.
//   - 148 tool_use chunks produced zero conversation entries —
//     transcripts looked frozen while Kael was editing at full speed.
//
// Each test below pins one of those invariants. Names start with
// `TestDispatchBugs_` so future readers can grep the audit narrative.
// ----------------------------------------------------------------------------

// 1. Duplicate MemberDone suppression.
//
// When `@done` has already been parsed for a member (MemberDoneBodies
// has an entry), the subsequent EOF-driven MemberDone in
// onSessionFailed must NOT fire. The FSM tolerates the no-op self
// loop but it churns transition events; the audit log showed two
// MemberDone transitions for Lyra 54ms apart in the Delegating→
// Delegating loop. After the fix only one transition is emitted.
func TestDispatchBugs_NoDuplicateMemberDoneOnEofAfterAtDone(t T) T {
    val seed = sampleModel().Copy(
        State            = Delegating(Pending = arrayToHashSet(ArrayOf("Felix"))),
        MemberDoneBodies = EmptyHashMap[string, string]().Put("Felix", "shipped"),
    )
    val before = pendingSizeOf(seed.State)
    val (m, _) = Update(seed, SessionFailed(Member = "Felix", ErrText = "EOF"))
    val after = pendingSizeOf(m.State)
    // The pending set must be UNCHANGED — afterMemberDone would have
    // removed "Felix" from Pending (Felix already done via @done).
    // The post-fix path early-returns before transitionLogged, so
    // Pending stays at its prior size.
    return Eq(t, after, before)
}

// pendingSizeOf returns the size of the Delegating pending set, or
// -1 when the state isn't Delegating. Test helper for the duplicate-
// MemberDone assertion.
func pendingSizeOf(s AppState) int = s match {
    case Delegating(pending) => pending.Size()
    case _                   => -1
}

func arrayToHashSet(xs Array[string]) HashSet[string] =
    xs.FoldLeft(EmptyHashSet[string](), (acc, s) => acc.Add(s))

// 2. Stuck-nudge prompt scoping.
//
// The aggregated prompt MUST tell the TL not to re-dispatch healthy
// teammates. Audit log: TL re-dispatched Lyra five times even though
// only Kael was stuck — the prior wording invited "reassign to other
// members" which the model interpreted as "respawn the whole team."
func TestDispatchBugs_StuckPrompt_ScopedToStuckMembersOnly(t T) T {
    val now = time_utils.Now()
    val m = sampleModel()
    val singleStuck = buildStuckNudgePrompt(m, "Kael", now)
    val t1 = IsTrue(t, strings.Contains(singleStuck, "DO NOT re-dispatch other team members"))
    val multiStuck = buildAggregatedStuckPrompt(m, ArrayOf("Kael", "Mira"), now)
    val t2 = IsTrue(t1, strings.Contains(multiStuck, "DO NOT re-dispatch other team members"))
    // Sanity: the aggregate prompt lists exactly the stuck names, not
    // every team member.
    val t3 = IsTrue(t2, strings.Contains(multiStuck, "@dispatch(Kael, Mira)"))
    return IsFalse(t3, strings.Contains(multiStuck, "@dispatch(Felix"))
}

// 3. LastChunkAt grace period on respawn.
//
// ensureSession must reset LastChunkAt[name] = now when it spawns a
// fresh subprocess so the heartbeat's "stuck since LastChunkAt"
// math measures against the NEW process, not the old one's stale
// last-chunk time. Without this, the new subprocess could be marked
// stuck 50 ms after spawn (audit log 05:18:38 → 05:18:38.199).
func TestDispatchBugs_EnsureSession_ResetsLastChunkAtToNow(t T) T {
    val proj = sampleProject()
    val team = sampleTeam()
    val member = team.Members.Get(0)  // first member — sampleTeam's lead "Iris"
    // Seed a model with LastChunkAt pointed at the deep past (stale
    // from a prior subprocess that crashed an hour ago).
    val pastInstant = time_utils.UnixEpoch()
    val seed = InitialModel(proj, team, DefaultWorkflow(), DefaultPolicy()).Copy(
        LastChunkAt = EmptyHashMap[string, time_utils.Instant]().Put(member.Name, pastInstant),
    )
    return ensureSession(seed, member) match {
        case Left(_)   => IsTrue(t, false)  // spawn failed — test setup issue
        case Right(m1) => {
            // The new LastChunkAt MUST be more recent than the
            // stale past instant. Any post-epoch timestamp counts;
            // we don't pin to exact-now because the production
            // path uses time_utils.Now() which moves.
            val updated = m1.LastChunkAt.Get(member.Name).GetOrElse(pastInstant)
            return IsTrue(t, updated.UnixNanos() > pastInstant.UnixNanos())
        }
    }
}

// 4. Tool-use activity flag.
//
// An assistant chunk containing a tool_use part but no visible text
// MUST: (a) flip the member's status to StWorking so the sidebar
// timer keeps ticking, (b) update LastChunkAt so the heartbeat
// doesn't escalate, (c) NOT append a conversation line — the
// "using <Tool>" rows we tried first were noise.
func TestDispatchBugs_ToolUseChunk_FlipsStatusNoTranscript(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"id\":\"t1\",\"name\":\"Edit\",\"input\":{\"file_path\":\"a.go\"}}],\"usage\":{\"input_tokens\":1,\"output_tokens\":1,\"cache_read_input_tokens\":0}}}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Felix", Line = line))
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Felix")
    val t1 = Eq(t, entries.Size(), 0)  // no chat pollution
    // Status flipped to working — heartbeat sees activity.
    val st = m.Statuses.Get("Felix").GetOrElse(StIdle())
    val t2 = st match {
        case StWorking() => IsTrue(t1, true)
        case _           => IsTrue(t1, false)
    }
    // LastChunkAt advanced past UnixEpoch (heartbeat will see this
    // member as alive on the next tick).
    val lca = m.LastChunkAt.Get("Felix").GetOrElse(time_utils.UnixEpoch())
    return IsTrue(t2, lca.UnixNanos() > int64(0))
}

// 100 silent tool_use chunks must NOT produce 100 transcript lines.
// With the new flag-not-Visible model, the chunk is dropped at the
// conversation-append step, so the transcript stays empty regardless
// of how many tool calls fire. Previously this was guarded by
// isDuplicateOfLastConvoLine; now it's guarded by IsToolActivity
// upstream of the append.
func TestDispatchBugs_ManyToolUseChunks_NoTranscriptSpam(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"tool_use\",\"id\":\"t2\",\"name\":\"Edit\",\"input\":{\"file_path\":\"b.go\"}}],\"usage\":{\"input_tokens\":1,\"output_tokens\":1,\"cache_read_input_tokens\":0}}}"
    val (m1, _) = Update(seed, ChunkArrived(Member = "Felix", Line = line))
    val (m2, _) = Update(m1,   ChunkArrived(Member = "Felix", Line = line))
    val (m3, _) = Update(m2,   ChunkArrived(Member = "Felix", Line = line))
    val (m4, _) = Update(m3,   ChunkArrived(Member = "Felix", Line = line))
    val (m5, _) = Update(m4,   ChunkArrived(Member = "Felix", Line = line))
    return Eq(t, m5.Conversation.Filter((cl) => cl.Speaker == "Felix").Size(), 0)
}

// Visible TEXT in a chunk still appears — the activity flag is only
// raised when the chunk has NO text AND non-AskUserQuestion tool_use
// parts. Mixed chunks render the text normally.
func TestDispatchBugs_ToolUseWithText_RendersTextOnly(t T) T {
    val seed = sampleModel()
    val line = "{\"type\":\"assistant\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"Plan: edit a.go\"},{\"type\":\"tool_use\",\"id\":\"t3\",\"name\":\"Edit\",\"input\":{\"file_path\":\"a.go\"}}],\"usage\":{\"input_tokens\":1,\"output_tokens\":1,\"cache_read_input_tokens\":0}}}"
    val (m, _) = Update(seed, ChunkArrived(Member = "Felix", Line = line))
    val entries = m.Conversation.Filter((cl) => cl.Speaker == "Felix")
    val t1 = Eq(t, entries.Size(), 1)
    return Eq(t1, entries.Get(0).Text, "Plan: edit a.go")
}

// ----------------------------------------------------------------------------
// TL livelock regression — `TurnBuffer` carrying stale `@dispatch`
// blocks from a prior turn caused the TL to re-fire the same dispatches
// on every nudge / relay. Audit log of the 0.49.0-migration session
// showed 250 dispatches for Kael over 80 minutes, every body
// byte-identical to the first turn's.
//
// Fix lives in spawnTLNudge: it clears TurnBuffer + ConsultsFired +
// closes any prior TL subprocess before spawning. Every TL re-spawn
// path (spawnTLRelay, stuck nudge, blocked nudge, help nudge,
// malformed-dispatch nudge, …) flows through spawnTLNudge, so
// fixing it there is structural.
// ----------------------------------------------------------------------------

func TestTlLivelock_SpawnTLNudge_ClearsStaleTurnBuffer(t T) T {
    // Seed: the TL just ran its prior turn and left a populated
    // TurnBuffer + a non-zero ConsultsFired. A nudge fires now (e.g.
    // because a member went stuck). The new TL session MUST start
    // with an empty buffer so the stale @dispatch in the old buffer
    // doesn't get re-parsed and re-fired.
    val staleTurnBuffer = "@dispatch(Felix)\nupgrade gala from 0.44.0 to 0.49.0\n@end"
    val seeded = sampleModel().Copy(
        TurnBuffer    = staleTurnBuffer,
        ConsultsFired = 7,
    )
    val (m, _) = spawnTLNudge(seeded, "stuck-felix", "System: Felix is stuck — decide")
    val t1 = Eq(t, m.TurnBuffer, "")
    return Eq(t1, m.ConsultsFired, 0)
}

// Belt-and-suspenders: spawnTLRelay funnels through spawnTLNudge, so
// the relay path also gets a clean TurnBuffer. Direct test pins it
// in case a future refactor takes a different route.
func TestTlLivelock_SpawnTLRelay_ClearsStaleTurnBuffer(t T) T {
    val seeded = sampleModel().Copy(
        TurnBuffer    = "@dispatch(Felix)\nold work\n@end",
        ConsultsFired = 3,
    )
    val (m, _) = spawnTLRelay(seeded)
    val t1 = Eq(t, m.TurnBuffer, "")
    return Eq(t1, m.ConsultsFired, 0)
}

// ----------------------------------------------------------------------------
// Spawn-failure + stderr instrumentation regression tests.
//
// `ensureSession` failures used to land only in `m.LastError` (toast-
// only); the silent QA-spawn-zero-output bug in the 0.49.0-migration
// audit took 10 hours to surface and had no durable trace explaining
// why. `LogSpawnFailure` and `LogStderr` close that visibility gap.
// These tests pin the event shapes so a future refactor doesn't
// silently drop the new fields from `events.jsonl`.
//
// `DebugEnabled()` reads `GALA_TEAM_DEBUG`; the helpers are no-ops
// when that env var isn't set. Tests flip it on for the duration,
// point SetDebugRepo at a temp dir, and read back the resulting
// events.jsonl. Sequential ordering matters — we share a single
// per-process debug repo, so each test mkTempDir's a fresh dir AND
// re-sets the repo to keep events isolated.
// ----------------------------------------------------------------------------

func setupDebugRepo(label string) string {
    val _ = os.Setenv("GALA_TEAM_DEBUG", "1")
    val dir, mkErr = os.MkdirTemp("", "gala_team_debug_" + label)
    if mkErr != nil { panic(s"MkdirTemp: ${mkErr.Error()}") }
    SetDebugRepo(dir)
    // Close any cached events.jsonl handle left over from a prior
    // test in the same binary — debugFile is a package-level singleton
    // and a stale handle from test A would silently swallow our
    // writes (the file was deleted from disk on test A's cleanup,
    // but the FD lives on). ResetDebugDir wipes the (still-empty)
    // debug subdir of the new repo and drops the handle so the next
    // AppendDebugEvent re-opens cleanly.
    val _ = ResetDebugDir()
    return dir
}

func eventsFilePath(repo string) string =
    filepath.Join(repo, ".gala_team", "sessions", "debug", "events.jsonl")

func readEventsFile(path string) string {
    val b, err = os.ReadFile(path)
    if err != nil { return "" }
    return string(b)
}

func TestSpawnFailureLog_EmitsEvent(t T) T {
    val dir = setupDebugRepo("spawn_fail")
    defer os.RemoveAll(dir)
    LogSpawnFailure("Sable", "qa_auto", "spawn Sable: workspace failed")
    val contents = readEventsFile(eventsFilePath(dir))
    val t1 = IsTrue(t, strings.Contains(contents, "\"kind\":\"spawn_failure\""))
    val t2 = IsTrue(t1, strings.Contains(contents, "\"member\":\"Sable\""))
    val t3 = IsTrue(t2, strings.Contains(contents, "qa_auto"))
    return IsTrue(t3, strings.Contains(contents, "workspace failed"))
}

func TestStderrLog_EmitsEventWithTextAndLength(t T) T {
    val dir = setupDebugRepo("stderr")
    defer os.RemoveAll(dir)
    LogStderr("Sable", "usage_limit_reached")
    val contents = readEventsFile(eventsFilePath(dir))
    val t1 = IsTrue(t, strings.Contains(contents, "\"kind\":\"stderr\""))
    val t2 = IsTrue(t1, strings.Contains(contents, "\"member\":\"Sable\""))
    return IsTrue(t2, strings.Contains(contents, "usage_limit_reached"))
}

func TestStderrLog_DropsEmptyLine(t T) T {
    val dir = setupDebugRepo("stderr_empty")
    defer os.RemoveAll(dir)
    LogStderr("Sable", "")
    val contents = readEventsFile(eventsFilePath(dir))
    return IsFalse(t, strings.Contains(contents, "\"kind\":\"stderr\""))
}

// End-to-end: onStderr should call LogStderr for non-empty lines.
// Verifies the wiring inside the chunk pump matches the durable
// log so a real claude stderr (rate limit message) survives in
// events.jsonl even after the toast TTL expires.
func TestOnStderr_FiresLogStderrEvent(t T) T {
    val dir = setupDebugRepo("on_stderr")
    defer os.RemoveAll(dir)
    val m = sampleModel()
    val (_, _) = Update(m, StderrArrived(Member = "Sable", Line = "Error: rate limit reached"))
    val contents = readEventsFile(eventsFilePath(dir))
    return IsTrue(t, strings.Contains(contents, "rate limit reached"))
}

// ---------------------------------------------------------------------------
// UI-thread offload regression tests.
//
// Past audits caught a session that froze indefinitely after a
// Delegating→QAGate FSM transition because buildQAReviewPrompt's
// synchronous git invocations blocked the gala-tui event loop.
// Animation stopped, keys went unanswered, no further events landed
// in events.jsonl. The TUI looked identical to a crash.
//
// Audits later identified the same pattern in onPasteClipboard
// (Ctrl+V → blocking powershell.exe shell-out), onMemberDone
// (engineer @finished → blocking hasUncommittedWork), and
// approveAndKickHooks / TL @summary (blocking checkPrReady).
//
// These tests pin the off-thread contract: the entry-point handler
// must return a Cmd that runs the IO in a worker Future, so Update
// itself stays non-blocking. Each test asserts:
//   1. the handler returns immediately with no model mutation that
//      depends on the IO result (state is held until the result
//      message lands), AND
//   2. the result-message handler applies the changes correctly.
// ---------------------------------------------------------------------------

// spawnQAReview's UI-thread half: when the FSM lands in QAGate and
// the team has a QA member, the entry returns the model UNCHANGED.
// The reviewBody / FoldLeft over QA members runs after QAPromptReady
// lands (and that handler is the one that flips Sable to StWorking).
func TestSpawnQAReview_ReturnsImmediatelyForQATeam(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    val sable = Member(
        Name = "Sable", Role = QA(),
        Personality = "rigorous",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val team = sampleTeam().Copy(Members = sampleTeam().Members.Append(sable))
    val seed = InitialModel(proj, team, DefaultWorkflow(), DefaultPolicy()).Copy(
        State    = QAGate(Pending = EmptyHashSet[string]()),
        Statuses = EmptyHashMap[string, Status]().Put("Felix", StIdle()),
    )
    val (m, _) = spawnQAReview(seed)
    // Status map untouched — applyQAPromptReady is the one that
    // upserts Sable to StWorking once the Future resolves.
    val sableStatus = m.Statuses.Get("Sable")
    return IsFalse(t, sableStatus.IsDefined())
}

// applyQAPromptReady is the back-channel of the QA fan-out. Fed a
// QAPromptReady result with the FSM in QAGate, it must upsert the
// QA member to StWorking (the visible UI signal that Sable started
// the review).
func TestApplyQAPromptReady_FlipsQAToWorking(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    val sable = Member(
        Name = "Sable", Role = QA(),
        Personality = "rigorous",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val team = sampleTeam().Copy(Members = sampleTeam().Members.Append(sable))
    val seed = InitialModel(proj, team, DefaultWorkflow(), DefaultPolicy()).Copy(
        State    = QAGate(Pending = EmptyHashSet[string]()),
        Statuses = EmptyHashMap[string, Status]().Put("Felix", StIdle()),
    )
    val (m, _) = applyQAPromptReady(seed, "synthetic review prompt")
    return m.Statuses.Get("Sable") match {
        case Some(s) => s match {
            case StWorking() => IsTrue(t, true)
            case _           => IsTrue(t, false)
        }
        case None() => IsTrue(t, false)
    }
}

// applyQAPromptReady should drop the result silently if the FSM has
// moved out of QAGate by the time the Future resolves (e.g. the user
// pressed Esc, a recovery flow ran, etc.). Without the guard, late
// results would re-dispatch the QA member after the model already
// transitioned away.
func TestApplyQAPromptReady_DroppedWhenNotInQAGate(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    val sable = Member(
        Name = "Sable", Role = QA(),
        Personality = "rigorous",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val team = sampleTeam().Copy(Members = sampleTeam().Members.Append(sable))
    val seed = InitialModel(proj, team, DefaultWorkflow(), DefaultPolicy()).Copy(
        State = Idle(),  // moved on — no longer waiting on QA
    )
    val (m, _) = applyQAPromptReady(seed, "synthetic review prompt")
    return IsFalse(t, m.Statuses.Get("Sable").IsDefined())
}

// onPasteClipboard's UI-thread half: Ctrl+V returns immediately
// with the model unchanged. The actual insert / toast / LastError
// updates fire when ClipboardPasted / ClipboardFailed lands.
func TestOnPasteClipboard_ReturnsImmediatelyUnchanged(t T) T {
    val seed = sampleModel().Copy(Composer = "abc", ComposerCursor = 3)
    val (m, _) = onPasteClipboard(seed)
    val t1 = Eq(t, m.Composer, "abc")
    return Eq(t1, m.ComposerCursor, 3)
}

// ClipboardPasted handler inserts the pasted text at cursor and
// pushes a toast. Mirrors the previous inline path's behaviour.
func TestOnClipboardPasted_InsertsAtCursorAndToasts(t T) T {
    val seed = sampleModel().Copy(Composer = "hi", ComposerCursor = 2)
    val (m, _) = onClipboardPasted(seed, "X\n")  // trailing \n stripped
    val t1 = Eq(t, m.Composer, "hiX")
    return Eq(t1, m.ComposerCursor, 3)
}

// ClipboardFailed surfaces the read error to LastError so the user
// sees why their paste didn't take.
func TestOnClipboardFailed_SetsLastError(t T) T {
    val (m, _) = onClipboardFailed(sampleModel(), "xclip not installed")
    return m.LastError match {
        case Some(s) => IsTrue(t, strings.Contains(s, "xclip not installed"))
        case None()  => IsTrue(t, false)
    }
}

// onMemberDone's UI-thread half for engineers: the @finished
// handler returns the model unchanged (no toast, no closeLiveSession,
// no MemberDoneBodies entry) until the uncommitted-work probe lands.
// Non-engineer roles bypass the probe entirely and finalise inline.
func TestOnMemberDone_Engineer_DefersUntilUncommittedCheckResult(t T) T {
    val proj = sampleProject()
    val seed = InitialModel(proj, sampleTeam(), DefaultWorkflow(), DefaultPolicy()).Copy(
        Statuses = EmptyHashMap[string, Status]().Put("Felix", StWorking()),
    )
    val (m, _) = onMemberDone(seed, "Felix", "shipped it")
    // MemberDoneBodies must NOT have a Felix entry yet — it lands
    // when UncommittedCheckResult fires, not on the initial @finished.
    val noBodyYet = !m.MemberDoneBodies.Get("Felix").IsDefined()
    // Status must NOT have flipped to StIdle yet either.
    val stillWorking = m.Statuses.Get("Felix") match {
        case Some(s) => s match {
            case StWorking() => true
            case _           => false
        }
        case None() => false
    }
    return IsTrue(t, noBodyYet && stillWorking)
}

// UncommittedCheckResult with dirty=false (clean worktree) finalises
// the @finished — adds the body to MemberDoneBodies and flips status
// to StIdle. Mirrors the inline path's behaviour.
func TestOnUncommittedCheckResult_CleanFinalises(t T) T {
    val seed = sampleModel().Copy(
        Statuses = EmptyHashMap[string, Status]().Put("Felix", StWorking()),
    )
    val (m, _) = Update(seed, UncommittedCheckResult(Member = "Felix", Body = "shipped it", Dirty = false))
    val bodyLogged = m.MemberDoneBodies.Get("Felix") match {
        case Some(b) => b == "shipped it"
        case None()  => false
    }
    val idleNow = m.Statuses.Get("Felix") match {
        case Some(s) => s match {
            case StIdle() => true
            case _        => false
        }
        case None() => false
    }
    return IsTrue(t, bodyLogged && idleNow)
}

// workflowWithPostPrompt is the default workflow with a non-empty
// post-engineer prompt — the only knob the feature exposes.
func workflowWithPostPrompt(prompt string) Workflow = DefaultWorkflow().Copy(
    PostEngineerPrompt = prompt,
)

// Regression: empty post-engineer prompt (the default) must not change
// behaviour at all. A finished + clean engineer drains immediately —
// body recorded, status idle, NOTHING added to PostPromptSent, no
// follow-up command. This is the "zero behavioural change when unset"
// guarantee.
func TestPostPrompt_EmptyConfig_DrainsImmediately(t T) T {
    val seed = sampleModel().Copy(
        Statuses = EmptyHashMap[string, Status]().Put("Felix", StWorking()),
    )
    val (m, _) = onUncommittedCheckResult(seed, "Felix", "shipped it", false)
    val bodyLogged = m.MemberDoneBodies.Get("Felix") match {
        case Some(b) => b == "shipped it"
        case None()  => false
    }
    val idleNow = m.Statuses.Get("Felix") match {
        case Some(s) => s match {
            case StIdle() => true
            case _        => false
        }
        case None() => false
    }
    val noPostPrompt = !m.PostPromptSent.Contains("Felix")
    return IsTrue(t, bodyLogged && idleNow && noPostPrompt)
}

// The pure one-shot guard. With a prompt configured and the member
// NOT yet in PostPromptSent the guard is due (the re-prompt should
// fire); once the member IS in PostPromptSent it is no longer due
// (the second finish must fall through to drain). Exactly-once per
// engineer per dispatch cycle.
func TestPostPrompt_GuardIsOneShot(t T) T {
    val base = sampleModel().Copy(Workflow = workflowWithPostPrompt("/simplify"))
    val firstPass = postPromptDue(base, "Felix")
    val afterSent = base.Copy(PostPromptSent = base.PostPromptSent.Add("Felix"))
    val secondPass = postPromptDue(afterSent, "Felix")
    return IsTrue(t, firstPass && !secondPass)
}

// With an empty prompt the guard is never due regardless of the
// PostPromptSent set — the unset config short-circuits before the
// membership check.
func TestPostPrompt_GuardNeverDueWhenUnset(t T) T {
    val base = sampleModel()  // DefaultWorkflow → PostEngineerPrompt == ""
    val due = postPromptDue(base, "Felix")
    return IsFalse(t, due)
}

// Parallel engineers: each is gated independently. With two finished
// engineers and only one (Felix) already in PostPromptSent, Felix is
// done (falls through to drain) while Mira is still due (her own
// one-shot round hasn't run). One engineer's post-prompt state never
// suppresses another's.
func TestPostPrompt_ParallelEngineersIndependent(t T) T {
    val mira = Member(
        Name = "Mira", Role = Engineer(),
        Personality = "sharp",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val team = sampleTeam().Copy(Members = sampleTeam().Members.Append(mira))
    val base = InitialModel(sampleProject(), team, workflowWithPostPrompt("/simplify"), DefaultPolicy()).Copy(
        PostPromptSent = arrayToHashSet(ArrayOf("Felix")),
    )
    val felixDone  = !postPromptDue(base, "Felix")  // already had its round
    val miraStillDue = postPromptDue(base, "Mira")   // independent, still due
    return IsTrue(t, felixDone && miraStillDue)
}

// The SECOND finish (member already in PostPromptSent) falls through
// to finaliseMemberDone exactly as the no-config path does: body
// recorded, status idle. This is what lets the FSM drain to QAGate —
// only AFTER the post-prompt round, never before. The FSM is seeded in
// Delegating(Pending={Felix}); the finalise here does not itself fire
// the MemberDone transition (that rides the session-close EOF), so the
// post-prompt round cannot drain Felix early — the pending set is
// still {Felix} immediately after the re-prompt would have been
// skipped on the second pass.
func TestPostPrompt_SecondFinishFinalises(t T) T {
    val seed = sampleModel().Copy(
        Workflow       = workflowWithPostPrompt("/simplify"),
        PostPromptSent = arrayToHashSet(ArrayOf("Felix")),
        State          = Delegating(Pending = arrayToHashSet(ArrayOf("Felix"))),
        Statuses       = EmptyHashMap[string, Status]().Put("Felix", StWorking()),
    )
    val (m, _) = onUncommittedCheckResult(seed, "Felix", "simplified it", false)
    val bodyLogged = m.MemberDoneBodies.Get("Felix") match {
        case Some(b) => b == "simplified it"
        case None()  => false
    }
    val idleNow = m.Statuses.Get("Felix") match {
        case Some(s) => s match {
            case StIdle() => true
            case _        => false
        }
        case None() => false
    }
    return IsTrue(t, bodyLogged && idleNow)
}

// The post-prompt path does NOT touch the FSM. Before the re-prompt is
// sent (first finish, prompt configured, member not yet marked), the
// member must still be in the Delegating pending set — MemberDone has
// not fired, so QAGate cannot be reached until the follow-up turn
// finalises. We assert the guard is due and the seeded pending set is
// untouched by the decision itself (the spawn side-effect is exercised
// by the same-session --resume precedent and is not unit-driven here
// to avoid launching a real subprocess).
func TestPostPrompt_FirstFinishKeepsMemberPending(t T) T {
    val seed = sampleModel().Copy(
        Workflow = workflowWithPostPrompt("/simplify"),
        State    = Delegating(Pending = arrayToHashSet(ArrayOf("Felix"))),
    )
    val due = postPromptDue(seed, "Felix")
    val stillPending = seed.State match {
        case Delegating(pending) => pending.Contains("Felix")
        case _                   => false
    }
    return IsTrue(t, due && stillPending)
}

// Dirty-before-post-prompt ordering: the post-prompt guard is only
// consulted on the CLEAN branch. A dirty result with the prompt
// configured and the member not yet marked must still leave the
// member UNMARKED — the dirty path returns before postPromptDue is
// ever reached, so the commit gate is never bypassed by the feature.
// (The dirty branch itself re-spawns a real subprocess, so we assert
// the guard-bypass invariant via the pure predicate rather than
// driving the spawn.)
func TestPostPrompt_DirtyNeverMarksMember(t T) T {
    val seed = sampleModel().Copy(
        Workflow = workflowWithPostPrompt("/simplify"),
    )
    // Pre-condition the test cares about: on a dirty result the guard
    // would have been due, yet the dirty branch returns first, so the
    // member is never added to PostPromptSent by the dirty path.
    val wouldBeDue = postPromptDue(seed, "Felix")
    val notMarked = !seed.PostPromptSent.Contains("Felix")
    return IsTrue(t, wouldBeDue && notMarked)
}

// approveAndKickHooks's UI-thread half: KeyApprove inside Approval
// returns the model UNCHANGED (no transition, no conversation log
// entry, no toast). The transition fires when ApprovalReadyResult
// lands. Crucial guarantee for the freeze fix — past audits caught a
// 30-minute Approval freeze because Ctrl+A → checkPrReady wedged the
// UI thread; now there's nothing on the hot path that can block.
func TestApprove_ReturnsImmediatelyWithoutTransition(t T) T {
    val seed = sampleModel().Copy(State = Approval(SummaryBody = "ship it"))
    val (m, _) = Update(seed, KeyApprove())
    val stillApproval = m.State match {
        case Approval(_) => true
        case _           => false
    }
    val noLogYet = m.Conversation.IsEmpty()
    return IsTrue(t, stillApproval && noLogYet)
}

// ApprovalReadyResult with Some(reason) lands the failure path:
// modal dismissed (FSM exits Approval via ApprovalRejected), error
// toast, LastError set. Without the dismissal, the past audit's
// 30-minute Approval-freeze regression would slip back in.
func TestOnApprovalReadyResult_BlockedDismissesModal(t T) T {
    val seed = sampleModel().Copy(State = Approval(SummaryBody = "ship it"))
    val (m, _) = Update(seed, ApprovalReadyResult(
        Body   = "ship it",
        Reason = Some("no commits ahead of main"),
    ))
    val notApproval = m.State match {
        case Approval(_) => false
        case _           => true
    }
    val hasError = m.LastError match {
        case Some(s) => strings.Contains(s, "no commits ahead of main")
        case None()  => false
    }
    return IsTrue(t, notApproval && hasError)
}

// onSessionFailed for the lead's @summary path: model must hold the
// parsed directives on PendingSummaryDirs and NOT transition the FSM
// until SummaryReadyResult lands. Confirms the freeze-fix split that
// keeps checkPrReady's git rev-list off the UI thread.
func TestTLSummary_DefersTransitionUntilSummaryReadyResult(t T) T {
    val proj = emptyLeadBranchProject()
    defer os.RemoveAll(proj.Repo)
    runGitInTmp(proj.Repo, ArrayOf("checkout", "-q", "-b", "gala_team/demo/lead"))
    runGitInTmp(proj.Repo, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                                   "commit", "--allow-empty", "-q", "-m", "lead work"))
    val goodBody = "## What\n- shipped the thing\n\n## Why\nthe user asked for it\n\n## Follow-ups\nnone"
    val seed = InitialModel(proj, sampleTeam(), DefaultWorkflow(), DefaultPolicy()).Copy(
        State      = TLThinking(),
        TurnBuffer = "@summary\n" + goodBody + "\n@end",
    )
    val (m, _) = Update(seed, SessionFailed(Member = "Iris", ErrText = "EOF"))
    val held = m.PendingSummaryDirs.IsDefined()
    // FSM must not have transitioned to Approval yet — the probe
    // hasn't resolved.
    val notApprovalYet = m.State match {
        case Approval(_) => false
        case _           => true
    }
    return IsTrue(t, held && notApprovalYet)
}

// SummaryReadyResult landing with PendingSummaryDirs=None must be a
// no-op. Late results (e.g. the user pressed Esc / recovery flow
// reset the model) MUST NOT side-effect — without the guard, a
// stray late SummaryReadyResult could nudge the TL out of an
// unrelated state.
func TestOnSummaryReadyResult_DroppedWhenNothingPending(t T) T {
    val seed = sampleModel()
    val (m, _) = Update(seed, SummaryReadyResult(Member = "Iris", Reason = None[string]()))
    val sameState = stateTag(m.State) == stateTag(seed.State)
    val sameConvo = m.Conversation.Size() == seed.Conversation.Size()
    return IsTrue(t, sameState && sameConvo)
}

// gitFilesList must prefix `--no-optional-locks` to defang stat-cache
// lock contention. We can't observe the subprocess args directly from
// a test, but we can confirm the helper still returns sensible output
// in a real git repo (the flag is silent on success — `git diff
// --no-optional-locks` is identical to `git diff` for read-only
// queries). Treating the test as an existence/smoke check.
func TestGitFilesList_RunsAgainstRealRepo(t T) T {
    val dir, err = os.MkdirTemp("", "gala_team_gitfiles_test_")
    if err != nil { panic(s"MkdirTemp: ${err.Error()}") }
    defer os.RemoveAll(dir)
    runGitInTmp(dir, ArrayOf("init", "-q", "-b", "main"))
    runGitInTmp(dir, ArrayOf("-c", "user.email=t@t", "-c", "user.name=t",
                             "commit", "--allow-empty", "-q", "-m", "base"))
    val files = gitFilesList(dir, ArrayOf("ls-files"))
    // Empty repo, no tracked files — IsEmpty() is the expected shape.
    return IsTrue(t, files.IsEmpty())
}
