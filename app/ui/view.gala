    "time"
    "martianoff/gala/time_utils"
    "github.com/martianoff/gala_team/app/guidance"
    "github.com/martianoff/gala_team/app/policy"
    "github.com/martianoff/gala_team/app/session"
    "github.com/martianoff/gala_team/app/version"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/go_interop"
    . "github.com/martianoff/gala-tui"
    . "github.com/martianoff/gala_team/app/consult"
    . "github.com/martianoff/gala_team/app/fsm"
    . "github.com/martianoff/gala_team/app/team"
    . "github.com/martianoff/gala_team/app/view"
)

// ============================================================================
// app/ui/view — top-level Elm view() function.
//
// Layout (DESIGN.md §8.1, simplified for Phase 1):
//   ┏━━━━ header ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
//   ┃ project · team · state · tick                    ┃
//   ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
//   ┌──── Team ────┬──── Conversation ───────────────┐
//   │ ▼ Lead       │ (placeholder until conversation │
//   │   ⠋ Iris     │  log + claude wiring lands)     │
//   │ ▼ Engineering│                                  │
//   │   ◇ Felix    │                                  │
//   │ Pipeline     │                                  │
//   │  (active)    │                                  │
//   ├─────────────────────────────────────────────────┤
//   │ Compose to Iris…                                │
//   └─────────────────────────────────────────────────┘
//   key hints
//
// ============================================================================

// View renders the AppModel as a gala-tui Widget tree. The main
// pane shows the live conversation by default; Tab swaps it for the
// consult viewer overlay; Ctrl+H swaps it for the history browser.
// Both overlays are mutually exclusive — opening one auto-closes
// the other isn't necessary because the toggle handlers leave both
// flags untouched (so the precedence below decides what's shown).
//
// Focus indicator: the focused panel gets a thick border; the
// unfocused panel keeps the rounded border. No text markers, no
// color tints — the heavier border weight is the only "you are
// here" signal, and it reads consistently regardless of which
// pane has focus.
//
// Click handling: gala-tui's HitRegistry auto-routes clicks to
// the bordered sidebar / composer panels (FocusSidebarClicked /
// FocusComposerClicked) and to individual sidebar rows
// (SidebarRowClicked). No hand-rolled coordinate hit-testing — the
// runtime uses the widgets' actually-rendered rectangles, so a
// resize / scroll / fold doesn't desync clicks from visuals.
//
// Overlay caveat: while a mouse-capturing modal is up
// (modalCapturesMouse) the base-layer interactive regions are
// dropped — the sidebar / composer .OnClick wrappers here and the
// conversation pane's per-entry drag region in conversationPanel.
// gala-tui's HitRegistry DOES descend into Overlay layers, so the
// modal's ButtonClick widgets are registered fine; the defect is
// that its click resolver checks drag regions before click regions
// on a fresh press (runtime.gala ResolveClickEventWithDrag). The
// conversation pane registers a per-entry drag region that tiles the
// whole centre pane, so a press on a centered modal button resolved
// to a conversation drag and the button never fired. We can't change
// drag-beats-click precedence without patching the external lib, so
// the base regions are suppressed while a modal owns the mouse.
func View(m AppModel) Widget {
    val header = headerWidget(m)
    val sidebar = sidebarWidget(m)
    val mainPanel = mainPanelWidget(m)
    val composer = composerWidget(m)
    val footer = footerWidget(m)
    val captureMouse = modalCapturesMouse(m)
    val sidebarBase  = BorderOf(sidebar, panelBorder(m, FocusSidebar()))
    val composerBase = BorderOf(composer, panelBorder(m, FocusComposer()))
    val sidebarPanel  = if (captureMouse) sidebarBase
                        else sidebarBase.OnClick(FocusSidebarClicked())
    val composerPanel = if (captureMouse) composerBase
                        else composerBase.OnClick(FocusComposerClicked())
    // Pick the body layout based on ViewMode. Default = sidebar +
    // conversation; Focus mode hides the sidebar (Frame M); Grid
    // replaces the conversation pane with a member-card grid (Frame
    // N); Pipeline shows the full-screen org chart (Frame O).
    val body = m.ViewMode match {
        case ViewFocus()    => focusBody(m, mainPanel)
        case ViewGrid()     => gridBody(m)
        case ViewPipeline() => pipelineBody(m)
        case ViewActivity() => activityBody(m)
        case ViewDefault()  => Row(ArrayOf[LayoutChild](
            Fixed(if (m.CompactSidebar) 20 else 28, sidebarPanel),
            Flex(1, Column(ArrayOf[LayoutChild](
                recoveryBanner(m),
                livenessBanner(m),
                toastBanner(m.Toasts),
                approvalBanner(m),
                Flex(1, BorderOf(mainPanel, RoundedBorder())),
            ))),
        ))
    }
    val base = Column(ArrayOf[LayoutChild](
        Fixed(headerHeight(m), header),
        Flex(1, body),
        // Activity band: full-width status strip for active members +
        // any sticky error. Spans the whole window (sidebar + chat)
        // so variable-length workflow phases / error remedies have
        // room to render without clipping. Renders 0 rows at rest.
        activityBand(m),
        // Plan panel sits below the chat log (above the composer)
        // when a multi-PR plan is active: a bordered, one-row-per-
        // step view of shipped → in progress → queued. Renders 0
        // rows when no plan is active.
        planPanel(m),
        Fixed(composerOuterHeight(m), composerPanel),
        Fixed(1, footer),
    ))
    // Overlay stack — paint each modal on top of the base, in
    // ascending z-order. Each overlay is conditional; when none are
    // open the base view is returned unchanged.
    //
    //   1. Member-detail (Frame I)
    //   2. Project-info (Frame S)
    //   3. Guidance (§5.7)
    //   4. Recovery (§5.6, replaces the legacy banner)
    //   5. Help (`?` / F6, §8.5)
    //   6. Palette (Frame J — always topmost)
    val withMemberOverlay = m.MemberDetailOpen match {
        case Some(name) => memberDetailModalOverlay(m, name, base)
        case None()     => base
    }
    val withProjectInfo = if (m.ProjectInfoOpen) projectInfoOverlay(m, withMemberOverlay) else withMemberOverlay
    val withGuidance    = if (m.GuidanceOpen)    guidanceOverlay(m, withProjectInfo)     else withProjectInfo
    val withRecovery    = if (m.Recovery.IsDefined()) recoveryModalOverlay(m, withGuidance) else withGuidance
    val withApproval    = m.State match {
        case Approval(body) => approvalModalOverlay(m, body, withRecovery)
        case _              => withRecovery
    }
    val withHelp        = if (m.HelpVisible) helpOverlay(m, withApproval) else withApproval
    return m.Palette match {
        case Some(pal) => paletteOverlay(pal, withHelp)
        case None()    => withHelp
    }
}

// helpOverlay paints the auto-generated help modal — every key
// binding + its mouse counterpart side-by-side. Closes on Esc / `F6`
// / clicking outside (Esc handler is in update.gala).
func helpOverlay(m AppModel, base Widget) Widget {
    val (cols, rows) = TermSize()
    val w = if (cols < 70) cols - 4 else MinInt(80, cols - 6)
    val h = if (rows < 18) rows - 2 else MinInt(24, rows - 4)
    val rowsArr = helpRows()
    val title = TextStyled(" Help · keys & mouse ", DefaultStyle().WithBold().WithReverse())
    val widgets = rowsArr.Map((r) => Fixed(1, TextStyled(r, DefaultStyle())))
    val footer = TextStyled("  Esc / F6 close", DefaultStyle().WithDim())
    val body = Column(ArrayOf[LayoutChild](
        Fixed(1, title),
        Fixed(1, FillCh('-')),
    ).AppendAll(widgets).Append(Fixed(1, FillCh('-'))).Append(Fixed(1, footer)))
    return Overlay(base, Modal(w, h, body))
}

// helpRows is the parity matrix laid out as a flat list of "key  →
// action" rows. Mouse counterparts are appended where they exist.
func helpRows() Array[string] = ArrayOf(
    "  Enter             submit prompt to lead       (or click ▶ in composer)",
    "  Tab / Ctrl+L      toggle composer ↔ sidebar   (or click panel)",
    "  Backspace         delete last rune in composer",
    "  ↑ / ↓             navigate sidebar / history",
    "  Space             fold/unfold a role group    (sidebar focus)",
    "  PgUp / PgDn       scroll conversation pane",
    "  End               re-stick conversation to bottom",
    "  Ctrl+P            command palette             (click ⌘ in header)",
    "  Ctrl+T            consult viewer modal",
    "  Ctrl+H            session-history browser",
    "  Ctrl+Y            yank conversation to clipboard",
    "  Ctrl+V            paste from clipboard",
    "  Ctrl+N            erase session (twice to confirm)",
    "  Ctrl+, / Ctrl+.   compact-left toggle (team panel)",
    "  F1 / F2 / F3      Default split / Focus / Grid",
    "  F4 / F5 / F6      Pipeline / Activity / Help",
    "  F7                toggle auto-approve (batch PRs)",
    "  Ctrl+Q / Ctrl+C   quit (twice to confirm)",
    "  Esc               close any open modal / drop focus",
)

// projectInfoOverlay shows project metadata in a centered modal —
// matches DESIGN.md Frame S.
func projectInfoOverlay(m AppModel, base Widget) Widget {
    val (cols, rows) = TermSize()
    val w = if (cols < 60) cols - 4 else MinInt(72, cols - 8)
    val h = if (rows < 14) rows - 2 else MinInt(18, rows - 4)
    val gh = m.Project.Github.GetOrElse("(none — git remote get-url origin failed)")
    val title = TextStyled(s" Project: ${m.Project.Name} ", DefaultStyle().WithBold().WithReverse())
    val rowsArr = ArrayOf(
        s"  Description:  ${m.Team.Description}",
        s"  Repo:         ${m.Project.Repo}",
        s"  GitHub:       ${gh}",
        s"  Branch:       ${m.Project.DefaultBranch}",
        s"  Team:         ${m.Team.Name} (${m.Team.Members.Size()} members)",
        s"  Workspace:    ${workspaceName(m)}",
    )
    val widgets = rowsArr.Map((r) => Fixed(1, TextStyled(r, DefaultStyle())))
    val footer = TextStyled("  Esc to close", DefaultStyle().WithDim())
    val body = Column(ArrayOf[LayoutChild](
        Fixed(1, title),
        Fixed(1, FillCh('-')),
    ).AppendAll(widgets).Append(Fixed(1, FillCh('-'))).Append(Fixed(1, footer)))
    return Overlay(base, Modal(w, h, body))
}

// workspaceName mirrors the policy.WorkspaceModeName helper so we
// don't have to dot-import the policy package here.
func workspaceName(m AppModel) string = policy.WorkspaceModeName(m.Policy.WorkspaceMode)

// guidanceOverlay surfaces the project guidance docs (§5.7). The
// current model still has the field stub on the AppModel; this
// overlay renders an empty state until the Guidance loader lands —
// the modal infrastructure is what unblocks the rest.
func guidanceOverlay(m AppModel, base Widget) Widget {
    val (cols, rows) = TermSize()
    val w = if (cols < 60) cols - 4 else MinInt(80, cols - 8)
    val h = if (rows < 14) rows - 2 else MinInt(20, rows - 4)
    val title = TextStyled(" Project guidance · standing orders ", DefaultStyle().WithBold().WithReverse())
    val rowsArr = guidanceRows(m)
    val widgets = rowsArr.Map((r) => Fixed(1, TextStyled(r, DefaultStyle())))
    val footer = TextStyled("  Esc to close · `g` to reopen", DefaultStyle().WithDim())
    val body = Column(ArrayOf[LayoutChild](
        Fixed(1, title),
        Fixed(1, FillCh('-')),
    ).AppendAll(widgets).Append(Fixed(1, FillCh('-'))).Append(Fixed(1, footer)))
    return Overlay(base, Modal(w, h, body))
}

// guidanceRows formats the loaded guidance docs as one row per slot.
// Walks m.Guidance.Docs and emits "slot → path  (sha bytes)" rows.
// Empty bundle shows the schema hint so the user knows how to wire
// guidance up.
func guidanceRows(m AppModel) Array[string] {
    val docs = m.Guidance.Docs
    if docs.IsEmpty() {
        return ArrayOf(
            "  (no guidance docs configured yet)",
            "",
            "  Add a `guidance:` block to team.yaml pointing at",
            "  TESTING.md / ARCHITECTURE.md / SECURITY.md / CLAUDE.md.",
            "  See DESIGN.md §5.7 for the full schema.",
        )
    }
    return docs.Map((d) =>
        s"  • ${d.Slot}  →  ${d.Path}  (sha ${guidance.Sha256Short(d)}, ${len(d.Body)} bytes)"
    )
}

// recoveryModalOverlay is the §5.6 Resume / Inspect / Start-fresh
// modal. Replaces the legacy single-line "↻ Restored …" banner.
// Each button is a real ButtonClick widget so mouse-only users can
// pick a choice; Tab/Enter still drive it from the keyboard via the
// dispatchMsg interception layer.
func recoveryModalOverlay(m AppModel, base Widget) Widget {
    val (cols, rows) = TermSize()
    val w = if (cols < 60) cols - 4 else MinInt(70, cols - 8)
    val h = if (rows < 14) rows - 2 else MinInt(16, rows - 4)
    val lines = m.Conversation.Size()
    val agents = m.RecoveredMembers.Size()
    val title = TextStyled(" ↺  Resume previous session? ", DefaultStyle().WithBold().WithReverse())
    val info = ArrayOf(
        s"  Project:    ${m.Project.Name}",
        s"  Team:       ${m.Team.Name}",
        s"  Lines:      ${lines}",
        s"  Pending:    ${agents} agent(s)",
    )
    val infoWidgets = info.Map((r) => Fixed(1, TextStyled(r, DefaultStyle())))
    val buttonRow = recoveryButtonRow(m)
    val footer = TextStyled("  Tab cycle · Enter / click · Esc cancel", DefaultStyle().WithDim())
    val body = Column(ArrayOf[LayoutChild](
        Fixed(1, title),
        Fixed(1, FillCh('-')),
    ).AppendAll(infoWidgets).Append(Fixed(1, Empty())).Append(Fixed(3, buttonRow))
        .Append(Fixed(1, FillCh('-'))).Append(Fixed(1, footer)))
    return Overlay(base, Modal(w, h, body))
}

// recoveryButtonRow renders the three buttons as real ButtonClick
// widgets so a mouse-click picks-and-confirms in one action. Each
// button dispatches a one-shot "set focus + confirm" message —
// SelectAndConfirm — that the update layer handles atomically.
func recoveryButtonRow(m AppModel) Widget {
    val focus = m.Recovery.GetOrElse(ResumeFocus())
    val resumeBtn = ButtonClick[AppMsg](
        "Resume",
        isResumeFocus(focus),
        KeyRecoveryClick(Choice = ResumeFocus()),
    )
    val inspectBtn = ButtonClick[AppMsg](
        "Inspect",
        isInspectFocus(focus),
        KeyRecoveryClick(Choice = InspectFocus()),
    )
    val freshBtn = ButtonClick[AppMsg](
        "Start fresh",
        isStartFreshFocus(focus),
        KeyRecoveryClick(Choice = StartFreshFocus()),
    )
    return Row(ArrayOf[LayoutChild](
        Flex(1, Empty()),
        Fixed(12, resumeBtn),
        Fixed(2, Empty()),
        Fixed(12, inspectBtn),
        Fixed(2, Empty()),
        Fixed(16, freshBtn),
        Flex(1, Empty()),
    ))
}

// isResumeFocus / isInspectFocus / isStartFreshFocus split the
// RecoveryChoice match into single-call predicates so the
// `recoveryButtonRow` widget call stays flat. Inline pattern-match
// would force a temp val per button, which obscures the intent.
func isResumeFocus(c RecoveryChoice) bool = c match {
    case ResumeFocus() => true
    case _             => false
}
func isInspectFocus(c RecoveryChoice) bool = c match {
    case InspectFocus() => true
    case _              => false
}
func isStartFreshFocus(c RecoveryChoice) bool = c match {
    case StartFreshFocus() => true
    case _                 => false
}

// modalCapturesMouse reports whether a modal overlay with its own
// clickable controls is up. While true, View / conversationPanel
// drop the base-layer interactive regions (sidebar + composer
// .OnClick, and the conversation pane's per-entry drag region) so a
// press lands on the modal's ButtonClick widgets instead of being
// swallowed by the base.
//
// Needed because gala-tui's click resolver checks drag regions
// before click regions on a fresh press: the conversation pane's
// drag region tiles the whole centre pane and otherwise shadows a
// centered modal's buttons. Scoped to the two modals that carry
// clickable controls and own the keyboard while up — the recovery
// modal (m.Recovery) and the approval dialog (State == Approval).
// The read-only overlays (help / project-info / guidance / member
// detail) close on Esc and don't act on clicks, so they're left out.
func modalCapturesMouse(m AppModel) bool {
    if m.Recovery.IsDefined() { return true }
    return m.State match {
        case Approval(_) => true
        case _           => false
    }
}

// approvalModalOverlay paints the §6.1 / Frame G approval dialog —
// a centered modal with the summary preview + Branch / Base / Title
// metadata + clickable [ Yes ] / [ No ] buttons. Mirrors the
// recovery modal's ButtonClick pattern so a mouse click picks AND
// confirms in one action.
func approvalModalOverlay(m AppModel, body string, base Widget) Widget {
    val (cols, rows) = TermSize()
    val w = if (cols < 70) cols - 4 else MinInt(78, cols - 8)
    val h = if (rows < 18) rows - 2 else MinInt(20, rows - 4)
    val title = TextStyled(" Open PR? ", DefaultStyle().WithBold().WithReverse())
    // Cap the summary to what fits inside the modal: subtract the
    // "  Summary:  " prefix (12 chars) plus a 2-col safety margin
    // so the row never overflows the modal frame visually.
    val summaryCap = MaxInt(20, w - 14)
    val firstLine = approvalFirstLine(body, summaryCap)
    val summaryRow = TextStyled(s"  Summary:  ${firstLine}", DefaultStyle())
    val branchHint = approvalBranchHint(m)
    val info = ArrayOf(
        s"  Branch:   ${branchHint}",
        s"  Base:     ${m.Project.DefaultBranch}",
        s"  Repo:     ${m.Project.Name}",
    )
    val infoWidgets = info.Map((r) => Fixed(1, TextStyled(r, DefaultStyle().WithDim())))
    val buttonRow = approvalButtonRow(m)
    val footer = TextStyled("  Tab cycles · Enter fires focused button · click either button · Esc rejects.",
        DefaultStyle().WithDim())
    val body2 = Column(ArrayOf[LayoutChild](
        Fixed(1, title),
        Fixed(1, FillCh('-')),
        Fixed(1, summaryRow),
        Fixed(1, Empty()),
    ).AppendAll(infoWidgets).Append(Fixed(1, Empty())).Append(Fixed(1, buttonRow))
        .Append(Fixed(1, FillCh('-'))).Append(Fixed(1, footer)))
    return Overlay(base, Modal(w, h, body2))
}

// approvalButtonRow renders Yes/No as ButtonClick widgets so a
// mouse click directly dispatches KeyApprove / KeyReject. The modal
// dialog (these buttons + the Tab/Enter/Esc/y/n keyboard fallbacks
// in approvalIntercept) is the only approval entry point — there is
// no global hotkey, so the buttons must always be reachable by both
// mouse and keyboard.
//
// `focused` parameter drives reverse-bold styling on the active
// button. The user Tab-cycles ApprovalFocus in the model; mouse
// clicks bypass focus and fire directly. Without per-render focus,
// users had no visual cue that BOTH buttons were clickable — the
// hardcoded "Yes always reverse, No always plain" rendering looked
// like only Yes was actionable.
func approvalButtonRow(m AppModel) Widget {
    val yesFocused = isApproveFocus(m.ApprovalFocus)
    val noFocused  = isRejectFocus(m.ApprovalFocus)
    val yesBtn = ButtonClick[AppMsg]("Yes — open PR", yesFocused, KeyApprove())
    val noBtn  = ButtonClick[AppMsg]("No — back",     noFocused,  KeyReject())
    return Row(ArrayOf[LayoutChild](
        Flex(1, Empty()),
        Fixed(18, yesBtn),
        Fixed(2, Empty()),
        Fixed(14, noBtn),
        Flex(1, Empty()),
    ))
}

// isApproveFocus / isRejectFocus split the ApprovalChoice match into
// single-call predicates so approvalButtonRow stays flat. Same shape
// as the recovery modal's isResumeFocus / isInspectFocus.
func isApproveFocus(c ApprovalChoice) bool = c match {
    case ApproveFocus() => true
    case _              => false
}
func isRejectFocus(c ApprovalChoice) bool = c match {
    case RejectFocus() => true
    case _             => false
}

// approvalFirstLine flattens the summary's first non-empty line and
// caps it to `cap` runes (caller-supplied so the renderer can match
// the modal width) — `cap` includes ellipsis room. Without a width-
// aware cap the row visually clips at the modal frame mid-word.
func approvalFirstLine(body string, cap int) string {
    val flat = strings.Join(strings.Fields(body), " ")
    val rs = ToRunes(flat)
    if len(rs) <= cap { return string(rs) }
    val keep = MaxInt(1, cap - 3)
    var prefix = EmptyArray[string]()
    var i = 0
    for i < keep {
        prefix = prefix.Append(string(rs[i]))
        i = i + 1
    }
    return prefix.MkString("") + "..."
}

// approvalBranchHint synthesises a sensible branch name from the
// project's default + a hash of the summary. We don't compute it
// here — `gh pr create` infers from current HEAD — so the hint just
// says "<current HEAD>" so the user knows they should have committed.
func approvalBranchHint(m AppModel) string {
    return s"current HEAD on ${m.Project.Name}"
}

// paletteOverlay paints the fuzzy-search action picker centered over
// `base`. Uses the click-aware variant so a mouse click on a row
// dispatches PalClick directly (which the dispatcher routes to
// PalConfirm via onPalClick); without this, the palette renders but
// click-to-pick is silently ignored on every row.
func paletteOverlay(pal Palette[AppMsg], base Widget) Widget {
    val (cols, rows) = TermSize()
    val w = if (cols < 60) cols - 4 else MinInt(80, cols - 8)
    val h = if (rows < 16) rows - 2 else MinInt(20, rows - 4)
    val body = PaletteViewAtHeightClick[AppMsg](pal, h - 2, true,
        (i) => KeyPaletteRowClick(Idx = i))
    val panel = Modal(w, h, body)
    return Overlay(base, panel)
}

// focusBody renders the conversation pane only — sidebar hidden.
// Useful when the team chrome is in the way and the user just wants
// to read the chat at full width (Frame M).
func focusBody(m AppModel, mainPanel Widget) Widget = Column(ArrayOf[LayoutChild](
    recoveryBanner(m),
    livenessBanner(m),
    toastBanner(m.Toasts),
    approvalBanner(m),
    Flex(1, BorderOf(mainPanel, RoundedBorder())),
))

// gridBody lays every team member out as a card in a Row of N
// columns (Frame N). Each card shows the member's name, role,
// status, and last activity timestamp. Wraps to a second row when
// there are >4 members so the layout stays readable.
func gridBody(m AppModel) Widget {
    val cards = m.Team.Members.Map((mem) => memberCard(m, mem))
    if cards.IsEmpty() { return Empty() }
    val children = cards.Map((c) => Flex(1, c))
    return Row(children)
}

// memberCard renders one member as a bordered card with their role
// badge, an animated severity-coloured status line (glyph + tag +
// work timer), the live workflow phase when one is in flight, a
// last-message preview, and token counters. Frame N in DESIGN.md. The
// status / timer / phase mirror the Activity band so the F3 grid
// reflects the same live signal as the default view.
func memberCard(m AppModel, mem Member) Widget {
    val st = m.Statuses.Get(mem.Name).GetOrElse(StIdle())
    val nameStyle = DefaultStyle().WithBold().WithFg(MemberColor(m.Team, mem))
    val name = TextStyled(s"  ${mem.Name}", nameStyle)
    val role = TextStyled(s"  ${RoleName(mem.Role)}", DefaultStyle().WithDim())
    // Status line: animated glyph (spins on m.Tick for working/slow) +
    // status tag + cumulative work timer, coloured by severity so a
    // failed / stuck card reads red at a glance.
    val timer = totalWorkFor(m, mem.Name, isRunningStatus(st))
    val statusText = if (timer == "") s"  ${bandGlyph(st, m.Tick)} ${statusTagFor(st)}"
                     else             s"  ${bandGlyph(st, m.Tick)} ${statusTagFor(st)} · ${timer}"
    val status = TextStyled(statusText, activityRowStyle(st))
    // Live workflow phase — only while the member is actively working
    // and a Workflow tool is in flight. Capped to the card width.
    val phaseRaw = m.WorkflowStatus.Get(mem.Name).GetOrElse("")
    val phaseText = if (phaseRaw == "" || !isActiveStatus(st)) ""
                    else s"  ⚙ ${cardCap(phaseRaw, 26)}"
    val phase = TextStyled(phaseText, DefaultStyle().WithFg(BrightCyan()))
    val preview = TextStyled(s"  \"${memberLastMessage(m, mem.Name)}\"",
        DefaultStyle().WithDim())
    val tokens = m.TokenUsage.Get(mem.Name).GetOrElse(zeroUsage())
    val turn = m.CurrentTurnUsage.Get(mem.Name).GetOrElse(zeroUsage())
    val cum = formatTokenCount(tokens.InputTokens + tokens.OutputTokens)
    val cur = turn.InputTokens + turn.OutputTokens
    val tokLabel = if (cur > 0)
        s"  ${cum} total · ${formatTokenCount(cur)} this turn"
    else
        s"  ${cum} total"
    val tok = TextStyled(tokLabel, DefaultStyle().WithDim())
    val body = Column(ArrayOf[LayoutChild](
        Fixed(1, name),
        Fixed(1, role),
        Fixed(1, status),
        Fixed(1, phase),
        Fixed(1, Empty()),
        Fixed(1, preview),
        Fixed(1, Empty()),
        Fixed(1, tok),
        Flex(1, Empty()),
    ))
    return BorderOf(body, RoundedBorder())
}

// cardCap clamps card text to `n` runes with an ellipsis so a long
// workflow phase doesn't overrun the (width / member-count) card.
func cardCap(s string, n int) string {
    val rs = ToRunes(s)
    if len(rs) <= n { return s }
    return runesPrefix(s, n - 1) + "…"
}

// memberLastMessage returns a one-line preview of `name`'s most
// recent message in the conversation log. Falls back to "—" when the
// member hasn't spoken yet. Capped to 24 cols so the card width
// stays predictable across teams of different name lengths.
func memberLastMessage(m AppModel, name string) string {
    var found = ""
    var i = m.Conversation.Size() - 1
    for i >= 0 {
        val cl = m.Conversation.Get(i)
        if cl.Speaker == name {
            found = cl.Text
            i = -1
        } else {
            i = i - 1
        }
    }
    if found == "" { return "—" }
    val flat = strings.Join(strings.Fields(found), " ")
    val rs = ToRunes(flat)
    if len(rs) <= 24 { return string(rs) }
    var prefix = EmptyArray[string]()
    var k = 0
    for k < 21 {
        prefix = prefix.Append(string(rs[k]))
        k = k + 1
    }
    return prefix.MkString("") + "…"
}

// pipelineBody renders the existing PipelineState chart full-screen
// (Frame O), with lane labels and a legend so users can read the
// chain-of-command at a glance even on big teams.
func pipelineBody(m AppModel) Widget {
    val laneRow = TextStyled(
        s"  Lanes:   You → Lead → Engineers → QA → Lead review → Approval",
        DefaultStyle().WithDim())
    val legend = TextStyled(
        "  Legend:  ⠋ working   ✓ done   ✗ failed   ◇ idle   ⟳ consult (dashed border)",
        DefaultStyle().WithDim())
    return BorderOf(
        Column(ArrayOf[LayoutChild](
            Fixed(1, TextStyled("  Pipeline view (F4 to toggle)", DefaultStyle().WithBold())),
            Fixed(1, laneRow),
            Fixed(1, legend),
            Fixed(1, Empty()),
            Flex(1, PipelineView(m.Pipeline)),
        )),
        RoundedBorder(),
    )
}

// activityBody renders the reverse-chronological event log (Frame P).
// We don't keep a separate event-stream model; the existing
// Conversation slice already records every notable event (user
// prompts, member chunks, dispatch markers, policy hooks, gh PR
// outcomes). Showing the most recent N entries with their speaker
// gives the same audit-trail surface the design specifies.
func activityBody(m AppModel) Widget {
    val (_, h) = TermSize()
    val viewportH = MaxInt(4, h - 8)
    val convo = m.Conversation
    val n = convo.Size()
    // Take the last `viewportH * 2` entries — long enough to show
    // recent activity, short enough to fit on screen even after each
    // entry wraps across multiple visible rows.
    val keepCount = MinInt(n, viewportH * 2)
    val skip = n - keepCount
    val taken = convo.Drop(skip)
    val rows = taken.Reverse().Map((cl session.ConversationLine) => {
        val rowStyle = if (cl.Undelivered) DefaultStyle().WithBold().WithFg(BrightRed())
                       else                speakerStyle(m.Team, cl.Speaker)
        val glyph = if (cl.Undelivered) "⚠" else activityGlyphFor(cl.Speaker)
        return TextStyled(s"  ${activityTimestamp(cl.At)}  ${glyph} ${cl.Speaker}  →  ${activityFirstLine(cl.Text)}", rowStyle)
    })
    val body = if (rows.IsEmpty())
        Column(ArrayOf[LayoutChild](
            Fixed(1, TextStyled("  (no activity yet)", DefaultStyle().WithDim())),
        ))
    else
        Column(rows.Map((r) => Fixed(1, r)))
    return BorderOf(
        Column(ArrayOf[LayoutChild](
            Fixed(1, TextStyled("  Activity log (F5 · most recent first)",
                DefaultStyle().WithBold())),
            Fixed(1, FillCh('-')),
            Flex(1, body),
        )),
        RoundedBorder(),
    )
}

// activityTimestamp formats the conversation-line timestamp as
// HH:MM:SS. Zero (legacy snapshots, pre-timestamp lines) renders as
// 8 spaces so the column alignment stays consistent.
func activityTimestamp(unixNanos int64) string {
    if unixNanos == int64(0) { return "        " }
    val t = time.Unix(int64(0), unixNanos)
    return t.Format("15:04:05")
}

// activityGlyphFor picks a glyph for the activity row by speaker
// kind. Mirrors DESIGN.md Frame P glyph language: ▣ user prompt, ⠋
// active work, ✓ done, ⊘ system. For unknown / member speakers we
// fall through to a bullet so the row still has a left-edge anchor.
func activityGlyphFor(speaker string) string {
    if speaker == "you"      { return "▣" }
    if speaker == "system"   { return "⊘" }
    if speaker == "policy"   { return "✓" }
    if speaker == "gh"       { return "▲" }
    if speaker == "shutdown" { return "⨯" }
    return "·"
}

// activityFirstLine returns the first non-empty line of `text`,
// trimmed and capped to 120 columns so each event row stays a single
// line in the activity view. Multi-line bodies (engineer summaries,
// TL drafts) wouldn't fit anyway.
func activityFirstLine(text string) string {
    val parts = strings.Split(text, "\n")
    var i = 0
    val n = len(parts)
    var first = ""
    for i < n {
        val ln = strings.TrimSpace(parts[i])
        if ln != "" { first = ln; i = n }
        i = i + 1
    }
    if first == "" { return "(empty)" }
    val rs = ToRunes(first)
    if len(rs) <= 120 { return first }
    var prefix = EmptyArray[string]()
    var k = 0
    for k < 117 {
        prefix = prefix.Append(string(rs[k]))
        k = k + 1
    }
    return prefix.MkString("") + "…"
}

// memberDetailModalOverlay paints the full transcript + role meta for
// `name` as a centered modal on top of `base`. Closes via Esc; the
// keymap routes Esc → KeyCloseMemberDetail when the modal is open.
//
// The transcript is filtered from m.Conversation by speaker — the
// design (Frame I) groups TL prompts, member responses, and any
// orchestrator nudges to that member into a single readable block.
// We include the user's `you:` lines too because they're the original
// task source.
func memberDetailModalOverlay(m AppModel, name string, base Widget) Widget {
    val (cols, rows) = TermSize()
    val w = if (cols < 60) cols - 4 else MinInt(120, cols - 8)
    val h = if (rows < 16) rows - 2 else MinInt(40, rows - 4)
    val body = memberDetailBody(m, name, w - 4)
    val panel = Modal(w, h, body)
    return Overlay(base, panel)
}

// memberDetailBody is the modal content: header line + role/meta
// block + filtered conversation. Width parameter is the inner-modal
// content width so paragraphHeight can wrap correctly.
func memberDetailBody(m AppModel, name string, width int) Widget {
    val mem = MemberByName(m.Team, name)
    val title = mem match {
        case Some(mb) => s" ${mb.Name} · ${RoleName(mb.Role)} · transcript "
        case None()   => s" ${name} · transcript "
    }
    val titleBar = TextStyled(title, DefaultStyle().WithBold().WithReverse())
    val metaLine = mem match {
        case Some(mb) => {
            val model = mb.Model.GetOrElse("(default)")
            val st = m.Statuses.Get(name).GetOrElse(StIdle())
            return TextStyled(s"  Role: ${RoleName(mb.Role)}    Model: ${model}    Status: ${statusTagFor(st)}",
                DefaultStyle().WithDim())
        }
        case None() => TextStyled(s"  ${name} is not on this team", DefaultStyle().WithDim())
    }
    val personality = mem match {
        case Some(mb) => if (mb.Personality == "") TextStyled("", DefaultStyle())
                        else                       TextStyled(s"  ${firstLineOf(mb.Personality)}",
                            DefaultStyle().WithDim())
        case None() => TextStyled("", DefaultStyle())
    }
    val filtered = m.Conversation.Filter((cl session.ConversationLine) =>
        cl.Speaker == name || cl.Speaker == "you")
    val entries = filtered.Map((cl session.ConversationLine) => {
        val raw = s"  ${cl.Speaker}: ${cl.Text}"
        return ConversationEntry(
            Body   = ParagraphStyled(raw, speakerStyle(m.Team, cl.Speaker)),
            Height = paragraphHeight(raw, width),
        )
    })
    val log = ConversationLog(
        Entries       = entries,
        Offset        = 0,
        StickToBottom = true,
    )
    val (_, h) = TermSize()
    val viewportH = MaxInt(4, h - 12)
    val transcript = if (entries.IsEmpty())
        TextStyled("  (no transcript yet for this member)", DefaultStyle().WithDim())
    else
        ConversationLogView(log, viewportH)
    // Footer carries the action buttons + key hints. Copy transcript
    // is bound to `c` while the modal is focused (also reachable via
    // palette → "Yank conversation"). Frame I in DESIGN.md asks for
    // [Copy transcript] and [Save to file…]; Save is captured as a
    // palette-only action for now to keep the modal footer terse.
    val actionRow = TextStyled("  [ Copy transcript: Ctrl+Y ]   [ Close: Esc ]",
        DefaultStyle())
    val footer = TextStyled("  scroll wheel / PgUp/PgDn to scroll",
        DefaultStyle().WithDim())
    return Column(ArrayOf[LayoutChild](
        Fixed(1, titleBar),
        Fixed(1, Empty()),
        Fixed(1, metaLine),
        Fixed(1, personality),
        Fixed(1, FillCh('-')),
        Flex(1, transcript),
        Fixed(1, FillCh('-')),
        Fixed(1, actionRow),
        Fixed(1, footer),
    ))
}

// statusTagFor maps a Status to a human-readable tag for the meta
// line. Mirrors the sidebar tags but without the spinner glyph.
func statusTagFor(s Status) string = s match {
    case StIdle()         => "idle"
    case StQueued()       => "queued"
    case StWorking()      => "working"
    case StSlow()         => "slow"
    case StStuck()        => "stuck"
    case StRecovering(att, max)  => s"recovering ${att}/${max}"
    case StHelpWaiting(_) => "needs help"
    case StDone()         => "done"
    case StFailed(r)      => s"failed: ${r}"
}

// firstLineOf returns the first non-empty line of a multi-line string.
// Used in the modal meta block to compress a multi-line personality
// into a single-row hint without dropping the first sentence.
func firstLineOf(s string) string {
    val parts = strings.Split(s, "\n")
    var i = 0
    val n = len(parts)
    for i < n {
        val ln = strings.TrimSpace(parts[i])
        if ln != "" { return ln }
        i = i + 1
    }
    return ""
}

// panelBorder returns ThickBorder when this panel is the focused
// one, RoundedBorder otherwise. Pure dispatch on AppModel.Focus.
func panelBorder(m AppModel, panel FocusState) BorderKind {
    val focused = focusEquals(m.Focus, panel)
    if focused { return ThickBorder() }
    return RoundedBorder()
}

// focusEquals avoids a generic equals on the FocusState sealed
// type — gala doesn't synthesise == for sealed cases by default.
func focusEquals(a FocusState, b FocusState) bool = a match {
    case FocusComposer() => b match {
        case FocusComposer() => true
        case FocusSidebar()  => false
    }
    case FocusSidebar()  => b match {
        case FocusComposer() => false
        case FocusSidebar()  => true
    }
}

// mainPanelWidget chooses the central pane: history browser takes
// precedence (it's a dedicated read-only mode the user opted into),
// then the consult viewer overlay, then the live conversation.
func mainPanelWidget(m AppModel) Widget {
    if m.HistoryMode { return historyPanel(m) }
    if m.ConsultViewerOpen { return consultViewerPanel(m) }
    return conversationPanel(m)
}

// approvalBanner points the user at the approval dialog above the
// conversation pane when the FSM is in Approval. Hidden in every
// other state by returning a zero-height layout child.
func approvalBanner(m AppModel) LayoutChild = m.State match {
    case Approval(body) => Fixed(2, Column(ArrayOf[LayoutChild](
        Fixed(1, TextStyled(s"  ▶ Ready to ship: ${approvalSnippet(body)}",
            DefaultStyle().WithBold().WithFg(BrightYellow()))),
        Fixed(1, TextStyled("    Review the summary — approve or reject in the dialog below",
            DefaultStyle().WithDim())),
    )))
    case _ => Fixed(0, Empty())
}

// recoveryBanner surfaces a "↻ Restored …" indicator on launch when
// session.Load found a prior snapshot. Hidden in normal use. The
// banner shows line count + agent count so the user understands
// what's been brought back, plus the dismiss/continue hints.
func recoveryBanner(m AppModel) LayoutChild {
    // Wiping banner takes precedence — Start fresh / Ctrl+N / Esc-on-
    // recovery-modal all spawn an async git wipe that can take 5-10s
    // (fetch + reset + per-engineer worktree-removes). Without this
    // surface, the user sees an empty conversation + idle sidebar
    // and doesn't know the IO is still in flight.
    if m.WipingWorktrees {
        return Fixed(2, Column(ArrayOf[LayoutChild](
            Fixed(1, TextStyled("  ⟳ Wiping worktrees (git fetch + reset + clean)…",
                DefaultStyle().WithBold().WithFg(BrightYellow()))),
            Fixed(1, TextStyled("    typically 5-10s; the TUI stays interactive while it runs",
                DefaultStyle().WithDim())),
        )))
    }
    if !m.RecoveryBannerVisible { return Fixed(0, Empty()) }
    val lines = m.Conversation.Size()
    val agents = m.RecoveredMembers.Size()
    val agentNote = if (agents == 0) ""
                    else if (agents == 1) s", ${agents} agent pending"
                    else                  s", ${agents} agents pending"
    return Fixed(2, Column(ArrayOf[LayoutChild](
        Fixed(1, TextStyled(s"  ↻ Restored ${lines} line(s) from prior session${agentNote}",
            DefaultStyle().WithBold().WithFg(BrightCyan()))),
        Fixed(1, TextStyled("    type a prompt to continue · Esc to discard and start fresh",
            DefaultStyle().WithDim())),
    )))
}

// approvalSnippet picks the first ~60 chars of the summary body for
// the banner; the full body still goes into the PR via gh pr create.
// Newlines are flattened to single spaces so the snippet always fits
// on the banner's single Fixed(1) line — without this, an embedded
// "\n" would corrupt the layout below the banner.
func approvalSnippet(body string) string {
    val flat = strings.Join(strings.Fields(body), " ")
    val rs = ToRunes(flat)
    val n = len(rs)
    return if (n <= 60) string(rs)
           else         string(SliceTo(rs, 60)) + "..."
}

// ----- pieces ---------------------------------------------------------------

// HeaderApplePadCols, HeaderAppleWidth and HeaderRowsWide describe the
// wide-mode header geometry. The Fixed-row totals here must match the
// outer Column's `Fixed(N, header)` slot in View — kept in sync via
// headerHeight, the inner Fixed(N, appleAndBrand) in wideHeader, and
// the appleColumn / appleRow0..2 grid (any change must touch ALL of
// them or the header crops or leaves a gap).
//   AppleWidth   = 7 cols of apple grid (see appleColumn).
//   AppleLeftPad = 1 col of empty space to the left of the apple —
//                  flush against the terminal edge reads as cramped,
//                  the single-col indent gives the silhouette air.
//   ApplePad     = 2 cols of breathing room between apple and brand.
//   HeaderRowsWide = 1 spacer + 3 apple/brand rows + 1 separator = 5.
//   HeaderRowsNarrow = 1 spacer + 1 brand + 1 sub + 1 separator  = 4.
//   NarrowCols   = below this terminal width, drop the apple and
//                  fall back to the original 4-row single-line layout
//                  so the brand doesn't get squeezed off-screen.
func HeaderAppleWidth() int    = 7
func HeaderAppleLeftPad() int  = 1
func HeaderApplePad() int      = 2
func HeaderRowsWide() int      = 5
func HeaderRowsNarrow() int    = 4
func HeaderNarrowCols() int    = 70

// appleShineDivisor scales how often the apple's shine column
// advances — `shineZone = (tick / divisor) % nZones`. The global
// TickSub fires every 120 ms; with divisor=3 the shine steps every
// 360 ms and a full 7-zone lap takes ~2.52 s. The apple's narrow
// 7-col belly otherwise reads as jittery at the full 120 ms beat
// — the highlight snaps across a stationary logo too fast to feel
// like motion. Bumping the divisor slows ONLY the apple — spinners
// elsewhere keep their 120 ms beat.
func appleShineDivisor() int = 3

// headerHeight is what the outer Column reserves for the header. Wide
// mode grows to 5 rows to fit the apple; narrow stays at the legacy 4.
// Recomputed each frame so a live resize re-flows correctly.
func headerHeight(m AppModel) int {
    val (cols, _) = TermSize()
    return if (cols < HeaderNarrowCols()) HeaderRowsNarrow() else HeaderRowsWide()
}

// headerWidget renders the gala-team brand region. In wide mode (cols
// >= HeaderNarrowCols), an animated multi-row ASCII apple sits to the
// left of the brand text + state/tokens line. In narrow terminals it
// degrades to the original single-row 🍎-emoji + brand layout so the
// project / team name doesn't get pushed off-screen.
//
// Row 0 is always a sacrificial blank: PowerShell / Windows Terminal
// regularly eats the very first visible row of an alt-screen TUI
// (artifact of the alt-screen mode switch interacting with the prior
// bottom row). Putting an empty spacer there means the eaten row is
// invisible and the brand survives intact.
func headerWidget(m AppModel) Widget {
    val (cols, _) = TermSize()
    return if (cols < HeaderNarrowCols()) narrowHeader(m, cols)
           else                            wideHeader(m, cols)
}

// narrowHeader is the legacy single-line layout — used when the
// terminal is too small to fit the apple + brand side-by-side without
// crowding. Total height: 4 rows.
func narrowHeader(m AppModel, cols int) Widget {
    val brand = buildBrandLine(m, cols)
    val brandLine = TextStyled(brand, DefaultStyle().WithBold().WithFg(BrightCyan()))
    val sub = TextStyled(s"      ${stateLabel(m.State)}${autoBadgeText(m)}${tokenSuffix(m)}",
        DefaultStyle().WithDim())
    return Column(ArrayOf[LayoutChild](
        Fixed(1, Empty()),
        Fixed(1, brandLine),
        Fixed(1, sub),
        Fixed(1, FillCh('-')),
    ))
}

// wideHeader is the apple+brand layout: 1 col left pad + 7-col apple
// + 2-col gap + flex brand. The left pad lives in the row (not the
// apple grid) so the apple silhouette itself stays a clean 7×3 — and
// flush against the terminal edge reads as cramped. The brand line
// is built without the 🍎 prefix here because the apple itself is
// the brand glyph. Total height: 5 rows.
//
// The brand right column is a 3-row block whose rows line up 1:1
// with the apple's 3 rows: the stem/leaf row carries the brand
// title, the top-chamfered belly carries the state line, the
// bottom-chamfered belly carries the tokens line. tokens shows
// empty when no usage has accrued (transiently at session start);
// once any member emits a result event it fills. No vertical empty
// rows are needed because the brand block matches the apple's row
// count — the layout has no wasted vertical space.
func wideHeader(m AppModel, cols int) Widget {
    val budget = cols - HeaderAppleLeftPad() - HeaderAppleWidth() - HeaderApplePad()
    val brand = buildBrandLineNoEmoji(m, budget)
    val brandLine = TextStyled(brand, DefaultStyle().WithBold().WithFg(BrightCyan()))
    val stateLine = TextStyled(s"${stateLabel(m.State)}${autoBadgeText(m)}",
        DefaultStyle().WithDim())
    val tokens = wideTokensText(m)
    val tokensLine = if (tokens == "") Empty()
                     else TextStyled(tokens, DefaultStyle().WithDim())
    val brandColumn = Column(ArrayOf[LayoutChild](
        Fixed(1, brandLine),
        Fixed(1, stateLine),
        Fixed(1, tokensLine),
    ))
    val appleAndBrand = Row(ArrayOf[LayoutChild](
        Fixed(HeaderAppleLeftPad(), Empty()),
        Fixed(HeaderAppleWidth(), appleColumn(m.Tick)),
        Fixed(HeaderApplePad(), Empty()),
        Flex(1, brandColumn),
    ))
    return Column(ArrayOf[LayoutChild](
        Fixed(1, Empty()),
        Fixed(3, appleAndBrand),
        Fixed(1, FillCh('-')),
    ))
}

// wideTokensText is the wide-header variant of tokenSuffix without
// the leading "  ·  " separator — that separator made sense when
// tokens were appended inline to the state row, but in the 5-row
// brand column tokens stand on their own line. Empty string when
// no usage has accrued so wideHeader can replace the row with
// Empty() (avoids painting a stray "·" on a fresh launch).
func wideTokensText(m AppModel) string {
    val usg = TotalTokenUsage(m)
    val total = usg.InputTokens + usg.OutputTokens + usg.CacheReadInputTokens
    if total == 0 { return "" }
    val ins   = formatTokenCount(usg.InputTokens)
    val outs  = formatTokenCount(usg.OutputTokens)
    val cache = formatTokenCount(usg.CacheReadInputTokens)
    return s"${ins} in / ${outs} out  ·  cache ${cache}  ·  ${formatCostUsd(m.TotalCostUsd)}"
}

// autoBadgeText extracts the AUTO (N open · plan x/y) suffix that
// trails the state label when batch-PR auto-approve is on. Pulled out
// of headerWidget so wide and narrow renderers stay byte-identical
// for the badge contents.
func autoBadgeText(m AppModel) string {
    if !m.AutoApprove { return "" }
    val total = m.Plan.Size()
    val shipped = m.PlanShipped
    val planSuffix = if (total == 0) ""
                     else if (shipped >= total) s" · plan ${total}/${total}"
                     else                       s" · plan ${shipped + 1}/${total}"
    return s"  ·  AUTO (${m.OpenPrs.Size()} open${planSuffix})"
}

// appleColumn renders the gala apple as a 3-row × 7-col grid of
// styled cells. `tick` advances every 120 ms (TickSub in cmd/main),
// driving a "shine" highlight that sweeps across the apple body.
//
// Shine cadence: shineZone = (tick / appleShineDivisor()) % nZones,
// so the highlight advances one column every 3 ticks (~360 ms) and
// a full lap takes 7 zones × 360 ms ≈ 2.52 s. The divisor decouples
// the apple's animation rate from the global tick — the spinner
// elsewhere on the screen still runs at the full 120 ms cadence,
// which it needs to look "alive" while the apple breathes slower.
//
// Zone scheme: nZones = 7 (the body width). Body cells live at every
// grid col 0..6 in the two belly rows, with zone == col. The cell
// at shineZone renders BrightWhite + bold (the highlight), the next
// zone over BrightRed (the trailing edge), the rest plain red.
// Half-block chamfer cells (▄ at the top corners, ▀ at the base
// corners) share the body palette so the shine wraps the silhouette
// smoothly. The chamfering compresses the apple visually so 3 rows
// of cells read as a fuller silhouette than the literal row count.
//
// Stem ('╲') is yellow-dim, leaf ('│' + cluster '▙') is bright
// green — the cluster glyph gives the leaf visible volume without
// stealing a second row.
func appleColumn(tick int) Widget {
    val nZones = 7
    val shineZone = (tick / appleShineDivisor()) % nZones
    val leafSt = DefaultStyle().WithFg(BrightGreen()).WithBold()
    val stemSt = DefaultStyle().WithFg(Yellow()).WithDim()
    return Column(ArrayOf[LayoutChild](
        Fixed(1, appleRow0(stemSt, leafSt)),
        Fixed(1, appleRow1(shineZone, nZones)),
        Fixed(1, appleRow2(shineZone, nZones)),
    ))
}

// applePalette picks the per-cell body style based on its zone vs the
// current shineZone — the shiny column gets BrightWhite+bold, the
// trailing column gets BrightRed, the rest are plain red.
func applePalette(zone int, shineZone int, nZones int) Style =
    if (zone == shineZone)
        DefaultStyle().WithFg(BrightWhite()).WithBold()
    else if (zone == (shineZone + 1) % nZones)
        DefaultStyle().WithFg(BrightRed())
    else
        DefaultStyle().WithFg(Red())

// appleSpace and appleCell are 1-col LayoutChildren — the apple grid
// is built as a Row of these so each cell can carry its own style.
func appleSpace() LayoutChild = Fixed(1, TextStyled(" ", DefaultStyle()))
func appleCell(g string, st Style) LayoutChild = Fixed(1, TextStyled(g, st))

// appleRow0..2 paint the three rows of the apple in a 7-col grid:
//
//   col:    0   1   2   3   4   5   6
//   row 0:  .   .   ╲   │   ▙   .   .     stem + leaf cluster (centred)
//   row 1:  ▄   █   █   █   █   █   ▄     top body (chamfered shoulders)
//   row 2:  ▀   █   █   █   █   █   ▀     bottom body (chamfered base)
//
// Both belly rows span the full 7-col width so every shine zone
// lands on a visible cell — the shine never disappears off-grid.
func appleRow0(stemSt Style, leafSt Style) Widget = Row(ArrayOf[LayoutChild](
    appleSpace(), appleSpace(),
    appleCell("╲", stemSt),
    appleCell("│", leafSt),
    appleCell("▙", leafSt),
    appleSpace(), appleSpace(),
))

func appleRow1(shineZone int, nZones int) Widget = Row(ArrayOf[LayoutChild](
    appleCell("▄", applePalette(0, shineZone, nZones)),
    appleCell("█", applePalette(1, shineZone, nZones)),
    appleCell("█", applePalette(2, shineZone, nZones)),
    appleCell("█", applePalette(3, shineZone, nZones)),
    appleCell("█", applePalette(4, shineZone, nZones)),
    appleCell("█", applePalette(5, shineZone, nZones)),
    appleCell("▄", applePalette(6, shineZone, nZones)),
))

func appleRow2(shineZone int, nZones int) Widget = Row(ArrayOf[LayoutChild](
    appleCell("▀", applePalette(0, shineZone, nZones)),
    appleCell("█", applePalette(1, shineZone, nZones)),
    appleCell("█", applePalette(2, shineZone, nZones)),
    appleCell("█", applePalette(3, shineZone, nZones)),
    appleCell("█", applePalette(4, shineZone, nZones)),
    appleCell("█", applePalette(5, shineZone, nZones)),
    appleCell("▀", applePalette(6, shineZone, nZones)),
))

// tokenSuffix renders the running cumulative token usage + cost
// across every member of the team. Hidden until at least one result
// event has accrued (so a fresh launch doesn't show "0 tok · $0.00").
//
// Format: " · 12.3k in / 4.5k out · cache 87.0k · $0.12"
//   - 'in' = sum of input_tokens (prompt + tools)
//   - 'out' = sum of output_tokens (assistant text)
//   - 'cache' = cache_read_input_tokens, the part the cache served
//   - dollars are claude's reported total_cost_usd, summed
func tokenSuffix(m AppModel) string {
    val usg = TotalTokenUsage(m)
    val total = usg.InputTokens + usg.OutputTokens + usg.CacheReadInputTokens
    if total == 0 { return "" }
    val ins   = formatTokenCount(usg.InputTokens)
    val outs  = formatTokenCount(usg.OutputTokens)
    val cache = formatTokenCount(usg.CacheReadInputTokens)
    return s"  ·  ${ins} in / ${outs} out  ·  cache ${cache}  ·  ${formatCostUsd(m.TotalCostUsd)}"
}

// formatTokenCount compresses big counts into a "12.3k" / "1.2M"
// form so the header fits on one line for long-running sessions.
func formatTokenCount(n int) string {
    if n < 1000 { return s"${n}" }
    if n < 1000000 {
        val whole = n / 100
        val tenths = whole - (whole / 10) * 10
        val major = whole / 10
        return s"${major}.${tenths}k"
    }
    val whole = n / 100000
    val tenths = whole - (whole / 10) * 10
    val major = whole / 10
    return s"${major}.${tenths}M"
}

// formatCostUsd shows fractional dollars with two decimals, dropping
// to "<$0.01" for sub-cent totals to avoid rendering "$0.00" after a
// real (non-zero) charge.
func formatCostUsd(usd float64) string {
    if usd < 0.005 && usd > 0.0 { return "<$0.01" }
    val cents = int(usd * 100.0 + 0.5)
    val dollars = cents / 100
    val pennies = cents - dollars * 100
    val pad = if (pennies < 10) "0" else ""
    // Concat rather than interpolate — gala's s-string handles `$$`
    // as a literal `$`, but the immediately-following `${dollars}`
    // still gets read as the literal text `${dollars}` instead of
    // an interpolation. Concatenating an explicit "$" sidesteps the
    // tokenizer ambiguity.
    return "$" + s"${dollars}.${pad}${pennies}"
}

// buildBrandLine assembles the narrow-mode brand row — the 🍎 emoji
// is included since narrow mode skips the rendered apple. Drops the
// description first, then ellipsises team / project as needed to fit
// `cols`. The prefix is treated as fixed-cost; only optional segments
// are sacrificed.
func buildBrandLine(m AppModel, cols int) string =
    buildBrandLineAt(m, cols, s"  🍎  Gala Team v${version.Version()}")

// buildBrandLineNoEmoji is the wide-mode variant — drops the 🍎
// from the prefix because the rendered apple sits to the left of
// this text. Same fit / truncate behaviour as buildBrandLine. No
// leading whitespace either — the apple column + HeaderApplePad
// already supply the left margin, so a "  Gala Team v..." prefix
// would compound into an awkward 4-cell gap between the apple's
// right edge and the title.
func buildBrandLineNoEmoji(m AppModel, cols int) string =
    buildBrandLineAt(m, cols, s"Gala Team v${version.Version()}")

// buildBrandLineAt is the shared truncation core: try the full line,
// then drop the description, then drop the team name, then runes-cap
// the prefix as a last resort.
func buildBrandLineAt(m AppModel, cols int, prefix string) string {
    val full = s"${prefix} | ${m.Project.Name} | ${m.Team.Name}${teamDescriptionSuffix(m.Team.Description)}"
    if visibleWidth(full) <= cols { return full }
    val withoutDesc = s"${prefix} | ${m.Project.Name} | ${m.Team.Name}"
    if visibleWidth(withoutDesc) <= cols { return withoutDesc }
    val withoutTeam = s"${prefix} | ${m.Project.Name}"
    if visibleWidth(withoutTeam) <= cols { return withoutTeam }
    return runesPrefixView(prefix, cols)
}

// visibleWidth returns the rune count of `s` — we don't try to be
// pedantic about wide-glyph (CJK / emoji) cell widths because the
// brand-line fits-or-truncates check tolerates a small overrun
// without breaking layout (the renderer clips at terminal edge).
func visibleWidth(s string) int = len(ToRunes(s))

// runesPrefixView mirrors update.gala's runesPrefix — kept local so
// view.gala doesn't import update.gala's helpers.
func runesPrefixView(s string, n int) string {
    val rs = ToRunes(s)
    if len(rs) <= n { return s }
    var out = EmptyArray[string]()
    var i = 0
    val cap = if (n < 1) 1 else n
    for i < cap {
        out = out.Append(string(rs[i]))
        i = i + 1
    }
    return out.MkString("")
}

// teamDescriptionSuffix appends "  ·  <description>" when the team
// declared one; empty otherwise so single-team setups without a
// description don't render a dangling separator.
func teamDescriptionSuffix(desc string) string =
    if (desc == "") "" else s"  ·  ${desc}"

// sidebarWidget renders the left-hand "Team / Pipeline" pane.
// When Focus=Sidebar, the team panel receives the live cursor so
// the user can see where Space/Enter will toggle; when
// Focus=Composer, cursor=-1 disables the highlight (the panel is
// purely informational).
//
// Each visible team-panel row is wired through gala-tui's
// HitRegistry via TeamPanelViewClickable so a row click dispatches
// SidebarRowClicked with the absolute row index, regardless of the
// scroll offset — the framework hands the visible-row index back,
// and the panel translates it to absolute internally.
func sidebarWidget(m AppModel) Widget {
    val cursor = m.Focus match {
        case FocusSidebar()  => m.SidebarCursor
        case FocusComposer() => -1
    }
    val rightFields = buildSidebarRightFields(m, m.Team.Members)
    val teamPanel = TeamPanelViewClickable[AppMsg](
        m.Team, m.Statuses, cursor, m.CollapsedGroups, m.Tick,
        (idx) => SidebarRowClicked(VisibleIdx = idx),
        rightFields,
    )
    // Pipeline gets a fixed band sized to its actual content so it
    // can't claim half the sidebar when empty. Team panel is Flex(1)
    // — it absorbs every remaining row, including the slack the
    // old 50/50 split was wasting.
    val pipelineRows = pipelineHeight(m.Pipeline)
    return Column(ArrayOf[LayoutChild](
        Fixed(1, TextStyled(sidebarHeading(m), sidebarHeadingStyle(m))),
        Flex(1, teamPanel),
        Fixed(1, TextStyled("  Pipeline", DefaultStyle().WithBold())),
        Fixed(pipelineRows, PipelineView(m.Pipeline)),
    ))
}

// buildSidebarRightFields computes the per-member right-aligned text
// rendered next to the member name in the sidebar — elapsed M:SS for
// active members, "recov n/m" for recovering, "✗ failed" for failed,
// etc. Members with no notable status (StIdle / StQueued / StDone)
// get no entry, so the sidebar stays clean during quiescence.
func buildSidebarRightFields(m AppModel, members Array[Member]) HashMap[string, string] {
    return members.FoldLeft(EmptyHashMap[string, string](), (acc, mem) => {
        val txt = sidebarRightField(m, mem.Name)
        if txt == "" { return acc }
        return acc.Put(mem.Name, txt)
    })
}

// sidebarRightField formats one member's right-side timer. The timer
// is the cumulative time the member has spent in a working status
// (StWorking/StSlow/StStuck/StRecovering) — pauses on idle, resumes
// on the next dispatch. LastChunkAt feeds the liveness FSM under the
// hood but isn't shown here; users were reading the chunk-elapsed
// number as "stopwatch" and getting confused when it reset on every
// chunk.
//
// Idle / queued / done shows nothing (no work to time). Failed and
// help-waiting show their static labels.
// The workflow-progress phase is intentionally NOT shown here. It used
// to be appended to the timer ("2:40 · Map: scout architecture"), but
// the sidebar column is too narrow for variable-length text — it
// clipped mid-word. The phase now renders in the full-width Activity
// band (see activityBand), which has room for the whole label. The
// sidebar keeps to the fixed-width timer/status, which always fits.
func sidebarRightField(m AppModel, name string) string {
    val status = m.Statuses.Get(name).GetOrElse(StIdle())
    return status match {
        case StIdle()           => totalWorkFor(m, name, false)
        case StQueued()         => ""
        case StDone()           => totalWorkFor(m, name, false)
        case StFailed(_)        => "✗ failed"
        case StRecovering(att, max) => s"${totalWorkFor(m, name, true)} r${att}/${max}"
        case StHelpWaiting(_)   => "help"
        case StWorking()        => totalWorkFor(m, name, true)
        case StSlow()           => s"${totalWorkFor(m, name, true)} slow"
        case StStuck()          => s"${totalWorkFor(m, name, true)} stuck"
    }
}

// totalWorkFor returns the formatted "M:SS" cumulative-work timer
// for `name`. Adds the live-segment delta (now - WorkStartedAt) when
// `running` is true, so the timer ticks while the member is
// working. When `running` is false, just renders the accumulated
// total — a fixed value that doesn't shift on every redraw.
//
// Returns "" when the member has zero accumulated time AND isn't
// currently running, so an unworked-yet sidebar row stays clean.
func totalWorkFor(m AppModel, name string, running bool) string {
    val accum = m.WorkElapsedNs.Get(name).GetOrElse(int64(0))
    val nowNs = m.NowAt.UnixNanos()
    val live = if (!running) int64(0) else liveSegmentNs(m, name, nowNs)
    val totalNs = accum + live
    if totalNs <= int64(0) { return "" }
    val secs = totalNs / int64(1000000000)
    return formatMSS(secs)
}

// liveSegmentNs returns the in-flight portion of the work timer
// (now - WorkStartedAt). Zero when the member doesn't have a stamp
// yet (just spawned, or status hasn't flipped to working).
func liveSegmentNs(m AppModel, name string, nowNs int64) int64 = m.WorkStartedAt.Get(name) match {
    case None()   => int64(0)
    case Some(at) => {
        val startNs = at.UnixNanos()
        if (nowNs > startNs) nowNs - startNs else int64(0)
    }
}

// formatElapsedSince computes (now - last) and renders it as M:SS.
// Returns "0:00" if the clock somehow went backwards (skew) or the
// inputs match — defensive, the timer never shows a negative number.
//
// Takes both Instants by value so auto-unwrap fires at the call
// boundary — methods on plain `Instant` are well-defined; methods
// on `Immutable[Instant]` may not lower in the current 0.39.x line.
func formatElapsedSince(now time_utils.Instant, last time_utils.Instant) string {
    val nanosNow = now.UnixNanos()
    val nanosLast = last.UnixNanos()
    if nanosNow <= nanosLast { return "0:00" }
    val secs = (nanosNow - nanosLast) / int64(1000000000)
    return formatMSS(secs)
}

func formatMSS(secs int64) string {
    val mins = secs / int64(60)
    val rem  = secs - mins * int64(60)
    if rem < int64(10) { return s"${mins}:0${rem}" }
    return s"${mins}:${rem}"
}

// LivenessCounts is the per-status tally used by the aggregate
// liveness header banner. One pass over the team members fills in
// every counter; formatting is a separate step so tests can
// assert on raw counts.
struct LivenessCounts(
    Working    int,
    Slow       int,
    Stuck      int,
    Recovering int,
    Failed     int,
)

// livenessBanner renders a one-line summary of how the team is doing
// when the orchestrator has dispatched work. Hidden in Idle / Approval
// (no active member work to summarise). When all members are still
// in StWorking, shows just "N working"; once any escalation kicks in
// (slow/stuck/recovering/failed), the breakdown appears.
func livenessBanner(m AppModel) LayoutChild {
    val show = m.State match {
        case Delegating(_, _) => true
        case QAGate(_, _)     => true
        case TLReview()    => true
        case _             => false
    }
    if !show { return Fixed(0, Empty()) }
    return Fixed(1, livenessBannerWidget(m, m.Team.Members))
}

// livenessBannerWidget builds the actual banner Widget. Takes
// `members` as a typed parameter so auto-unwrap fires at the call
// boundary (same pattern as buildSidebarRightFields).
func livenessBannerWidget(m AppModel, members Array[Member]) Widget {
    val counts = countLiveness(m, members)
    return TextStyled(formatLivenessCounts(counts), DefaultStyle().WithDim())
}

// countLiveness tallies each member's current status into the five
// liveness buckets. StIdle / StQueued / StDone / StHelpWaiting are
// not surfaced in the banner — keeps the line short.
func countLiveness(m AppModel, members Array[Member]) LivenessCounts =
    members.FoldLeft(
        LivenessCounts(Working = 0, Slow = 0, Stuck = 0, Recovering = 0, Failed = 0),
        (acc, mem) => tallyOne(acc, m.Statuses.Get(mem.Name).GetOrElse(StIdle())),
    )

// tallyOne increments the counter for the given status. Statuses
// outside the liveness vocabulary (Idle/Queued/Done/HelpWaiting)
// pass through untouched.
func tallyOne(c LivenessCounts, s Status) LivenessCounts = s match {
    case StWorking()        => c.Copy(Working    = c.Working    + 1)
    case StSlow()           => c.Copy(Slow       = c.Slow       + 1)
    case StStuck()          => c.Copy(Stuck      = c.Stuck      + 1)
    case StRecovering(_, _) => c.Copy(Recovering = c.Recovering + 1)
    case StFailed(_)        => c.Copy(Failed     = c.Failed     + 1)
    case _                  => c
}

// formatLivenessCounts builds the dim "  N working · M slow · ..."
// header line. Always five segments so the layout stays stable as
// counts shift.
func formatLivenessCounts(c LivenessCounts) string {
    val parts = ArrayOf[string](
        s"  ${c.Working} working",
        s"${c.Slow} slow",
        s"${c.Stuck} stuck",
        s"${c.Recovering} recovering",
        s"${c.Failed} failed",
    )
    return parts.MkString(" · ")
}

// toastBanner mounts the live toast queue as a Fixed-height column at
// the top of the conversation pane. Sized to the queue length so the
// rows don't squeeze each other, hidden entirely when the queue is
// empty (most of the session). Pruning happens in onTick — by the
// time this renders, expired toasts are already gone.
//
// Takes `q` as a typed parameter so auto-unwrap fires at the call
// boundary (`m.Toasts` is Immutable[ToastQueue], `.IsEmpty()` /
// `.Length()` work on plain ToastQueue).
func toastBanner(q ToastQueue) LayoutChild {
    if q.IsEmpty() { return Fixed(0, Empty()) }
    return Fixed(q.Length(), ToastStackView(q))
}

// pipelineHeight returns the fixed row count the Pipeline pane
// occupies. Empty state is the single "(no active turn)" line;
// active state is two rows per dispatched node (connector + box).
// Capped at 8 rows so a wide fan-out doesn't crowd out the team
// panel either.
func pipelineHeight(p PipelineState) int {
    val nodes = p.Nodes.Size()
    if nodes == 0 { return 1 }
    val raw = nodes * 2
    if raw > 8 { return 8 }
    return raw
}

// sidebarHeading is just "Team" — focus is communicated through
// the panel's border weight (see View() / panelBorder), not via
// in-pane text markers or color tints. Keeping the heading text
// stable means screen-readers and copy-paste workflows don't get
// confused by transient suffixes.
func sidebarHeading(m AppModel) string = "  Team"

func sidebarHeadingStyle(m AppModel) Style = DefaultStyle().WithBold()

// conversationPanel renders the chat scrollback as a gala-tui
// ConversationLog: append-only entries with sticky-bottom semantics
// and PgUp/PgDn navigation. Each ConversationLine becomes one entry
// whose intrinsic Height is the wrapped row count at the current
// pane width. The log clamps the scroll offset to its valid range
// every frame, so we don't need to mirror that logic in the model.
func conversationPanel(m AppModel) Widget {
    val header = TextStyled("  Conversation with Team Lead", DefaultStyle().WithBold())
    if m.Conversation.IsEmpty() {
        return Column(ArrayOf[LayoutChild](
            Fixed(1, header),
            Fixed(1, Empty()),
            Fixed(1, TextStyled("  (no conversation yet — type a prompt below)",
                  DefaultStyle().WithDim())),
            Flex(1, Empty()),
        ))
    }
    val width = conversationPaneWidth(m)
    // Walk the conversation lines explicitly so we can build a
    // parallel "log-entry index → conversation-line index" map
    // alongside the flattened entry list. renderConversationLine
    // splits a single conversation line into multiple log entries
    // (prose / code / fence bars), so a click on any entry needs
    // to resolve back to the underlying line for selection.
    var entries = EmptyArray[ConversationEntry]()
    var lineIdxByEntry = EmptyArray[int]()
    var lineIdx = 0
    val totalLines = m.Conversation.Size()
    // Selection range (inclusive): min(anchor, focus) .. max. When
    // both are None the range is (-1, -2) which excludes everything,
    // so isSelected stays false for every line. When only anchor is
    // set (legacy V1-style state) we fall back to single-entry
    // highlight by treating focus = anchor.
    val anchor = m.SelectedEntry.GetOrElse(-1)
    val focus  = m.SelectionFocus.GetOrElse(anchor)
    val rangeLo = if (anchor < focus) anchor else focus
    val rangeHi = if (anchor < focus) focus else anchor
    for lineIdx < totalLines {
        val cl = m.Conversation.Get(lineIdx)
        val isSelected = m.SelectedEntry.IsDefined() && lineIdx >= rangeLo && lineIdx <= rangeHi
        val newEntries = renderConversationLine(m, cl, width, isSelected)
        var k = 0
        val nNew = newEntries.Size()
        for k < nNew {
            entries = entries.Append(newEntries.Get(k))
            lineIdxByEntry = lineIdxByEntry.Append(lineIdx)
            k = k + 1
        }
        lineIdx = lineIdx + 1
    }
    val log = ConversationLog(
        Entries       = entries,
        Offset        = m.ConversationOffset,
        StickToBottom = m.ConversationSticky,
    )
    val viewportH = conversationViewportHeight(m)
    val mapSize = lineIdxByEntry.Size()
    // While a mouse-capturing modal is up, render the log WITHOUT the
    // per-entry drag region. gala-tui resolves a fresh press against
    // drag regions before click regions, so a tiling conversation
    // drag region would otherwise shadow the centered modal's
    // ButtonClick widgets and the buttons would never fire. The
    // non-drag view is visually identical (same layout builder); only
    // the drag-to-select hit registration is dropped — and selecting
    // conversation text while a modal owns input isn't reachable
    // anyway. Restored automatically on the next frame once the modal
    // closes.
    val logWidget = if (modalCapturesMouse(m))
        ConversationLogView(log, viewportH)
    else
        ConversationLogViewDrag[AppMsg](log, viewportH, (logIdx, phase) => {
            // Defensive clamp — gala-tui shouldn't dispatch an out-of-
            // range idx for a non-empty log, but a stale frame is
            // safer to ignore than to crash. Resolves the log-entry
            // idx to a conversation-line idx through the parallel
            // map built above.
            val safe = if (logIdx < 0 || logIdx >= mapSize) -1
                       else lineIdxByEntry.Get(logIdx)
            return ConversationDragMsg(Idx = safe, Phase = phase)
        })
    return Column(ArrayOf[LayoutChild](
        Fixed(1, header),
        Flex(1, logWidget),
    ))
}

// conversationViewportHeight estimates how many rows the conversation
// pane gets at runtime. Total terminal rows minus the chrome (header
// 2 + state line 1 + dividers 2 + composer box 3 + footer 1 + a few
// optional banner rows). Conservative undercount means the
// ConversationLog clamps to a slightly shorter viewport than reality;
// the visible window is still correct, the scrollbar just shows a
// touch more "below" than there actually is — better than overflowing
// the layout.
func conversationViewportHeight(m AppModel) int {
    val (_, rows) = TermSize()
    val h = rows - 12
    if h < 4 { return 4 }
    return h
}

// renderConversationLine produces one or more ConversationEntries for
// a single ConversationLine. Plain prose renders as a single entry
// styled by the speaker. Lines containing fenced code blocks
// (```lang ... ```) split into multiple entries: the prose around
// the fence keeps the speaker color; the code body renders dim with
// a `│ ` left bar so it visually reads as a code block.
//
// We return Array[ConversationEntry] rather than a single composite
// widget because ConversationLog needs an explicit Height per entry
// for sticky-bottom math; a Column widget hides those heights and
// breaks scrollback.
func renderConversationLine(m AppModel, cl session.ConversationLine, width int, isSelected bool) Array[ConversationEntry] {
    // Undelivered lines override the speaker color with a bold-red
    // warning style so a message that never reached its model is
    // impossible to miss while scrolling — the whole rendered block
    // (prose + any code) reads red, and the prefix carries an
    // explicit "⚠ … (not delivered)" tag.
    val baseProseStyle = if (cl.Undelivered)
                             DefaultStyle().WithBold().WithFg(BrightRed())
                         else
                             speakerStyle(m.Team, cl.Speaker)
    val baseCodeStyle = DefaultStyle().WithFg(BrightCyan())
    val baseCodeBarStyle = DefaultStyle().WithFg(BrightCyan()).WithDim()
    // Selection highlight: every entry under the selected line gets
    // reverse-video so the whole rendered message reads as one
    // unambiguous unit, even when it spans prose + code + fence bars.
    val proseStyle    = if (isSelected) baseProseStyle.WithReverse()    else baseProseStyle
    val codeStyle     = if (isSelected) baseCodeStyle.WithReverse()     else baseCodeStyle
    val codeBarStyle  = if (isSelected) baseCodeBarStyle.WithReverse()  else baseCodeBarStyle
    val prefix = if (cl.Undelivered)
                     s"  ⚠ ${cl.Speaker} (not delivered): "
                 else
                     s"  ${cl.Speaker}: "
    // Render directive markers at display time — the conversation
    // log stores raw `@summary` / `@end` / `@dispatch` directives
    // so resume-time Approval recovery can parse them. The view
    // applies formatDirectiveMarkers to swap them for human-readable
    // forms ("Summary:", "→ Target:") before laying out the chunk.
    val displayText = formatDirectiveMarkers(cl.Text)
    // Walk the text line by line, toggling between prose and code on
    // fence markers. The first prose segment keeps the speaker prefix;
    // subsequent prose segments are unprefixed continuations.
    val lines = strings.Split(displayText, "\n")
    var entries = EmptyArray[ConversationEntry]()
    var prose = EmptyArray[string]()
    var code = EmptyArray[string]()
    var inCode = false
    var firstProse = true
    var i = 0
    val n = len(lines)
    for i < n {
        val ln = lines[i]
        val trimmed = strings.TrimSpace(ln)
        if strings.HasPrefix(trimmed, "```") {
            if !inCode {
                // Flush prose, enter code.
                if !prose.IsEmpty() {
                    val raw = (if (firstProse) prefix else "  ") + prose.MkString("\n")
                    entries = entries.Append(ConversationEntry(
                        Body   = ParagraphStyled(raw, proseStyle),
                        Height = paragraphHeight(raw, width),
                    ))
                    prose = EmptyArray[string]()
                    firstProse = false
                }
                val lang = strings.TrimPrefix(trimmed, "```")
                val openLine = if (lang == "") "  ╭───────"
                               else            s"  ╭── ${lang} ──"
                entries = entries.Append(ConversationEntry(
                    Body   = ParagraphStyled(openLine, codeBarStyle),
                    Height = 1,
                ))
                inCode = true
            } else {
                // Flush code, exit.
                if !code.IsEmpty() {
                    val codeBlock = code.Map((c) => "  │ " + c).MkString("\n")
                    entries = entries.Append(ConversationEntry(
                        Body   = ParagraphStyled(codeBlock, codeStyle),
                        Height = paragraphHeight(codeBlock, width),
                    ))
                    code = EmptyArray[string]()
                }
                entries = entries.Append(ConversationEntry(
                    Body   = ParagraphStyled("  ╰───────", codeBarStyle),
                    Height = 1,
                ))
                inCode = false
            }
        } else {
            if inCode {
                code = code.Append(ln)
            } else {
                prose = prose.Append(ln)
            }
        }
        i = i + 1
    }
    // Flush trailing prose (or trailing unclosed code, which we
    // render as code anyway — better to show it than silently swallow).
    if !prose.IsEmpty() {
        val raw = (if (firstProse) prefix else "  ") + prose.MkString("\n")
        entries = entries.Append(ConversationEntry(
            Body   = ParagraphStyled(raw, proseStyle),
            Height = paragraphHeight(raw, width),
        ))
    }
    if !code.IsEmpty() {
        val codeBlock = code.Map((c) => "  │ " + c).MkString("\n")
        entries = entries.Append(ConversationEntry(
            Body   = ParagraphStyled(codeBlock, codeStyle),
            Height = paragraphHeight(codeBlock, width),
        ))
    }
    if entries.IsEmpty() {
        // Empty text — preserve a one-row placeholder so the
        // entry-count stays in sync with Conversation.Size for
        // scrollback math.
        val raw = prefix
        return ArrayOf(ConversationEntry(
            Body   = ParagraphStyled(raw, proseStyle),
            Height = 1,
        ))
    }
    return entries
}

// speakerStyle picks a text style based on who's speaking. Distinct
// colors per role (and per engineer ordinal) so a multi-member turn
// is visually parseable — the user can tell at a glance whether the
// next paragraph is the TL summarising, an engineer reporting, or QA
// pushing back.
//
//   you      → bright white  (the user)
//   TL       → bright cyan
//   engineer → palette cycled by author order: yellow / magenta / blue
//   qa       → bright green
//   unknown  → dim white      (consult target from another team, etc.)
func speakerStyle(team Team, speaker string) Style {
    if speaker == "you" {
        return DefaultStyle().WithBold().WithFg(BrightWhite())
    }
    return MemberByName(team, speaker) match {
        case None()    => DefaultStyle().WithFg(BrightWhite()).WithDim()
        case Some(mem) => DefaultStyle().WithBold().WithFg(MemberColor(team, mem))
    }
}

// memberColor / engineerColor / engineerOrdinal moved to
// app/view/team_panel.gala (exported as MemberColor / EngineerColor /
// EngineerOrdinal) so the sidebar can tint member rows in the same
// hue as their transcript voice. One source of truth, no drift.

// conversationPaneWidth returns how many cells the conversation pane
// gets at the current terminal size: total width minus the 28-cell
// sidebar minus 6 cells of border / padding on both panes.
//
// Probed via TermSize() at view time rather than carried in AppModel
// because (a) the terminal can resize between updates without an
// intervening Msg and (b) we don't want every model-level helper to
// have to thread cols through. A small undercount is safe — lines
// wrap a row or two earlier than necessary, never clip — but a large
// undercount (the prior hardcoded 80) makes paragraphHeight reserve
// huge phantom row counts on wide terminals, leaving giant blank
// gaps between conversation lines.
func conversationPaneWidth(m AppModel) int {
    val (cols, _) = TermSize()
    val w = cols - 28 - 6
    if w < 20 { return 20 }
    return w
}

// paragraphHeight returns the row count `content` will occupy when
// rendered as a Paragraph at the given pane width. Wraps on word
// boundaries, splits on explicit \n. Always at least 1 row even for
// empty content (the `(no conversation yet)` placeholder).
func paragraphHeight(content string, width int) int {
    if width < 1 { return 1 }
    val rows = WrapParagraph(content, width).Size()
    if rows < 1 { return 1 }
    return rows
}

// consultViewerVisibleLines is how many of each consult's most-
// recent stdout lines we render in the modal — the full transcript
// is in the conversation log under speaker `consult/<name>`. Tail
// preview here gives the user a "is the child stuck?" signal without
// fighting the main pane for vertical space.
val consultViewerVisibleLines = 8

// consultViewerMaxEntries caps how many active consults are
// rendered in the modal at once. Each entry is ~10 rows
// (title + tail of consultViewerVisibleLines + spacer), so the
// limit keeps the modal from blowing past a typical 24-row
// terminal even when the lead has fanned out aggressively. The
// remaining consults are surfaced with a "↓ N more open"
// footer-hint row.
val consultViewerMaxEntries = 3

// consultViewerPanel renders the modal overlay listing every active
// cross-team consult with its target team / project header and the
// last few streamed stdout lines. Replaces the main conversation
// pane when AppModel.ConsultViewerOpen is true. With more consults
// open than fit, only the first N are rendered with a "N more
// running" hint below.
func consultViewerPanel(m AppModel) Widget {
    val header = TextStyled("  Consult viewer  (Ctrl+T to close)",
        DefaultStyle().WithBold().WithFg(BrightYellow()))
    val active = m.ActiveConsults
    if active.IsEmpty() {
        return Column(ArrayOf[LayoutChild](
            Fixed(1, header),
            Fixed(1, Empty()),
            Fixed(1, TextStyled(
                "  (no active consults — Ctrl+T again or wait for the lead to @consult someone)",
                DefaultStyle().WithDim())),
            Flex(1, Empty()),
        ))
    }
    val total = active.Size()
    val accum = active.FoldLeftKV(
        Tuple[Array[LayoutChild], int](EmptyArray[LayoutChild](), 0),
        (state, name, sess) => {
            val (rows, count) = state
            if count >= consultViewerMaxEntries {
                return Tuple[Array[LayoutChild], int](rows, count + 1)
            }
            return Tuple[Array[LayoutChild], int](
                rows.AppendAll(consultEntryRows(m, name, sess)),
                count + 1,
            )
        },
    )
    val (rows, _) = accum
    val overflow = total - consultViewerMaxEntries
    val moreHint = if (overflow > 0)
                       ArrayOf[LayoutChild](Fixed(1, TextStyled(
                           s"  ↓ ${overflow} more consult(s) running — see latest.json for full transcripts",
                           DefaultStyle().WithDim())))
                   else
                       EmptyArray[LayoutChild]()
    val children = ArrayOf[LayoutChild](Fixed(1, header), Fixed(1, Empty()))
        .AppendAll(rows)
        .AppendAll(moreHint)
        .Append(Flex(1, Empty()))
    return Column(children)
}

// consultEntryRows renders one consult: a "▶ name @ team · repo" header
// line followed by up to consultViewerVisibleLines tail lines of the
// child team's stdout.
func consultEntryRows(m AppModel, name string, sess ConsultSession) Array[LayoutChild] {
    val title = TextStyled(
        s"  ▶ ${name}  ·  team: ${sess.TeamName}  ·  ${sess.Project.Name}",
        DefaultStyle().WithBold().WithFg(BrightCyan()),
    )
    val buffer = m.ConsultBuffers.Get(name).GetOrElse(EmptyArray[string]())
    val total = buffer.Size()
    val tail = if (total <= consultViewerVisibleLines) buffer
               else                                     buffer.Drop(total - consultViewerVisibleLines)
    val hidden = total - tail.Size()
    val hiddenRow = if (hidden > 0)
                        ArrayOf[LayoutChild](Fixed(1, TextStyled(
                            s"      …${hidden} earlier line(s) hidden",
                            DefaultStyle().WithDim())))
                    else
                        EmptyArray[LayoutChild]()
    val tailRows = if (tail.IsEmpty())
                       ArrayOf[LayoutChild](Fixed(1, TextStyled(
                           "      (waiting for first chunk…)",
                           DefaultStyle().WithDim())))
                   else
                       tail.Map((line) => Fixed(1, TextStyled(
                           s"      ${line}",
                           DefaultStyle().WithFg(BrightCyan()),
                       )))
    return ArrayOf[LayoutChild](Fixed(1, title))
        .AppendAll(hiddenRow)
        .AppendAll(tailRows)
        .Append(Fixed(1, Empty()))
}

func composerWidget(m AppModel) Widget {
    val style = composerStyle(m)
    val rendered = composerRendered(m)
    val (cols, rows) = TermSize()
    val innerW = composerInnerWidth(cols)
    val wrapped = WrapParagraph(rendered, innerW)
    val rawTotal = wrapped.Size()
    val totalRows = if (rawTotal < 1) 1 else rawTotal
    val visibleRows = composerVisibleRows(totalRows, rows)
    if totalRows <= visibleRows {
        return ParagraphStyled(rendered, style)
    }
    // Wrapped content exceeds the panel — slide a viewport over the
    // full paragraph so the row holding the cursor glyph stays in
    // view. ScrollableViewport renders the paragraph into a hidden
    // buffer of `totalRows` rows and copies the visible slice.
    val cursorRow = composerCursorRow(wrapped, totalRows)
    val offset = composerScrollOffset(cursorRow, visibleRows, totalRows)
    return ScrollableViewport(ParagraphStyled(rendered, style), offset, totalRows)
}

// composerStyle picks dim grey for the placeholder, bright white once
// the user has started typing. Split out so composerWidget and the
// future inline-rename / mode-indicator overlays stay in sync.
func composerStyle(m AppModel) Style =
    if (m.Composer == "") DefaultStyle().WithDim()
    else                  DefaultStyle().WithFg(BrightWhite())

// composerRendered builds the displayable string with the cursor
// glyph (▌) inserted at the user's cursor offset. Extracted from
// composerWidget so the height computation in composerOuterHeight
// wraps the exact same string the renderer will, keeping the panel
// height in sync with the visible row count.
//
// Rendering the cursor INSIDE the text (rather than always at the
// end) is what gives the user visual feedback for Left / Right /
// Home / End; without it, every keystroke looks identical regardless
// of where the cursor actually is.
func composerRendered(m AppModel) string {
    if m.Composer == "" {
        return m.PendingQuestion match {
            case Some(pending) => s"  Answer for ${pending.Member}… (Esc to skip)▌"
            case None()        => s"  Type to ${m.Team.Lead.Name}…▌"
        }
    }
    val rs = ToRunes(m.Composer)
    val n = len(rs)
    val cur = clampCursor(m.ComposerCursor, n)
    val left = string(SliceTo(rs, cur))
    val right = string(SliceFrom(rs, cur))
    return s"  ${left}▌${right}"
}

// composerInnerWidth returns the cells available for composer content
// at the given terminal width — total cols minus the 2 cells of side
// border. Floored at 8 so wrap math stays sane on absurdly narrow
// terminals (the rendered string would still clip but won't divide-
// by-zero or loop forever).
func composerInnerWidth(cols int) int {
    val w = cols - 2
    if w < 8 { return 8 }
    return w
}

// composerCap returns the maximum inner content rows the composer
// panel will grow to: never more than half the terminal height and
// never more than 12 rows. Floors at 1 so the placeholder always
// renders even on a minuscule terminal.
func composerCap(rows int) int {
    val byHalf = rows / 2
    val capped = if (byHalf < 12) byHalf else 12
    if capped < 1 { return 1 }
    return capped
}

// composerVisibleRows returns the inner content rows the panel will
// reserve: min(needed, cap). Pulled out so composerWidget and
// composerOuterHeight can't drift.
func composerVisibleRows(totalRows int, termRows int) int {
    val cap = composerCap(termRows)
    if totalRows < cap { return totalRows }
    return cap
}

// composerCursorRow finds the wrapped-line index that contains the
// cursor glyph "▌". Used to compute the scroll offset that keeps the
// cursor on screen. If the glyph isn't found (composerRendered always
// inserts one, but be defensive), pin to the last row so end-of-text
// stays visible.
func composerCursorRow(wrapped Array[string], totalRows int) int {
    var i = 0
    for i < totalRows {
        if strings.Contains(wrapped.Get(i), "▌") {
            return i
        }
        i = i + 1
    }
    return totalRows - 1
}

// composerScrollOffset picks the viewport offset that keeps the
// cursor row visible. Cursor in the first `visibleRows` lines stays
// pinned to the top of the panel; below that, the viewport slides
// down so the cursor sits on the last visible row.
func composerScrollOffset(cursorRow int, visibleRows int, totalRows int) int {
    if cursorRow < visibleRows { return 0 }
    val want = cursorRow - visibleRows + 1
    val maxOffset = totalRows - visibleRows
    if want > maxOffset { return maxOffset }
    return want
}

// composerOuterHeight returns the panel's outer height — visible
// content rows plus 2 for the top/bottom border. Mirrors
// composerWidget's wrap so the layout slot exactly fits the rendered
// content (no blank rows below the text, no clipped cursor row).
func composerOuterHeight(m AppModel) int {
    val (cols, rows) = TermSize()
    val innerW = composerInnerWidth(cols)
    val wrapped = WrapParagraph(composerRendered(m), innerW)
    val rawTotal = wrapped.Size()
    val totalRows = if (rawTotal < 1) 1 else rawTotal
    return composerVisibleRows(totalRows, rows) + 2
}

// footerWidget chooses what one-line legend to render at the
// bottom of the screen. Quit confirmation wins (a transient,
// safety-critical prompt — only Esc or a second Ctrl+C resolves
// it), then any recent error, then the context-appropriate key
// hints.
func footerWidget(m AppModel) Widget {
    if m.QuitPending {
        return TextStyled(
            "  ⚠ Quit? Press Ctrl+Q again to confirm · Esc to cancel",
            DefaultStyle().WithBold().WithFg(BrightYellow()),
        )
    }
    if m.EraseSessionPending {
        return TextStyled(
            "  ⚠ Erase session? Press Ctrl+N again to confirm · Esc to cancel",
            DefaultStyle().WithBold().WithFg(BrightYellow()),
        )
    }
    // LastError is rendered as a separate banner above the composer
    // (see errorBanner) so it doesn't sit on top of the keybind row.
    // The footer always shows the keybind hints; quit/erase prompts
    // override above so the user can see the safety prompt clearly.
    return TextStyled(footerHints(m), DefaultStyle().WithDim())
}

// activityBand is the full-width status strip rendered above the
// composer. It is the single home for the variable-length, actionable
// text the narrow sidebar can't hold:
//
//   • one row per ACTIVE member — animated spinner glyph + name +
//     work timer + the live workflow phase (or a status word). The
//     glyph cycles on m.Tick so an active row visibly spins, matching
//     the sidebar's spinner cadence.
//   • a ⚠ error row sourced from LastError, carrying a remedy hint —
//     so an error is shown once, in one place, with something the user
//     can act on (instead of a raw envelope echoed in both a toast and
//     a footer bar). It is not manually dismissable; transient liveness
//     notices clear automatically at the next at-rest checkpoint (see
//     reconcileActivityAtRest), and the record stays in the Activity
//     log + debug trace.
//
// Renders 0 rows when the team is quiescent and there's no error, so
// the strip is invisible at rest. Member rows are capped so a wide
// fan-out can't crowd out the conversation.
// bandSpinnerFrames mirrors the team panel's braille spinner so the
// Activity band's animated glyphs share the sidebar's visual cadence.
// (The canonical set lives in package view but is private to it.)
val bandSpinnerFrames = ArrayOf("⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏")

// bandSpinnerIdx clamps `tick` into the frame range, handling negative
// ticks defensively (hand-built test models).
func bandSpinnerIdx(tick int) int {
    val n = bandSpinnerFrames.Size()
    if n == 0 { return 0 }
    val raw = tick % n
    if raw < 0 { return raw + n }
    return raw
}

// bandGlyph picks the band row's left marker, cycling the spinner on
// `tick` for working/slow members so the row visibly animates. Mirrors
// the sidebar's statusGlyph.
func bandGlyph(status Status, tick int) string = status match {
    case StIdle()           => "◇"
    case StQueued()         => "○"
    case StWorking()        => bandSpinnerFrames.Get(bandSpinnerIdx(tick))
    case StSlow()           => bandSpinnerFrames.Get(bandSpinnerIdx(tick / 2))  // half-speed
    case StStuck()          => "!"
    case StRecovering(_, _) => "↻"
    case StHelpWaiting(_)   => "?"
    case StDone()           => "✓"
    case StFailed(_)        => "✗"
}

// bandPad right-pads `s` with spaces to `width`; returns `s` unchanged
// when it already meets/exceeds the width.
func bandPad(s string, width int) string {
    val deficit = width - len(s)
    if deficit <= 0 { return s }
    return s + strings.Repeat(" ", deficit)
}

func activityBand(m AppModel) LayoutChild {
    val (cols, _) = TermSize()
    val memberRows = activeMemberRows(m, cols)
    val hasErr = m.LastError.IsDefined()
    if memberRows.IsEmpty() && !hasErr { return Fixed(0, Empty()) }
    val header = ArrayOf[LayoutChild](
        Fixed(1, TextStyled("  Activity", DefaultStyle().WithBold())),
    )
    val withErr = m.LastError match {
        case Some(err) => header.Append(Fixed(1, TextStyled(
            capForBand(s"  ⚠ ${err}${errorRemedy(err)}", cols),
            DefaultStyle().WithFg(BrightRed()))))
        case None()    => header
    }
    val children = memberRows.FoldLeft(withErr, (acc, w) => acc.Append(Fixed(1, w)))
    return Fixed(children.Size(), Column(children))
}

// activityBandMaxRows caps how many member rows the band shows so a
// large fan-out can't push the conversation off-screen. Overflow is
// summarised in a trailing "…and N more" row.
func activityBandMaxRows() int = 8

// activeMemberRows builds one band row per active member of the main
// team, in team order, capped at activityBandMaxRows.
func activeMemberRows(m AppModel, cols int) Array[Widget] {
    val active = m.Team.Members.FoldLeft(EmptyArray[Member](), (acc, mem) => {
        val st = m.Statuses.Get(mem.Name).GetOrElse(StIdle())
        if (isActiveStatus(st)) acc.Append(mem) else acc
    })
    if active.IsEmpty() { return EmptyArray[Widget]() }
    val shown = active.FoldLeft(EmptyArray[Widget](), (acc, mem) => {
        if (acc.Size() >= activityBandMaxRows()) acc
        else                                     acc.Append(activityMemberRow(m, mem, cols))
    })
    if active.Size() <= activityBandMaxRows() { return shown }
    val extra = active.Size() - activityBandMaxRows()
    return shown.Append(TextStyled(s"  …and ${extra} more active", DefaultStyle().WithDim()))
}

// activityMemberRow renders one full-width member row: animated glyph +
// padded name + work timer + descriptive detail. The text is capped to
// the terminal width so a long workflow phase can't wrap and corrupt
// the layout below.
func activityMemberRow(m AppModel, mem Member, cols int) Widget {
    val status = m.Statuses.Get(mem.Name).GetOrElse(StIdle())
    val glyph = bandGlyph(status, m.Tick)
    val timer = totalWorkFor(m, mem.Name, isRunningStatus(status))
    val timerCol = if (timer == "") "     " else bandPad(timer, 5)
    // Keep the glyph/name/timer columns intact and give only the
    // detail the remaining width. The detail is MIDDLE-truncated, not
    // tail-truncated: a member's phase often ends in the part that
    // matters (the file being edited, the destination of a long
    // `cd <path>`), so dropping the tail throws away the signal and
    // leaves the redundant prefix. capMiddle keeps both ends.
    val prefix = s"  ${glyph} ${bandPad(mem.Name, 10)} ${timerCol} "
    val budget = MaxInt(8, cols - 1 - visibleWidth(prefix))
    val detail = capMiddle(activityDetail(m, mem.Name, status), budget)
    return TextStyled(prefix + detail, activityRowStyle(status))
}

// isActiveStatus is true for the statuses that warrant a band row —
// anything the user might want to watch or act on. Idle / queued /
// done members are quiescent and stay out so the band collapses to
// nothing when the team is at rest.
func isActiveStatus(status Status) bool = status match {
    case StWorking()        => true
    case StSlow()           => true
    case StStuck()          => true
    case StRecovering(_, _) => true
    case StHelpWaiting(_)   => true
    case StFailed(_)        => true
    case StIdle()           => false
    case StQueued()         => false
    case StDone()           => false
}

// isRunningStatus is true when the member's work timer should include
// the live in-flight segment (still actively working). Failed /
// help-waiting members are paused, so their timer shows the frozen
// accumulated total.
func isRunningStatus(status Status) bool = status match {
    case StWorking()        => true
    case StSlow()           => true
    case StStuck()          => true
    case StRecovering(_, _) => true
    case _                  => false
}

// activityDetail is the right-hand descriptive text for a member's
// band row. Prefers the live workflow phase (the claude-code Workflow
// task_progress label) when one is in flight; otherwise falls back to
// a status word so the row is never blank.
func activityDetail(m AppModel, name string, status Status) string {
    val phase = m.WorkflowStatus.Get(name).GetOrElse("")
    return status match {
        case StFailed(reason)    => if (reason == "") "failed" else s"failed — ${reason}"
        case StHelpWaiting(q)    => if (q == "") "needs help" else s"needs help — ${q}"
        case StRecovering(a, mx) => if (phase == "") s"recovering (retry ${a}/${mx})"
                                    else              s"recovering (retry ${a}/${mx}) · ${phase}"
        case StStuck()           => if (phase == "") "stuck — no output yet" else s"stuck · ${phase}"
        case StSlow()            => if (phase == "") "slow — still working"   else s"slow · ${phase}"
        case StWorking()         => if (phase == "") "working"                else phase
        case _                   => phase
    }
}

// activityRowStyle colours a band row by severity: red for things that
// need attention (failed / stuck), yellow for caution (slow / help),
// cyan for healthy in-flight work, default otherwise.
func activityRowStyle(status Status) Style = status match {
    case StFailed(_)        => DefaultStyle().WithFg(BrightRed())
    case StStuck()          => DefaultStyle().WithFg(BrightRed())
    case StSlow()           => DefaultStyle().WithFg(BrightYellow())
    case StHelpWaiting(_)   => DefaultStyle().WithFg(BrightYellow())
    case StRecovering(_, _) => DefaultStyle().WithFg(BrightCyan())
    case StWorking()        => DefaultStyle().WithFg(BrightCyan())
    case _                  => DefaultStyle()
}

// capForBand clamps a band line to the terminal width (minus a column
// of breathing room) with an ellipsis, so a long workflow phase or
// error message never wraps into the row below.
func capForBand(s string, cols int) string {
    val maxw = MaxInt(8, cols - 1)
    val rs = ToRunes(s)
    if len(rs) <= maxw { return s }
    return runesPrefix(s, maxw - 1) + "…"
}

// capMiddle clamps `s` to `width` runes by dropping the MIDDLE and
// joining head and tail with a single ellipsis. Unlike capForBand
// (which drops the tail), this keeps the informative END of a value —
// the file/destination a long phase ends in — which is usually what
// the reader is actually watching for. Used for band member-row
// detail; the error row keeps capForBand since errors read head-first.
func capMiddle(s string, width int) string {
    val w = MaxInt(8, width)
    val rs = ToRunes(s)
    if len(rs) <= w { return s }
    val budget = w - 1            // one column for the ellipsis
    val head = budget / 2
    val tail = budget - head      // tail gets the odd column
    return runesPrefix(s, head) + "…" + runesSuffix(s, tail)
}

// runesSuffix returns the last `n` runes of `s` (the whole string when
// it is already shorter). Rune-safe counterpart to runesPrefix.
func runesSuffix(s string, n int) string {
    val rs = ToRunes(s)
    if len(rs) <= n || n < 0 { return s }
    var out = EmptyArray[string]()
    var i = len(rs) - n
    for i < len(rs) {
        out = out.Append(string(rs[i]))
        i = i + 1
    }
    return out.MkString("")
}

// errorRemedy maps a known LastError shape to a short actionable hint
// appended to the band's error row. Returns "" for errors we have no
// specific remedy for — the raw message still shows.
func errorRemedy(err string) string {
    val low = strings.ToLower(err)
    if strings.Contains(low, "auth") || strings.Contains(low, "login") || strings.Contains(low, "credential") {
        return " — run `claude /login`, then re-send"
    }
    if strings.Contains(low, "rate") && strings.Contains(low, "limit") {
        return " — rate limited, retry shortly"
    }
    if strings.Contains(low, "session id") {
        return " — will respawn fresh on next send"
    }
    return ""
}

// planPanel renders the active multi-PR plan as a BORDERED panel
// (one row per step) directly below the chat log. Hidden (0 rows)
// when no plan is active or the plan has fully drained.
//
//   ╭───────────────────────────────────────────────╮
//   │  📋 Plan — step 2 of 4                          │
//   │  ✓ 1. Remove the approve/reject hotkeys         │
//   │  ▶ 2. Custom post-engineer prompt hook          │
//   │  ☐ 3. FSM hardening — directive replay          │
//   │  ☐ 4. FSM hardening — heartbeat races           │
//   ╰───────────────────────────────────────────────╯
//
// Each step is flattened to ONE line (whitespace collapsed) and
// truncated to the pane width before rendering. The old single-line
// banner crammed the whole in-progress step body — newlines and all —
// into one row, so a multi-sentence plan item overflowed and visually
// collided with the chat box border (the garbled overlap users saw).
// A row per step + per-step truncation removes that failure mode and
// makes "what's done / running / queued" scannable at a glance.
//
// Steps are windowed to keep a long plan from eating the screen: at
// most planPanelMaxRows steps are shown, always including the
// in-progress one, with "⋯ N earlier / N more" markers.
val planPanelMaxRows = 8

func planPanel(m AppModel) LayoutChild {
    if m.Plan.IsEmpty() { return Fixed(0, Empty()) }
    val total   = m.Plan.Size()
    val shipped = m.PlanShipped
    // shipped >= total is NOT "no plan" — it's "plan finished". The
    // panel must NOT vanish here: for steps 1..N-1 finishing a PR
    // visibly advances the panel to the next step, so for the LAST
    // step it has to advance to a terminal "all shipped" state, not
    // disappear. Vanishing at the finish line removed the one
    // persistent confirmation that every step landed. The completed
    // panel sticks around until m.Plan is cleared by the next genuine
    // user prompt (onSubmit, non-continuation) — the right lifetime.
    val complete = shipped >= total
    val (cols, _) = TermSize()
    val bodyMax = MaxInt(20, cols - 16)
    val titleRow = if (complete)
        Fixed(1, TextStyled(
            s"  📋 Plan complete — ${total}/${total} PRs shipped",
            DefaultStyle().WithBold().WithFg(BrightGreen())))
    else
        Fixed(1, TextStyled(
            s"  📋 Plan — step ${shipped + 1} of ${total}",
            DefaultStyle().WithBold().WithFg(BrightCyan())))
    val startIdx = if (total <= planPanelMaxRows) 0
                   else MinInt(MaxInt(0, shipped - 1), total - planPanelMaxRows)
    val endIdx = MinInt(total, startIdx + planPanelMaxRows)
    var rows = ArrayOf[LayoutChild](titleRow)
    if startIdx > 0 {
        rows = rows.Append(Fixed(1, TextStyled(
            s"     ⋯ ${startIdx} earlier step(s)", DefaultStyle().WithDim())))
    }
    var i = startIdx
    for i < endIdx {
        val flat = strings.Join(strings.Fields(m.Plan.Get(i)), " ")
        val glyph = if (i < shipped) "✓" else if (i == shipped) "▶" else "☐"
        val st = if (i < shipped)       DefaultStyle().WithFg(BrightGreen())
                 else if (i == shipped) DefaultStyle().WithBold().WithFg(BrightCyan())
                 else                   DefaultStyle().WithDim()
        rows = rows.Append(Fixed(1, TextStyled(
            s"  ${glyph} ${i + 1}. ${truncateTitle(flat, bodyMax)}", st)))
        i = i + 1
    }
    if endIdx < total {
        rows = rows.Append(Fixed(1, TextStyled(
            s"     ⋯ ${total - endIdx} more step(s)", DefaultStyle().WithDim())))
    }
    return Fixed(rows.Size() + 2, BorderOf(Column(rows), RoundedBorder()))
}

// footerHints picks a context-appropriate key legend. There is no
// merge hint — merging is done on GitHub after approval, never from
// the app, so an open PR doesn't change the legend.
// Quit is bound to Ctrl+Q (with two-press confirmation); Ctrl+C
// is gala-tui's hard-kill backstop and isn't advertised. Quit
// comes first so it survives narrow-terminal clipping; new users
// always need to know how to exit. Tab moves focus to the sidebar
// (Ctrl+L is the alias); Ctrl+T toggles the consult viewer modal;
// Ctrl+H opens the saved-archive browser.
func footerHints(m AppModel) string {
    // Selection-aware override. When the user has clicked or
    // drag-selected a conversation entry (or a range of them), the
    // footer should advertise the actions specific to selection —
    // Ctrl+Y copy, Esc clear — rather than the default Enter-send
    // hints which aren't useful while reviewing a highlighted range.
    // Without this, users reported "I select text in the chat box
    // but I no longer see the menu with Ctrl-Y etc." — the reverse-
    // video highlight was the only feedback that anything had
    // happened.
    if m.SelectedEntry.IsDefined() {
        val isRange = m.SelectionFocus match {
            case Some(focus) => m.SelectedEntry match {
                case Some(anchor) => anchor != focus
                case None()       => false
            }
            case None()      => false
        }
        val label = if (isRange) "selected range" else "selected entry"
        return s"  ${label} · Ctrl+Y copy · Esc clear · Ctrl+P palette · F6 help · Ctrl+Q quit"
    }
    return m.Focus match {
        case FocusSidebar() => "  ↑↓ navigate · Space fold/unfold · Esc composer · F2/F3/F4/F5 views · F6 help · Ctrl+Q quit"
        case FocusComposer() => {
            if (m.AutoApprove) {
                // AutoApprove drops the approval hints — the gate is
                // off. No merge hint: open PRs are merged on GitHub.
                return "  Enter send · F7 auto:on · Ctrl+P palette · F1-F5 views · F6 help · Ctrl+Q quit"
            }
            return "  Enter send · Ctrl+P palette · F1-F5 views · F6 help · Ctrl+Q quit"
        }
    }
}

// stateLabel pretty-prints the current AppState for the header line.
func stateLabel(s AppState) string = s match {
    case Idle()           => "state: idle"
    case TLThinking()     => "state: TL thinking"
    case Delegating(_, _)    => "state: delegating"
    case QAGate(_, _)        => "state: QA gate"
    case TLReview()       => "state: TL review"
    case TLNudging(why, _, _) => s"state: TL nudging (${why})"
    case Approval(_)      => "state: approval"
}

// ----------------------------------------------------------------------------
// History browser
// ----------------------------------------------------------------------------

// historyPanel renders the read-only browser. With no archive
// selected, shows the index list (cursor-highlighted entry, savedAt,
// project name, line count). When ViewingArchive is set, shows that
// archive's full conversation and a hint to press Esc.
func historyPanel(m AppModel) Widget = m.ViewingArchive match {
    case Some(snap) => historyDetailPanel(m, snap)
    case None()     => historyIndexPanel(m)
}



// historyIndexVisibleRows is the soft cap on rendered archive
// rows. With more, the window slides so HistoryCursor stays in
// view (same scrolling treatment as the team sidebar). Picked to
// fill a reasonable fraction of the main pane without crowding
// the conversation pane behind it.
val historyIndexVisibleRows = 18

// historyIndexPanel renders the list of past archives. Empty case
// surfaces a friendly "no merges yet" so first-time users understand
// the lifecycle. When the archive list overflows
// historyIndexVisibleRows, the window scrolls to keep
// HistoryCursor on screen with "↑/↓ N more" hints at the edges.
func historyIndexPanel(m AppModel) Widget {
    val header = TextStyled(
        "  History  ·  ↑↓ navigate · Enter open · Ctrl+H close",
        DefaultStyle().WithBold().WithFg(BrightYellow()),
    )
    if m.Archives.IsEmpty() {
        return Column(ArrayOf[LayoutChild](
            Fixed(1, header),
            Fixed(1, Empty()),
            Fixed(1, TextStyled(
                "  (no archives yet — sessions are saved here on every successful merge)",
                DefaultStyle().WithDim())),
            Flex(1, Empty()),
        ))
    }
    val rows = scrolledHistoryRows(m)
    val children = ArrayOf[LayoutChild](Fixed(1, header), Fixed(1, Empty()))
        .AppendAll(rows)
        .Append(Flex(1, Empty()))
    return Column(children)
}

// scrolledHistoryRows builds the visible window of archive rows
// around HistoryCursor. Reuses the same scrollStart / "N more"
// hint convention as the team sidebar so the two scrollable
// panels feel consistent.
func scrolledHistoryRows(m AppModel) Array[LayoutChild] {
    val total = m.Archives.Size()
    if total <= historyIndexVisibleRows {
        return m.Archives.ZipWithIndex().Map((pair) => Fixed(
            1,
            archiveRowWidget(pair.V1, pair.V2 == m.HistoryCursor),
        ))
    }
    val start = scrollStartGeneric(m.HistoryCursor, total, historyIndexVisibleRows)
    val end = start + historyIndexVisibleRows
    val above = start
    val below = total - end
    var out = EmptyArray[LayoutChild]()
    var i = start
    for i < end {
        val widget = if (i == start && above > 0)
                         scrollEdgeHint(s"  ↑ ${above} more above")
                     else if (i == end - 1 && below > 0)
                         scrollEdgeHint(s"  ↓ ${below} more below")
                     else
                         archiveRowWidget(m.Archives.Get(i), i == m.HistoryCursor)
        out = out.Append(Fixed(1, widget))
        i = i + 1
    }
    return out
}

// scrollStartGeneric is the local copy of app/view's scrollStart
// — same algorithm, kept here so app/ui doesn't have to depend on
// app/view's helper. Cursor < 0 anchors the window at 0; cursor
// past the upper half slides the window down; the result is
// always within [0, total - windowH].
func scrollStartGeneric(cursor int, total int, windowH int) int {
    if cursor < 0 { return 0 }
    if cursor < windowH { return 0 }
    val maxStart = total - windowH
    val want = cursor - windowH + 1
    if want > maxStart { return maxStart }
    return want
}

func scrollEdgeHint(text string) Widget = TextStyled(text, DefaultStyle().WithDim())

// archiveRowWidget renders one entry in the history index. The
// cursor-highlighted row gets a "▶ " prefix and bright styling;
// other rows are dim.
func archiveRowWidget(meta session.SnapshotMeta, isCursor bool) Widget {
    val marker = if (isCursor) "▶ " else "  "
    val text = s"  ${marker}${formatSavedAt(meta.SavedAt)}  ·  ${meta.Label}  ·  ${meta.ProjectName}  (${meta.LineCount} lines)"
    val style = if (isCursor) DefaultStyle().WithBold().WithFg(BrightCyan())
                else          DefaultStyle().WithDim()
    return TextStyled(text, style)
}

// historyDetailPanel renders a fully-loaded archive in read-only
// mode. Tail-clips at a fixed cap (the history modal isn't yet
// wired to the scrollable ConversationLog widget — that's a future
// follow-up; the live conversation pane uses the scrollable path).
val historyVisibleLines = 20

func historyDetailPanel(m AppModel, snap session.Snapshot) Widget {
    val header = TextStyled(
        s"  ${formatSavedAt(snap.SavedAt)}  ·  ${snap.ProjectName}  ·  Esc to return to index",
        DefaultStyle().WithBold().WithFg(BrightYellow()),
    )
    val all = snap.Conversation
    val total = all.Size()
    val visible = if (total <= historyVisibleLines) all
                  else                              all.Drop(total - historyVisibleLines)
    val hidden = total - visible.Size()
    val hiddenLine = if (hidden > 0)
                         ArrayOf[LayoutChild](Fixed(1, TextStyled(
                             s"  …${hidden} earlier line(s) hidden",
                             DefaultStyle().WithDim())))
                     else
                         EmptyArray[LayoutChild]()
    val lines = visible.Map((cl session.ConversationLine) => Fixed(
        1,
        TextStyled(s"  ${cl.Speaker}: ${cl.Text}", speakerStyle(m.Team, cl.Speaker)),
    ))
    val body = hiddenLine.AppendAll(lines)
    val children = ArrayOf[LayoutChild](Fixed(1, header), Fixed(1, Empty()))
        .AppendAll(body)
        .Append(Flex(1, Empty()))
    return Column(children)
}

// formatSavedAt converts a unix-nano timestamp into a friendly
// "YYYY-MM-DD HH:MM" string so the index doesn't look like a list
// of `1714233600000000000`.
func formatSavedAt(ns int64) string {
    val secs = ns / int64(1000000000)
    val rem  = ns - secs * int64(1000000000)
    return time.Unix(secs, rem).Format("2006-01-02 15:04")
}
