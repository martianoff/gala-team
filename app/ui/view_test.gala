// Closed: history panel doesn't render.
func TestView_History_Closed_RendersConversation(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsFalse(t, strings.Contains(out, "History  ·"))
}

// Opened with no archives: empty-state explains the lifecycle.
func TestView_History_OpenEmpty_ShowsHint(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(HistoryMode = true)
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "History  ·"))
    return IsTrue(t1, strings.Contains(out, "no archives yet"))
}

// Opened with archives: index list shows each entry's project + line count.
func TestView_History_OpenWithArchives_RendersIndex(t T) T {
    val a1 = sampleArchiveV(int64(1714233600000000000), "merged", "myproject", 47)
    val a2 = sampleArchiveV(int64(1714074600000000000), "merged", "myproject", 62)
    val m = mkModel(mkTeam("X", "")).Copy(
        HistoryMode = true,
        Archives    = ArrayOf(a1, a2),
    )
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "myproject"))
    val t2 = IsTrue(t1, strings.Contains(out, "47 lines"))
    return IsTrue(t2, strings.Contains(out, "62 lines"))
}

// Cursor on first entry: that entry has the "▶ " prefix; others don't.
func TestView_History_Index_HighlightsCursoredEntry(t T) T {
    val a1 = sampleArchiveV(int64(2000000000000000000), "merged", "alpha", 10)
    val a2 = sampleArchiveV(int64(1000000000000000000), "merged", "beta", 20)
    val m = mkModel(mkTeam("X", "")).Copy(
        HistoryMode   = true,
        Archives      = ArrayOf(a1, a2),
        HistoryCursor = 0,
    )
    val out = render(m)
    // "▶ " followed by the first entry's project name (alpha) should appear.
    return IsTrue(t, strings.Contains(out, "▶ "))
}

// Selecting an archive (ViewingArchive set) renders its conversation in
// read-only mode.
func TestView_History_Detail_RendersSnapshotConversation(t T) T {
    val convo = ArrayOf(
        session.ConversationLine(Speaker = "you", Text = "ship it"),
        session.ConversationLine(Speaker = "Iris", Text = "on it"),
    )
    val snap = session.Snapshot("demo", int64(1714233600000000000), convo, EmptyArray[string]())
    val m = mkModel(mkTeam("X", "")).Copy(
        HistoryMode    = true,
        ViewingArchive = Some(snap),
    )
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "Esc to return to index"))
    val t2 = IsTrue(t1, strings.Contains(out, "ship it"))
    return IsTrue(t2, strings.Contains(out, "on it"))
}

// ---------------------------------------------------------------------------
// Pane precedence: history mode wins over consult viewer
// ---------------------------------------------------------------------------

func TestView_HistoryMode_BeatsConsultViewer(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        HistoryMode       = true,
        ConsultViewerOpen = true,
    )
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "History  ·"))
    return IsFalse(t1, strings.Contains(out, "Consult viewer"))
}

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

func sampleArchiveV(savedAt int64, label string, projectName string, lineCount int) session.SnapshotMeta =
    session.SnapshotMeta(
        Path        = s"/fake/archive/${label}-${savedAt}.json",
        Label       = label,
        ProjectName = projectName,
        SavedAt     = savedAt,
        LineCount   = lineCount,
    )

// ---------------------------------------------------------------------------
// Edge cases — oversized inputs
// ---------------------------------------------------------------------------

// Oversized team name shouldn't crash the layout. We assert the
// rendered output is non-empty and includes the state label so the
// header line still functions.
func TestView_Header_VeryLongTeamName_DoesNotCrash(t T) T {
    val longName = strings.Repeat("Skunkworks", 30)  // 300 chars
    val out = render(mkModel(mkTeam(longName, "")))
    val t1 = IsTrue(t, len(out) > 0)
    return IsTrue(t1, strings.Contains(out, "state: idle"))
}

// Oversized description gets clipped by the viewport — we don't
// guarantee it's all visible, only that the layout doesn't break.
func TestView_Header_VeryLongDescription_DoesNotCrash(t T) T {
    val longDesc = strings.Repeat("a long product team description ", 20)
    val out = render(mkModel(mkTeam("X", longDesc)))
    return IsTrue(t, len(out) > 0)
}

// 60+ rune approval body must truncate — the rendered banner still
// renders the "Ready to ship" prefix and doesn't crash. We can't
// reliably assert the "..." indicator survives the viewport's right-
// column clipping (sidebar takes 28 cols of 100), so we test the
// invariant that always holds: the banner header is present and
// the layout below it (composer / footer hint) still renders.
// Oversized summary body still fits because the modal flattens / caps
// the first line at 70 cols (approvalFirstLine). Just assert the modal
// renders without crashing.
func TestView_ApprovalBanner_OversizedBody_DoesNotCrash(t T) T {
    val big = strings.Repeat("ship the metrics endpoint ", 10)
    val m = mkModel(mkTeam("X", "")).Copy(State = Approval(SummaryBody = big))
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "Open PR?"))
    return IsTrue(t1, strings.Contains(out, "Yes"))
}

// Composer with a string longer than the viewport renders without
// crashing; the trailing cursor caret "▌" stays visible.
func TestView_Composer_VeryLongText_DoesNotCrash(t T) T {
    val long = strings.Repeat("ship the metrics endpoint ", 20)  // ~520 chars
    val m = mkModel(mkTeam("X", "")).Copy(Composer = long)
    val out = render(m)
    return IsTrue(t, len(out) > 0)
}

// 200-line conversation now goes through ConversationLog. Sticky
// bottom keeps the most recent line on-screen; older lines aren't
// "hidden" in the old sense — they're just scrolled-off (PgUp brings
// them back).
func TestView_Conversation_TwoHundredLines_ReportsHidden(t T) T {
    var convo = EmptyArray[session.ConversationLine]()
    var i = 0
    for i < 200 {
        convo = convo.Append(session.ConversationLine(Speaker = "Iris", Text = s"line ${i}"))
        i = i + 1
    }
    val m = mkModel(mkTeam("X", "")).Copy(Conversation = convo)
    val out = render(m)
    return IsTrue(t, strings.Contains(out, "line 199"))
}

// One conversation line with a very long Text. The renderer doesn't
// wrap it (TUI single-line widget), so the layout shouldn't corrupt
// downstream rows. Just assert the speaker prefix made it.
// Long line wraps inside the Paragraph-rendered ConversationLog
// entry. We don't assert "Iris:" because the speaker prefix may sit
// on its own row when the line wraps; just check the rendered text
// contains a known token from the body.
func TestView_Conversation_VeryLongLine_DoesNotCrash(t T) T {
    val convo = ArrayOf(session.ConversationLine(
        Speaker = "Iris",
        Text    = strings.Repeat("very long output ", 50),  // ~850 chars
    ))
    val m = mkModel(mkTeam("X", "")).Copy(Conversation = convo)
    val out = render(m)
    return IsTrue(t, strings.Contains(out, "very long"))
}

// ---------------------------------------------------------------------------
// Recovery banner — appears above the conversation pane when a prior
// session was loaded at startup (cmd/main.gala::primeFromSnapshot
// sets RecoveryBannerVisible).
// ---------------------------------------------------------------------------

func TestView_RecoveryBanner_HiddenByDefault(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsFalse(t, strings.Contains(out, "Restored"))
}

func TestView_RecoveryBanner_ShowsLineAndAgentCounts(t T) T {
    val convo = ArrayOf(session.ConversationLine(Speaker = "you", Text = "ship"))
    val m = mkModel(mkTeam("X", "")).Copy(
        Conversation          = convo,
        RecoveredMembers      = ArrayOf("Iris", "Felix"),
        RecoveryBannerVisible = true,
    )
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "Restored"))
    val t2 = IsTrue(t1, strings.Contains(out, "1 line"))
    val t3 = IsTrue(t2, strings.Contains(out, "2 agents pending"))
    return IsTrue(t3, strings.Contains(out, "type a prompt to continue"))
}

func TestView_RecoveryBanner_NoAgentsPending_OmitsAgentNote(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        Conversation          = ArrayOf(session.ConversationLine(Speaker = "you", Text = "x")),
        RecoveredMembers      = EmptyArray[string](),
        RecoveryBannerVisible = true,
    )
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "Restored"))
    return IsFalse(t1, strings.Contains(out, "agent"))
}

// ---------------------------------------------------------------------------
// Sidebar focus indicator — the focused panel switches from a
// rounded border to a thick border. The heading text is identical
// in both states; the border weight is the only "you are here"
// signal.
// ---------------------------------------------------------------------------

func TestView_Sidebar_RoundedBorder_WhenComposerFocused(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    // Rounded corners — the unfocused border kind.
    val t1 = IsTrue(t,  strings.Contains(out, "╭"))
    return IsFalse(t1, strings.Contains(splitTopBorder(out), "┏"))
}

func TestView_Sidebar_ThickBorder_WhenSidebarFocused(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(Focus = FocusSidebar())
    // A thick top-border glyph appears somewhere on screen.
    return IsTrue(t, strings.Contains(render(m), "┏"))
}

// splitTopBorder returns just the top border line so we can assert
// "no thick glyph in the SIDEBAR border" without false positives
// from the composer / mainpanel borders below. The sidebar's top
// border sits immediately under the header — at row HeaderRowsWide
// in wide mode (viewportW = 100, the test default), or
// HeaderRowsNarrow in the narrow fallback.
func splitTopBorder(out string) string {
    val lines = strings.Split(out, "\n")
    val headerRows = if (viewportW < HeaderNarrowCols()) HeaderRowsNarrow()
                     else                                 HeaderRowsWide()
    if len(lines) <= headerRows { return out }
    return lines[headerRows]
}

// ---------------------------------------------------------------------------
// Sidebar fold/unfold — collapsed groups render "▶ <Name>" and hide
// their member rows; expanded groups render "▼ <Name>" with rows.
// ---------------------------------------------------------------------------

func TestView_Sidebar_AllGroupsExpandedByDefault(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    val t1 = IsTrue(t, strings.Contains(out, "▼ Lead"))
    val t2 = IsTrue(t1, strings.Contains(out, "▼ Engineering"))
    return IsTrue(t2, strings.Contains(out, "▼ QA"))
}

func TestView_Sidebar_CollapsedGroupShowsCarat(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(CollapsedGroups = ArrayOf("Lead"))
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "▶ Lead"))
    return IsFalse(t1, strings.Contains(out, "▼ Lead"))
}

// Member rows under a collapsed group are hidden from render.
func TestView_Sidebar_CollapsedGroup_HidesMembers(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(CollapsedGroups = ArrayOf("Engineering"))
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "Iris"))   // Lead still visible
    return IsFalse(t1, strings.Contains(out, "Felix"))  // engineer hidden
}

// Cursor highlight: the row at SidebarCursor gets a `▎` (left-edge
// bar) lead — distinct from the `▼`/`▶` group-fold glyphs so users
// don't read "▶ ▼" as a doubled arrow.
func TestView_Sidebar_Cursor_HighlightsCursoredRow(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        Focus         = FocusSidebar(),
        SidebarCursor = 0,
    )
    val out = render(m)
    return IsTrue(t, strings.Contains(out, "▎ ▼ Lead"))
}

// When Focus=Composer, the cursor row is NOT highlighted even if
// SidebarCursor was previously moved (cursor only matters when the
// sidebar is the active panel).
func TestView_Sidebar_Cursor_NotHighlightedWhenComposerFocused(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(SidebarCursor = 0)
    val out = render(m)
    return IsFalse(t, strings.Contains(out, "▶ ▼ Lead"))
}

// ---------------------------------------------------------------------------
// Footer per-focus legend — sidebar mode hides the composer-mode
// hints and surfaces the navigation keys instead.
// ---------------------------------------------------------------------------

func TestView_Footer_SidebarFocus_ShowsNavLegend(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(Focus = FocusSidebar())
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "↑↓ navigate"))
    val t2 = IsTrue(t1, strings.Contains(out, "Space fold/unfold"))
    return IsTrue(t2, strings.Contains(out, "Esc composer"))
}

// "Tab sidebar" hint was retired in favour of palette + paste + view
// hints; the new footer surfaces Ctrl+P palette as the load-bearing
// power-user shortcut.
func TestView_Footer_ComposerFocus_ShowsCtrlLHint(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsTrue(t, strings.Contains(out, "Ctrl+P palette"))
}

// ---------------------------------------------------------------------------
// Sidebar scrolling — when the row list exceeds SidebarVisibleRows
// the rendered window slides so the cursor stays in view, with a
// "N more above/below" hint replacing the edge row.
// ---------------------------------------------------------------------------

func mkBigTeam() Team {
    val iris = Member(
        Name = "Iris", Role = TeamLead(),
        Personality = "calm", Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    var members = ArrayOf(iris)
    var i = 0
    for i < 20 {
        members = members.Append(Member(
            Name = s"Eng${i}", Role = Engineer(),
            Personality = "", Model = None[string](), Extra = "",
            Onboarding = EmptyArray[string](),
        ))
        i = i + 1
    }
    return Team(
        Key = "main", Name = "BigTeam", Description = "",
        Members = members, Lead = iris,
        Onboarding = EmptyArray[string](),
        DangerouslySkipPermissions = false,
    )
}

// Cursor at row 0 with 20+ members → "more below" hint appears,
// "more above" doesn't.
func TestView_Sidebar_Scroll_CursorAtTop_ShowsBelowHint(t T) T {
    val m = mkModel(mkBigTeam()).Copy(Focus = FocusSidebar(), SidebarCursor = 0)
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "more below"))
    return IsFalse(t1, strings.Contains(out, "more above"))
}

// Cursor at the actual last row → "more above" appears, "more
// below" gone (the cursor IS the bottom). mkBigTeam has 1 lead +
// 20 engineers + 0 QA → 3 group headers + 21 members = 24 rows;
// cursor index 23 is the QA group header (the trailing empty
// group row).
func TestView_Sidebar_Scroll_CursorAtBottom_ShowsAboveHint(t T) T {
    val tm = mkBigTeam()
    val m = mkModel(tm).Copy(
        Focus         = FocusSidebar(),
        SidebarCursor = 23,
    )
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "more above"))
    return IsFalse(t1, strings.Contains(out, "more below"))
}

// Cursor in the middle → both hints visible; the cursor row is
// somewhere inside the window between them.
func TestView_Sidebar_Scroll_CursorMiddle_ShowsBothHints(t T) T {
    val m = mkModel(mkBigTeam()).Copy(Focus = FocusSidebar(), SidebarCursor = 10)
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "more above"))
    return IsTrue(t1, strings.Contains(out, "more below"))
}

// History index also scrolls — at 30 archives with cursor at 0,
// "more below" appears.
func TestView_HistoryIndex_Scroll_CursorAtTop_ShowsBelowHint(t T) T {
    var archives = EmptyArray[session.SnapshotMeta]()
    var i = 0
    for i < 30 {
        archives = archives.Append(sampleArchiveV(int64(i), "merged", s"proj${i}", i))
        i = i + 1
    }
    val m = mkModel(mkTeam("X", "")).Copy(
        HistoryMode   = true,
        Archives      = archives,
        HistoryCursor = 0,
    )
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "more below"))
    return IsFalse(t1, strings.Contains(out, "more above"))
}

func TestView_HistoryIndex_Scroll_CursorAtBottom_ShowsAboveHint(t T) T {
    var archives = EmptyArray[session.SnapshotMeta]()
    var i = 0
    for i < 30 {
        archives = archives.Append(sampleArchiveV(int64(i), "merged", s"proj${i}", i))
        i = i + 1
