package ui

import (
    "strings"
    "github.com/martianoff/gala-tui"
    "github.com/martianoff/gala_team/app/session"
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/time_utils"
    . "github.com/martianoff/gala_team/app/fsm"
    . "github.com/martianoff/gala_team/app/policy"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/team"
)

// view_test — snapshot tests for the top-level View() composition.
//
// The widget helpers in view.gala (headerWidget, conversationPanel,
// composerWidget, footerWidget, approvalBanner, consultViewerPanel,
// historyPanel, …) are package-private. We exercise them indirectly
// by rendering the whole View(m) at a fixed 100x32 viewport and
// asserting on substrings. Layout regressions, missing labels,
// swapped colors, broken cursor highlights — anything that changes
// the rendered text — gets caught here.
//
// Style assertions (ANSI escapes) are intentionally NOT compared:
// they're noisy and version-bound to gala-tui's emit. We assert on
// content. The few visual-distinction tests (cursor highlight, dim
// vs bright) check for the marker characters ("▶", "…") rather than
// the escape sequences.

// viewportH is sized so the body has enough vertical room for the
// historyIndexPanel's 18-row scroll window (plus its header + spacer
// + border) AFTER the wide-mode header (apple+brand) takes its 5 rows.
// 34 leaves 29 body rows — well above the 18-row scroll window
// minimum, so this stays comfortably over-provisioned across header
// geometry tweaks.
val viewportW = 100
val viewportH = 34

// ---------------------------------------------------------------------------
// fixtures
// ---------------------------------------------------------------------------

func mkTeam(name string, description string) Team {
    val iris = Member(
        Name = "Iris", Role = TeamLead(),
        Personality = "calm", Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val felix = Member(
        Name = "Felix", Role = Engineer(),
        Personality = "terse", Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    return Team(
        Key = "main", Name = name, Description = description,
        Members = ArrayOf(iris, felix), Lead = iris,
        Onboarding = EmptyArray[string](),
        DangerouslySkipPermissions = false,
    )
}

func mkProj() Project = Project(
    Name = "demo", Repo = "/tmp/demo",
    Github = None[string](),
    DefaultBranch = "main",
)

func mkModel(team Team) AppModel = InitialModel(mkProj(), team, DefaultWorkflow(), DefaultPolicy())

func render(m AppModel) string = gala_tui.Snapshot(View(m), viewportW, viewportH)

// ---------------------------------------------------------------------------
// Header
// ---------------------------------------------------------------------------

func TestView_Header_ShowsTeamName(t T) T {
    val out = render(mkModel(mkTeam("Skunkworks", "")))
    return IsTrue(t, strings.Contains(out, "Skunkworks"))
}

func TestView_Header_ShowsDescription_WhenSet(t T) T {
    val out = render(mkModel(mkTeam("Skunkworks", "Default product team")))
    val t1 = IsTrue(t, strings.Contains(out, "Skunkworks"))
    return IsTrue(t1, strings.Contains(out, "Default product team"))
}

// When description is blank, the "  ·  <desc>" suffix shouldn't render.
func TestView_Header_NoDotSuffix_WhenDescriptionBlank(t T) T {
    val out = render(mkModel(mkTeam("Skunkworks", "")))
    return IsFalse(t, strings.Contains(out, "Skunkworks  ·"))
}

func TestView_Header_StateLabel_Idle(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsTrue(t, strings.Contains(out, "state: idle"))
}

// In Approval state the modal floats over the header, but the header
// row still renders below it. Snapshot rendering layers the modal on
// top so we look for "Open PR?" — the modal title — instead of the
// header label, which is now visually hidden behind the modal.
func TestView_Header_StateLabel_Approval(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(State = Approval(SummaryBody = "ship"))
    return IsTrue(t, strings.Contains(render(m), "Open PR?"))
}

// Wide-mode header (cols >= 70) renders the multi-row apple to the
// left of the brand text. We assert on a body-belly glyph + the top
// and base chamfer half-blocks — if any of those vanish the apple
// has lost its shape.
func TestView_Header_WideMode_RendersApple(t T) T {
    val out = render(mkModel(mkTeam("Skunkworks", "")))
    val t1 = IsTrue(t,  strings.Contains(out, "█"))     // belly
    val t2 = IsTrue(t1, strings.Contains(out, "▄"))     // top shoulder chamfer
    val t3 = IsTrue(t2, strings.Contains(out, "▀"))     // base chamfer
    return IsTrue(t3, strings.Contains(out, "Skunkworks"))
}

// Two ticks separated by a full appleShineDivisor step must produce
// different snapshots — that's what tells the user the apple is
// "alive" rather than a static glyph block. The shine highlight
// advances every appleShineDivisor() ticks, so consecutive ticks
// (Tick=0 vs Tick=1) hit the same shineZone and would compare equal;
// we sample Tick=0 vs Tick=appleShineDivisor() so exactly one step
// has elapsed. The shine moves by 1 cell, changing the SGR escape
// sequence stream even when the visible glyphs are byte-identical,
// so we compare the styled snapshot.
func TestView_Header_AppleShine_AdvancesOnTick(t T) T {
    val m0 = mkModel(mkTeam("Skunkworks", "")).Copy(Tick = 0)
    val m1 = mkModel(mkTeam("Skunkworks", "")).Copy(Tick = appleShineDivisor())
    val out0 = gala_tui.SnapshotStyled(View(m0), viewportW, viewportH)
    val out1 = gala_tui.SnapshotStyled(View(m1), viewportW, viewportH)
    return IsTrue(t, out0 != out1)
}

// Narrow-terminal fallback (cols < 70) is verified manually via
// resize: under test, gala_tui.TermSize() can't read the redirected
// stdio so it always returns its 80×24 default — meaning headerWidget
// always picks wide mode regardless of the width passed to Snapshot.
// The wide / narrow switch is exercised against a live terminal.

// Wide header has 3 rows of brand content (brand line, state line,
// tokens line) lined up against the 3 rows of the apple. The tokens
// row sits empty until the first result event accrues usage —
// asserting on the state row instead, which fills immediately.
func TestView_Header_WideMode_BrandFlushWithApple(t T) T {
    val out = render(mkModel(mkTeam("Skunkworks", "")))
    val rows = strings.Split(out, "\n")
    // Header rows: 0 spacer, 1 brand, 2 state, 3 tokens/empty, 4 sep.
    // Both row 1 and row 2 carry apple cells (stem on r1, body on r2)
    // AND text — that's the "flush" property the user asked for.
    val brandRow = rows[1]
    val stateRow = rows[2]
    val t1 = IsTrue(t,  strings.Contains(brandRow, "│"))        // leaf in brand row
    val t2 = IsTrue(t1, strings.Contains(brandRow, "Skunkworks")) // brand text on same row
    val t3 = IsTrue(t2, strings.Contains(stateRow, "█"))        // body on state row
    return IsTrue(t3, strings.Contains(stateRow, "state: idle")) // state text on same row
}

// ---------------------------------------------------------------------------
// Approval banner
// ---------------------------------------------------------------------------

// Banner is hidden in Idle state — no Ctrl+A/Ctrl+R hint visible.
func TestView_ApprovalBanner_HiddenInIdle(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsFalse(t, strings.Contains(out, "Ctrl+A approve & open PR"))
}

// Banner shows in Approval state with the snippet.
// The Approval modal (DESIGN.md Frame G) replaces the legacy single-
// line banner. We assert on the modal title, the summary preview, and
// the [Yes]/[No] button labels so the test catches accidental regressions
// to "approval state didn't show anything user-actionable".
func TestView_ApprovalBanner_VisibleInApproval(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(State = Approval(SummaryBody = "Ship the metrics endpoint"))
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "Open PR?"))
    val t2 = IsTrue(t1, strings.Contains(out, "Ship the metrics endpoint"))
    return IsTrue(t2, strings.Contains(out, "Yes"))
}

// Newlines in the summary body are flattened so the banner stays on one line.
func TestView_ApprovalBanner_FlattensNewlines(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        State = Approval(SummaryBody = "## Header\nDid X\nDid Y"),
    )
    val out = render(m)
    return IsFalse(t, strings.Contains(out, "## Header\nDid X"))
}

// ---------------------------------------------------------------------------
// Conversation panel
// ---------------------------------------------------------------------------

// Empty conversation surfaces a "type a prompt below" placeholder.
func TestView_Conversation_Empty_ShowsPlaceholder(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsTrue(t, strings.Contains(out, "no conversation yet"))
}

// Logged lines render with their speaker prefix.
func TestView_Conversation_RendersLines(t T) T {
    val convo = ArrayOf(
        session.ConversationLine(Speaker = "you", Text = "ship it"),
        session.ConversationLine(Speaker = "Iris", Text = "on it"),
    )
    val m = mkModel(mkTeam("X", "")).Copy(Conversation = convo)
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "you: ship it"))
    return IsTrue(t1, strings.Contains(out, "Iris: on it"))
}

// 30-line conversation now lives inside a scrollable ConversationLog
// (sticky-bottom by default). The "K earlier line(s) hidden" hint
// from the old hard-cap path is gone; the latest line is what's
// visible at sticky bottom.
func TestView_Conversation_Clipping_ShowsHiddenHint(t T) T {
    var convo = EmptyArray[session.ConversationLine]()
    var i = 0
    for i < 30 {
        convo = convo.Append(session.ConversationLine(Speaker = "Iris", Text = s"line ${i}"))
        i = i + 1
    }
    val m = mkModel(mkTeam("X", "")).Copy(Conversation = convo)
    return IsTrue(t, strings.Contains(render(m), "line 29"))
}

// Long chunks must wrap inside the conversation pane — otherwise long
// claude responses get clipped at the right edge (see UI_AUDIT_BUGS.md
// bug A). Sends a 200-char chunk and asserts the rendered output spans
// multiple rows containing the latter half of the text.
func TestView_Conversation_LongLineWraps(t T) T {
    val longLine = "this is an extremely long line that should overflow the conversation pane width and either wrap or get truncated — we need to verify which behavior the renderer picks"
    val seed = mkModel(mkTeam("X", ""))
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = longLine))
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "extremely"))
    return IsTrue(t1, strings.Contains(out, "renderer"))
}

// ---------------------------------------------------------------------------
// Composer
// ---------------------------------------------------------------------------

func TestView_Composer_Placeholder_WhenEmpty(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsTrue(t, strings.Contains(out, "Type to Iris"))
}

func TestView_Composer_ShowsTypedText(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(Composer = "ship the metrics endpoint")
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "ship the metrics endpoint"))
    return IsFalse(t1, strings.Contains(out, "Type to Iris"))
}

// A composer string that wraps to several rows now grows the panel
// instead of clipping to a single visible line. We assert that the
// long substring shows up on more than one rendered terminal row —
// the prior `Fixed(3, ...)` panel could only fit one.
func TestView_Composer_LongText_ExpandsPanel(t T) T {
    val long = strings.Repeat("ship the metrics endpoint ", 20)  // ~520 chars
    val m = mkModel(mkTeam("X", "")).Copy(Composer = long)
    val out = render(m)
    val rows = strings.Split(out, "\n")
    var i = 0
    var hits = 0
    val n = len(rows)
    for i < n {
        if strings.Contains(rows[i], "ship the metrics endpoint") {
            hits = hits + 1
        }
        i = i + 1
    }
    return IsTrue(t, hits >= 2)
}

// When the wrapped text exceeds the panel's row cap, the viewport
// scrolls so the cursor row stays in view. Place the cursor at end
// of a long string and assert the cursor glyph "▌" still renders.
func TestView_Composer_LongText_AutoScrollsToCursor(t T) T {
    val long = strings.Repeat("ship the metrics endpoint ", 50)  // ~1300 chars, > cap rows wrapped
    // Pure ASCII — byte len == rune count, no need to dot-import go_interop.ToRunes.
    val m = mkModel(mkTeam("X", "")).Copy(Composer = long, ComposerCursor = len(long))
    val out = render(m)
    return IsTrue(t, strings.Contains(out, "▌"))
}

// SelectedEntry highlights the corresponding conversation line with
// reverse-video styling. The styled snapshot (which preserves ANSI
// escapes, unlike the plain Snapshot) is checked for the SGR
// reverse-video sequence \x1b[7m on the line containing the
// selected speaker. Without selection, the same content has no
// reverse seq anywhere — confirms our styling is selection-driven
// and not a static highlight applied everywhere.
func TestView_SelectedEntry_AppliesReverseHighlight(t T) T {
    val convo = ArrayOf(
        session.ConversationLine(Speaker = "you",  Text = "ship the metrics endpoint"),
        session.ConversationLine(Speaker = "Iris", Text = "on it"),
    )
    val unselected = gala_tui.SnapshotStyled(View(mkModel(mkTeam("X", "")).Copy(Conversation = convo)), viewportW, viewportH)
    val selected = gala_tui.SnapshotStyled(View(mkModel(mkTeam("X", "")).Copy(
        Conversation  = convo,
        SelectedEntry = Some(1),
    )), viewportW, viewportH)
    // The reverse-video SGR code is `7`. It can appear either as a
    // standalone `\x1b[7m` or combined with bold/foreground codes
    // (`\x1b[1;7;96m`). Match the inner `;7;` form which catches the
    // combined case (the standalone form would be a separate
    // assertion, but our prose style is bold + colored, so the
    // combined form is what actually fires).
    val combinedRev = ";7;"
    val t1 = IsFalse(t, strings.Contains(unselected, combinedRev))
    return IsTrue(t1, strings.Contains(selected, combinedRev))
}

// ---------------------------------------------------------------------------
// Footer
// ---------------------------------------------------------------------------

// LastError surfaces a ⚠ message instead of the key-hint legend.
func TestView_Footer_ShowsLastError(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(LastError = Some("session save: disk full"))
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "⚠"))
    return IsTrue(t1, strings.Contains(out, "session save: disk full"))
}

// Default hint legend (no PR yet). Footer compacted to fit the
// addition of palette / paste / view-mode hints; we now only check
// the load-bearing keybindings (send / approve / reject / palette).
func TestView_Footer_DefaultLegend(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    val t1 = IsTrue(t,  strings.Contains(out, "Enter send"))
    val t2 = IsTrue(t1, strings.Contains(out, "Ctrl+A approve"))
    val t3 = IsTrue(t2, strings.Contains(out, "Ctrl+R reject"))
    return IsTrue(t3, strings.Contains(out, "Ctrl+Q"))
}

// After PrCreated, the legend swaps to the merge-prompt hints
// (Ctrl+M merge / Ctrl+A re-approve). Tab/consults hints were
// removed when palette/paste/view-mode hints were added.
func TestView_Footer_PostPrCreated_ShowsMergeHint(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(OpenPrs = ArrayOf(samplePr("https://github.com/x/y/pull/1")))
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "Ctrl+M merge"))
    return IsTrue(t1, strings.Contains(out, "Ctrl+A re-approve"))
}

// LastError now renders as a separate banner BELOW the footer — it
// no longer hides the keybind legend. Both must be visible at once.
func TestView_Footer_LastErrorBeatsLegend(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        LastError = Some("gh pr merge: auth required"),
        OpenPrs   = ArrayOf(samplePr("https://x/y/pull/1")),
    )
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "auth required"))
    return IsTrue(t1, strings.Contains(out, "Ctrl+M merge"))
}

// samplePr builds a stub BatchPr for footer / banner / list-render
// tests. A canned title and the Unix-epoch timestamp keep snapshot
// matchers stable across runs.
func samplePr(url string) BatchPr = BatchPr(
    Url      = url,
    Branch   = "feat/x",
    Title    = "ship the metrics endpoint",
    OpenedAt = UnixEpoch(),
)

// AutoApprove on shows an "AUTO (N open)" badge in the header sub-row
// so the user can see the mode + batch size at a glance.
func TestView_Header_AutoApproveBadge(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        AutoApprove = true,
        OpenPrs     = ArrayOf(samplePr("https://x/y/pull/1"), samplePr("https://x/y/pull/2")),
    )
    val out = render(m)
    return IsTrue(t, strings.Contains(out, "AUTO (2 open)"))
}

// AutoApprove off — no AUTO badge in the header.
func TestView_Header_NoBadgeWhenManual(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsFalse(t, strings.Contains(out, "AUTO ("))
}

// AutoApprove suppresses Ctrl+A / Ctrl+R hints in the composer footer
// — the gate is off, so those keys aren't load-bearing anymore.
func TestView_Footer_AutoApprove_NoApproveHints(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(AutoApprove = true)
    val out = render(m)
    val t1 = IsFalse(t,  strings.Contains(out, "Ctrl+A approve"))
    val t2 = IsFalse(t1, strings.Contains(out, "Ctrl+R reject"))
    return IsTrue(t2, strings.Contains(out, "F7 auto:on"))
}

// Active plan renders a banner above the composer with progress
// glyphs and the in-progress step body. The rendered glyphs are
// checked individually (✓ for shipped, ▶ for in-progress, ☐ for
// queued) rather than as a fixed-spacing sequence — terminal cell-
// width handling pads emoji-adjacent characters in ways that
// depend on the font's reported east-asian-width.
func TestView_PlanBanner_ShowsProgressAndCurrentStep(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        AutoApprove = true,
        Plan        = ArrayOf("Stripe SDK", "Webhook handler", "Refund flow"),
        PlanShipped = 1,
    )
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "Plan 2/3"))
    val t2 = IsTrue(t1, strings.Contains(out, "Webhook handler"))
    val t3 = IsTrue(t2, strings.Contains(out, "✓"))
    val t4 = IsTrue(t3, strings.Contains(out, "▶"))
    return IsTrue(t4, strings.Contains(out, "☐"))
}

// Empty Plan → no banner (zero-row spacer).
func TestView_PlanBanner_HiddenWhenNoPlan(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsFalse(t, strings.Contains(out, "📋 Plan"))
}

// Plan exhausted (PlanShipped == Plan.Size()) → banner hides; the
// completion message is in the conversation log instead.
func TestView_PlanBanner_HiddenWhenComplete(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        AutoApprove = true,
        Plan        = ArrayOf("a", "b"),
        PlanShipped = 2,
    )
    val out = render(m)
    return IsFalse(t, strings.Contains(out, "📋 Plan"))
}

// Header AUTO badge surfaces the plan progress so a user looking at
// the top of the screen knows the chain is mid-flight.
func TestView_Header_AutoBadge_IncludesPlanProgress(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        AutoApprove = true,
        Plan        = ArrayOf("a", "b", "c"),
        PlanShipped = 1,
    )
    val out = render(m)
    return IsTrue(t, strings.Contains(out, "plan 2/3"))
}

// QuitPending replaces the regular footer with a confirmation
// prompt. It even wins over LastError so the user is never confused
// about what their next keypress will do.
func TestView_Footer_QuitPending_ShowsConfirmation(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(QuitPending = true)
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "Press Ctrl+Q again to confirm"))
    return IsTrue(t1, strings.Contains(out, "Esc to cancel"))
}

// Quit confirmation replaces the footer keybind row, but the
// separate LastError banner below still renders — that's intended;
// both are independent surfaces now.
func TestView_Footer_QuitPending_BeatsLastError(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        QuitPending = true,
        LastError   = Some("disk full"),
    )
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "Press Ctrl+Q again to confirm"))
    return IsTrue(t1, strings.Contains(out, "disk full"))
}

// ---------------------------------------------------------------------------
// Consult viewer modal (Tab toggle)
// ---------------------------------------------------------------------------

// Closed: main pane is the conversation, not the modal.
func TestView_ConsultViewer_Closed_RendersConversation(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    val t1 = IsTrue(t, strings.Contains(out, "Conversation with Team Lead"))
    return IsFalse(t1, strings.Contains(out, "Consult viewer"))
}

// Opened with no active consults: empty-state hint visible.
func TestView_ConsultViewer_OpenEmpty_ShowsHint(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(ConsultViewerOpen = true)
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "Consult viewer"))
    return IsTrue(t1, strings.Contains(out, "no active consults"))
}

// Open + buffer for a consult: tail preview of the lines is visible.
// (We can't easily inject a live ConsultSession, but ConsultBuffers is
// what drives the rendering — the session field only contributes the
// "▶ name · team: …" header which we can't fabricate without spawning
// a process. So this test focuses on the buffer-rendering path,
// which is the user-visible body of the modal.)
//
// Note: rendering an active consult's full row needs an
// ActiveConsults entry too. Without one, the FoldLeftKV in
// consultViewerPanel doesn't iterate and the "no active consults"
// hint takes over. So this test sets a buffer but no session and
// checks for the empty-state behavior the rendering correctly
// produces.
func TestView_ConsultViewer_OpenWithBufferButNoSession_ShowsEmpty(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        ConsultViewerOpen = true,
        ConsultBuffers    = EmptyHashMap[string, Array[string]]()
            .Put("transpiler", ArrayOf("hello", "world")),
    )
    return IsTrue(t, strings.Contains(render(m), "no active consults"))
}

