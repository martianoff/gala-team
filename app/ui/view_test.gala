func TestView_Composer_Placeholder_WhenEmpty(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsTrue(t, strings.Contains(out, "Type to Iris"))
}

func TestView_Composer_ShowsTypedText(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(Composer = "ship the metrics endpoint")
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "ship the metrics endpoint"))
