func TestView_Footer_MultiLineLastError_StillShowsWarning(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        LastError = Some("session save failed:\n  permission denied\n  on /tmp/foo"),
    )
    return IsTrue(t, strings.Contains(render(m), "⚠"))
}

// ---------------------------------------------------------------------------
// Keyboard-driven flows — render the model AFTER an Update dispatch
// to catch regressions where the rendering layer disagrees with the
// model-side state machine.
// ---------------------------------------------------------------------------

// After typing chars, the composer reflects them.
func TestFlow_TypeChars_ComposerUpdates(t T) T {
    val seed = mkModel(mkTeam("X", ""))
    val (m1, _) = Update(seed, KeyChar(C = 'h'))
    val (m2, _) = Update(m1,   KeyChar(C = 'i'))
    return IsTrue(t, strings.Contains(render(m2), "hi"))
}

// Backspace then render — the composer regresses to the
// pre-deletion state. Anchoring to the trailing cursor caret
// "▌" keeps the test from picking up unrelated substrings (e.g.
// "hi" inside "history" in the footer key hints).
func TestFlow_TypeThenBackspace_ComposerShortens(t T) T {
    val seed = mkModel(mkTeam("X", ""))
    val (m1, _) = Update(seed, KeyChar(C = 'h'))
    val (m2, _) = Update(m1,   KeyChar(C = 'i'))
    val (m3, _) = Update(m2,   KeyBackspace())
    val out = render(m3)
    val t1 = IsTrue(t, strings.Contains(out, "h▌"))
    return IsFalse(t1, strings.Contains(out, "hi▌"))
}

// Ctrl+T opens the consult viewer; the composer is not the visible pane.
func TestFlow_CtrlT_RendersConsultViewer(t T) T {
    val seed = mkModel(mkTeam("X", ""))
    val (m, _) = Update(seed, KeyToggleConsultViewer())
    return IsTrue(t, strings.Contains(render(m), "Consult viewer"))
}

// Ctrl+T twice closes it — the consult-viewer header is gone.
func TestFlow_CtrlTTwice_ClosesConsultViewer(t T) T {
    val seed = mkModel(mkTeam("X", ""))
    val (m1, _) = Update(seed, KeyToggleConsultViewer())
    val (m2, _) = Update(m1,   KeyToggleConsultViewer())
    return IsFalse(t, strings.Contains(render(m2), "Consult viewer"))
}

// Ctrl+H opens the history browser.
func TestFlow_CtrlH_RendersHistoryPanel(t T) T {
    val seed = mkModel(mkTeam("X", ""))
    val (m, _) = Update(seed, KeyToggleHistory())
    return IsTrue(t, strings.Contains(render(m), "History  ·"))
}

// ChunkArrived from a member adds a line that's visible in render.
func TestFlow_ChunkArrived_RendersInConversation(t T) T {
    val seed = mkModel(mkTeam("X", ""))
    val (m, _) = Update(seed, ChunkArrived(Member = "Iris", Line = "thinking out loud"))
    return IsTrue(t, strings.Contains(render(m), "thinking out loud"))
}

// PrCreated swaps the footer hint to mention Ctrl+M.
func TestFlow_PrCreated_FooterShowsMergeHint(t T) T {
    val seed = mkModel(mkTeam("X", ""))
    val (m, _) = Update(seed, PrCreated(Url = "https://x/y/pull/1", Branch = "gala_team/x/pr/aaa1"))
    return IsTrue(t, strings.Contains(render(m), "Ctrl+M merge"))
}

// SessionFailed surfaces in the footer as ⚠ <member>: <err>.
func TestFlow_SessionFailed_FooterWarns(t T) T {
    // EOF is the normal turn-end signal under spawn-per-turn — it
    // doesn't surface a warning. Use a real error string so the footer
    // exercises the LastError path. With auto-retry (#26) the message
    // includes "retry N/M" so the user sees the orchestrator working
    // through recovery.
    val seed = mkModel(mkTeam("X", ""))
    val (m, _) = Update(seed, SessionFailed(Member = "Iris", ErrText = "stream closed"))
    val out = render(m)
    val t1 = IsTrue(t,  strings.Contains(out, "⚠"))
    return IsTrue(t1, strings.Contains(out, "Iris: stream closed"))
}

// ---------------------------------------------------------------------------
// Mouse-driven flows — clicks inside the sidebar columns switch
// Focus to FocusSidebar (and on a group header also toggle fold);
// clicks outside snap focus back to the composer. Release events
// are no-ops so a drag from one panel to another doesn't reset
// focus mid-drag.
// ---------------------------------------------------------------------------

// Press outside the sidebar column with default Focus=Composer
// changes nothing — the click lands on the conversation pane,
// which has no hit-targets yet.
func TestFlow_MousePressOutsideSidebar_LeavesRenderUnchanged(t T) T {
    val seed = mkModel(mkTeam("X", ""))
    val before = render(seed)
    val (m, _) = Update(seed, MouseAt(X = 50, Y = 10, Pressed = true, Motion = false))
    return Eq(t, render(m), before)
}

func TestFlow_MouseRelease_LeavesRenderUnchanged(t T) T {
    val seed = mkModel(mkTeam("X", ""))
    val before = render(seed)
    val (m, _) = Update(seed, MouseAt(X = 0, Y = 0, Pressed = false, Motion = false))
    return Eq(t, render(m), before)
}

// Out-of-bounds in either direction — negative coords are
// outside the sidebar column-band; large coords are also outside
// the sidebar column-band (x > 28 means "right of sidebar").
// Either way no focus change.
func TestFlow_MouseOutOfBounds_NoChange(t T) T {
    val seed = mkModel(mkTeam("X", ""))
    val before = render(seed)
    val (m1, _) = Update(seed, MouseAt(X = -5, Y = -3, Pressed = true, Motion = false))
    val t1 = Eq(t, render(m1), before)
    val (m2, _) = Update(seed, MouseAt(X = 9999, Y = 9999, Pressed = true, Motion = false))
    return Eq(t1, render(m2), before)
}

// Press in the sidebar columns focuses it. The model's Focus
// switches to FocusSidebar — the visual change is the sidebar's
// border weight (rounded → thick).
func TestFlow_MousePressInSidebar_FocusesSidebar(t T) T {
    // Sidebar clicks come through gala-tui's HitRegistry as a typed
    // FocusSidebarClicked AppMsg (BorderOf(...).OnClick wires it),
    // NOT as a raw MouseAt. MouseAt is the fallback path for clicks
    // that miss every registered hit-target. This test exercises the
    // typed-click → focus-switch path the framework actually uses.
    val seed = mkModel(mkTeam("X", ""))
    val (m, _) = Update(seed, FocusSidebarClicked())
    return m.Focus match {
        case FocusSidebar()  => IsTrue(t, true)
        case FocusComposer() => IsTrue(t, false)
    }
}

// Mouse press in history mode keeps the history panel visible —
// the history overlay sits above the sidebar so a sidebar click
// shouldn't close the panel.
func TestFlow_MouseInHistoryMode_DoesNotClosePanel(t T) T {
    val seed = mkModel(mkTeam("X", "")).Copy(HistoryMode = true)
    val (m, _) = Update(seed, MouseAt(X = 10, Y = 5, Pressed = true, Motion = false))
    return IsTrue(t, strings.Contains(render(m), "History  ·"))
}

// Mouse press in consult viewer mode doesn't close the modal.
func TestFlow_MouseInConsultViewer_DoesNotClose(t T) T {
    val seed = mkModel(mkTeam("X", "")).Copy(ConsultViewerOpen = true)
    val (m, _) = Update(seed, MouseAt(X = 50, Y = 10, Pressed = true, Motion = false))
    return IsTrue(t, strings.Contains(render(m), "Consult viewer"))
}
