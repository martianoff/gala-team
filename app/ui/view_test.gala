package main

import (
    "strings"
    "github.com/martianoff/gala-tui"
    "github.com/martianoff/gala_team/app/session"
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "github.com/martianoff/gala_team/app/fsm"
    . "github.com/martianoff/gala_team/app/policy"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/team"
    . "github.com/martianoff/gala_team/app/ui"
)

// view_test — snapshot tests for the top-level View() composition.
//
// The widget helpers in view.gala (headerWidget, conversationPanel,
// composerWidget, footerWidget, approvalBanner, consultViewerPanel,
// historyPanel, …) are package-private. We exercise them indirectly
// by rendering the whole View(m) at a fixed 100x32 viewport and
// asserting on substrings. Layout regressions, missing labels,
// swapped colors, broken cursor highlights — anything that changes
// the rendered text — gets caught here.
//
// Style assertions (ANSI escapes) are intentionally NOT compared:
// they're noisy and version-bound to gala-tui's emit. We assert on
// content. The few visual-distinction tests (cursor highlight, dim
// vs bright) check for the marker characters ("▶", "…") rather than
// the escape sequences.

val viewportW = 100
val viewportH = 32

// ---------------------------------------------------------------------------
// fixtures
// ---------------------------------------------------------------------------

func mkTeam(name string, description string) Team {
    val iris = Member(
        Name = "Iris", Role = TeamLead(),
        Personality = "calm", Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val felix = Member(
        Name = "Felix", Role = Engineer(),
        Personality = "terse", Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    return Team(
        Key = "main", Name = name, Description = description,
        Members = ArrayOf(iris, felix), Lead = iris,
        Onboarding = EmptyArray[string](),
        DangerouslySkipPermissions = false,
    )
}

func mkProj() Project = Project(
    Name = "demo", Repo = "/tmp/demo",
    Github = None[string](),
    DefaultBranch = "main",
)

func mkModel(team Team) AppModel = InitialModel(mkProj(), team, DefaultWorkflow(), DefaultPolicy())

// Function-valued val to bypass a transpiler quirk: when `session`
// is qualified-imported and exports a `Snapshot` struct, plain or
// qualified `Snapshot(...)` calls get resolved to the struct
// constructor instead of gala_tui's Snapshot function. Routing
// through `takeSnap` keeps the call site free of the offending name.
val takeSnap = gala_tui.Snapshot

func render(m AppModel) string = takeSnap(View(m), viewportW, viewportH)

// ---------------------------------------------------------------------------
// Header
// ---------------------------------------------------------------------------

func TestView_Header_ShowsTeamName(t T) T {
    val out = render(mkModel(mkTeam("Skunkworks", "")))
    return IsTrue(t, strings.Contains(out, "Skunkworks"))
}

func TestView_Header_ShowsDescription_WhenSet(t T) T {
    val out = render(mkModel(mkTeam("Skunkworks", "Default product team")))
    val t1 = IsTrue(t, strings.Contains(out, "Skunkworks"))
    return IsTrue(t1, strings.Contains(out, "Default product team"))
}

// When description is blank, the "  ·  <desc>" suffix shouldn't render.
func TestView_Header_NoDotSuffix_WhenDescriptionBlank(t T) T {
    val out = render(mkModel(mkTeam("Skunkworks", "")))
    return IsFalse(t, strings.Contains(out, "Skunkworks  ·"))
}

func TestView_Header_StateLabel_Idle(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsTrue(t, strings.Contains(out, "state: idle"))
}

func TestView_Header_StateLabel_Approval(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(State = Approval(SummaryBody = "ship"))
    return IsTrue(t, strings.Contains(render(m), "state: approval"))
}

// ---------------------------------------------------------------------------
// Approval banner
// ---------------------------------------------------------------------------

// Banner is hidden in Idle state — no Ctrl+A/Ctrl+R hint visible.
func TestView_ApprovalBanner_HiddenInIdle(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsFalse(t, strings.Contains(out, "Ctrl+A approve & open PR"))
}

// Banner shows in Approval state with the snippet.
func TestView_ApprovalBanner_VisibleInApproval(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(State = Approval(SummaryBody = "Ship the metrics endpoint"))
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "Ready to ship"))
    val t2 = IsTrue(t1, strings.Contains(out, "Ship the metrics endpoint"))
    return IsTrue(t2, strings.Contains(out, "Ctrl+A approve & open PR"))
}

// Newlines in the summary body are flattened so the banner stays on one line.
func TestView_ApprovalBanner_FlattensNewlines(t T) T {
    val m = mkModel(mkTeam("X", "")).Copy(
        State = Approval(SummaryBody = "## Header\nDid X\nDid Y"),
    )
    val out = render(m)
    return IsFalse(t, strings.Contains(out, "## Header\nDid X"))
}

// ---------------------------------------------------------------------------
// Conversation panel
// ---------------------------------------------------------------------------

// Empty conversation surfaces a "type a prompt below" placeholder.
func TestView_Conversation_Empty_ShowsPlaceholder(t T) T {
    val out = render(mkModel(mkTeam("X", "")))
    return IsTrue(t, strings.Contains(out, "no conversation yet"))
}

// Logged lines render with their speaker prefix.
func TestView_Conversation_RendersLines(t T) T {
    val convo = ArrayOf(
        session.ConversationLine(Speaker = "you", Text = "ship it"),
        session.ConversationLine(Speaker = "Iris", Text = "on it"),
    )
    val m = mkModel(mkTeam("X", "")).Copy(Conversation = convo)
    val out = render(m)
    val t1 = IsTrue(t, strings.Contains(out, "you: ship it"))
    return IsTrue(t1, strings.Contains(out, "Iris: on it"))
}

// >20 lines triggers the "K earlier line(s) hidden" hint.
func TestView_Conversation_Clipping_ShowsHiddenHint(t T) T {
    var convo = EmptyArray[session.ConversationLine]()
    var i = 0
    for i < 30 {
        convo = convo.Append(session.ConversationLine(Speaker = "Iris", Text = s"line ${i}"))
        i = i + 1
    }
    val m = mkModel(mkTeam("X", "")).Copy(Conversation = convo)
    return IsTrue(t, strings.Contains(render(m), "earlier line(s) hidden"))
}

