package main

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "github.com/martianoff/gala-tui"
    . "github.com/martianoff/gala_team/app/team"
    . "github.com/martianoff/gala_team/app/view"
)

func skunkworks() Team {
    val iris = Member(
        Name = "Iris", Role = TeamLead(),
        Personality = "calm",
        Model = None[string](), Extra = "",
    )
    val felix = Member(
        Name = "Felix", Role = Engineer(),
        Personality = "terse",
        Model = None[string](), Extra = "",
    )
    val theo = Member(
        Name = "Theo", Role = QA(),
        Personality = "evidence-driven",
        Model = None[string](), Extra = "",
    )
    return Team(
        Name    = "Skunkworks",
        Members = ArrayOf[Member](iris, felix, theo),
        Lead    = iris,
    )
}

func TestTeamPanel_AllIdle_ShowsAllMembers(t T) T {
    val w = TeamPanelView(skunkworks(), EmptyHashMap[string, Status]())
    val rendered = Snapshot(w, 40, 12)
    val t1 = IsTrue(t, contains(rendered, "Iris"))
    val t2 = IsTrue(t1, contains(rendered, "Felix"))
    val t3 = IsTrue(t2, contains(rendered, "Theo"))
    return IsTrue(t3, contains(rendered, "idle"))
}

func TestTeamPanel_WorkingMember_ShowsSpinnerGlyph(t T) T {
    val statuses = EmptyHashMap[string, Status]()
        .Put("Felix", StWorking())
    val w = TeamPanelView(skunkworks(), statuses)
    val rendered = Snapshot(w, 40, 12)
    return IsTrue(t, contains(rendered, "working"))
}

func TestTeamPanel_DoneAndFailed(t T) T {
    val statuses = EmptyHashMap[string, Status]()
        .Put("Felix", StDone())
        .Put("Theo",  StFailed(Reason = "boom"))
    val w = TeamPanelView(skunkworks(), statuses)
    val rendered = Snapshot(w, 40, 12)
    val t1 = IsTrue(t, contains(rendered, "done"))
    return IsTrue(t1, contains(rendered, "failed"))
}

// Status mapping for QA + multiple Working members at once.
func TestTeamPanel_QueuedAndMultipleWorking(t T) T {
    val statuses = EmptyHashMap[string, Status]()
        .Put("Felix", StWorking())
        .Put("Theo",  StQueued())
    val w = TeamPanelView(skunkworks(), statuses)
    val rendered = Snapshot(w, 40, 12)
    val t1 = IsTrue(t, contains(rendered, "working"))
    return IsTrue(t1, contains(rendered, "queued"))
}

// Mixed steady-state: TL idle, engineer working, QA done — the full
// pipeline mid-flight shape.
func TestTeamPanel_MixedThreeStatusesRender(t T) T {
    val statuses = EmptyHashMap[string, Status]()
        .Put("Iris",  StIdle())
        .Put("Felix", StWorking())
        .Put("Theo",  StDone())
    val w = TeamPanelView(skunkworks(), statuses)
    val rendered = Snapshot(w, 40, 12)
    val t1 = IsTrue(t, contains(rendered, "Iris"))
    val t2 = IsTrue(t1, contains(rendered, "Felix"))
    return IsTrue(t2, contains(rendered, "Theo"))
}

// Single-member team — boundary case for the tree rendering. No QA,
// no second engineer; the panel still renders the lead.
func TestTeamPanel_SingleMember(t T) T {
    val onlyMember = Member(
        Name = "Iris", Role = TeamLead(),
        Personality = "solo",
        Model = None[string](), Extra = "",
    )
    val solo = Team(
        Name    = "Solo",
        Members = ArrayOf(onlyMember),
        Lead    = onlyMember,
    )
    val w = TeamPanelView(solo, EmptyHashMap[string, Status]())
    val rendered = Snapshot(w, 40, 8)
    return IsTrue(t, contains(rendered, "Iris"))
}

// Member with a status entry pointing to a member name not in the
// team should still render the named team members; the orphan status
// is just dropped on the floor.
func TestTeamPanel_OrphanStatus_DoesNotCrash(t T) T {
    val statuses = EmptyHashMap[string, Status]()
        .Put("Ghost", StWorking())  // no "Ghost" member in skunkworks()
    val w = TeamPanelView(skunkworks(), statuses)
    val rendered = Snapshot(w, 40, 12)
    return IsTrue(t, contains(rendered, "Iris"))
}

// Failure reason text isn't rendered verbatim in the panel (it lives
// in the conversation log) — only the "failed" label leaks. This
// regression guard catches accidental "leak the entire reason into the
// status pane" changes.
func TestTeamPanel_FailedReason_NotRenderedInline(t T) T {
    val statuses = EmptyHashMap[string, Status]()
        .Put("Felix", StFailed(Reason = "something-very-specific-here"))
    val w = TeamPanelView(skunkworks(), statuses)
    val rendered = Snapshot(w, 40, 12)
    val t1 = IsTrue(t, contains(rendered, "failed"))
    return IsFalse(t1, contains(rendered, "something-very-specific-here"))
}

// contains is a test helper so we can assert on substring presence in
// snapshot output without pulling in strings.* at every call site.
func contains(haystack string, needle string) bool {
    var i = 0
    val hayLen = len(haystack)
    val ndlLen = len(needle)
    if ndlLen == 0 { return true }
    if hayLen < ndlLen { return false }
    val limit = hayLen - ndlLen
    for i <= limit {
        var j = 0
        var ok = true
        for j < ndlLen {
            if haystack[i + j] != needle[j] { ok = false; j = ndlLen }
            else { j = j + 1 }
        }
        if ok { return true }
        i = i + 1
    }
    return false
}
