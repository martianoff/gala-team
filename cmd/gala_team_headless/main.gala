package main

import (
    "os"
    "path/filepath"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "github.com/martianoff/gala_team/app/config"
    . "github.com/martianoff/gala_team/app/headless"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/team"
    "github.com/martianoff/gala_team/app/runtime"
    "github.com/martianoff/gala_team/app/version"
)

// ============================================================================
// gala_team_headless — non-interactive driver. Reads --team / --project /
// --prompt, runs the team-lead session once, prints the result as JSON
// on stdout. Exit 0 on success (even if the team itself reported an
// error in conversation), 1 on infrastructure failure (missing yaml,
// missing repo, claude spawn failed).
//
// Used by: scripts/real_claude_audit.sh, the consult runner once that
// lands, and any CI integration that wants to drive the team without
// a TTY.
// ============================================================================

// flagValue scans os.Args for the named flag and returns its value
// (or `dflt` when missing). Linear scan; the headless surface has
// only three flags so a flag library is overkill.
func flagValue(name string, dflt string) string {
    val args = ArrayOf(os.Args...)
    val n = args.Size()
    var i = 1
    var found = dflt
    for i < n - 1 {
        if args.Get(i) == name {
            found = args.Get(i + 1)
        }
        i = i + 1
    }
    return found
}

// die prints msg to stderr + exits 1. Used for missing required args
// and config-load failures.
func die(msg string) {
    val _ = os.Stderr.WriteString(s"gala_team_headless: ${msg}\n")
    os.Exit(1)
}

func main() {
    // --version short-circuits before arg validation so CI / scripts
    // can probe the binary without supplying a team.yaml. Mirrors the
    // TUI binary's flag.
    val args = ArrayOf(os.Args...)
    if args.Contains("--version") || args.Contains("-V") {
        val _ = os.Stdout.WriteString(s"gala_team_headless ${version.Version()} (${version.GitDescribe()}) commit ${version.Commit()}\n")
        os.Exit(0)
    }
    val teamPath = flagValue("--team", "")
    val projDir  = flagValue("--project", ".")
    val prompt   = flagValue("--prompt", "")
    val member   = flagValue("--member", "")
    if teamPath == "" {
        die("--team is required (path to team.yaml)")
    }
    if prompt == "" {
        die("--prompt is required (the prompt to send to the team lead)")
    }
    val info, statErr = os.Stat(teamPath)
    val _ = info
    if statErr != nil {
        die(s"--team: cannot stat '${teamPath}': ${statErr.Error()}")
    }
    val raw, readErr = os.ReadFile(teamPath)
    if readErr != nil {
        die(s"--team: cannot read '${teamPath}': ${readErr.Error()}")
    }
    val cfgTry = LoadFromString(string(raw))
    if cfgTry.IsFailure() {
        die(s"--team: parse '${teamPath}': ${cfgTry.GetError().Error()}")
    }
    val cfg = cfgTry.Get()
    val projTry = Resolve(projDir, NoOverrides())
    if projTry.IsFailure() {
        die(s"--project: ${projTry.GetError().Error()}")
    }
    val proj = projTry.Get()
    // Register the project repo with the debug logger so headless
    // runs (CI, audit scripts, consult driver) emit the same
    // events.jsonl + per-member chunk traces as the TUI binary
    // when GALA_TEAM_DEBUG=1. Both calls are no-ops when the flag
    // is unset.
    runtime.SetDebugRepo(proj.Repo)
    runtime.LogSessionInit()
    scanStaleWorktrees(proj, cfg.Team)
    // --member targets a specific role (engineer / QA name) instead of
    // the team lead. Used by multi-member E2E tests that orchestrate
    // each role manually. Defaults to the lead when omitted.
    val outcome = if (member == "")
        RunHeadless(proj, cfg.Team, cfg.Policy.WorkspaceMode, prompt)
    else
        RunHeadlessAs(proj, cfg.Team, cfg.Policy.WorkspaceMode, member, prompt)
    outcome match {
        case Left(err) => {
            val _ = os.Stderr.WriteString(s"gala_team_headless: ${err}\n")
            runtime.LogSessionDone("headless_error")
            os.Exit(1)
        }
        case Right(result) => {
            EncodeJson(result) match {
                case Success(j) => {
                    val _ = os.Stdout.WriteString(j)
                    val _ = os.Stdout.WriteString("\n")
                }
                case Failure(e) => die(s"encode result: ${e.Error()}")
            }
        }
    }
    runtime.LogSessionDone("headless_complete")
}

// scanStaleWorktrees mirrors the TUI binary's logic — list any
// .gala_team/worktrees/<name>/ dir whose name isn't in the current
// team config, and emit a kind=stale_worktree event for each. Lets
// CI / audit runs surface ghost worktrees the same way the
// interactive TUI does.
func scanStaleWorktrees(proj Project, tm Team) {
    if !runtime.DebugEnabled() { return }
    val wtDir = filepath.Join(proj.Repo, ".gala_team", "worktrees")
    val entries, readErr = os.ReadDir(wtDir)
    if readErr != nil { return }
    val memberNames = tm.Members.Map((mem) => mem.Name)
    var i = 0
    val n = len(entries)
    for i < n {
        val name = entries[i].Name()
        if entries[i].IsDir() && !memberNames.Contains(name) {
            runtime.LogStaleWorktree(name, filepath.Join(wtDir, name))
        }
        i = i + 1
    }
}
