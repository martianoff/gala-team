package main

import (
    . "martianoff/gala/std"
    . "github.com/martianoff/gala_team/app/team"
)

// ============================================================================
// gala_team — TUI orchestrator that turns a team of Claude CLI sessions into
// a single chain-of-command.  The user only ever talks to the Team Lead;
// the Team Lead delegates to subordinate agents (Engineers, QAs), reviews
// their work, and produces a final summary + PR for the user to approve.
//
// This Phase-1 main.gala is Println-only: it loads no team yet, opens no
// TUI yet — those wire up once the cross-module struct-construction
// transpiler bug clears (then cmd/ takes a gala_tui dep, app/runtime
// gets wrapped in FutureCmd, and update + view land per DESIGN.md §13).
//
// Verifies end-to-end build wiring: cmd → app/team → gala stdlib.
//
// Run:
//     bazel run cmd:gala_team
// ============================================================================

func main() {
    val role = TeamLead{}.Apply()
    Println(s"gala_team — Phase 1 skeleton (role probe: ${RoleName(role)})")
    Println("  cmd → app/team → gala stdlib 0.37.0 wired cleanly")
    Println("  TUI front-end + claude orchestration land once cross-module")
    Println("  struct construction is fixed (TRANSPILER_BUG_GALA_TUI_*.md)")
}
