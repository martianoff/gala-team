// ============================================================================
// gala_team — TUI orchestrator that turns a team of Claude CLI sessions into
// a single chain-of-command. The user only ever talks to the Team Lead;
// the Team Lead delegates to subordinate agents (Engineers, QAs), reviews
// their work, and produces a final summary + PR for the user to approve.
//
// Usage:
//     gala_team [--project <dir>] [--team <yaml-path>]
//
//   --project <dir>     project directory (must be a git repo). Defaults
//                       to the current working directory when omitted.
//   --team <yaml-path>  path to team.yaml. When omitted falls back to
//                       a hard-coded three-member sample so the binary
//                       still launches end-to-end (useful for demos).
//
// The keyboard plumbing translates raw KeyEvents into the AppMsg sealed
// type. A 120 ms TickSub drives spinner animation. Pressing Enter sends
// the composed prompt to the Team Lead's claude subprocess (spawned on
// first prompt) and the read pump streams chunks back into the
// conversation log.
// ============================================================================

// Keyboard / mouse routing lives in app/cli (KeyToAppMsg,
// InputToAppMsg) so the dispatch table is unit-testable without
// spawning the gala-tui runtime.

// flagValue scans `os.Args` for any of the supplied `--name <value>`
// pairs and returns the value if present, otherwise `dflt`. Multiple
// names act as aliases — the first match wins after a left-to-right
// scan. Simple linear scan is fine for the handful of flags we
// expose; we deliberately avoid pulling in `flag` to keep the CLI
// surface tiny and the error messages friendly.
func flagValue(names Array[string], dflt string) string {
    val args = ArrayOf(os.Args...)
    val n = args.Size()
    var i = 1
    var found = dflt
    for i < n - 1 {
        if names.Contains(args.Get(i)) {
            found = args.Get(i + 1)
        }
        i = i + 1
    }
    return found
}

// hasFlag reports whether any of the given switch names appear in
// the argv. Used for boolean flags like --help that don't take a
// following value.
func hasFlag(names Array[string]) bool {
    val args = ArrayOf(os.Args...)
    return args.Exists((a) => names.Contains(a))
}

// validateArgs sanity-checks the argv for unrecognized --flags so a
// typo like `--teams` (instead of `--team`) errors out instead of
// silently falling back to the demo team. Positional args after the
// last flag/value are not currently used; we ignore them rather
// than reject so the user can pipe additional context through if a
// future flag wants it.
func validateArgs() {
    val known = ArrayOf("--help", "-h", "--version", "-V", "--project", "--team", "--teams", "--team-key", "--test-mode")
    val takesValue = ArrayOf("--project", "--team", "--teams", "--team-key")
    val args = ArrayOf(os.Args...)
    val n = args.Size()
    var i = 1
    for i < n {
        val a = args.Get(i)
        if strings.HasPrefix(a, "-") {
            if !known.Contains(a) {
                die(s"unknown flag '${a}'\n  see --help for the supported list")
            }
            if takesValue.Contains(a) {
                if i + 1 >= n {
                    die(s"flag '${a}' needs a value")
                }
                i = i + 2
            } else {
                i = i + 1
            }
        } else {
            i = i + 1
        }
    }
}

// printUsage writes the human-readable help text to stdout. Keep the
// flag list in sync with validateArgs and the docstring at the top
// of this file.
func printUsage() {
    val usage = "gala_team — TUI orchestrator for a team of Claude CLI sessions\n" +
        "\n" +
        "USAGE\n" +
        "  gala_team --team <yaml> [--project <dir>] [--team-key <key>]\n" +
        "\n" +
        "FLAGS\n" +
        "  --team <yaml>      Path to team.yaml. Required. Alias: --teams.\n" +
        "  --project <dir>    Project directory (must be a git repo).\n" +
        "                     Defaults to the current working directory.\n" +
        "  --team-key <key>   Pick the main team from a multi-team yaml.\n" +
        "                     Defaults to the first entry under `teams:`.\n" +
        "                     The remaining teams become @consult targets.\n" +
        "  -h, --help         Show this message and exit.\n" +
        "\n" +
        "EXAMPLES\n" +
        "  gala_team --project ~/work/auth-service --team ./skunkworks.yaml\n" +
        "  gala_team --team examples/multi-team.yaml --team-key transpiler\n" +
        "\n" +
        "KEYBOARD\n" +
        "  Ctrl+Q     Quit (twice to confirm; closes every claude subprocess)\n" +
        "  Ctrl+C     Force-kill (gala-tui escape hatch — no confirmation)\n" +
        "  Tab        Toggle focus between composer and sidebar (Ctrl+L alias)\n" +
        "  Ctrl+T     Toggle the consult viewer modal\n" +
        "  Ctrl+H     Open the session-archive browser\n" +
        "  Ctrl+A/R   Approve / reject in the approval state\n" +
        "\n" +
        "See README.md for the full team.yaml schema and key bindings.\n"
    val _ = os.Stdout.WriteString(usage)
}

// die prints a one-line user-facing error to stderr and exits with
// code 1. Used instead of `panic` for startup configuration errors
// — invalid CLI args, unparseable team.yaml, missing project repo —
// so the user sees a clean diagnostic instead of a Go stack trace.
func die(msg string) {
    val _ = os.Stderr.WriteString(s"gala_team: ${msg}\n")
    os.Exit(1)
}

// loadTeamConfig reads `path`, decodes the YAML, and exits cleanly
// on any failure with a message pointing at the file + the
// underlying YAML parser error. Specifically tagged failures:
//   - the path doesn't exist                →  "FILE NOT FOUND" diagnostic
//   - yaml: expected sequence, got mapping  →  hint to use `- ` list items
func loadTeamConfig(path string) TeamConfig {
    val info, statErr = os.Stat(path)
    if statErr != nil {
        if os.IsNotExist(statErr) {
            die(s"--team: FILE NOT FOUND: '${path}'")
        }
        die(s"--team: cannot stat '${path}': ${statErr.Error()}")
    }
    if info.IsDir() {
        die(s"--team: '${path}' is a directory, expected a yaml file")
    }
    return Try(() => os.ReadFile(path)) match {
        case Failure(err) => {
            die(s"--team: cannot read '${path}': ${err.Error()}")
            sampleTeamConfig()  // unreachable — die() called os.Exit
        }
        case Success(b)   => LoadFromString(string(b)) match {
            case Failure(err) => {
                die(s"--team: failed to parse '${path}'\n  ${err.Error()}\n  ${yamlHint(err.Error())}")
                sampleTeamConfig()  // unreachable
            }
            case Success(cfg) => cfg
        }
    }
}

// yamlHint translates a few common gala-yaml error messages into
// human-readable suggestions so the user knows how to fix their
// team.yaml without reading the parser source.
func yamlHint(msg string) string {
    if strings.Contains(msg, "expected sequence, got mapping") {
        return "hint: a list-shaped field (members:, pre_merge:, onboarding:, teams:) needs `- ` block-style items, not a single inline mapping"
    }
    if strings.Contains(msg, "expected sequence, got scalar") {
        return "hint: this list field is empty or scalar — write `[]` doesn't work either; just omit the key, or list `- entries` underneath"
    }
    if strings.Contains(msg, "expected mapping") {
        return "hint: this field expects a key/value block, not a list or scalar"
    }
    return "see README.md for the team.yaml schema"
}

// resolveProject runs the resolver and exits cleanly on failure
// (missing dir / not a git repo). Falls back to a placeholder
// Project on the unreachable path after die() has called Exit.
func resolveProject(dir string) Project = Resolve(dir, NoOverrides()) match {
    case Success(p)   => p
    case Failure(err) => {
        die(s"--project: ${err.Error()}")
        Project(Name = "", Repo = "", Github = None[string](), DefaultBranch = "main")  // unreachable
    }
}

// loadRegistry reads `<repo>/.gala_team/consults.yaml` first, then
// merges in entries from the user-scoped fallback at
// `~/.config/gala_team/registry.yaml`. Project entries win on name
// collisions (DESIGN.md §6.2.1). Failure to load either file is
// non-fatal — the user can still run the team interactively; only
// `@consult(<name>)` directives will fail until they fix the YAML.
func loadRegistry(proj Project) consult.Registry {
    val projPath = filepath.Join(proj.Repo, ".gala_team", "consults.yaml")
    val home, _ = os.UserHomeDir()
    val userPath = if (home == "") "" else filepath.Join(home, ".config", "gala_team", "registry.yaml")
    return consult.LoadWithFallback(projPath, userPath) match {
        case Success(r) => r
        case Failure(_) => consult.EmptyRegistry()
    }
}

// ----- demo fallback (only used when --team is omitted) ---------------------

// sampleTeamConfig wraps sampleTeam() into a TeamConfig with default
// workflow/policy and a one-entry Teams list, so the if-as-expression
// in main() doesn't need an explicit `return` (which currently
// triggers a transpiler bug — gala issue #289 — emitting a dead
// `return nil` that fails Go compile).
func sampleTeamConfig() TeamConfig {
    val tm = sampleTeam()
    return TeamConfig(
        Team     = tm,
        Teams    = ArrayOf(tm),
        Workflow = DefaultWorkflow(),
        Policy   = DefaultPolicy(),
        Guidance = EmptyArray[GuidancePair](),
    )
}

func sampleTeam() Team {
    val iris = Member(
        Name = "Iris",  Role = TeamLead(),
        Personality = "calm",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val felix = Member(
        Name = "Felix", Role = Engineer(),
        Personality = "terse",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val quinn = Member(
        Name = "Quinn", Role = QA(),
        Personality = "skeptical",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    return Team(
        Key                        = "main",
        Name                       = "Skunkworks",
        Description                = "Default product team — calm lead, terse engineer, skeptical QA.",
        Members                    = ArrayOf(iris, felix, quinn),
        Lead                       = iris,
        Onboarding                 = EmptyArray[string](),
        DangerouslySkipPermissions = false,
    )
}

func main() {
    if hasFlag(ArrayOf("--help", "-h")) {
        printUsage()
        os.Exit(0)
    }
    if hasFlag(ArrayOf("--version", "-V")) {
        val _ = os.Stdout.WriteString(s"gala_team ${version.Version()} (${version.GitDescribe()}) commit ${version.Commit()}\n")
        os.Exit(0)
    }
    validateArgs()
    val projDir  = flagValue(ArrayOf("--project"),         ".")
    val teamPath = flagValue(ArrayOf("--team", "--teams"), "")
    val teamKey  = flagValue(ArrayOf("--team-key"),        "")
    if teamPath == "" {
        die("--team is required (path to team.yaml)\n  see --help for usage")
    }
    val proj   = resolveProject(projDir)
    // Register the project repo with the debug logger so subsequent
    // runtime.LogEvent / TraceClaudeLine calls can derive their
    // target paths without threading repoDir through every dispatch
    // site. Both calls are no-ops when GALA_TEAM_DEBUG is unset.
    runtime.SetDebugRepo(proj.Repo)
    runtime.LogSessionInit()
    // Append .gala_team/ to .gitignore on first run so engineer
    // worktrees + session snapshots don't leak into the user's
    // commits. Best-effort — non-git dirs and IO errors are silent.
    val _ = session.EnsureGitignore(proj.Repo)
    val cfgRaw = loadTeamConfig(teamPath)
    val cfg = PickMainTeam(cfgRaw, teamKey) match {
        case Success(c) => c
        case Failure(e) => {
            die(e.Error())
            sampleTeamConfig()  // unreachable — die() called os.Exit
        }
    }
    // Surface leftover worktree dirs from prior sessions whose
    // member name isn't in the current team config. Caused the
    // ghost-Mira incident — TL inspected .gala_team/worktrees/Mira/
    // (left from a prior team config that had Mira on the roster)
    // and reasoned about a non-existent team member. Each ghost dir
    // emits a kind=stale_worktree event so a debug audit shows
    // "we noticed Mira's worktree but ignored her".
    scanStaleWorktrees(proj, cfg.Team)
    // Restore the prior conversation log if a snapshot exists under
    // <repo>/.gala_team/sessions/latest.json. None on first launch.
    val registry = loadRegistry(proj)
    val archives = loadArchives(proj)
    // Load guidance docs (DESIGN.md §5.7). Missing docs surface as
    // warnings on stderr but don't sink startup.
    val (guidanceBundle, guidanceWarns) = loadGuidance(proj, cfg.Guidance)
    guidanceWarns.ForEach((w) => {
        val _ = os.Stderr.WriteString(s"gala_team: guidance warning: ${w}\n")
    })
    val seeded = primeFromSnapshot(InitialModelWithTeams(proj, cfg.Team, cfg.Workflow, cfg.Policy, registry, cfg.Teams))
    val initial = seeded.Copy(Archives = archives, Guidance = guidanceBundle)
    val program = Program[AppModel, AppMsg](
        Initial = initial,
        Update  = (m, msg) => Update(m, msg),
        View    = (m) => View(m),
    )
    if hasFlag(ArrayOf("--test-mode")) {
        // Skip the gala-tui terminal runtime entirely — the harness
        // reads JSON commands from stdin and emits frames on stdout.
        // All Cmds returned by Update are discarded so the test stays
        // deterministic; the driver injects whatever runtime events
        // it wants to simulate.
        testdriver.RunTestDriver(initial)
        runtime.LogSessionDone("test_driver_exit")
        return
    }
    val tickSub = TickSub[AppMsg](Interval = Milliseconds(int64(120)), Make = () => TickMsg())
    // Disable gala-tui's runtime-level Ctrl+C escape hatch so the
    // app's keymap can receive it. onQuit then runs the two-press
    // confirmation flow + CloseAllSessions cleanup before exit.
    SetEscapeHatchOnCtrlC(false)
    val _ = RunWithMouse[AppModel, AppMsg](program, (ev) => InputToAppMsg(ev), tickSub)
    // Reached only on clean TUI exit — onQuit's two-press flow or
    // the runtime returning normally. A crash exit / panic skips this
    // and leaves the events.jsonl without a session_done marker, so
    // a replayer can detect "the process died" by the absence.
    runtime.LogSessionDone("tui_exit")
}

// scanStaleWorktrees lists `<repo>/.gala_team/worktrees/` and emits
// a kind=stale_worktree debug event for any subdir whose name isn't
// in the current team's member list. The TL otherwise can read the
// on-disk worktree state and treat it as authoritative team
// membership, leading to reasoning about phantom engineers — past
// audits captured this as the "ghost member" incident.
//
// Best-effort: if the worktrees dir doesn't exist yet (first run),
// or the read fails, we silently skip. The events are diagnostic-
// only — orchestration logic still treats `cfg.Team.Members` as the
// source of truth.
func scanStaleWorktrees(proj Project, tm Team) {
    if !runtime.DebugEnabled() { return }
    val wtDir = filepath.Join(proj.Repo, ".gala_team", "worktrees")
    val entries, readErr = os.ReadDir(wtDir)
    if readErr != nil { return }
    val memberNames = tm.Members.Map((m) => m.Name)
    var i = 0
    val n = len(entries)
    for i < n {
        val name = entries[i].Name()
        if entries[i].IsDir() && !memberNames.Contains(name) {
            runtime.LogStaleWorktree(name, filepath.Join(wtDir, name))
        }
        i = i + 1
    }
}

// loadArchives reads .gala_team/sessions/archive/ at startup so the
// history browser has its index ready. Failures are non-fatal — we
// fall back to an empty list so the UI launches even on a corrupted
// archive directory.
func loadArchives(proj Project) Array[session.SnapshotMeta] =
    session.ListArchives(proj.Repo).GetOrElse(EmptyArray[session.SnapshotMeta]())

// loadGuidance materialises the guidance: block from team.yaml into
// a Guidance bundle (sha256'd, ready to paste into the TL system
// prompt). Missing files surface as warnings on the returned array
// but don't sink startup — DESIGN.md §5.7 calls them "drop the
// slot" failures.
func loadGuidance(proj Project, pairs Array[GuidancePair]) Tuple[Guidance, Array[string]] {
    val tuples = pairs.Map((p) => (p.Slot, p.Path))
    return guidance.LoadAll(proj.Repo, tuples)
}

// primeFromSnapshot replays the persisted conversation log into a
// fresh AppModel and lifts the prior session's ActiveMembers list
// into RecoveredMembers so ensureSession spawns those members with
// `--continue` on first use. The recovery banner is shown above the
// conversation pane until the user types the next prompt or hits
// Esc to discard.
//
// SavedAt / ProjectName are read but unused for now — they would
// drive cross-project mismatch detection if a user moved their
// .gala_team/sessions/ directory between repos.
// primeFromSnapshot loads the prior session's conversation log and
// kicks the §5.6 recovery modal — the user picks Resume / Inspect /
// Start fresh before any orchestration spawns.
//
// Empty-snapshot short-circuit: if the loaded Conversation has zero
// entries AND no recovered members, there's nothing to resume —
// previous Start fresh / Esc-on-recovery flushed the snapshot to
// empty. Skip the modal entirely so the user lands on a fresh
// composer instead of being asked to "resume" a blank session
// (which is what they explicitly asked for last time).
func primeFromSnapshot(m AppModel) AppModel = session.Load(m.Project.Repo) match {
    case None()       => m
    case Some(snap)   => {
        if snap.Conversation.IsEmpty() && snap.ActiveMembers.IsEmpty() {
            return m
        }
        return m.Copy(
            Conversation          = snap.Conversation,
            RecoveredMembers      = snap.ActiveMembers,
            RecoveryBannerVisible = true,
            RecoveryModalOpen     = true,
            RecoveryFocus         = ResumeFocus(),
        )
    }
}
