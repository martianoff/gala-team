package main

import (
    . "github.com/martianoff/gala-tui"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/team"
    . "github.com/martianoff/gala_team/app/ui"
)

// ============================================================================
// gala_team — TUI orchestrator that turns a team of Claude CLI sessions into
// a single chain-of-command. The user only ever talks to the Team Lead;
// the Team Lead delegates to subordinate agents (Engineers, QAs), reviews
// their work, and produces a final summary + PR for the user to approve.
//
// Phase-1 main: wires the Elm-architecture skeleton in app/ui (AppModel +
// Update + View) against a hard-coded sample team. The keyboard plumbing
// translates raw KeyEvents into the AppMsg sealed type. Real claude
// subprocess pumping (spawning, prompt forwarding, NextChunk pump) lands
// in a follow-up commit alongside YAML team loading.
//
// Run:
//     bazel run cmd:gala_team
// ============================================================================

func keyToAppMsg(ev KeyEvent) AppMsg {
    if KeyMatchesAny(ev, "ctrl+c", "ctrl+q") { return QuitMsg{}.Apply() }
    return ev.Key match {
        case Backspace()  => KeyBackspace{}.Apply()
        case Enter()      => KeySubmit{}.Apply()
        case Char(c)      => KeyChar(C = c)
        case Space()      => KeyChar(C = ' ')
        case _            => NoOp{}.Apply()
    }
}

func sampleTeam() Team {
    val iris = Member(
        Name = "Iris",  Role = TeamLead{}.Apply(),
        Personality = "calm",
        Model = None[string](), Extra = "",
    )
    val felix = Member(
        Name = "Felix", Role = Engineer{}.Apply(),
        Personality = "terse",
        Model = None[string](), Extra = "",
    )
    val quinn = Member(
        Name = "Quinn", Role = QA{}.Apply(),
        Personality = "skeptical",
        Model = None[string](), Extra = "",
    )
    return Team(
        Name    = "Skunkworks",
        Members = ArrayOf[Member](iris, felix, quinn),
        Lead    = iris,
    )
}

func sampleProject() Project = Project(
    Name = "gala_team", Repo = ".",
    Github = None[string](),
    DefaultBranch = "main",
)

func main() {
    val program = Program[AppModel, AppMsg](
        Initial = InitialModel(sampleProject(), sampleTeam(), DefaultWorkflow()),
        Update  = (m, msg) => Update(m, msg),
        View    = (m) => View(m),
    )
    val _ = Run[AppModel, AppMsg](program, (ev) => keyToAppMsg(ev))
}
