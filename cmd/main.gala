package main

import (
    "os"
    "path/filepath"
    "strings"
    . "github.com/martianoff/gala-tui"
    . "martianoff/gala/std"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/time_utils"
    "github.com/martianoff/gala_team/app/consult"
    "github.com/martianoff/gala_team/app/session"
    . "github.com/martianoff/gala_team/app/cli"
    . "github.com/martianoff/gala_team/app/config"
    . "github.com/martianoff/gala_team/app/policy"
    . "github.com/martianoff/gala_team/app/project"
    . "github.com/martianoff/gala_team/app/team"
    . "github.com/martianoff/gala_team/app/ui"
)

// ============================================================================
// gala_team — TUI orchestrator that turns a team of Claude CLI sessions into
// a single chain-of-command. The user only ever talks to the Team Lead;
// the Team Lead delegates to subordinate agents (Engineers, QAs), reviews
// their work, and produces a final summary + PR for the user to approve.
//
// Usage:
//     gala_team [--project <dir>] [--team <yaml-path>]
//
//   --project <dir>     project directory (must be a git repo). Defaults
//                       to the current working directory when omitted.
//   --team <yaml-path>  path to team.yaml. When omitted falls back to
//                       a hard-coded three-member sample so the binary
//                       still launches end-to-end (useful for demos).
//
// The keyboard plumbing translates raw KeyEvents into the AppMsg sealed
// type. A 120 ms TickSub drives spinner animation. Pressing Enter sends
// the composed prompt to the Team Lead's claude subprocess (spawned on
// first prompt) and the read pump streams chunks back into the
// conversation log.
// ============================================================================

// Keyboard / mouse routing lives in app/cli (KeyToAppMsg,
// InputToAppMsg) so the dispatch table is unit-testable without
// spawning the gala-tui runtime.

// flagValue scans `os.Args` for a `--name <value>` pair and returns the
// value if present, otherwise `dflt`. Simple linear scan is fine for the
// two flags we expose; we deliberately avoid pulling in `flag` to keep
// the CLI surface tiny and the error messages friendly.
func flagValue(name string, dflt string) string {
    val args = ArrayOf(os.Args...)
    val n = args.Size()
    var i = 1
    var found = dflt
    for i < n - 1 {
        if args.Get(i) == name {
            found = args.Get(i + 1)
        }
        i = i + 1
    }
    return found
}

// die prints a one-line user-facing error to stderr and exits with
// code 1. Used instead of `panic` for startup configuration errors
// — invalid CLI args, unparseable team.yaml, missing project repo —
// so the user sees a clean diagnostic instead of a Go stack trace.
func die(msg string) {
    val _ = os.Stderr.WriteString(s"gala_team: ${msg}\n")
    os.Exit(1)
}

// loadTeamConfig reads `path`, decodes the YAML, and exits cleanly
// on any failure with a message pointing at the file + the
// underlying YAML parser error. Common failures we tag specially:
//   - yaml: expected sequence, got mapping  →  hint to use `- ` list items
func loadTeamConfig(path string) TeamConfig =
    Try(() => os.ReadFile(path)) match {
        case Failure(err) => {
            die(s"--team: cannot read '${path}': ${err.Error()}")
            sampleTeamConfig()  // unreachable — die() called os.Exit
        }
        case Success(b)   => LoadFromString(string(b)) match {
            case Failure(err) => {
                die(s"--team: failed to parse '${path}'\n  ${err.Error()}\n  ${yamlHint(err.Error())}")
                sampleTeamConfig()  // unreachable
            }
            case Success(cfg) => cfg
        }
    }

// yamlHint translates a few common gala-yaml error messages into
// human-readable suggestions so the user knows how to fix their
// team.yaml without reading the parser source.
func yamlHint(msg string) string {
    if strings.Contains(msg, "expected sequence, got mapping") {
        return "hint: a list-shaped field (members:, pre_merge:, onboarding:, teams:) needs `- ` block-style items, not a single inline mapping"
    }
    if strings.Contains(msg, "expected sequence, got scalar") {
        return "hint: this list field is empty or scalar — write `[]` doesn't work either; just omit the key, or list `- entries` underneath"
    }
    if strings.Contains(msg, "expected mapping") {
        return "hint: this field expects a key/value block, not a list or scalar"
    }
    return "see README.md for the team.yaml schema"
}

// resolveProject runs the resolver and exits cleanly on failure
// (missing dir / not a git repo). Falls back to a placeholder
// Project on the unreachable path after die() has called Exit.
func resolveProject(dir string) Project = Resolve(dir, NoOverrides()) match {
    case Success(p)   => p
    case Failure(err) => {
        die(s"--project: ${err.Error()}")
        Project(Name = "", Repo = "", Github = None[string](), DefaultBranch = "main")  // unreachable
    }
}

// loadRegistry reads `<repo>/.gala_team/consults.yaml`, falling back to
// an empty registry on missing-file or decode failure. Failure to load
// the consults file is non-fatal — the user can still run the team
// interactively; only `@consult(<name>)` directives will fail until
// they fix the YAML.
func loadRegistry(proj Project) consult.Registry =
    consult.LoadFromFile(filepath.Join(proj.Repo, ".gala_team", "consults.yaml")) match {
        case Success(r)   => r
        case Failure(_)   => consult.EmptyRegistry()
    }

// ----- demo fallback (only used when --team is omitted) ---------------------

// sampleTeamConfig wraps sampleTeam() into a TeamConfig with default
// workflow/policy and a one-entry Teams list, so the if-as-expression
// in main() doesn't need an explicit `return` (which currently
// triggers a transpiler bug — gala issue #289 — emitting a dead
// `return nil` that fails Go compile).
func sampleTeamConfig() TeamConfig {
    val tm = sampleTeam()
    return TeamConfig(
        Team     = tm,
        Teams    = ArrayOf(tm),
        Workflow = DefaultWorkflow(),
        Policy   = DefaultPolicy(),
    )
}

func sampleTeam() Team {
    val iris = Member(
        Name = "Iris",  Role = TeamLead(),
        Personality = "calm",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val felix = Member(
        Name = "Felix", Role = Engineer(),
        Personality = "terse",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    val quinn = Member(
        Name = "Quinn", Role = QA(),
        Personality = "skeptical",
        Model = None[string](), Extra = "",
        Onboarding = EmptyArray[string](),
    )
    return Team(
        Key                        = "main",
        Name                       = "Skunkworks",
        Description                = "Default product team — calm lead, terse engineer, skeptical QA.",
        Members                    = ArrayOf(iris, felix, quinn),
        Lead                       = iris,
        Onboarding                 = EmptyArray[string](),
        DangerouslySkipPermissions = false,
    )
}

func main() {
    val projDir  = flagValue("--project", ".")
    val teamPath = flagValue("--team", "")
    val teamKey  = flagValue("--team-key", "")
    val proj     = resolveProject(projDir)
    val cfgRaw = if (teamPath == "") sampleTeamConfig()
                 else                 loadTeamConfig(teamPath)
    val cfg = PickMainTeam(cfgRaw, teamKey) match {
        case Success(c) => c
        case Failure(e) => {
            die(e.Error())
            sampleTeamConfig()  // unreachable — die() called os.Exit
        }
    }
    // Restore the prior conversation log if a snapshot exists under
    // <repo>/.gala_team/sessions/latest.json. None on first launch.
    val registry = loadRegistry(proj)
    val archives = loadArchives(proj)
    val seeded = primeFromSnapshot(InitialModelWithTeams(proj, cfg.Team, cfg.Workflow, cfg.Policy, registry, cfg.Teams))
    val initial = seeded.Copy(Archives = archives)
    val program = Program[AppModel, AppMsg](
        Initial = initial,
        Update  = (m, msg) => Update(m, msg),
        View    = (m) => View(m),
    )
    val tickSub = TickSub[AppMsg](Interval = Milliseconds(int64(120)), Make = () => TickMsg())
    val _ = RunWithMouse[AppModel, AppMsg](program, (ev) => InputToAppMsg(ev), tickSub)
}

// loadArchives reads .gala_team/sessions/archive/ at startup so the
// history browser has its index ready. Failures are non-fatal — we
// fall back to an empty list so the UI launches even on a corrupted
// archive directory.
func loadArchives(proj Project) Array[session.SnapshotMeta] =
    session.ListArchives(proj.Repo).GetOrElse(EmptyArray[session.SnapshotMeta]())

// primeFromSnapshot replays the persisted conversation log into a fresh
// AppModel. We ignore SavedAt and ProjectName for now — the user's
// next prompt picks up where the prior session left off.
func primeFromSnapshot(m AppModel) AppModel = session.Load(m.Project.Repo) match {
    case None()       => m
    case Some(snap)   => m.Copy(Conversation = snap.Conversation)
}
